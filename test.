Сначала создам скрипт для анализа серверов:

bash
Копировать
#!/bin/bash
# server_info.sh - Скрипт сбора информации о серверах

echo "==================================="
echo "ИНФОРМАЦИЯ О СЕРВЕРЕ: $(hostname)"
echo "==================================="
echo ""

echo "--- HOSTNAME И IP ---"
hostname
hostname -I
echo ""

echo "--- CPU ---"
lscpu | grep -E "^Model name|^CPU\(s\)|^Thread|^Core|^Socket"
echo ""

echo "--- GPU ---"
if command -v nvidia-smi &> /dev/null; then
    nvidia-smi --query-gpu=index,name,memory.total,driver_version --format=csv,noheader
else
    echo "GPU не обнаружен или драйвера не установлены"
fi
echo ""

echo "--- ПАМЯТЬ ---"
free -h
echo ""

echo "--- ДИСКИ ---"
lsblk -o NAME,SIZE,TYPE,MOUNTPOINT,FSTYPE
echo ""
df -h
echo ""

echo "--- RAID ---"
if [ -f /proc/mdstat ]; then
    cat /proc/mdstat
else
    echo "Software RAID не обнаружен"
fi

if command -v megacli &> /dev/null; then
    megacli -LDInfo -Lall -aALL
elif command -v storcli &> /dev/null; then
    storcli /c0 show
else
    echo "Hardware RAID контроллер не обнаружен"
fi
echo ""

echo "--- СЕТЕВЫЕ ИНТЕРФЕЙСЫ ---"
ip addr show
echo ""
ip route show
echo ""

echo "--- СЕТЕВЫЕ НАСТРОЙКИ ---"
cat /etc/sysconfig/network-scripts/ifcfg-* 2>/dev/null || echo "Конфиги не найдены"
echo ""

echo "--- ОС ---"
cat /etc/redos-release 2>/dev/null || cat /etc/os-release
uname -r
echo ""

echo "--- ПРОИЗВОДИТЕЛЬНОСТЬ ДИСКА ---"
echo "Тест записи (это займет время):"
dd if=/dev/zero of=/tmp/testfile bs=1G count=1 oflag=direct 2>&1 | grep -v records
rm -f /tmp/testfile
echo ""

echo "--- СЕТЕВАЯ ПРОИЗВОДИТЕЛЬНОСТЬ ---"
ethtool eth0 2>/dev/null | grep Speed || echo "Не удалось определить скорость eth0"
ethtool eth1 2>/dev/null | grep Speed || echo "Не удалось определить скорость eth1"
echo ""

echo "==================================="
echo "Сбор информации завершен"
echo "==================================="
