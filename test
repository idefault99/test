FROM python:3.12-slim as base

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    patchelf \
    ccache \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
RUN pip install --no-cache-dir nuitka

# Копируем весь пакет — нужен для импортов при компиляции
COPY minio_client/ ./minio_client/

# Компилируем upload.py в самодостаточный бинарник
RUN python -m nuitka \
    --onefile \
    --static-libpython=no \
    --include-package=minio_client \
    --include-package=boto3 \
    --include-package=botocore \
    --output-dir=/app \
    minio_client/upload.py

# Финальный образ — без Nuitka и компилятора
FROM python:3.12-slim as production

RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Копируем только бинарник
COPY --from=base /app/upload.bin /usr/local/bin/upload.bin

ENTRYPOINT ["/usr/local/bin/upload.bin"]


---
- /usr/local/bin/upload.bin
