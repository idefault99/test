#!/usr/bin/env bash
set -euo pipefail

# =========================
# Настройки подключения
# =========================

PGHOST=""   # Haproxy
PGPORT=""
PGUSER=""
PGPASSWORD=""
export PGPASSWORD

DEFAULT_DB="${DEFAULT_DB:-postgres}"
CURRENT_DB="$DEFAULT_DB"
SAMPLE_ROWS="${SAMPLE_ROWS:-5}"

PSQL_BASE=(psql -h "$PGHOST" -p "$PGPORT" -U "$PGUSER" -X -v ON_ERROR_STOP=1 -P pager=off)

header() {
  echo
  echo "============================================================"
  echo "$1"
  echo "============================================================"
}

run_sql() {
  local db="$1"
  local sql="$2"
  "${PSQL_BASE[@]}" -d "$db" -c "$sql"
}

run_sql_quiet() {
  local db="$1"
  local sql="$2"
  "${PSQL_BASE[@]}" -d "$db" -A -t -c "$sql"
}

pause() {
  echo
  read -r -p "Нажми Enter для продолжения..." _
}

check_connection() {
  header "Проверка подключения"
  run_sql "$DEFAULT_DB" "
    select
      current_user as current_user,
      current_database() as current_database,
      inet_server_addr() as server_ip,
      inet_server_port() as server_port,
      version() as postgres_version;
  "
}

list_databases() {
  header "Список БД"
  run_sql "$DEFAULT_DB" "
    select
      datname as database_name,
      pg_size_pretty(pg_database_size(datname)) as size
    from pg_database
    where datistemplate = false
    order by datname;
  "
}

select_database() {
  header "Выбор БД"

  mapfile -t DBS < <(run_sql_quiet "$DEFAULT_DB" "
    select datname
    from pg_database
    where datistemplate = false
    order by datname;
  ")

  if [[ ${#DBS[@]} -eq 0 ]]; then
    echo "Базы данных не найдены."
    return
  fi

  echo "Доступные БД:"
  local i=1
  for db in "${DBS[@]}"; do
    echo "  $i) $db"
    ((i++))
  done

  echo
  read -r -p "Введи номер БД: " db_num

  if [[ ! "$db_num" =~ ^[0-9]+$ ]]; then
    echo "Некорректный ввод."
    return
  fi

  if (( db_num < 1 || db_num > ${#DBS[@]} )); then
    echo "Нет такого номера."
    return
  fi

  CURRENT_DB="${DBS[$((db_num-1))]}"
  echo "Выбрана БД: $CURRENT_DB"
}

show_current_db() {
  header "Текущая БД"
  echo "Сейчас выбрана: $CURRENT_DB"
}

list_schemas() {
  header "Схемы в БД: $CURRENT_DB"
  run_sql "$CURRENT_DB" "
    select schema_name
    from information_schema.schemata
    where schema_name not in ('pg_catalog', 'information_schema')
    order by schema_name;
  "
}

list_tables() {
  header "Таблицы в БД: $CURRENT_DB"
  run_sql "$CURRENT_DB" "
    select
      table_schema,
      table_name
    from information_schema.tables
    where table_type = 'BASE TABLE'
      and table_schema not in ('pg_catalog', 'information_schema')
    order by table_schema, table_name;
  "
}

table_sizes() {
  header "Размеры таблиц в БД: $CURRENT_DB"
  run_sql "$CURRENT_DB" "
    select
      n.nspname as schema_name,
      c.relname as table_name,
      pg_size_pretty(pg_total_relation_size(c.oid)) as total_size,
      c.reltuples::bigint as estimated_rows
    from pg_class c
    join pg_namespace n on n.oid = c.relnamespace
    where c.relkind = 'r'
      and n.nspname not in ('pg_catalog', 'information_schema')
    order by pg_total_relation_size(c.oid) desc
    limit 100;
  "
}

pick_table() {
  mapfile -t TABLES < <(run_sql_quiet "$CURRENT_DB" "
    select n.nspname || '|' || c.relname
    from pg_class c
    join pg_namespace n on n.oid = c.relnamespace
    where c.relkind = 'r'
      and n.nspname not in ('pg_catalog', 'information_schema')
    order by n.nspname, c.relname;
  ")

  if [[ ${#TABLES[@]} -eq 0 ]]; then
    echo "В БД $CURRENT_DB нет пользовательских таблиц."
    return 1
  fi

  echo "Доступные таблицы:"
  local i=1
  local item schema table
  for item in "${TABLES[@]}"; do
    schema="${item%%|*}"
    table="${item##*|}"
    echo "  $i) ${schema}.${table}"
    ((i++))
  done

  echo
  read -r -p "Введи номер таблицы: " tbl_num

  if [[ ! "$tbl_num" =~ ^[0-9]+$ ]]; then
    echo "Некорректный ввод."
    return 1
  fi

  if (( tbl_num < 1 || tbl_num > ${#TABLES[@]} )); then
    echo "Нет такого номера."
    return 1
  fi

  SELECTED_ITEM="${TABLES[$((tbl_num-1))]}"
  SELECTED_SCHEMA="${SELECTED_ITEM%%|*}"
  SELECTED_TABLE="${SELECTED_ITEM##*|}"
  return 0
}

table_columns() {
  header "Выбор таблицы для просмотра колонок"
  pick_table || return

  header "Колонки таблицы ${SELECTED_SCHEMA}.${SELECTED_TABLE}"
  run_sql "$CURRENT_DB" "
    select
      ordinal_position,
      column_name,
      data_type,
      is_nullable,
      coalesce(character_maximum_length::text, '') as max_length,
      coalesce(column_default, '') as default_value
    from information_schema.columns
    where table_schema = '${SELECTED_SCHEMA}'
      and table_name = '${SELECTED_TABLE}'
    order by ordinal_position;
  "
}

table_sample() {
  header "Выбор таблицы для просмотра строк"
  pick_table || return

  header "Первые ${SAMPLE_ROWS} строк из ${SELECTED_SCHEMA}.${SELECTED_TABLE}"
  run_sql "$CURRENT_DB" "
    select *
    from \"${SELECTED_SCHEMA}\".\"${SELECTED_TABLE}\"
    limit ${SAMPLE_ROWS};
  "
}

database_size() {
  header "Размер БД: $CURRENT_DB"
  run_sql "$CURRENT_DB" "
    select
      current_database() as database_name,
      pg_size_pretty(pg_database_size(current_database())) as size,
      pg_database_size(current_database()) as size_bytes;
  "
}

connections() {
  header "Активные подключения"
  run_sql "$DEFAULT_DB" "
    select
      datname,
      usename,
      state,
      count(*) as connections
    from pg_stat_activity
    where datname is not null
    group by datname, usename, state
    order by connections desc, datname, usename, state;
  "
}

long_queries() {
  header "Долгие запросы"
  run_sql "$DEFAULT_DB" "
    select
      pid,
      usename,
      datname,
      state,
      now() - query_start as duration,
      left(query, 300) as query
    from pg_stat_activity
    where state <> 'idle'
      and query not ilike '%pg_stat_activity%'
    order by query_start asc;
  "
}

vacuum_stats() {
  header "Vacuum/Analyze статистика по БД: $CURRENT_DB"
  run_sql "$CURRENT_DB" "
    select
      schemaname,
      relname,
      n_live_tup,
      n_dead_tup,
      last_vacuum,
      last_autovacuum,
      last_analyze,
      last_autoanalyze
    from pg_stat_user_tables
    order by n_dead_tup desc
    limit 50;
  "
}

change_sample_rows() {
  echo
  read -r -p "Сколько строк показывать (текущее значение: $SAMPLE_ROWS): " new_rows
  if [[ "$new_rows" =~ ^[0-9]+$ ]] && (( new_rows > 0 )); then
    SAMPLE_ROWS="$new_rows"
    echo "Новое значение SAMPLE_ROWS: $SAMPLE_ROWS"
  else
    echo "Некорректное число."
  fi
}

run_custom_sql() {
  header "Выполнить SQL в БД: $CURRENT_DB"
  echo "Введи SQL-запрос одной строкой."
  echo "Пример:"
  echo "  select now();"
  echo "  select * from public.my_table limit 10;"
  echo

  read -r -p "SQL> " user_sql

  if [[ -z "${user_sql// }" ]]; then
    echo "Пустой запрос."
    return
  fi

  echo
  echo "Будет выполнено в БД: $CURRENT_DB"
  echo "Запрос:"
  echo "$user_sql"
  echo

  run_sql "$CURRENT_DB" "$user_sql"
}

# =========================
# Показать права пользователя
# =========================

show_user_privileges() {
  local target_user="$1"
  local target_db="$2"

  header "Права пользователя: $target_user"

  echo
  echo "--- Атрибуты роли ---"
  run_sql "$DEFAULT_DB" "
    select
      rolname,
      rolsuper        as superuser,
      rolinherit      as inherit,
      rolcreaterole   as createrole,
      rolcreatedb     as createdb,
      rolcanlogin     as canlogin,
      rolreplication  as replication,
      rolbypassrls    as bypassrls,
      rolconnlimit    as connlimit
    from pg_roles
    where rolname = '${target_user}';
  "

  echo
  echo "--- Членство в ролях ---"
  run_sql "$DEFAULT_DB" "
    select
      r.rolname  as role,
      m.rolname  as member_of,
      g.admin_option
    from pg_auth_members g
    join pg_roles r on r.oid = g.member
    join pg_roles m on m.oid = g.roleid
    where r.rolname = '${target_user}'
    order by m.rolname;
  "

  echo
  echo "--- Права на базы данных ---"
  run_sql "$DEFAULT_DB" "
    select
      datname as database,
      array_to_string(
        array(
          select case
            when has_database_privilege('${target_user}', datname, 'CONNECT')  then 'CONNECT'  end
          union all select case
            when has_database_privilege('${target_user}', datname, 'CREATE')   then 'CREATE'   end
          union all select case
            when has_database_privilege('${target_user}', datname, 'TEMP')     then 'TEMP'     end
        ), ', '
      ) as privileges
    from pg_database
    where datistemplate = false
    order by datname;
  "

  echo
  echo "--- Права на схемы в БД: $target_db ---"
  run_sql "$target_db" "
    select
      nspname as schema,
      array_to_string(
        array(
          select case when has_schema_privilege('${target_user}', nspname, 'USAGE')  then 'USAGE'  end
          union all select case when has_schema_privilege('${target_user}', nspname, 'CREATE') then 'CREATE' end
        ), ', '
      ) as privileges
    from pg_namespace
    where nspname not in ('pg_catalog', 'information_schema', 'pg_toast')
    order by nspname;
  "

  echo
  echo "--- Права на таблицы в БД: $target_db ---"
  run_sql "$target_db" "
    select
      table_schema,
      table_name,
      string_agg(privilege_type, ', ' order by privilege_type) as privileges
    from information_schema.role_table_grants
    where grantee = '${target_user}'
    group by table_schema, table_name
    order by table_schema, table_name;
  "

  echo
  echo "--- Права на sequences в БД: $target_db ---"
  run_sql "$target_db" "
    select
      sequence_schema,
      sequence_name,
      string_agg(privilege_type, ', ' order by privilege_type) as privileges
    from information_schema.role_usage_grants
    where object_type = 'SEQUENCE'
      and grantee = '${target_user}'
    group by sequence_schema, sequence_name
    order by sequence_schema, sequence_name;
  "
}

# =========================
# Подключение под пользователем (проверка логина/пароля)
# =========================

test_user_connection() {
  header "Проверка подключения под пользователем"

  read -r -p "Имя пользователя: " test_user
  if [[ -z "${test_user// }" ]]; then
    echo "Пустое имя пользователя."
    return
  fi

  # Читаем пароль без echo
  local test_password
  read -r -s -p "Пароль: " test_password
  echo

  # Выбор БД для подключения
  mapfile -t DBS < <(run_sql_quiet "$DEFAULT_DB" "
    select datname
    from pg_database
    where datistemplate = false
    order by datname;
  ")

  echo
  echo "Выбери БД для подключения:"
  local i=1
  for db in "${DBS[@]}"; do
    echo "  $i) $db"
    ((i++))
  done
  echo "  0) Использовать текущую ($CURRENT_DB)"
  echo

  read -r -p "Номер БД (или 0): " db_choice

  local target_db="$CURRENT_DB"
  if [[ "$db_choice" =~ ^[1-9][0-9]*$ ]] && (( db_choice >= 1 && db_choice <= ${#DBS[@]} )); then
    target_db="${DBS[$((db_choice-1))]}"
  fi

  echo
  echo "Подключение: user=$test_user db=$target_db host=$PGHOST port=$PGPORT"
  echo

  # Пробуем подключиться от имени test_user
  local connect_result
  if PGPASSWORD="$test_password" psql \
      -h "$PGHOST" -p "$PGPORT" \
      -U "$test_user" \
      -d "$target_db" \
      -X -v ON_ERROR_STOP=1 -P pager=off \
      -c "select current_user, current_database(), inet_server_addr() as server_ip, inet_server_port() as server_port;" \
      2>&1; then
    echo
    echo "✔ Подключение успешно!"
  else
    echo
    echo "✘ Подключение не удалось. Проверь логин, пароль или права на подключение к БД."
    return
  fi

  # Показываем права этого пользователя через основное подключение (с правами admin)
  show_user_privileges "$test_user" "$target_db"
}

# =========================
# Управление правами пользователя
# =========================

pick_user() {
  mapfile -t USERS < <(run_sql_quiet "$DEFAULT_DB" "
    select rolname
    from pg_roles
    where rolcanlogin = true
    order by rolname;
  ")

  if [[ ${#USERS[@]} -eq 0 ]]; then
    echo "Пользователи не найдены."
    return 1
  fi

  echo "Пользователи с правом входа:"
  local i=1
  for u in "${USERS[@]}"; do
    echo "  $i) $u"
    ((i++))
  done
  echo

  read -r -p "Введи номер пользователя: " u_num
  if [[ ! "$u_num" =~ ^[0-9]+$ ]] || (( u_num < 1 || u_num > ${#USERS[@]} )); then
    echo "Некорректный ввод."
    return 1
  fi

  SELECTED_USER="${USERS[$((u_num-1))]}"
  return 0
}

manage_user_privileges() {
  header "Управление правами пользователя"

  pick_user || return
  local target_user="$SELECTED_USER"

  # Показываем текущие права сразу
  show_user_privileges "$target_user" "$CURRENT_DB"

  while true; do
    header "Управление правами: $target_user | БД: $CURRENT_DB"
    echo "1)  GRANT  — права на БД (CONNECT/CREATE/TEMP)"
    echo "2)  REVOKE — права на БД"
    echo "3)  GRANT  — права на схему (USAGE/CREATE)"
    echo "4)  REVOKE — права на схему"
    echo "5)  GRANT  — права на таблицу (SELECT/INSERT/UPDATE/DELETE/ALL)"
    echo "6)  REVOKE — права на таблицу"
    echo "7)  GRANT  — права на все таблицы схемы"
    echo "8)  REVOKE — права на все таблицы схемы"
    echo "9)  GRANT  — роль пользователю"
    echo "10) REVOKE — роль у пользователя"
    echo "11) ALTER ROLE — атрибуты (SUPERUSER/CREATEDB/CREATEROLE/LOGIN и др.)"
    echo "12) Показать текущие права"
    echo "0)  Назад"
    echo

    read -r -p "Выбери действие: " priv_choice

    case "$priv_choice" in

      1)
        echo "Привилегии: CONNECT, CREATE, TEMP (через запятую или ALL)"
        read -r -p "Привилегии: " privs
        local db_for_grant
        read -r -p "На БД (Enter = $CURRENT_DB): " db_for_grant
        db_for_grant="${db_for_grant:-$CURRENT_DB}"
        run_sql "$DEFAULT_DB" "GRANT ${privs} ON DATABASE \"${db_for_grant}\" TO \"${target_user}\";"
        echo "✔ GRANT выполнен."
        ;;

      2)
        echo "Привилегии: CONNECT, CREATE, TEMP (через запятую или ALL)"
        read -r -p "Привилегии: " privs
        local db_for_revoke
        read -r -p "На БД (Enter = $CURRENT_DB): " db_for_revoke
        db_for_revoke="${db_for_revoke:-$CURRENT_DB}"
        run_sql "$DEFAULT_DB" "REVOKE ${privs} ON DATABASE \"${db_for_revoke}\" FROM \"${target_user}\";"
        echo "✔ REVOKE выполнен."
        ;;

      3)
        echo "Схемы в БД $CURRENT_DB:"
        run_sql_quiet "$CURRENT_DB" "
          select nspname from pg_namespace
          where nspname not in ('pg_catalog','information_schema','pg_toast')
          order by nspname;
        " | nl -ba
        echo "Привилегии: USAGE, CREATE (через запятую или ALL)"
        read -r -p "Схема: " schema_name
        read -r -p "Привилегии: " privs
        run_sql "$CURRENT_DB" "GRANT ${privs} ON SCHEMA \"${schema_name}\" TO \"${target_user}\";"
        echo "✔ GRANT выполнен."
        ;;

      4)
        echo "Схемы в БД $CURRENT_DB:"
        run_sql_quiet "$CURRENT_DB" "
          select nspname from pg_namespace
          where nspname not in ('pg_catalog','information_schema','pg_toast')
          order by nspname;
        " | nl -ba
        read -r -p "Схема: " schema_name
        echo "Привилегии: USAGE, CREATE (через запятую или ALL)"
        read -r -p "Привилегии: " privs
        run_sql "$CURRENT_DB" "REVOKE ${privs} ON SCHEMA \"${schema_name}\" FROM \"${target_user}\";"
        echo "✔ REVOKE выполнен."
        ;;

      5)
        pick_table || continue
        echo "Привилегии: SELECT, INSERT, UPDATE, DELETE, TRUNCATE, REFERENCES, TRIGGER, ALL"
        read -r -p "Привилегии: " privs
        run_sql "$CURRENT_DB" "GRANT ${privs} ON TABLE \"${SELECTED_SCHEMA}\".\"${SELECTED_TABLE}\" TO \"${target_user}\";"
        echo "✔ GRANT выполнен."
        ;;

      6)
        pick_table || continue
        echo "Привилегии: SELECT, INSERT, UPDATE, DELETE, TRUNCATE, REFERENCES, TRIGGER, ALL"
        read -r -p "Привилегии: " privs
        run_sql "$CURRENT_DB" "REVOKE ${privs} ON TABLE \"${SELECTED_SCHEMA}\".\"${SELECTED_TABLE}\" FROM \"${target_user}\";"
        echo "✔ REVOKE выполнен."
        ;;

      7)
        echo "Схемы в БД $CURRENT_DB:"
        run_sql_quiet "$CURRENT_DB" "
          select nspname from pg_namespace
          where nspname not in ('pg_catalog','information_schema','pg_toast')
          order by nspname;
        " | nl -ba
        read -r -p "Схема: " schema_name
        echo "Привилегии: SELECT, INSERT, UPDATE, DELETE, ALL"
        read -r -p "Привилегии: " privs
        run_sql "$CURRENT_DB" "GRANT ${privs} ON ALL TABLES IN SCHEMA \"${schema_name}\" TO \"${target_user}\";"
        echo
        read -r -p "Установить DEFAULT PRIVILEGES для новых таблиц? (y/N): " set_default
        if [[ "${set_default,,}" == "y" ]]; then
          run_sql "$CURRENT_DB" "ALTER DEFAULT PRIVILEGES IN SCHEMA \"${schema_name}\" GRANT ${privs} ON TABLES TO \"${target_user}\";"
        fi
        echo "✔ GRANT выполнен."
        ;;

      8)
        echo "Схемы в БД $CURRENT_DB:"
        run_sql_quiet "$CURRENT_DB" "
          select nspname from pg_namespace
          where nspname not in ('pg_catalog','information_schema','pg_toast')
          order by nspname;
        " | nl -ba
        read -r -p "Схема: " schema_name
        echo "Привилегии: SELECT, INSERT, UPDATE, DELETE, ALL"
        read -r -p "Привилегии: " privs
        run_sql "$CURRENT_DB" "REVOKE ${privs} ON ALL TABLES IN SCHEMA \"${schema_name}\" FROM \"${target_user}\";"
        echo "✔ REVOKE выполнен."
        ;;

      9)
        echo "Доступные роли:"
        run_sql_quiet "$DEFAULT_DB" "
          select rolname from pg_roles
          where rolname <> '${target_user}'
          order by rolname;
        " | nl -ba
        read -r -p "Имя роли: " role_name
        read -r -p "WITH ADMIN OPTION? (y/N): " with_admin
        local admin_opt=""
        [[ "${with_admin,,}" == "y" ]] && admin_opt=" WITH ADMIN OPTION"
        run_sql "$DEFAULT_DB" "GRANT \"${role_name}\" TO \"${target_user}\"${admin_opt};"
        echo "✔ GRANT роли выполнен."
        ;;

      10)
        echo "Текущие роли пользователя $target_user:"
        run_sql "$DEFAULT_DB" "
          select m.rolname as role
          from pg_auth_members g
          join pg_roles r on r.oid = g.member
          join pg_roles m on m.oid = g.roleid
          where r.rolname = '${target_user}'
          order by m.rolname;
        "
        read -r -p "Имя роли для отзыва: " role_name
        run_sql "$DEFAULT_DB" "REVOKE \"${role_name}\" FROM \"${target_user}\";"
        echo "✔ REVOKE роли выполнен."
        ;;

      11)
        echo "Изменить атрибуты роли $target_user."
        echo "Доступные флаги (пример: SUPERUSER, NOSUPERUSER, CREATEDB, NOCREATEDB,"
        echo "  CREATEROLE, NOCREATEROLE, LOGIN, NOLOGIN, REPLICATION, NOREPLICATION,"
        echo "  BYPASSRLS, NOBYPASSRLS, CONNECTION LIMIT N, PASSWORD 'xxx', VALID UNTIL 'date')"
        read -r -p "Атрибуты: " role_attrs
        if [[ -z "${role_attrs// }" ]]; then
          echo "Пустой ввод."
        else
          run_sql "$DEFAULT_DB" "ALTER ROLE \"${target_user}\" ${role_attrs};"
          echo "✔ ALTER ROLE выполнен."
        fi
        ;;

      12)
        show_user_privileges "$target_user" "$CURRENT_DB"
        ;;

      0)
        return
        ;;

      *)
        echo "Неизвестный пункт."
        ;;
    esac

    pause
  done
}

# =========================
# Главное меню
# =========================

main_menu() {
  while true; do
    header "Postgres menu | host=$PGHOST port=$PGPORT user=$PGUSER current_db=$CURRENT_DB sample_rows=$SAMPLE_ROWS"
    echo "1)  Проверить подключение"
    echo "2)  Показать список БД"
    echo "3)  Выбрать БД"
    echo "4)  Показать текущую БД"
    echo "5)  Показать схемы"
    echo "6)  Показать таблицы"
    echo "7)  Показать размеры таблиц"
    echo "8)  Показать колонки таблицы"
    echo "9)  Показать первые N строк таблицы"
    echo "10) Показать размер текущей БД"
