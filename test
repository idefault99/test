{{- $stand := .Values.stand.name -}}
{{- $vault := .Values.vault -}}

{{/* ExternalSecrets для infra */}}
{{- range .Values.stand.infra.services }}
---
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{ .secretName }}
  namespace: {{ $stand }}
  labels:
    {{- include "stand-secrets.labels" $ | nindent 4 }}
    vault-section: infra
    vault-service: {{ .name }}
spec:
  refreshInterval: {{ $vault.refreshInterval }}
  secretStoreRef:
    name: {{ $vault.clusterSecretStore.name }}
    kind: ClusterSecretStore
  target:
    name: {{ .secretName }}
    creationPolicy: Owner
    deletionPolicy: Retain
  dataFrom:
    - extract:
        key: {{ $stand }}/infra/{{ .name }}
{{- end }}

{{/* ExternalSecrets для каждого app namespace */}}
{{- range .Values.stand.apps }}
{{- $appNs := printf "%s-%s" $stand .suffix }}
{{- range .services }}
---
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{ .secretName }}
  namespace: {{ $appNs }}
  labels:
    {{- include "stand-secrets.labels" $ | nindent 4 }}
    vault-section: {{ $.suffix }}
    vault-service: {{ .name }}
spec:
  refreshInterval: {{ $vault.refreshInterval }}
  secretStoreRef:
    name: vault-cluster-store
    kind: ClusterSecretStore
  target:
    name: {{ .secretName }}
    creationPolicy: Owner
    deletionPolicy: Retain
  dataFrom:
    - extract:
        key: {{ $stand }}/{{ $.suffix }}/{{ .name }}
{{- end }}
{{- end }}
