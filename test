# Для одного образа — проверь сначала на k8s-1.32.13
mkdir -p /tmp/oci-import/k8s
tar -xzf /tmp/k8s/k8s-1.32.13.tar.gz -C /tmp/oci-import/k8s

# Импортируем первый образ из архива (kube-apiserver)
skopeo copy \
  --insecure-policy \
  oci:/tmp/oci-import/k8s:v1.32.13 \
  oci-archive:/tmp/kube-apiserver.tar

# Теперь ctr import понимает oci-archive
ctr -n k8s.io images import /tmp/kube-apiserver.tar
