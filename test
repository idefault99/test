#!/bin/bash
#
set -e  # останавливаемся при любой ошибке

# --- Настройки ---
OUTPUT_DIR="./longhorn-images"
mkdir -p "$OUTPUT_DIR"

# --- 1. Образы Kubernetes (core) ---
# Для версии 1.32.13 стандартные теги:
# K8S_IMAGES=(
#     "registry.k8s.io/kube-apiserver:v1.32.13"
#     "registry.k8s.io/kube-controller-manager:v1.32.13"
#     "registry.k8s.io/kube-scheduler:v1.32.13"
#     "registry.k8s.io/kube-proxy:v1.32.13"
#     "registry.k8s.io/coredns/coredns:v1.11.3"
#     "registry.k8s.io/pause:3.10"
#     "registry.k8s.io/etcd:3.5.16-0"
# )

# # --- 2. Calico v3.29.5 ---
CALICO_IMAGES=(
    "docker.io/calico/cni:v3.29.5"
    "docker.io/calico/node:v3.29.5"
    "docker.io/calico/kube-controllers:v3.29.5"
)

# # --- 3. Longhorn v1.10.2 ---
LONGHORN_IMAGES=(
    "longhornio/longhorn-manager:v1.10.2"
    "longhornio/longhorn-engine:v1.10.2"
    "longhornio/longhorn-instance-manager:v1.10.2"
    "longhornio/longhorn-share-manager:v1.10.2"
    "longhornio/longhorn-ui:v1.10.2"
)

# --- 4. kube-vip v0.9.2 ---
# VIP_IMAGES=(
#     "ghcr.io/kube-vip/kube-vip:v0.9.2"
# )

# --- Объединяем все списки ---
ALL_IMAGES=("${LONGHORN_IMAGES[@]}")

echo "=== Начинаем pull образов ==="
for image in "${ALL_IMAGES[@]}"; do
    echo "Pull: $image"
    docker pull "$image"
done

echo "=== Сохраняем все образы в один архив images.tar.gz ==="
docker save "${ALL_IMAGES[@]}" | gzip > "$OUTPUT_DIR/all-images.tar.gz"

echo "=== Готово ==="
echo "Все архивы лежат в папке: $OUTPUT_DIR"
echo "Общий размер:"
du -sh "$OUTPUT_DIR"

echo "=== Удаляем образы из Docker (освобождаем место) ==="
docker rmi "${ALL_IMAGES[@]}" 2>/dev/null || true