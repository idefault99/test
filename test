# =====================================================================
# WORKER NODES FIX / CHECKLIST
# Cluster:
#   control-plane: coparking-5, coparking-6, coparking-7
#   workers:       coparking-8, coparking-9, coparking-10
# VIP/API:         k8s-api / 172.16.175.20:6443
# =====================================================================


# =====================================================================
# 0. ВАЖНОЕ ПОНИМАНИЕ
# =====================================================================

# STATUS Ready у worker-нод означает, что нода подключена к кластеру.
# ROLES <none> — это НЕ ошибка.
# В kubeadm worker-ноды по умолчанию не получают роль worker в kubectl get nodes.
# Роль — это просто label:
#
#   node-role.kubernetes.io/worker=
#
# Если хочешь видеть worker вместо <none>, надо повесить label вручную.


# =====================================================================
# 1. ВЫПОЛНЯТЬ НА CONTROL-PLANE, например на coparking-5
# =====================================================================

ssh root@coparking-5


# Проверить ноды:

kubectl get nodes -o wide


# Повесить worker role label на worker-ноды:

kubectl label node coparking-8 node-role.kubernetes.io/worker= --overwrite
kubectl label node coparking-9 node-role.kubernetes.io/worker= --overwrite
kubectl label node coparking-10 node-role.kubernetes.io/worker= --overwrite


# Проверить, что теперь ROLE стал worker:

kubectl get nodes -o wide


# Ожидаемо:
#
# coparking-8    Ready    worker
# coparking-9    Ready    worker
# coparking-10   Ready    worker


# =====================================================================
# 2. ПРОВЕРИТЬ, ЧТО НА WORKER-НОДАХ ЕСТЬ СИСТЕМНЫЕ POD'Ы
# =====================================================================

kubectl -n kube-system get pods -o wide | egrep 'coparking-8|coparking-9|coparking-10|NAME'


# На каждой worker-ноде должны быть минимум:
#
# calico-node-xxxxx   1/1 Running   ...   coparking-8
# kube-proxy-xxxxx    1/1 Running   ...   coparking-8
#
# Аналогично для coparking-9 и coparking-10.


# =====================================================================
# 3. ПРОВЕРИТЬ ВСЕ POD'Ы ПО НОДАМ
# =====================================================================

kubectl get pods -A -o wide --field-selector spec.nodeName=coparking-8
kubectl get pods -A -o wide --field-selector spec.nodeName=coparking-9
kubectl get pods -A -o wide --field-selector spec.nodeName=coparking-10


# =====================================================================
# 4. ПРОБЛЕМА: НА WORKER-НОДЕ kubectl get pods ДАЁТ connection refused
# =====================================================================

# Это обычно НЕ проблема worker-ноды.
# Это значит, что на worker-ноде kubectl смотрит не в кластерный API,
# а пытается подключиться к localhost:8080 или 127.0.0.1:6443.
#
# На worker-нодах по умолчанию обычно НЕТ /etc/kubernetes/admin.conf.
# kubelet использует /etc/kubernetes/kubelet.conf,
# но kubectl для root не настроен.


# =====================================================================
# 5. ПРОВЕРИТЬ НА WORKER-НОДЕ, КУДА СМОТРИТ kubectl
# =====================================================================

ssh root@coparking-8

kubectl config view
echo $KUBECONFIG
ls -lah ~/.kube/config /etc/kubernetes/admin.conf /etc/kubernetes/kubelet.conf 2>/dev/null || true


# Если kubectl config view пустой или server localhost:8080 —
# отсюда и connection refused.


# Повторить для остальных:

ssh root@coparking-9

kubectl config view
echo $KUBECONFIG
ls -lah ~/.kube/config /etc/kubernetes/admin.conf /etc/kubernetes/kubelet.conf 2>/dev/null || true


ssh root@coparking-10

kubectl config view
echo $KUBECONFIG
ls -lah ~/.kube/config /etc/kubernetes/admin.conf /etc/kubernetes/kubelet.conf 2>/dev/null || true


# =====================================================================
# 6. ПРАВИЛЬНЫЙ ВАРИАНТ: СКОПИРОВАТЬ kubeconfig НА WORKER-НОДЫ
# =====================================================================

# Выполнять с coparking-5.

ssh root@coparking-5


# Создать ~/.kube на worker-нодах:

for n in coparking-8 coparking-9 coparking-10; do
  ssh root@$n "mkdir -p /root/.kube"
done


# Скопировать admin.conf как kubeconfig для root:

for n in coparking-8 coparking-9 coparking-10; do
  scp /etc/kubernetes/admin.conf root@$n:/root/.kube/config
done


# Выставить права:

for n in coparking-8 coparking-9 coparking-10; do
  ssh root@$n "chown root:root /root/.kube/config && chmod 600 /root/.kube/config"
done


# Проверить, что в kubeconfig указан нормальный API endpoint:

for n in coparking-8 coparking-9 coparking-10; do
  echo "===== $n ====="
  ssh root@$n "grep 'server:' /root/.kube/config"
done


# Желательно, чтобы было так:
#
# server: https://k8s-api:6443
#
# или так:
#
# server: https://172.16.175.20:6443
#
# Если там случайно https://127.0.0.1:6443 или https://localhost:6443,
# на worker-ноде kubectl будет падать.


# =====================================================================
# 7. ЕСЛИ В config УКАЗАН 127.0.0.1 ИЛИ localhost
# =====================================================================

# На каждой worker-ноде заменить server на VIP/DNS:

for n in coparking-8 coparking-9 coparking-10; do
  ssh root@$n "sed -i 's#server: https://127.0.0.1:6443#server: https://k8s-api:6443#g' /root/.kube/config"
  ssh root@$n "sed -i 's#server: https://localhost:6443#server: https://k8s-api:6443#g' /root/.kube/config"
done


# Проверить:

for n in coparking-8 coparking-9 coparking-10; do
  echo "===== $n ====="
  ssh root@$n "grep 'server:' /root/.kube/config"
done


# =====================================================================
# 8. ПРОВЕРИТЬ hosts И ДОСТУП К API НА WORKER-НОДАХ
# =====================================================================

for n in coparking-8 coparking-9 coparking-10; do
  echo "===== $n ====="
  ssh root@$n "getent hosts k8s-api"
  ssh root@$n "curl -k --max-time 5 https://k8s-api:6443/healthz"
  ssh root@$n "curl -k --max-time 5 https://172.16.175.20:6443/healthz"
done


# Ожидаемо:
#
# 172.16.175.20 k8s-api
# ok
# ok


# Если getent hosts k8s-api ничего не выводит,
# добавить запись в /etc/hosts на worker-нодах:

for n in coparking-8 coparking-9 coparking-10; do
  ssh root@$n "grep -q '172.16.175.20 k8s-api' /etc/hosts || echo '172.16.175.20 k8s-api' >> /etc/hosts"
done


# Повторить проверку:

for n in coparking-8 coparking-9 coparking-10; do
  echo "===== $n ====="
  ssh root@$n "getent hosts k8s-api"
  ssh root@$n "curl -k --max-time 5 https://k8s-api:6443/healthz"
done


# =====================================================================
# 9. ПРОВЕРИТЬ kubectl НА WORKER-НОДАХ
# =====================================================================

for n in coparking-8 coparking-9 coparking-10; do
  echo "===== $n ====="
  ssh root@$n "kubectl get nodes -o wide"
  ssh root@$n "kubectl get pods -A -o wide | head -n 30"
done


# Если теперь работает — проблема была только в отсутствии kubeconfig для kubectl.


# =====================================================================
# 10. ПРОВЕРИТЬ kubelet НА WORKER-НОДАХ
# =====================================================================

for n in coparking-8 coparking-9 coparking-10; do
  echo "===== $n ====="
  ssh root@$n "systemctl is-active kubelet"
  ssh root@$n "systemctl status kubelet --no-pager -l | sed -n '1,25p'"
done


# Проверить kubelet.conf:

for n in coparking-8 coparking-9 coparking-10; do
  echo "===== $n ====="
  ssh root@$n "ls -lah /etc/kubernetes/kubelet.conf"
  ssh root@$n "grep 'server:' /etc/kubernetes/kubelet.conf"
done


# В kubelet.conf тоже должен быть нормальный API endpoint:
#
# server: https://k8s-api:6443
# или
# server: https://172.16.175.20:6443


# Если kubelet.conf смотрит на 127.0.0.1 или localhost,
# это плохо для worker-ноды.
# Тогда заменить:

for n in coparking-8 coparking-9 coparking-10; do
  ssh root@$n "cp /etc/kubernetes/kubelet.conf /etc/kubernetes/kubelet.conf.bak.$(date +%F-%H%M%S)"
  ssh root@$n "sed -i 's#server: https://127.0.0.1:6443#server: https://k8s-api:6443#g' /etc/kubernetes/kubelet.conf"
  ssh root@$n "sed -i 's#server: https://localhost:6443#server: https://k8s-api:6443#g' /etc/kubernetes/kubelet.conf"
done


# После изменения kubelet.conf перезапустить kubelet:

for n in coparking-8 coparking-9 coparking-10; do
  ssh root@$n "systemctl restart kubelet"
done


# Проверить:

kubectl get nodes -o wide


# =====================================================================
# 11. ПРОВЕРИТЬ containerd НА WORKER-НОДАХ
# =====================================================================

for n in coparking-8 coparking-9 coparking-10; do
  echo "===== $n ====="
  ssh root@$n "systemctl is-active containerd"
  ssh root@$n "systemctl status containerd --no-pager -l | sed -n '1,20p'"
  ssh root@$n "crictl ps -a | head -n 30"
done


# =====================================================================
# 12. ПРОВЕРИТЬ CNI НА WORKER-НОДАХ
# =====================================================================

for n in coparking-8 coparking-9 coparking-10; do
  echo "===== $n ====="
  ssh root@$n "ls -lah /etc/cni/net.d"
  ssh root@$n "ls -lah /opt/cni/bin | head -n 40"
  ssh root@$n "ip -br link | grep -E 'cali|tunl|vxlan' || true"
  ssh root@$n "ip route | grep -E '10.244|cali|tunl|vxlan' || true"
done


# =====================================================================
# 13. ПРОВЕРИТЬ kube-proxy И calico-node ДЛЯ WORKER-НОД
# =====================================================================

kubectl -n kube-system get pods -o wide | egrep 'NAME|coparking-8|coparking-9|coparking-10'


# Посмотреть конкретно:

kubectl -n kube-system get pods -o wide | grep calico-node
kubectl -n kube-system get pods -o wide | grep kube-proxy


# Если на worker нет calico-node или kube-proxy — это проблема DaemonSet.
# Проверить DaemonSet:

kubectl -n kube-system get ds -o wide
kubectl -n kube-system describe ds calico-node
kubectl -n kube-system describe ds kube-proxy


# =====================================================================
# 14. ПРОВЕРИТЬ TAINTS НА WORKER-НОДАХ
# =====================================================================

kubectl describe node coparking-8 | grep -i taints -A2
kubectl describe node coparking-9 | grep -i taints -A2
kubectl describe node coparking-10 | grep -i taints -A2


# На worker-нодах обычно должно быть:
#
# Taints: <none>
#
# Если там есть что-то вроде NoSchedule, удалить:

kubectl taint node coparking-8 node-role.kubernetes.io/control-plane:NoSchedule- 2>/dev/null || true
kubectl taint node coparking-9 node-role.kubernetes.io/control-plane:NoSchedule- 2>/dev/null || true
kubectl taint node coparking-10 node-role.kubernetes.io/control-plane:NoSchedule- 2>/dev/null || true

kubectl taint node coparking-8 node.kubernetes.io/not-ready:NoSchedule- 2>/dev/null || true
kubectl taint node coparking-9 node.kubernetes.io/not-ready:NoSchedule- 2>/dev/null || true
kubectl taint node coparking-10 node.kubernetes.io/not-ready:NoSchedule- 2>/dev/null || true


# Проверить снова:

kubectl describe node coparking-8 | grep -i taints -A2
kubectl describe node coparking-9 | grep -i taints -A2
kubectl describe node coparking-10 | grep -i taints -A2


# =====================================================================
# 15. ПРОВЕРИТЬ LABELS НА WORKER-НОДАХ
# =====================================================================

kubectl get node coparking-8 --show-labels
kubectl get node coparking-9 --show-labels
kubectl get node coparking-10 --show-labels


# Нужный минимум:
#
# kubernetes.io/hostname=coparking-8
# node-role.kubernetes.io/worker=
#
# Если worker label пропал:

kubectl label node coparking-8 node-role.kubernetes.io/worker= --overwrite
kubectl label node coparking-9 node-role.kubernetes.io/worker= --overwrite
kubectl label node coparking-10 node-role.kubernetes.io/worker= --overwrite


# =====================================================================
# 16. ПРОВЕРИТЬ СЕТЕВОЙ POD-TO-POD / POD-TO-SERVICE
# =====================================================================

# Создать тестовый pod на worker-ноде coparking-8:

kubectl run test-worker-8 \
  --image=busybox:1.36 \
  --restart=Never \
  --overrides='{"spec":{"nodeName":"coparking-8","containers":[{"name":"test-worker-8","image":"busybox:1.36","command":["sleep","3600"]}]}}'


# Создать тестовый pod на worker-ноде coparking-9:

kubectl run test-worker-9 \
  --image=busybox:1.36 \
  --restart=Never \
  --overrides='{"spec":{"nodeName":"coparking-9","containers":[{"name":"test-worker-9","image":"busybox:1.36","command":["sleep","3600"]}]}}'


# Создать тестовый pod на worker-ноде coparking-10:

kubectl run test-worker-10 \
  --image=busybox:1.36 \
  --restart=Never \
  --overrides='{"spec":{"nodeName":"coparking-10","containers":[{"name":"test-worker-10","image":"busybox:1.36","command":["sleep","3600"]}]}}'


# Проверить запуск:

kubectl get pods -o wide | grep test-worker


# Проверить DNS внутри pod:

kubectl exec test-worker-8 -- nslookup kubernetes.default.svc.cluster.local
kubectl exec test-worker-9 -- nslookup kubernetes.default.svc.cluster.local
kubectl exec test-worker-10 -- nslookup kubernetes.default.svc.cluster.local


# Проверить доступ к Kubernetes service:

kubectl exec test-worker-8 -- wget -qO- --no-check-certificate https://kubernetes.default.svc.cluster.local/healthz
kubectl exec test-worker-9 -- wget -qO- --no-check-certificate https://kubernetes.default.svc.cluster.local/healthz
kubectl exec test-worker-10 -- wget -qO- --no-check-certificate https://kubernetes.default.svc.cluster.local/healthz


# Ожидаемо:
#
# ok


# Удалить тестовые pod'ы:

kubectl delete pod test-worker-8 test-worker-9 test-worker-10 --ignore-not-found


# =====================================================================
# 17. ЕСЛИ TEST POD ЗАСТРЯЛ В ContainerCreating
# =====================================================================

kubectl describe pod test-worker-8
kubectl describe pod test-worker-9
kubectl describe pod test-worker-10


# Смотреть Events.
# Типовые проблемы:
#
# Failed to pull image              -> проблема с registry/proxy/containerd
