redact() {
  sed -E \
    -e 's/[a-z0-9]{6}\.[a-z0-9]{16}/<TOKEN>/g' \
    -e 's/sha256:[a-f0-9]{64}/sha256:<HASH>/g' \
    -e 's/(certificate-key|--certificate-key)[ =:]?[a-f0-9]{64}/\1 <CERT_KEY>/g' \
    -e 's/(token: )[A-Za-z0-9._-]+/\1<REDACTED>/g' \
    -e 's/(bearerToken: )[A-Za-z0-9._-]+/\1<REDACTED>/g' \
    -e 's/(Authorization: Bearer )[A-Za-z0-9._-]+/\1<REDACTED>/g' \
    -e 's/(client-certificate-data: ).*/\1<REDACTED>/g' \
    -e 's/(client-key-data: ).*/\1<REDACTED>/g' \
    -e 's/(certificate-authority-data: ).*/\1<REDACTED>/g'
}

echo "== kubeadm log =="
tail -n 160 /root/kubeadm-init.log 2>&1 | redact

echo "== kubelet status =="
systemctl status kubelet --no-pager -l 2>&1 | redact

echo "== kubelet recent logs =="
journalctl -u kubelet -n 120 --no-pager 2>&1 | redact

echo "== manifests =="
ls -l /etc/kubernetes/manifests 2>&1 | redact
grep -n "path: /etc/kubernetes" /etc/kubernetes/manifests/kube-vip.yaml 2>&1 | redact

echo "== kube-vip manifest =="
sed -n '1,160p' /etc/kubernetes/manifests/kube-vip.yaml 2>&1 | redact

echo "== containerd/crictl =="
systemctl is-active containerd 2>&1 | redact
crictl pods 2>&1 | redact
crictl ps -a 2>&1 | redact

echo "== kube-vip logs =="
VIP_CONTAINER="$(crictl ps -a --name kube-vip -q | head -n1)"
if [ -n "$VIP_CONTAINER" ]; then
  crictl logs "$VIP_CONTAINER" 2>&1 | redact
else
  echo "no kube-vip container found"
fi

echo "== apiserver logs tail =="
APISERVER_CONTAINER="$(crictl ps -a --name kube-apiserver -q | head -n1)"
if [ -n "$APISERVER_CONTAINER" ]; then
  crictl logs --tail=120 "$APISERVER_CONTAINER" 2>&1 | redact
else
  echo "no kube-apiserver container found"
fi

echo "== api health =="
curl -k --max-time 5 https://127.0.0.1:6443/healthz 2>&1 | redact
echo
curl -k --max-time 5 https://172.16.175.19:6443/healthz 2>&1 | redact
echo
curl -k --max-time 5 https://172.16.175.20:6443/healthz 2>&1 | redact
echo

echo "== vip/network =="
ip addr show eno1 2>&1 | redact
ip route 2>&1 | redact
ip neigh show dev eno1 2>&1 | redact
ping -c 3 172.16.175.20 2>&1 | redact

echo "== kubeconfig server only =="
grep 'server:' /etc/kubernetes/admin.conf 2>&1 | redact
grep 'server:' /etc/kubernetes/super-admin.conf 2>&1 | redact
grep k8s-api /etc/hosts 2>&1 | redact

echo "== kubectl =="
KUBECONFIG=/etc/kubernetes/admin.conf kubectl get nodes -o wide 2>&1 | redact
KUBECONFIG=/etc/kubernetes/admin.conf kubectl get pods -A -o wide 2>&1 | redact
