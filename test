{{- if and (eq .Values.enableService.redis.enable true) (eq .Values.enableService.redis.type "cluster") }}
{{- $modules := .Files.Get "files/redis_module.yaml" | fromYaml -}}
{{- range $module := $modules.main }}
{{- if or (index $.Values.enableModules $module) (eq $module "")}}
---
apiVersion: batch/v1
kind: Job
metadata:
  name: {{ $.Values.labels.redis }}-job
  labels:
    app: {{ $.Values.labels.redis }}
  namespace: {{ $.Release.Namespace }}{{ if eq $module "" }}{{ else }}-{{ $module }}{{ end }}
spec:
  template:
    spec:
      serviceAccountName: redis-waiter-sa
      initContainers:
      - name: wait-for-redis-nodes
        image: registry.test.model.svo.aero/dpm/iac/infra:kubectl
        command: ['sh', '-c']
        args:
        - |
          kubectl auth can-i get pods -n {{ $.Release.Namespace }}{{ if eq $module "" }}{{ else }}-{{ $module }}{{ end }}
          kubectl wait --for=condition=Ready -n {{ $.Release.Namespace }}{{ if eq $module "" }}{{ else }}-{{ $module }}{{ end }} pod/{{ $.Values.labels.redis }}-deployment-0 --timeout=300s
          kubectl wait --for=condition=Ready -n {{ $.Release.Namespace }}{{ if eq $module "" }}{{ else }}-{{ $module }}{{ end }} pod/{{ $.Values.labels.redis }}-deployment-1 --timeout=300s  
          kubectl wait --for=condition=Ready -n {{ $.Release.Namespace }}{{ if eq $module "" }}{{ else }}-{{ $module }}{{ end }} pod/{{ $.Values.labels.redis }}-deployment-2 --timeout=300s
      containers:
      - name: {{ $.Values.labels.redis }}
        image: {{ $.Values.images.redis }}
        imagePullPolicy: "IfNotPresent"
        command: [ "sh", "-c" ]
        args:
          - |
            redis-cli --cluster create \
            {{- range $i := until 3 }}
            {{ $.Values.labels.redis }}-deployment-{{ $i }}.{{ $.Values.labels.redis }}-service.{{ $.Release.Namespace }}{{ if eq $module "" }}{{ else }}-{{ $module }}{{ end }}.svc.cluster.local:{{ $.Values.ports.internal.redis.client }} \
            {{- end }}
            --cluster-yes
      restartPolicy: Never
      imagePullSecrets:
        - name: {{ $.Values.imagePullSecret }}
  backoffLimit: 3
  activeDeadlineSeconds: 30
  ttlSecondsAfterFinished: 40
{{- end }}
{{- end }}
{{- end }}
