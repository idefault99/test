script:
  - rm -rf ./artifacts
  - mkdir -p ./artifacts
  - chmod 777 ./artifacts
  - export TAG=$(eval $TAG_SCRIPT)
  - TEST_EXIT_CODE=0
  - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} up \
      --remove-orphans --renew-anon-volumes --force-recreate --exit-code-from test test \
      || TEST_EXIT_CODE=$?
  - echo "TEST_EXIT_CODE=$TEST_EXIT_CODE"
  - chmod -R 777 ./artifacts || true   # <-- вот это
  - sed -n '1,120p' ./artifacts/report.xml || true
  - sed -i 's|" filename="|" filename="src/|g' ./artifacts/coverage.xml || true
  - exit $TEST_EXIT_CODE
