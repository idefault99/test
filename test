{{- $modules := .Files.Get "files/redis_module.yaml" | fromYaml -}}
{{- range $module := $modules.main }}
{{- if or (index $.Values.enableModules $module) (eq $module "")}}
{{- $ns := printf "%s%s" $.Release.Namespace (ternary "" (printf "-%s" $module) (eq $module "")) }}
---
apiVersion: batch/v1
kind: Job
metadata:
  name: {{ $.Values.labels.redis }}-pre-upgrade-{{ $.Release.Revision }}
  namespace: {{ $ns }}
  annotations:
    "helm.sh/hook": pre-upgrade
    "helm.sh/hook-weight": "-5"
    "helm.sh/hook-delete-policy": before-hook-creation,hook-succeeded
spec:
  backoffLimit: 1
  activeDeadlineSeconds: 120
  ttlSecondsAfterFinished: 60
  template:
    spec:
      serviceAccountName: {{ $.Values.labels.redis }}-waiter-sa
      restartPolicy: Never
      imagePullSecrets:
        - name: {{ $.Values.imagePullSecret }}
      containers:
        - name: pre-upgrade
          image: registry.test.model.svo.aero/dpm/iac/infra:kubectl
          command: ['sh', '-c']
          args:
            - |
              NS="{{ $ns }}"
              STS="{{ $.Values.labels.redis }}-deployment"
              REDIS_ENABLED="{{ $.Values.enableService.redis.enable }}"
              REDIS_TYPE="{{ $.Values.enableService.redis.type }}"
              STORAGE_CLASS="{{ $.Values.enableService.redis.storageClassName | default "" }}"

              echo "==> Redis pre-upgrade hook"
              echo "    namespace=$NS"
              echo "    enabled=$REDIS_ENABLED"
              echo "    type=$REDIS_TYPE"
              echo "    storageClass=$STORAGE_CLASS"

              # Проверяем существует ли StatefulSet вообще
              if ! kubectl get statefulset $STS -n $NS > /dev/null 2>&1; then
                echo "==> StatefulSet не найден — пропускаем"
                exit 0
              fi

              echo "==> StatefulSet найден, анализируем..."

              # Если redis выключен — удаляем StatefulSet и поды полностью
              if [ "$REDIS_ENABLED" = "false" ]; then
                echo "==> Redis выключен — удаляем StatefulSet и поды"
                kubectl delete statefulset $STS -n $NS --cascade=foreground 2>/dev/null || true
                echo "==> Удалено"
                exit 0
              fi

              # Получаем текущий volumeClaimTemplates из существующего StatefulSet
              CURRENT_VCT=$(kubectl get statefulset $STS -n $NS \
                -o jsonpath='{.spec.volumeClaimTemplates}' 2>/dev/null)

              # Определяем целевое состояние — нужен ли PVC в новой версии
              # PVC нужен если storageClassName задан
              TARGET_HAS_PVC="false"
              if [ -n "$STORAGE_CLASS" ]; then
                TARGET_HAS_PVC="true"
              fi

              # Определяем текущее состояние — есть ли PVC сейчас
              CURRENT_HAS_PVC="false"
              if [ -n "$CURRENT_VCT" ] && [ "$CURRENT_VCT" != "null" ] && [ "$CURRENT_VCT" != "[]" ]; then
                CURRENT_HAS_PVC="true"
              fi

              echo "==> Текущий StatefulSet с PVC: $CURRENT_HAS_PVC"
              echo "==> Целевой StatefulSet с PVC: $TARGET_HAS_PVC"

              # Если состояние не меняется — ничего не делаем
              if [ "$CURRENT_HAS_PVC" = "$TARGET_HAS_PVC" ]; then
                echo "==> PVC конфигурация не изменилась — пропускаем удаление StatefulSet"
                exit 0
              fi

              # Состояние меняется — нужно пересоздать StatefulSet
              echo "==> PVC конфигурация изменилась ($CURRENT_HAS_PVC → $TARGET_HAS_PVC)"
              echo "==> Удаляем StatefulSet с --cascade=orphan (поды остаются живыми)..."
              kubectl delete statefulset $STS -n $NS --cascade=orphan

              echo "==> Удаляем поды чтобы они пересоздались с новой спецификацией..."
              kubectl delete pods -l app={{ $.Values.labels.redis }} -n $NS 2>/dev/null || true

              echo "==> Готово. Helm создаст новый StatefulSet."
{{- end }}
{{- end }}
