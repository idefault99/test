---
- name: Backup probegi PostgreSQL from docker container
  hosts: probegi_db
  gather_facts: false

  vars:
    backup_tmp_dir: /tmp
    backup_local_dir: "{{ lookup('env', 'CI_PROJECT_DIR') }}/dump"

  tasks:
    - name: Generate backup filename
      set_fact:
        backup_file_name: "probegi_{{ lookup('pipe', 'date +%d-%m-%Y_%H%M_%S') }}.sql.gz"
        backup_remote_path: "{{ backup_tmp_dir }}/probegi_{{ lookup('pipe', 'date +%d-%m-%Y_%H%M_%S') }}.sql.gz"

    - name: Ensure local dump directory exists on runner
      delegate_to: localhost
      become: false
      file:
        path: "{{ backup_local_dir }}"
        state: directory
        mode: "0755"

    - name: Create dump on remote host from docker container
      shell: |
        set -euo pipefail
        docker exec {{ probegi_pg_container }} pg_dumpall -c -U {{ probegi_pg_user }} | gzip -c > {{ backup_remote_path }}
      args:
        executable: /bin/bash

    - name: Check remote dump exists
      stat:
        path: "{{ backup_remote_path }}"
      register: backup_stat

    - name: Fail if dump was not created
      fail:
        msg: "Backup file was not created on remote host: {{ backup_remote_path }}"
      when: not backup_stat.stat.exists

    - name: Fetch dump from remote host to runner
      fetch:
        src: "{{ backup_remote_path }}"
        dest: "{{ backup_local_dir }}/"
        flat: true

    - name: Remove remote temporary dump
      file:
        path: "{{ backup_remote_path }}"
        state: absent

---
---
probegi_pg_container: "probegi-db"
probegi_pg_user: "db-user"

---
stages:
  - backup
  - upload

default:
  tags:
    - docker
  image:
    name: registry.test.model.svo.aero/dpm/iac/infra/ansible:ansible-pip
    entrypoint: [ "" ]
  before_script:
    - chmod 400 "$SSH_PRIVATE_KEY"
    - git -c http.sslVerify=false clone --single-branch --branch master https://gitlab-ci-token:${CI_JOB_TOKEN}@gitlab.test.model.svo.aero/dpm/probegi/infra.git

.backup:
  stage: backup
  variables:
    ANSIBLE_HOST_KEY_CHECKING: "False"
    ANSIBLE_STDOUT_CALLBACK: "debug"
  when: manual

.upload:
  stage: upload
  when: manual

backup-probegi-dev:
  extends: .backup
  environment: dev
  script:
    - ansible-playbook -i infra/ansible/inventory.yml infra/ansible/backup/backup.yml
    - ls -lh dump/
  artifacts:
    expire_in: 7 days
    paths:
      - dump/*.sql.gz

upload-probegi-dev:
  extends: .upload
  environment: dev
  image:
    name: minio/mc:RELEASE.2025-01-17T23-25-50Z
    entrypoint: [ "" ]
  needs:
    - job: backup-probegi-dev
      artifacts: true
  script:
    - mc alias set minio "$MINIO_ENDPOINT" "$MINIO_ACCESS_KEY" "$MINIO_SECRET_KEY"
    - mc ls "minio/$MINIO_BUCKET" >/dev/null 2>&1 || mc mb "minio/$MINIO_BUCKET"
    - FILE="$(ls -1 dump/*.sql.gz | head -n 1)"
    - echo "Uploading $FILE to minio/$MINIO_BUCKET/"
    - mc cp "$FILE" "minio/$MINIO_BUCKET/$(basename "$FILE")"
    - mc stat "minio/$MINIO_BUCKET/$(basename "$FILE")"

---
