#!/bin/bash
# =============================================================
# Helm — Redeploy all environments from GitLab projects
# с rate limiting между деплоями
# =============================================================
set -euo pipefail

# --- Конфиг ---
GITLAB_URL="https://gitlab.example.com"
GITLAB_TOKEN="glpat-xxxx"

# Пауза между деплоями (секунды)
DEPLOY_PAUSE=30
# Таймаут ожидания rollout (секунды)
ROLLOUT_TIMEOUT=120
# Максимум параллельных деплоев (1 = строго последовательно)
MAX_PARALLEL=1

# "project_id:ref:release_name"
PROJECTS=(
  "123:develop:audit"
  "456:main:schedule"
  "789:develop:payments"
)

# --- Определяем команды для microk8s ---
if command -v microk8s.helm3 &>/dev/null; then
  HELM="microk8s.helm3"
  KUBECTL="microk8s.kubectl"
elif command -v microk8s &>/dev/null; then
  helm() { microk8s helm "$@"; }
  kubectl() { microk8s kubectl "$@"; }
  export -f helm kubectl
  HELM="helm"
  KUBECTL="kubectl"
elif command -v helm &>/dev/null; then
  HELM="helm"
  KUBECTL="kubectl"
else
  echo "ERROR: helm не найден"
  exit 1
fi

# --- Цвета ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# --- Результаты ---
DEPLOYED=()
ERRORS=()
DEPLOY_COUNT=0

WORK_DIR="./helm-redeploy-$(date +%Y%m%d-%H%M%S)"
mkdir -p "$WORK_DIR"

# --- Функция: получить переменные проекта ---
get_variables() {
  local project_id=$1
  curl -sf \
    --header "PRIVATE-TOKEN: $GITLAB_TOKEN" \
    "$GITLAB_URL/api/v4/projects/$project_id/variables?per_page=100"
}

# --- Функция: скачать Helm чарт ---
download_chart() {
  local project_id=$1
  local ref=$2
  local dest=$3

  curl -sf \
    --header "PRIVATE-TOKEN: $GITLAB_TOKEN" \
    "$GITLAB_URL/api/v4/projects/$project_id/repository/archive.tar.gz?path=Helm&ref=$ref" \
    -o "$dest/chart.tar.gz"

  mkdir -p "$dest/chart"
  tar -xzf "$dest/chart.tar.gz" -C "$dest/chart" --strip-components=2
}

# --- Функция: ждать rollout всех деплойментов в неймспейсе ---
wait_rollout() {
  local namespace=$1
  echo -e "  ${CYAN}Ожидаем rollout в namespace: $namespace (timeout: ${ROLLOUT_TIMEOUT}s)${NC}"

  # Получаем все deployments в неймспейсе
  DEPLOYMENTS=$($KUBECTL get deployments -n "$namespace" -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)

  if [[ -z "$DEPLOYMENTS" ]]; then
    echo "    Deployments не найдены, пропускаем ожидание"
    return 0
  fi

  local all_ok=true
  for DEPLOY in $DEPLOYMENTS; do
    echo -e "    Ожидаем: $DEPLOY"
    if ! $KUBECTL rollout status deployment/"$DEPLOY" \
      -n "$namespace" \
      --timeout="${ROLLOUT_TIMEOUT}s" 2>/dev/null; then
      echo -e "  ${RED}Rollout не завершился: $DEPLOY${NC}"
      all_ok=false
    fi
  done

  if $all_ok; then
    echo -e "  ${GREEN}Rollout завершён успешно${NC}"
    return 0
  else
    return 1
  fi
}

# --- Функция: показать текущее потребление памяти ---
show_memory() {
  echo -e "  ${CYAN}Память на нодах:${NC}"
  $KUBECTL top nodes 2>/dev/null || echo "    kubectl top недоступен"
}

# --- Основной цикл по проектам ---
for PROJECT_ENTRY in "${PROJECTS[@]}"; do
  IFS=':' read -r PROJECT_ID REF RELEASE_NAME <<< "$PROJECT_ENTRY"

  echo ""
  echo -e "${BLUE}=========================================="
  echo "  Проект: $PROJECT_ID | ref: $REF | release: $RELEASE_NAME"
  echo -e "==========================================${NC}"

  PROJECT_DIR="$WORK_DIR/project-$PROJECT_ID"
  mkdir -p "$PROJECT_DIR"

  # --- Получаем переменные ---
  echo ">>> Получаем переменные из GitLab API..."
  VARIABLES=$(get_variables "$PROJECT_ID") || {
    echo -e "${RED}ERROR: Не удалось получить переменные проекта $PROJECT_ID${NC}"
    ERRORS+=("project-$PROJECT_ID|—|—|Не удалось получить переменные из API")
    continue
  }

  # --- Получаем все уникальные environment_scope ---
  SCOPES=$(echo "$VARIABLES" | jq -r '.[].environment_scope' | sort -u | grep -v '^\*$' || true)

  if [[ -z "$SCOPES" ]]; then
    echo -e "${YELLOW}Нет environment scope в проекте $PROJECT_ID${NC}"
    ERRORS+=("project-$PROJECT_ID|—|—|Нет environment scope")
    continue
  fi

  # --- Скачиваем чарт один раз для проекта ---
  echo ">>> Скачиваем Helm чарт (ref: $REF)..."
  if ! download_chart "$PROJECT_ID" "$REF" "$PROJECT_DIR"; then
    echo -e "${RED}ERROR: Не удалось скачать чарт проекта $PROJECT_ID${NC}"
    ERRORS+=("project-$PROJECT_ID|—|—|Не удалось скачать Helm чарт")
    continue
  fi
  echo "    Чарт скачан: $PROJECT_DIR/chart/"

  # --- Цикл по environment scope ---
  while IFS= read -r SCOPE; do
    echo ""
    echo -e "  ${YELLOW}>>> Environment: $SCOPE${NC}"

    # Получаем NAMESPACE
    NAMESPACE=$(echo "$VARIABLES" | jq -r \
      '.[] | select(.key == "NAMESPACE" and .environment_scope == "'"$SCOPE"'") | .value')

    if [[ -z "$NAMESPACE" ]]; then
      echo -e "  ${RED}NAMESPACE не найден для scope: $SCOPE${NC}"
      ERRORS+=("project-$PROJECT_ID|$SCOPE|—|NAMESPACE переменная не найдена")
      continue
    fi

    # Получаем VALUES
    VALUES_CONTENT=$(echo "$VARIABLES" | jq -r \
      '.[] | select(.key == "VALUES" and .environment_scope == "'"$SCOPE"'") | .value')

    SCOPE_DIR="$PROJECT_DIR/$SCOPE"
    mkdir -p "$SCOPE_DIR"

    if [[ -n "$VALUES_CONTENT" ]]; then
      echo "$VALUES_CONTENT" > "$SCOPE_DIR/values.yaml"
      VALUES_FLAG="-f $SCOPE_DIR/values.yaml"
    else
      echo -e "  ${YELLOW}VALUES не найден — деплоим без values файла${NC}"
      VALUES_FLAG=""
    fi

    echo "    Namespace: $NAMESPACE"
    echo "    Release:   $RELEASE_NAME"

    # --- Показываем память перед деплоем ---
    show_memory

    # --- helm upgrade ---
    if $HELM upgrade --install "$RELEASE_NAME" "$PROJECT_DIR/chart/" \
      -n "$NAMESPACE" \
      --reuse-values \
      $VALUES_FLAG \
      --create-namespace \
      > "$SCOPE_DIR/deploy.log" 2>&1; then

      echo -e "  ${GREEN}Helm upgrade OK${NC}"

      # --- Ждём rollout ---
      if wait_rollout "$NAMESPACE"; then
        DEPLOYED+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|$RELEASE_NAME|OK")
      else
        DEPLOYED+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|$RELEASE_NAME|ROLLOUT_TIMEOUT")
        ERRORS+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|Rollout не завершился за ${ROLLOUT_TIMEOUT}s")
      fi

    else
      ERROR_MSG=$(tail -3 "$SCOPE_DIR/deploy.log" | tr '\n' ' ')
      echo -e "  ${RED}ОШИБКА: $ERROR_MSG${NC}"
      ERRORS+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|$ERROR_MSG")
    fi

    # --- Пауза перед следующим деплоем ---
    DEPLOY_COUNT=$((DEPLOY_COUNT + 1))
    echo ""
    echo -e "  ${CYAN}Пауза ${DEPLOY_PAUSE}s перед следующим деплоем...${NC}"
    sleep "$DEPLOY_PAUSE"

  done <<< "$SCOPES"

done

# =============================================================
# --- Таблица 1: Успешно задеплоено ---
# =============================================================
echo ""
echo "=========================================="
echo "  ЗАДЕПЛОЕНО"
echo "=========================================="
printf "%-15s %-25s %-30s %-20s %-15s\n" "PROJECT" "SCOPE" "NAMESPACE" "RELEASE" "СТАТУС"
printf "%-15s %-25s %-30s %-20s %-15s\n" "---------------" "-------------------------" "------------------------------" "--------------------" "---------------"

if [[ ${#DEPLOYED[@]} -eq 0 ]]; then
  echo "  Нет успешных деплоев"
else
  for ROW in "${DEPLOYED[@]}"; do
    IFS='|' read -r PROJ SCOPE NS REL STATUS <<< "$ROW"
    if [[ "$STATUS" == "OK" ]]; then
      printf "%-15s %-25s %-30s %-20s ${GREEN}%-15s${NC}\n" "$PROJ" "$SCOPE" "$NS" "$REL" "$STATUS"
    else
      printf "%-15s %-25s %-30s %-20s ${YELLOW}%-15s${NC}\n" "$PROJ" "$SCOPE" "$NS" "$REL" "$STATUS"
    fi
  done
fi

# =============================================================
# --- Таблица 2: Ошибки ---
# =============================================================
echo ""
echo "=========================================="
echo "  ОШИБКИ / ПРОПУЩЕНО"
echo "=========================================="
printf "%-15s %-25s %-30s %-40s\n" "PROJECT" "SCOPE" "NAMESPACE" "ПРИЧИНА"
printf "%-15s %-25s %-30s %-40s\n" "---------------" "-------------------------" "------------------------------" "----------------------------------------"

if [[ ${#ERRORS[@]} -eq 0 ]]; then
  echo "  Ошибок нет"
else
  for ROW in "${ERRORS[@]}"; do
    IFS='|' read -r PROJ SCOPE NS REASON <<< "$ROW"
    printf "%-15s %-25s %-30s ${RED}%-40s${NC}\n" "$PROJ" "$SCOPE" "$NS" "$REASON"
  done
fi

echo ""
echo "Всего задеплоено: $DEPLOY_COUNT"
echo "Рабочая директория: $WORK_DIR/"
