#!/bin/bash
# ============================================================
# Тест Redis до и после миграции в dev-devops
# ============================================================

NS="dev-devops"
REDIS_POD="redis-deployment-0"
PORT=6379

# Цвета для вывода
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ok()   { echo -e "${GREEN}  ✓ $1${NC}"; }
fail() { echo -e "${RED}  ✗ $1${NC}"; }
info() { echo -e "${YELLOW}  → $1${NC}"; }

# ============================================================
# Функция проверки состояния Redis
# ============================================================
check_redis() {
  local PHASE=$1  # "ДО" или "ПОСЛЕ"
  echo ""
  echo "============================================"
  echo "  ПРОВЕРКА REDIS [$PHASE]"
  echo "============================================"

  # 1. Под живой?
  info "Проверяем под..."
  POD_STATUS=$(kubectl get pod $REDIS_POD -n $NS --no-headers 2>/dev/null | awk '{print $3}')
  if [ "$POD_STATUS" = "Running" ]; then
    ok "Под $REDIS_POD Running"
  else
    fail "Под $REDIS_POD не Running (статус: $POD_STATUS)"
    return 1
  fi

  # 2. Redis отвечает на PING?
  info "Проверяем PING..."
  PONG=$(kubectl exec -n $NS $REDIS_POD -- redis-cli ping 2>/dev/null)
  if [ "$PONG" = "PONG" ]; then
    ok "PING → PONG"
  else
    fail "Redis не отвечает на PING (ответ: $PONG)"
    return 1
  fi

  # 3. Сколько ключей?
  info "Считаем ключи..."
  DBSIZE=$(kubectl exec -n $NS $REDIS_POD -- redis-cli dbsize 2>/dev/null)
  ok "Ключей в БД: $DBSIZE"

  # 4. Сохраняем список ключей для сравнения
  if [ "$PHASE" = "ДО" ]; then
    kubectl exec -n $NS $REDIS_POD -- redis-cli keys '*' 2>/dev/null | sort > /tmp/redis_keys_before.txt
    ok "Список ключей сохранён → /tmp/redis_keys_before.txt"
  fi

  if [ "$PHASE" = "ПОСЛЕ" ]; then
    kubectl exec -n $NS $REDIS_POD -- redis-cli -c keys '*' 2>/dev/null | sort > /tmp/redis_keys_after.txt
    ok "Список ключей сохранён → /tmp/redis_keys_after.txt"

    info "Сравниваем ключи до и после..."
    DIFF=$(diff /tmp/redis_keys_before.txt /tmp/redis_keys_after.txt)
    if [ -z "$DIFF" ]; then
      ok "Ключи идентичны — данные не потеряны"
    else
      fail "Есть расхождения в ключах:"
      echo "$DIFF"
    fi
  fi

  # 5. Тип Redis (single или cluster)?
  info "Проверяем режим Redis..."
  CLUSTER_ENABLED=$(kubectl exec -n $NS $REDIS_POD -- redis-cli config get cluster-enabled 2>/dev/null | tail -1)
  if [ "$CLUSTER_ENABLED" = "yes" ]; then
    CLUSTER_STATE=$(kubectl exec -n $NS $REDIS_POD -- redis-cli cluster info 2>/dev/null | grep cluster_state | cut -d: -f2 | tr -d '[:space:]')
    CLUSTER_NODES=$(kubectl exec -n $NS $REDIS_POD -- redis-cli cluster info 2>/dev/null | grep cluster_known_nodes | cut -d: -f2 | tr -d '[:space:]')
    if [ "$CLUSTER_STATE" = "ok" ]; then
      ok "Redis Cluster: state=$CLUSTER_STATE, nodes=$CLUSTER_NODES"
    else
      fail "Redis Cluster: state=$CLUSTER_STATE (не ok!)"
    fi
  else
    ok "Redis Single mode (cluster-enabled=no)"
  fi

  # 6. Проверяем PVC
  info "Проверяем PVC..."
  PVC_STATUS=$(kubectl get pvc -n $NS 2>/dev/null | grep redis)
  if [ -n "$PVC_STATUS" ]; then
    ok "PVC найдены:"
    echo "$PVC_STATUS" | while read line; do echo "    $line"; done
  else
    if [ "$PHASE" = "ДО" ]; then
      info "PVC нет (ожидаемо до миграции)"
    else
      fail "PVC не найдены после миграции!"
    fi
  fi

  # 7. Запись и чтение тестового ключа
  info "Тест записи/чтения..."
  TEST_KEY="migration-test-$(date +%s)"
  TEST_VAL="ok-$(hostname)-$(date +%H%M%S)"

  # -c флаг для cluster redirect, для single тоже работает
  SET_RESULT=$(kubectl exec -n $NS $REDIS_POD -- redis-cli -c set $TEST_KEY "$TEST_VAL" 2>/dev/null)
  GET_RESULT=$(kubectl exec -n $NS $REDIS_POD -- redis-cli -c get $TEST_KEY 2>/dev/null)

  if [ "$GET_RESULT" = "$TEST_VAL" ]; then
    ok "Запись/чтение работает (key=$TEST_KEY)"
    # Чистим тестовый ключ
    kubectl exec -n $NS $REDIS_POD -- redis-cli -c del $TEST_KEY >/dev/null 2>&1
  else
    fail "Запись/чтение не работает (set=$SET_RESULT, get=$GET_RESULT)"
  fi

  echo ""
}

# ============================================================
# Функция проверки связи приложения с Redis
# ============================================================
check_app_connectivity() {
  local PHASE=$1
  echo ""
  echo "============================================"
  echo "  СВЯЗЬ ПРИЛОЖЕНИЙ С REDIS [$PHASE]"
  echo "============================================"

  # Находим все поды в namespace кроме redis и служебных
  APP_PODS=$(kubectl get pods -n $NS --no-headers 2>/dev/null \
    | grep -v "redis\|init\|job\|hook" \
    | grep "Running" \
    | awk '{print $1}')

  if [ -z "$APP_PODS" ]; then
    info "Нет запущенных подов приложений в $NS"
    return 0
  fi

  for POD in $APP_PODS; do
    info "Проверяем под $POD..."

    # Пробуем достучаться до redis-service:6379 из пода приложения
    CONN=$(kubectl exec -n $NS $POD -- sh -c \
      "redis-cli -h redis-service -p $PORT ping 2>/dev/null || \
       nc -z -w3 redis-service $PORT 2>/dev/null && echo 'OPEN' || echo 'CLOSED'" \
      2>/dev/null)

    if echo "$CONN" | grep -qE "PONG|OPEN"; then
      ok "$POD → redis-service:$PORT доступен"
    else
      # redis-cli может не быть в поде — проверяем через /dev/tcp
      CONN2=$(kubectl exec -n $NS $POD -- sh -c \
        "timeout 3 bash -c 'echo > /dev/tcp/redis-service/$PORT' 2>/dev/null && echo 'OPEN' || echo 'CLOSED'" \
        2>/dev/null)
      if [ "$CONN2" = "OPEN" ]; then
        ok "$POD → redis-service:$PORT доступен (tcp check)"
      else
        fail "$POD → redis-service:$PORT НЕДОСТУПЕН"
      fi
    fi

    # Ищем MOVED/CROSSSLOT ошибки в логах (признак несовместимости с cluster)
    if [ "$PHASE" = "ПОСЛЕ" ]; then
      MOVED_ERRORS=$(kubectl logs -n $NS $POD --since=5m 2>/dev/null \
        | grep -c "MOVED\|CROSSSLOT\|CLUSTERDOWN" || true)
      if [ "$MOVED_ERRORS" -gt 0 ]; then
        fail "$POD: найдено $MOVED_ERRORS ошибок MOVED/CROSSSLOT/CLUSTERDOWN в логах — приложение не поддерживает Redis Cluster!"
      else
        ok "$POD: ошибок MOVED/CROSSSLOT нет в логах за последние 5 минут"
      fi
    fi
  done
}

# ============================================================
# ГЛАВНЫЙ СЦЕНАРИЙ
# ============================================================

case "${1}" in

  before)
    echo ""
    echo "██████████████████████████████████████████"
    echo "  ПРОВЕРКА ДО МИГРАЦИИ — $NS"
    echo "██████████████████████████████████████████"
    check_redis "ДО"
    check_app_connectivity "ДО"
    echo ""
    ok "==> Снимок ДО сохранён. Теперь выполняй миграцию."
    echo ""
    ;;

  after)
    echo ""
    echo "██████████████████████████████████████████"
    echo "  ПРОВЕРКА ПОСЛЕ МИГРАЦИИ — $NS"
    echo "██████████████████████████████████████████"
    check_redis "ПОСЛЕ"
    check_app_connectivity "ПОСЛЕ"
    echo ""
    info "==> Итог: проверь что все строки зелёные ✓"
    info "    Если есть красные ✗ — смотри раздел откат в README"
    echo ""
    ;;

  failover)
    echo ""
    echo "██████████████████████████████████████████"
    echo "  ТЕСТ ОТКАЗОУСТОЙЧИВОСТИ — $NS"
    echo "██████████████████████████████████████████"
    info "Записываем тестовый ключ..."
    kubectl exec -n $NS $REDIS_POD -- redis-cli -c set failover-test "alive" ex 300

    info "Убиваем под $REDIS_POD..."
    kubectl delete pod $REDIS_POD -n $NS

    info "Ждём восстановления..."
    kubectl wait --for=condition=Ready pod/$REDIS_POD -n $NS --timeout=120s

    info "Проверяем ключ после восстановления..."
    VAL=$(kubectl exec -n $NS $REDIS_POD -- redis-cli -c get failover-test 2>/dev/null)
    if [ "$VAL" = "alive" ]; then
      ok "Ключ сохранился после рестарта пода — PVC работает"
    else
      fail "Ключ потерян (значение: '$VAL')"
    fi

    kubectl exec -n $NS $REDIS_POD -- redis-cli cluster info | grep cluster_state
    echo ""
    ;;

  *)
    echo "Использование:"
    echo "  $0 before    — снимок состояния ДО миграции"
    echo "  $0 after     — проверка ПОСЛЕ миграции + сравнение ключей"
    echo "  $0 failover  — тест выживаемости (удаляет под и проверяет данные)"
    echo ""
    echo "Порядок запуска:"
    echo "  1. bash redis_test.sh before"
    echo "  2. <выполняй миграцию>"
    echo "  3. bash redis_test.sh after"
    echo "  4. bash redis_test.sh failover"
    ;;
esac
