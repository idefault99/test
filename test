kubectl -n gpu-operator rollout restart ds/nvidia-device-plugin-daemonset
kubectl -n gpu-operator rollout status  ds/nvidia-device-plugin-daemonset --timeout=180s
---
kubectl get nodes -o custom-columns=NODE:.metadata.name,'GPU:.status.capacity.nvidia\.com/gpu'
---
kubectl get clusterpolicy -o jsonpath='{.items[0].spec.devicePlugin.config}{"\n"}'
---
kubectl -n gpu-operator logs ds/nvidia-device-plugin-daemonset -c nvidia-device-plugin --tail=50 \
  | grep -iE 'replicas|timeslic|sharing|config'
