Поправь манифесты, нужно чтобы из чарта с инфрой создавался ClusterSecretStore (Он будет в templates/vault), а ExternalSecret был отдельно в каждом шаблоне - у меня есть templates/redis templates/kafka templates/mongodb templates/elasticsearch templates/postgresql templates/s3minio
В values будут прописаны все значения в .Values.stand.infra.services
И vault-job вероятно тоже должен запускаться отдельно для каждого приложения
У меня есть манифест со всеми namespace где указаны хуки, учитывай их, они должны создаваться раньше всех
  annotations:
    "helm.sh/hook": pre-install,pre-upgrade
    "helm.sh/hook-weight": "-200"
    "helm.sh/hook-delete-policy": before-hook-creation
Потом вероятно общий ClusterSecretStore на стенд, потом vault-job, а потом ExternalSecret
То есть логика такая чтобы приложение само ходило в vault, но если секрета нет, то приложение продолжит работать с configmap как раньше
{{- if eq .Values.enableService.vault.enable true }}
{{- $suffixes := list "infra" }}
{{- range .Values.stand.apps }}
  {{- $suffixes = concat $suffixes (list .suffix) }}
{{- end }}
{{- $standsStr := printf "%s:%s" .Values.stand.name (join "," $suffixes) }}
---
apiVersion: v1
kind: Secret
metadata:
  name: vault-env
  annotations:
    "helm.sh/hook": pre-install,pre-upgrade
    "helm.sh/hook-weight": "-50"
    "helm.sh/hook-delete-policy": before-hook-creation
stringData:
  VAULT_ADDR: {{ .Values.vault.address | quote }}
  VAULT_TOKEN: {{ .Values.vault.token | quote }}
  K8S_HOST: {{ .Values.kubernetes.host | quote }}
  ESO_SA_NAME: {{ .Values.vault.serviceAccount.name | quote }}
  ESO_SA_NAMESPACE: {{ .Values.vault.serviceAccount.namespace | quote }}
  STANDS: {{ $standsStr | quote }}
---
apiVersion: batch/v1
kind: Job                                 # На основе образа с Vault создает политику и роль в самом волте
metadata:
  name: vault
  annotations:
    "helm.sh/hook": pre-install,pre-upgrade
    "helm.sh/hook-weight": "-40"
    "helm.sh/hook-delete-policy": before-hook-creation,hook-succeeded
spec:
  template:
    spec:
      restartPolicy: Never
      imagePullSecrets:
        - name: {{ .Values.imagePullSecret | quote }}
      containers:
        - name: vault
          image: {{ .Values.images.vault | quote }}
          envFrom:
            - secretRef:
                name: vault-env
{{- end }}
---
{{- if eq .Values.enableService.vault.enable true }}
{{- $stand := .Values.stand.name -}}
{{- $vault := .Values.vault -}}
{{- range .Values.stand.infra.services }}
---
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{ .secretName }}
  namespace: {{ $stand }}
  labels:
    vault-section: infra
    vault-service: {{ .name }}
spec:
  refreshInterval: {{ $vault.refreshInterval }}
  secretStoreRef:
    name: {{ $vault.clusterSecretStore.name }}
    kind: ClusterSecretStore
  target:
    name: {{ .secretName }}
    creationPolicy: Owner
    deletionPolicy: Retain
  dataFrom:
    - extract:
        key: {{ $stand }}/infra/{{ .name }}
{{- end }}
{{- end }}
---
{{- if eq .Values.enableService.vault.enable true }}
{{- $vault := .Values.vault -}}
{{- $vaultRole := .Values.vault.roleName | default .Values.stand.name -}}

apiVersion: external-secrets.io/v1beta1
kind: ClusterSecretStore
metadata:
  name: {{ $vault.clusterSecretStore.name }}
  annotations:
    "helm.sh/hook": pre-install,pre-upgrade
    "helm.sh/hook-weight": "-30"
    "helm.sh/hook-delete-policy": before-hook-creation
spec:
  provider:
    vault:
      server: {{ $vault.address }}
      path: {{ $vault.kvMount }}
      version: v2
      auth:
        kubernetes:
          mountPath: {{ $vault.authPath }}
          role: {{ $vaultRole }}
          serviceAccountRef:
            name: {{ $vault.serviceAccount.name }}
            namespace: {{ $vault.serviceAccount.namespace }}
      caProvider:
        type: Secret
        name: {{ $vault.caSecretName }}
        key: ca.crt                 # Публичная часть корневого сертификата Vault, находится в секрете vault-ca-secret в ns external-secrets
        namespace: {{ $vault.serviceAccount.namespace }}
{{- end }}
---
enableService:
  vault:
    enable: false
baseNs: test-dev
vault:
  address: "https://vault.test.ru"
  token: example
  kvMount: "stands"
  authPath: "kubernetes"
  serviceAccount:
    name: "external-secrets"
    namespace: "external-secrets"
  caSecretName: "vault-ca-secret"
  refreshInterval: "5s"
  clusterSecretStore:
    name: vault-cluster-store-{{ .Values.baseNs }}

kubernetes:
  host: https://192.168.0.111:16443

stand:                                      
  name: "{{ .Values.baseNs }}"
  infra:
    services:
      - name: example
        secretName: example-vault-secret