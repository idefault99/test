### Шаг 1.8 — containerd

**[ВСЕ СЕРВЕРЫ]**

```bash
dnf install -y containerd

mkdir -p /etc/containerd
containerd config default > /etc/containerd/config.toml

# Обязательно для kubeadm 1.32
sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /etc/containerd/config.toml

# RedOS 8: CNI бинари в /usr/libexec/cni, а не /opt/cni/bin
sed -i 's|bin_dir = "/opt/cni/bin"|bin_dir = "/usr/libexec/cni"|g' /etc/containerd/config.toml
mkdir -p /opt/cni/bin
ln -sf /usr/libexec/cni/* /opt/cni/bin/ 2>/dev/null || true

# pause образ для k8s 1.32
sed -i 's|sandbox_image = "registry.k8s.io/pause:3.8"|sandbox_image = "registry.k8s.io/pause:3.10"|' \
  /etc/containerd/config.toml

# [ТОЛЬКО ДЛЯ ПРОКСИ]
mkdir -p /etc/systemd/system/containerd.service.d
cat > /etc/systemd/system/containerd.service.d/proxy.conf <<EOF
