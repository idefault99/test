#!/usr/bin/env bash
# =============================================================================
#  install-kafka-tools.sh — Установка kcat + Kafka binaries (WSL/Ubuntu/Debian)
# =============================================================================

set -euo pipefail

# ─── Цвета ───────────────────────────────────────────────────────────────────
R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'
C='\033[0;36m'; W='\033[1;37m'; D='\033[2m'; NC='\033[0m'

info()  { echo -e "  ${G}✔${NC}  $*"; }
warn()  { echo -e "  ${Y}⚠${NC}  $*"; }
err()   { echo -e "  ${R}✖${NC}  $*" >&2; }
step()  { echo -e "\n  ${C}▶${NC}  ${W}$*${NC}"; }
sep()   { echo -e "  ${D}────────────────────────────────────────────────────────${NC}"; }

# ─── Конфигурация ─────────────────────────────────────────────────────────────
KAFKA_VERSION="${KAFKA_VERSION:-3.7.1}"
SCALA_VERSION="${SCALA_VERSION:-2.13}"
KAFKA_INSTALL_DIR="${KAFKA_INSTALL_DIR:-/opt/kafka}"
KAFKA_TGZ="kafka_${SCALA_VERSION}-${KAFKA_VERSION}.tgz"
KAFKA_URL="https://downloads.apache.org/kafka/${KAFKA_VERSION}/${KAFKA_TGZ}"
KAFKA_MIRROR="https://archive.apache.org/dist/kafka/${KAFKA_VERSION}/${KAFKA_TGZ}"
DOWNLOAD_DIR="/tmp/kafka-install-$$"

# ─── Утилиты ──────────────────────────────────────────────────────────────────
require_root() {
  if [[ $EUID -ne 0 ]]; then
    err "Скрипт требует прав root. Запустите через sudo:"
    echo -e "  ${W}sudo bash $0${NC}"
    exit 1
  fi
}

check_distro() {
  if ! command -v apt-get &>/dev/null; then
    err "Поддерживается только Debian/Ubuntu (apt). Ваша система не совместима."
    exit 1
  fi
}

spinner() {
  local pid=$1 msg="${2:-Выполняется...}"
  local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    printf "  ${C}%s${NC}  %s\r" "${frames[$((i % 10))]}" "$msg"
    sleep 0.08; ((i++))
  done
  printf "%-60s\r" " "
}

run_quiet() {
  local msg="$1"; shift
  "$@" &>/tmp/kafka-install-out.txt &
  local pid=$!
  spinner "$pid" "$msg"
  if ! wait "$pid"; then
    err "$msg — ОШИБКА"
    echo -e "\n  ${D}Вывод:${NC}"
    tail -20 /tmp/kafka-install-out.txt | sed 's/^/    /'
    return 1
  fi
  info "$msg"
}

# ─── Баннер ───────────────────────────────────────────────────────────────────
banner() {
  clear
  echo -e "${C}"
  echo "  ╔══════════════════════════════════════════════════════╗"
  echo "  ║         KAFKA TOOLS INSTALLER  для WSL/Ubuntu        ║"
  echo "  ║                                                      ║"
  echo "  ║   Компоненты:                                        ║"
  echo "  ║   • kcat (kafkacat)  — consume / produce / meta      ║"
  echo "  ║   • Kafka binaries   — kafka-topics.sh и другие      ║"
  echo "  ║   • Java (OpenJDK)   — требуется для kafka bin       ║"
  echo "  ╚══════════════════════════════════════════════════════╝"
  echo -e "${NC}"
}

# ─── Проверка уже установленного ─────────────────────────────────────────────
check_existing() {
  local kcat_ok=false kafka_ok=false java_ok=false

  step "Проверка уже установленных компонентов"
  sep

  if command -v kcat &>/dev/null; then
    info "kcat уже установлен: $(kcat -V 2>&1 | head -1)"
    kcat_ok=true
  elif command -v kafkacat &>/dev/null; then
    info "kafkacat уже установлен: $(kafkacat -V 2>&1 | head -1)"
    kcat_ok=true
  else
    warn "kcat/kafkacat не найден"
  fi

  if [[ -x "$KAFKA_INSTALL_DIR/bin/kafka-topics.sh" ]]; then
    local ver
    ver=$("$KAFKA_INSTALL_DIR/bin/kafka-topics.sh" --version 2>/dev/null || echo "?")
    info "Kafka binaries уже установлены в $KAFKA_INSTALL_DIR (версия: $ver)"
    kafka_ok=true
  elif command -v kafka-topics.sh &>/dev/null; then
    info "kafka-topics.sh найден в PATH: $(command -v kafka-topics.sh)"
    kafka_ok=true
  else
    warn "Kafka binaries не найдены"
  fi

  if command -v java &>/dev/null; then
    info "Java: $(java -version 2>&1 | head -1)"
    java_ok=true
  else
    warn "Java не найдена (нужна для Kafka binaries)"
  fi

  echo ""
  if $kcat_ok && $kafka_ok; then
    echo -e "  ${G}Все компоненты уже установлены!${NC}"
    echo ""
    read -rp "  Переустановить? (y/N): " reinstall
    [[ "$reinstall" != "y" && "$reinstall" != "Y" ]] && exit 0
  fi

  NEED_KCAT=$( $kcat_ok && echo false || echo true )
  NEED_KAFKA=$( $kafka_ok && echo false || echo true )
  NEED_JAVA=$( $java_ok && echo false || echo true )
}

# ─── Выбор компонентов ────────────────────────────────────────────────────────
select_components() {
  step "Выбор компонентов для установки"
  sep

  echo -e "  ${D}Kafka version : ${W}${KAFKA_VERSION}${NC}"
  echo -e "  ${D}Install dir   : ${W}${KAFKA_INSTALL_DIR}${NC}"
  echo ""

  local install_kcat=true install_kafka=true

  read -rp "  Установить kcat?            (Y/n): " c
  [[ "$c" == "n" || "$c" == "N" ]] && install_kcat=false

  read -rp "  Установить Kafka binaries?  (Y/n): " c
  [[ "$c" == "n" || "$c" == "N" ]] && install_kafka=false

  if $install_kafka; then
    echo ""
    read -rp "  Версия Kafka [${KAFKA_VERSION}]: " v
    [[ -n "$v" ]] && KAFKA_VERSION="$v"
    KAFKA_TGZ="kafka_${SCALA_VERSION}-${KAFKA_VERSION}.tgz"
    KAFKA_URL="https://downloads.apache.org/kafka/${KAFKA_VERSION}/${KAFKA_TGZ}"
    KAFKA_MIRROR="https://archive.apache.org/dist/kafka/${KAFKA_VERSION}/${KAFKA_TGZ}"

    read -rp "  Директория установки [${KAFKA_INSTALL_DIR}]: " d
    [[ -n "$d" ]] && KAFKA_INSTALL_DIR="$d"
  fi

  INSTALL_KCAT=$install_kcat
  INSTALL_KAFKA=$install_kafka
  echo ""
}

# ─── Установка kcat ───────────────────────────────────────────────────────────
install_kcat() {
  step "Установка kcat"
  sep

  run_quiet "Обновление apt индекса" apt-get update -qq

  # Пробуем пакет kcat (Ubuntu 22.04+), если нет — kafkacat
  if apt-cache show kcat &>/dev/null 2>&1; then
    run_quiet "Установка kcat" apt-get install -y -qq kcat
    info "Установлено: $(kcat -V 2>&1 | head -1)"
  elif apt-cache show kafkacat &>/dev/null 2>&1; then
    run_quiet "Установка kafkacat" apt-get install -y -qq kafkacat
    info "Установлено: $(kafkacat -V 2>&1 | head -1)"
  else
    warn "Пакет kcat/kafkacat не найден в apt, собираем из исходников..."
    install_kcat_from_source
  fi
}

install_kcat_from_source() {
  run_quiet "Установка зависимостей для сборки" \
    apt-get install -y -qq \
      build-essential git cmake pkg-config \
      libssl-dev libsasl2-dev libzstd-dev

  local src_dir="/tmp/kcat-build-$$"
  mkdir -p "$src_dir"

  step "Клонирование репозитория kcat"
  run_quiet "git clone kcat" \
    git clone --depth=1 https://github.com/edenhill/kcat.git "$src_dir"

  pushd "$src_dir" >/dev/null
  run_quiet "bootstrap kcat" bash bootstrap.sh
  run_quiet "Копирование kcat в /usr/local/bin" \
    cp kcat /usr/local/bin/kcat
  popd >/dev/null

  rm -rf "$src_dir"
  info "kcat собран и установлен из исходников: $(kcat -V 2>&1 | head -1)"
}

# ─── Установка Java ───────────────────────────────────────────────────────────
install_java() {
  step "Установка Java (OpenJDK 17)"
  sep
  run_quiet "Установка openjdk-17-jre-headless" \
    apt-get install -y -qq openjdk-17-jre-headless
  info "Java: $(java -version 2>&1 | head -1)"
}

# ─── Установка Kafka binaries ─────────────────────────────────────────────────
install_kafka_binaries() {
  step "Установка Kafka ${KAFKA_VERSION} binaries"
  sep

  # Java
  if ! command -v java &>/dev/null; then
    install_java
  else
    info "Java уже есть: $(java -version 2>&1 | head -1)"
  fi

  mkdir -p "$DOWNLOAD_DIR"

  # Скачиваем архив
  local tgz_path="$DOWNLOAD_DIR/$KAFKA_TGZ"

  echo -e "  ${D}Скачивание: ${W}${KAFKA_URL}${NC}"
  if ! wget -q --show-progress -O "$tgz_path" "$KAFKA_URL" 2>/dev/null; then
    warn "Основной источник недоступен, пробуем зеркало..."
    if ! wget -q --show-progress -O "$tgz_path" "$KAFKA_MIRROR" 2>/dev/null; then
      err "Не удалось скачать Kafka. Проверьте интернет или версию."
      err "URL: $KAFKA_MIRROR"
      return 1
    fi
  fi
  info "Архив скачан: $tgz_path"

  # Проверка архива
  run_quiet "Проверка целостности архива" tar -tzf "$tgz_path"

  # Распаковка
  if [[ -d "$KAFKA_INSTALL_DIR" ]]; then
    warn "Директория $KAFKA_INSTALL_DIR уже существует, делаем бэкап..."
    mv "$KAFKA_INSTALL_DIR" "${KAFKA_INSTALL_DIR}.bak.$(date +%Y%m%d%H%M%S)"
  fi

  mkdir -p "$(dirname "$KAFKA_INSTALL_DIR")"
  run_quiet "Распаковка в $KAFKA_INSTALL_DIR" \
    bash -c "tar -xzf '$tgz_path' -C '$(dirname "$KAFKA_INSTALL_DIR")' && \
             mv '$(dirname "$KAFKA_INSTALL_DIR")/kafka_${SCALA_VERSION}-${KAFKA_VERSION}' '$KAFKA_INSTALL_DIR'"

  chmod +x "$KAFKA_INSTALL_DIR"/bin/*.sh

  info "Kafka распакована в $KAFKA_INSTALL_DIR"
  info "Версия: $("$KAFKA_INSTALL_DIR/bin/kafka-topics.sh" --version 2>/dev/null || echo "OK")"

  # Symlinks в /usr/local/bin
  step "Создание символических ссылок в /usr/local/bin"
  sep
  local tools=(
    kafka-topics kafka-configs kafka-consumer-groups
    kafka-console-producer kafka-console-consumer
    kafka-log-dirs kafka-broker-api-versions
    kafka-run-class kafka-acls kafka-leader-election
  )
  for tool in "${tools[@]}"; do
    if [[ -f "$KAFKA_INSTALL_DIR/bin/${tool}.sh" ]]; then
      ln -sf "$KAFKA_INSTALL_DIR/bin/${tool}.sh" "/usr/local/bin/${tool}.sh"
      info "Symlink: /usr/local/bin/${tool}.sh → $KAFKA_INSTALL_DIR/bin/${tool}.sh"
    fi
  done
}

# ─── Настройка переменных окружения ───────────────────────────────────────────
setup_env() {
  step "Настройка переменных окружения"
  sep

  local profile_file="/etc/profile.d/kafka.sh"
  cat >"$profile_file" <<EOF
# Kafka binaries — добавлено install-kafka-tools.sh
export KAFKA_HOME="${KAFKA_INSTALL_DIR}"
export PATH="\$PATH:\${KAFKA_HOME}/bin"
export JAVA_HOME=\$(dirname \$(dirname \$(readlink -f \$(which java) 2>/dev/null)))
EOF
  info "Профиль записан: $profile_file"
  info "Выполните 'source $profile_file' или откройте новый терминал"
}

# ─── Очистка ──────────────────────────────────────────────────────────────────
cleanup() {
  rm -rf "$DOWNLOAD_DIR" /tmp/kafka-install-out.txt 2>/dev/null || true
}

# ─── Итоговая сводка ──────────────────────────────────────────────────────────
print_summary() {
  echo ""
  echo -e "  ${C}╔══════════════════════════════════════════════════════╗${NC}"
  echo -e "  ${C}║${NC}               ${W}УСТАНОВКА ЗАВЕРШЕНА${NC}                    ${C}║${NC}"
  echo -e "  ${C}╚══════════════════════════════════════════════════════╝${NC}"
  echo ""

  if command -v kcat &>/dev/null || command -v kafkacat &>/dev/null; then
    local kcat_bin
    kcat_bin=$(command -v kcat 2>/dev/null || command -v kafkacat)
    info "kcat        : $kcat_bin"
  fi

  if [[ -x "$KAFKA_INSTALL_DIR/bin/kafka-topics.sh" ]]; then
    info "Kafka home  : $KAFKA_INSTALL_DIR"
    info "kafka-topics: $KAFKA_INSTALL_DIR/bin/kafka-topics.sh"
  fi

  echo ""
  echo -e "  ${D}Активируйте переменные окружения:${NC}"
  echo -e "  ${W}source /etc/profile.d/kafka.sh${NC}"
  echo ""
  echo -e "  ${D}Быстрая проверка:${NC}"
  echo -e "  ${W}kcat -b localhost:9092 -L${NC}"
  echo -e "  ${W}kafka-topics.sh --bootstrap-server localhost:9092 --list${NC}"
  echo ""
  echo -e "  ${D}Теперь запустите:${NC}"
  echo -e "  ${W}./kafka-manager.sh${NC}"
  echo ""
}

# ─── MAIN ─────────────────────────────────────────────────────────────────────
main() {
  banner
  require_root
  check_distro
  check_existing
  select_components

  trap cleanup EXIT

  if ${INSTALL_KCAT:-true}; then
    install_kcat
  fi

  if ${INSTALL_KAFKA:-true}; then
    install_kafka_binaries
    setup_env
  fi

  print_summary
}

main "$@"
