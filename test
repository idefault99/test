initContainers:
  - name: init-data-dir
    image: busybox
    command: ['sh', '-c']
    args:
      - |
        CLUSTER_MODE="{{ $.Values.enableService.redis.type }}"
        NODES_CONF="/data/nodes.conf"
        DUMP_RDB="/data/dump.rdb"

        echo "Режим: $CLUSTER_MODE"

        if [ "$CLUSTER_MODE" = "cluster" ]; then
          # Переключаемся на cluster — очищаем данные от single
          # В single mode нет nodes.conf, но есть dump.rdb с databases>1
          if [ -f "$DUMP_RDB" ] && [ ! -f "$NODES_CONF" ]; then
            echo "Обнаружены данные от single mode — очищаем для cluster"
            rm -rf /data/* /data/.* 2>/dev/null || true
          else
            echo "Данные совместимы с cluster mode — пропускаем"
          fi
        else
          # Переключаемся на single — очищаем данные от cluster
          if [ -f "$NODES_CONF" ]; then
            echo "Обнаружен nodes.conf от cluster mode — очищаем для single"
            rm -rf /data/* /data/.* 2>/dev/null || true
          else
            echo "Данные совместимы с single mode — пропускаем"
          fi
        fi
    volumeMounts:
      - name: {{ $.Values.labels.redis }}-data
        mountPath: /data
