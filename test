#!/bin/bash
# =============================================================
# ДИАГНОСТИКА REDIS ДЛЯ МИГРАЦИИ НА PVC + CLUSTER
# Выполни команды ниже и скинь весь вывод
# =============================================================

# 1. StorageClass — что доступно в кластере
kubectl get sc

# 2. Текущий манифест одного redis (берём первый попавшийся namespace как пример)
kubectl get statefulset redis-deployment -n develop -o yaml

# 3. Существующие PV/PVC в кластере (проверяем что уже есть)
kubectl get pv
kubectl get pvc -A | grep redis

# 4. Текущий Service redis в namespace develop
kubectl get svc redis-service -n develop -o yaml

# 5. Ноды кластера и их лейблы (нужно для понимания topology)
kubectl get nodes -o wide
kubectl get nodes --show-labels

# 6. Сколько нод в кластере (всего)
kubectl get nodes --no-headers | wc -l

# 7. Реальное потребление памяти Redis в одном из namespace
# (выбери любой активный namespace из списка)
kubectl exec -n develop redis-deployment-0 -- redis-cli info memory | grep -E "used_memory_human|maxmemory_human"

# 8. Количество ключей в Redis (чтобы понять объём данных)
kubectl exec -n develop redis-deployment-0 -- redis-cli dbsize

# 9. Текущий образ Redis (версия важна для cluster mode)
kubectl get statefulset redis-deployment -n develop -o jsonpath='{.spec.template.spec.containers[0].image}'

# 10. Доступные namespace с redis (для понимания масштаба)
kubectl get pods -A | grep "redis-deployment-0" | awk '{print $1}' | wc -l

# 11. ConfigMap redis если есть (для cluster type)
kubectl get configmap -A | grep redis

# 12. Текущий values.yaml используемый для деплоя
# (скинь содержимое файла values.yaml или укажи путь)
# cat path/to/your/values.yaml

# =============================================================
# ИТОГО: скинь вывод команд 1-11 + содержимое values.yaml
# =============================================================
