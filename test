---
- name: Deploy docker-compose with new image tag
  hosts: all
  become: true

  tasks:

    # ── 1. Логин в registry ─────────────────────────────────────────────────
    - name: Login to container registry
      ansible.builtin.shell: |
        echo "{{ registry_password }}" | docker login {{ registry_host }} \
          -u {{ registry_user }} --password-stdin
      no_log: true

    # ── 2. Pull нового образа ───────────────────────────────────────────────
    - name: Pull new image
      ansible.builtin.shell: |
        docker pull {{ deploy_image }}:{{ deploy_tag }}

    # ── 3. Обновить тег в docker-compose.yml ────────────────────────────────
    - name: Update image tag in docker-compose.yml
      ansible.builtin.shell: |
        sed -i "s|image: {{ deploy_image }}:.*|image: {{ deploy_image }}:{{ deploy_tag }}|g" \
          {{ compose_dir }}/docker-compose.yml

    # ── 4. Пересоздать контейнеры ───────────────────────────────────────────
    - name: docker compose up
      ansible.builtin.shell: |
        cd {{ compose_dir }} && docker compose up -d --force-recreate --remove-orphans
      register: compose_result

    # ── 5. Вывести результат ────────────────────────────────────────────────
    - name: Show compose result
      ansible.builtin.debug:
        var: compose_result.stdout_lines

    # ── 6. Проверить что контейнер запущен ──────────────────────────────────
    - name: Wait for container to be running
      ansible.builtin.shell: |
        docker inspect -f '{{ "{{.State.Running}}" }}' {{ compose_service }}
      register: container_state
      until: container_state.stdout == "true"
      retries: 24
      delay: 5

    # ── 7. Удалить dangling образы ──────────────────────────────────────────
    - name: Remove dangling images
      ansible.builtin.shell: |
        docker image prune -f

    # ── 8. Logout ───────────────────────────────────────────────────────────
    - name: Logout from registry
      ansible.builtin.shell: |
        docker logout {{ registry_host }}
