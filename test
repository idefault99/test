# BACKUP
.backup:
  stage: backup
  variables:
    ANSIBLE_HOST_KEY_CHECKING: "False"
    ANSIBLE_STDOUT_CALLBACK: "debug"
  rules:
    - if: '$BACKUP_DB == "true"'
      when: on_success
    - when: never

.upload:
  stage: upload
  rules:
    - if: '$BACKUP_DB == "true"'
      when: on_success
    - when: never

backup-probegi-dev:
  extends: .backup
  environment: dev
  script:
    - ansible-playbook -i infra/ansible/inventory.yml infra/ansible/backup/backup.yml
  artifacts:
    expire_in: 1 day
    paths:
      - dump-meta/*

upload-probegi-dev:
  extends: .upload
  environment: dev
  image:
    name: registry.test.model.svo.aero/dpm/iac/infra:s3publisher-1.0.0
    entrypoint: [ "" ]
  variables:
    S3_CONNECTOR: ${S3_HOST_IP}:${S3_API_PORT}
    S3_BUCKET: ${S3_BUCKET}
    FOLDER_NAME: ${FOLDER_NAME}
    S3_ACCESS_KEY: ${S3_ACCESS_KEY}
    S3_SECRET_KEY: ${S3_SECRET_KEY}
    S3_SECURE: "False"
    SOURCE_PATH: ./dump
  needs:
    - job: backup-probegi-dev
      artifacts: true
  script:
    - chmod 400 "$SSH_PRIVATE_KEY"
    - mkdir -p dump
    - DUMP_NAME="$(tr -d '\r\n' < dump-meta/dump_name.txt)"
    - DUMP_PATH="$(tr -d '\r\n' < dump-meta/dump_path.txt)"
    - DUMP_HOST="$(tr -d '\r\n' < dump-meta/dump_host.txt)"
    - DUMP_USER="$(tr -d '\r\n' < dump-meta/dump_user.txt)"
    - apt-get update && apt-get install -y openssh-client
    - scp -i "$SSH_PRIVATE_KEY" -o StrictHostKeyChecking=no "${DUMP_USER}@${DUMP_HOST}:${DUMP_PATH}" "./dump/${DUMP_NAME}"
    - ls -lh ./dump
    - /app/code/main.bin