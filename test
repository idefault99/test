stages:
  - backup
  - upload
  - cleanup

default:
  tags:
    - docker
  image:
    name: registry.test.model.svo.aero/dpm/iac/infra/ansible:ansible-pip
    entrypoint: [ "" ]
  before_script:
    - chmod 400 "$SSH_PRIVATE_KEY"
    - git -c http.sslVerify=false clone --single-branch --branch master https://gitlab-ci-token:${CI_JOB_TOKEN}@gitlab.test.model.svo.aero/dpm/probegi/infra.git

.backup:
  stage: backup
  variables:
    ANSIBLE_HOST_KEY_CHECKING: "False"
    ANSIBLE_STDOUT_CALLBACK: "debug"
  rules:
    - if: '$RUN_PROBEGI_BACKUP == "true"'
      when: on_success
    - when: never

.upload:
  stage: upload
  rules:
    - if: '$RUN_PROBEGI_BACKUP == "true"'
      when: on_success
    - when: never

.cleanup:
  stage: cleanup
  rules:
    - if: '$RUN_PROBEGI_BACKUP == "true"'
      when: on_success
    - when: never

---
cleanup-probegi-dev:
  extends: .cleanup
  environment: dev
  image:
    name: minio/mc:RELEASE.2025-01-17T23-25-50Z
    entrypoint: [ "" ]
  needs:
    - job: upload-probegi-dev
  script:
    - mc alias set minio "http://${S3_HOST_IP}:${S3_API_PORT}" "$S3_ACCESS_KEY" "$S3_SECRET_KEY"
    - |
      mc ls minio/"$S3_BUCKET" | awk '{print $6}' | grep '^probegi_.*\.sql\.gz$' | sort -r > objects.txt
    - echo "All objects:"
    - cat objects.txt || true
    - |
      tail -n +3 objects.txt | while read -r obj; do
        [ -n "$obj" ] || continue
        echo "Removing old dump: $obj"
        mc rm "minio/$S3_BUCKET/$obj"
      done

---
backup_timestamp: "{{ lookup('pipe', 'date +%Y%m%d_%H%M%S') }}"
backup_file_name: "probegi_{{ backup_timestamp }}.sql.gz"
---
