echo "== kubeadm log =="
tail -n 120 /root/kubeadm-init.log

echo "== kubelet status =="
systemctl status kubelet --no-pager -l

echo "== kubelet recent logs =="
journalctl -u kubelet -n 150 --no-pager

echo "== manifests =="
ls -l /etc/kubernetes/manifests
grep -n "path: /etc/kubernetes" /etc/kubernetes/manifests/kube-vip.yaml || true

echo "== containerd =="
systemctl is-active containerd
crictl ps -a

echo "== static pod logs =="
crictl pods
crictl ps -a | egrep 'kube-apiserver|etcd|kube-controller|kube-scheduler|kube-vip' || true

echo "== api health =="
curl -k --max-time 5 https://127.0.0.1:6443/healthz || true
curl -k --max-time 5 https://172.16.175.19:6443/healthz || true
curl -k --max-time 5 https://172.16.175.20:6443/healthz || true

echo "== vip/network =="
ip addr show eno1
ip route
ping -c 3 172.16.175.20 || true

echo "== kubectl =="
ls -l /etc/kubernetes/admin.conf $HOME/.kube/config 2>/dev/null || true
KUBECONFIG=/etc/kubernetes/admin.conf kubectl get nodes -o wide || true
KUBECONFIG=/etc/kubernetes/admin.conf kubectl get pods -A -o wide || true
