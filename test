#!/bin/bash
# ns-scale.sh
# Использование:
#   ./ns-scale.sh <namespaces-file> [dry-run]   — из файла
#   ./ns-scale.sh --ns <namespace> [dry-run]    — один неймспейс

set -euo pipefail

SINGLE_NS=""
NS_FILE=""
DRY_RUN="false"

# --- Парсинг аргументов ---
if [[ "${1:-}" == "--ns" ]]; then
  SINGLE_NS="${2:?Укажи неймспейс после --ns}"
  DRY_RUN="${3:-false}"
else
  NS_FILE="${1:?Укажи файл с неймспейсами или --ns <namespace>}"
  DRY_RUN="${2:-false}"
  [[ ! -f "$NS_FILE" ]] && { echo "Файл не найден: $NS_FILE"; exit 1; }
fi

KUBECTL_ARGS=""
[[ "$DRY_RUN" == "true" ]] && KUBECTL_ARGS="--dry-run=client"

WAIT_TIMEOUT=120
RESTART_THRESHOLD=3  # рестартов больше этого — считаем проблемой

# --- Меню ---
echo ""
echo "Выбери действие:"
echo "  1) Scale в 0  (+ suspend CronJobs)"
echo "  2) Scale в 1  (+ unsuspend CronJobs)"
echo "  3) Проверить статус NS из файла"
echo ""
read -rp "Введи 1, 2 или 3: " CHOICE

case "$CHOICE" in
  1) ACTION="down"  ;;
  2) ACTION="up"    ;;
  3) ACTION="check" ;;
  *) echo "Неверный выбор: $CHOICE"; exit 1 ;;
esac

echo ""
echo "=== Действие: $ACTION | dry-run: $DRY_RUN ==="

# ─────────────────────────────────────────────
# SCALE функции
# ─────────────────────────────────────────────

scale_resources() {
  local kind="$1" ns="$2" replicas="$3"
  local names
  names=$(kubectl get "$kind" -n "$ns" \
    -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)
  [[ -z "$names" ]] && return
  for name in $names; do
    echo "        → $kind/$name"
    kubectl scale "$kind" "$name" -n "$ns" --replicas="$replicas" $KUBECTL_ARGS
  done
}

patch_daemonsets() {
  local ns="$1"
  local names
  names=$(kubectl get daemonsets -n "$ns" \
    -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)
  [[ -z "$names" ]] && return
  for name in $names; do
    echo "        → daemonset/$name"
    if [[ "$ACTION" == "down" ]]; then
      kubectl patch daemonset "$name" -n "$ns" $KUBECTL_ARGS \
        -p '{"spec":{"template":{"spec":{"nodeSelector":{"non-existing-node":"true"}}}}}'
    else
      kubectl patch daemonset "$name" -n "$ns" $KUBECTL_ARGS \
        -p '{"spec":{"template":{"spec":{"nodeSelector":null}}}}'
    fi
  done
}

patch_cronjobs() {
  local ns="$1" suspend="$2"
  local names
  names=$(kubectl get cronjobs -n "$ns" \
    -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)
  [[ -z "$names" ]] && return
  for name in $names; do
    echo "        → cronjob/$name"
    kubectl patch cronjob "$name" -n "$ns" $KUBECTL_ARGS \
      -p "{\"spec\":{\"suspend\":$suspend}}"
  done
}

# ─────────────────────────────────────────────
# WAIT & DIAGNOSE после scale-up
# ─────────────────────────────────────────────

wait_and_check() {
  local ns="$1"
  [[ "$DRY_RUN" == "true" ]] && return

  echo ""
  echo "  ⏳ Ожидаем Ready всех подов в $ns (timeout: ${WAIT_TIMEOUT}s)..."

  local deadline=$(( $(date +%s) + WAIT_TIMEOUT ))
  local all_ready=false

  while [[ $(date +%s) -lt $deadline ]]; do
    local total ready
    total=$(kubectl get pods -n "$ns" --no-headers 2>/dev/null | wc -l)
    ready=$(kubectl get pods -n "$ns" --no-headers 2>/dev/null \
      | awk '{print $2}' \
      | awk -F'/' '$1==$2 {count++} END {print count+0}')

    if [[ "$total" -gt 0 && "$ready" -eq "$total" ]]; then
      all_ready=true
      break
    fi

    echo "    готово: $ready / $total"
    sleep 5
  done

  echo ""
  if [[ "$all_ready" == "true" ]]; then
    echo "  ✅ $ns — все поды Ready"
  else
    echo "  ❌ $ns — не все поды поднялись за ${WAIT_TIMEOUT}s"
    diagnose_pods "$ns"
  fi
}

# ─────────────────────────────────────────────
# ДИАГНОСТИКА подов
# ─────────────────────────────────────────────

diagnose_pods() {
  local ns="$1"

  echo ""
  echo "  --- Проблемные поды ---"
  kubectl get pods -n "$ns" --no-headers 2>/dev/null \
    | awk '$3 != "Running" && $3 != "Completed" && $3 != "Succeeded" {
        printf "    %-45s %-15s %s\n", $1, $3, $2
      }' || true

  echo ""
  kubectl get pods -n "$ns" --no-headers 2>/dev/null \
    | awk '$3 != "Running" && $3 != "Completed" && $3 != "Succeeded" {print $1}' \
    | while read -r pod; do
        echo ""
        echo "  ┌── Pod: $pod"

        # Причина из state/lastState
        local reason
        reason=$(kubectl get pod "$pod" -n "$ns" \
          -o jsonpath='{range .status.containerStatuses[*]}{.state}{.lastState}{end}' \
          2>/dev/null || true)

        # Events
        echo "  │ Events:"
        kubectl describe pod "$pod" -n "$ns" 2>/dev/null \
          | awk '/^Events:/,0' \
          | grep -v "^Events:" \
          | grep -v "^$" \
          | tail -5 \
          | sed 's/^/  │   /' || true

        # Логи
        echo "  │ Logs (last 10):"
        kubectl logs "$pod" -n "$ns" --tail=10 2>/dev/null \
          | sed 's/^/  │   /' \
          || kubectl logs "$pod" -n "$ns" --previous --tail=10 2>/dev/null \
          | sed 's/^/  │   [prev] /' \
          || echo "  │   (логи недоступны)"

        echo "  └──"
      done
}

# ─────────────────────────────────────────────
# ПРОВЕРКА статуса NS (пункт 3)
# ─────────────────────────────────────────────

check_namespace() {
  local ns="$1"
  echo ""
  echo "━━━ Namespace: $ns ━━━"

  # Проверяем есть ли вообще workload'ы
  local deploy_names sts_names
  deploy_names=$(kubectl get deployments -n "$ns" \
    -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)
  sts_names=$(kubectl get statefulsets -n "$ns" \
    -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)

  if [[ -z "$deploy_names" && -z "$sts_names" ]]; then
    echo "  ⚪ Нет Deployments и StatefulSets — пропускаем"
    return
  fi

  local ns_ok=true

  # --- Deployments ---
  if [[ -n "$deploy_names" ]]; then
    echo "  Deployments:"
    for name in $deploy_names; do
      local desired ready
      desired=$(kubectl get deployment "$name" -n "$ns" \
        -o jsonpath='{.spec.replicas}' 2>/dev/null || echo "0")
      ready=$(kubectl get deployment "$name" -n "$ns" \
        -o jsonpath='{.status.readyReplicas}' 2>/dev/null || echo "0")
      ready="${ready:-0}"

      if [[ "$desired" == "0" ]]; then
        echo "    ⚪ $name — scaled to 0"
      elif [[ "$ready" == "$desired" ]]; then
        echo "    ✅ $name — $ready/$desired Running"
      else
        echo "    ❌ $name — $ready/$desired Running"
        ns_ok=false
      fi
    done
  fi

  # --- StatefulSets ---
  if [[ -n "$sts_names" ]]; then
    echo "  StatefulSets:"
    for name in $sts_names; do
      local desired ready
      desired=$(kubectl get statefulset "$name" -n "$ns" \
        -o jsonpath='{.spec.replicas}' 2>/dev/null || echo "0")
      ready=$(kubectl get statefulset "$name" -n "$ns" \
        -o jsonpath='{.status.readyReplicas}' 2>/dev/null || echo "0")
      ready="${ready:-0}"

      if [[ "$desired" == "0" ]]; then
        echo "    ⚪ $name — scaled to 0"
      elif [[ "$ready" == "$desired" ]]; then
        echo "    ✅ $name — $ready/$desired Running"
      else
        echo "    ❌ $name — $ready/$desired Running"
        ns_ok=false
      fi
    done
  fi

  # --- Рестарты ---
  echo "  Рестарты:"
  local restart_issues=false
  kubectl get pods -n "$ns" --no-headers 2>/dev/null \
    | while read -r pod_line; do
        local pod_name restarts status
        pod_name=$(echo "$pod_line" | awk '{print $1}')
        status=$(echo "$pod_line"   | awk '{print $3}')
        restarts=$(echo "$pod_line" | awk '{print $4}')

        if [[ "$restarts" -gt "$RESTART_THRESHOLD" ]] 2>/dev/null; then
          echo "    ⚠️  $pod_name — $restarts рестартов (статус: $status)"
          restart_issues=true
        fi
      done

  if [[ "$restart_issues" == "false" ]]; then
    echo "    ✅ Рестартов сверх нормы нет (порог: $RESTART_THRESHOLD)"
  fi

  # --- Если есть проблемы — диагностика ---
  if [[ "$ns_ok" == "false" ]]; then
    diagnose_pods "$ns"
  fi
}

# ─────────────────────────────────────────────
# SCALE NS
# ─────────────────────────────────────────────

process_namespace() {
  local ns="$1"
  echo ""
  echo "━━━ Namespace: $ns ━━━"

  if [[ "$ACTION" == "down" ]]; then
    echo "  [1/4] Deployments → replicas=0"
    scale_resources deployments "$ns" 0
    echo "  [2/4] StatefulSets → replicas=0"
    scale_resources statefulsets "$ns" 0
    echo "  [3/4] DaemonSets → nodeSelector patch"
    patch_daemonsets "$ns"
    echo "  [4/4] CronJobs → suspend=true"
    patch_cronjobs "$ns" true
    echo "  ✓ $ns — готово"
  else
    echo "  [1/4] Deployments → replicas=1"
    scale_resources deployments "$ns" 1
    echo "  [2/4] StatefulSets → replicas=1"
    scale_resources statefulsets "$ns" 1
    echo "  [3/4] DaemonSets → nodeSelector убран"
    patch_daemonsets "$ns"
    echo "  [4/4] CronJobs → suspend=false"
    patch_cronjobs "$ns" false
    wait_and_check "$ns"
  fi
}

# ─────────────────────────────────────────────
# ТОЧКА ВХОДА
# ─────────────────────────────────────────────

run_for_ns() {
  local ns="$1"
  if [[ "$ACTION" == "check" ]]; then
    check_namespace "$ns"
  else
    process_namespace "$ns"
  fi
}

if [[ -n "$SINGLE_NS" ]]; then
  run_for_ns "$SINGLE_NS"
else
  while IFS= read -r line <&3 || [[ -n "$line" ]]; do
    line="${line// /}"
    [[ -z "$line" ]] && continue
    [[ "$line" == \#* ]] && continue
    run_for_ns "$line"
  done 3< "$NS_FILE"
fi

echo ""
echo "=== Всё готово ==="
