{{- if eq $.Values.enableService.redis.type "cluster" }}
initContainers:
  - name: clear-data-for-cluster
    image: busybox
    command: ['sh', '-c']
    args:
      - |
        echo "Проверяем совместимость данных с cluster mode..."
        # Если есть RDB/AOF от single mode — удаляем
        # В cluster mode допустима только 1 БД, single по умолчанию создаёт 16
        if [ -f /data/dump.rdb ] || [ -d /data/appendonlydir ]; then
          echo "Найдены данные от single mode — очищаем /data/"
          rm -rf /data/*
          rm -rf /data/.*  2>/dev/null || true
          echo "Очищено"
        else
          echo "/data/ пуста — пропускаем"
        fi
    volumeMounts:
      - name: {{ $.Values.labels.redis }}-data
        mountPath: /data
{{- end }}
