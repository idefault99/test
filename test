#!/bin/bash
# unseal-vault.sh — Распечатывание Vault после перезагрузки VM
# Запускать от root: sudo bash unseal-vault.sh
#
# Скрипт берёт ключи из /root/vault-init.json автоматически
# или позволяет ввести их вручную если файл удалён.
set -euo pipefail

# ══════════════════════════════════════════
#   НАСТРОЙ ПОД СЕБЯ
# ══════════════════════════════════════════
VAULT_DOMAIN="vault.internal"
VAULT_TLS_DIR="/opt/vault/tls"
VAULT_INIT_FILE="/root/vault-init.json"
KEY_THRESHOLD=3   # сколько ключей нужно для unseal (должно совпадать с install-vault.sh)
# ══════════════════════════════════════════

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
log()     { echo -e "${GREEN}[INFO]${NC}  $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()     { echo -e "${RED}[ERR]${NC}   $*"; exit 1; }
section() { echo -e "\n${CYAN}══════ $* ══════${NC}"; }

export VAULT_ADDR="https://127.0.0.1:8200"
export VAULT_CACERT="${VAULT_TLS_DIR}/ca.crt"

section "Проверка состояния Vault"

# Ждём пока vault.service поднимется
log "Ожидаем запуска vault.service..."
for i in $(seq 1 20); do
  if systemctl is-active --quiet vault; then
    break
  fi
  log "  vault.service ещё не активен (попытка ${i}/20)..."
  sleep 3
done

systemctl is-active --quiet vault || err "vault.service не запустился. Смотри: journalctl -u vault -n 50"
log "vault.service активен"

# Ждём пока Vault начнёт отвечать по API
log "Ожидаем Vault API..."
for i in $(seq 1 20); do
  STATUS_CODE=$(curl -sk -o /dev/null -w "%{http_code}" \
    "${VAULT_ADDR}/v1/sys/health" || true)
  if [[ "${STATUS_CODE}" =~ ^(200|429|472|473|501|503)$ ]]; then
    break
  fi
  log "  API не отвечает (попытка ${i}/20, code=${STATUS_CODE})..."
  sleep 3
done

# Проверяем текущий статус
VAULT_STATUS=$(vault status -format=json 2>/dev/null || true)
if [[ -z "${VAULT_STATUS}" ]]; then
  err "Vault не отвечает на ${VAULT_ADDR}"
fi

SEALED=$(echo "${VAULT_STATUS}" | jq -r '.sealed')
INITIALIZED=$(echo "${VAULT_STATUS}" | jq -r '.initialized')

if [[ "${INITIALIZED}" != "true" ]]; then
  err "Vault не инициализирован. Сначала запусти install-vault.sh и setup-vault.sh."
fi

if [[ "${SEALED}" == "false" ]]; then
  log "Vault уже распечатан (unsealed). Ничего делать не нужно."
  vault status
  exit 0
fi

log "Vault sealed=true — начинаем unseal"

section "Unseal"

if [[ -f "${VAULT_INIT_FILE}" ]]; then
  log "Найден файл ${VAULT_INIT_FILE} — берём ключи автоматически"

  for i in $(seq 0 $((KEY_THRESHOLD - 1))); do
    KEY=$(jq -r ".unseal_keys_b64[${i}]" "${VAULT_INIT_FILE}")
    if [[ -z "${KEY}" || "${KEY}" == "null" ]]; then
      err "Ключ ${i} не найден в ${VAULT_INIT_FILE}"
    fi
    vault operator unseal "${KEY}" > /dev/null
    log "  Ключ $((i+1))/${KEY_THRESHOLD} применён"
  done

else
  warn "Файл ${VAULT_INIT_FILE} не найден — введи ключи вручную"
  echo ""
  echo -e "${YELLOW}Введи ${KEY_THRESHOLD} unseal-ключа (по одному, Enter после каждого):${NC}"
  echo ""

  for i in $(seq 1 ${KEY_THRESHOLD}); do
    read -rsp "  Ключ ${i}/${KEY_THRESHOLD}: " KEY
    echo ""
    if [[ -z "${KEY}" ]]; then
      err "Пустой ключ — отмена"
    fi
    vault operator unseal "${KEY}" > /dev/null
    log "  Ключ ${i}/${KEY_THRESHOLD} применён"
  done
fi

section "Результат"

SEALED_AFTER=$(vault status -format=json | jq -r '.sealed')
if [[ "${SEALED_AFTER}" == "false" ]]; then
  echo ""
  echo -e "${GREEN}╔══════════════════════════════════════════════╗${NC}"
  echo -e "${GREEN}║      Vault успешно распечатан!              ║${NC}"
  echo -e "${GREEN}╚══════════════════════════════════════════════╝${NC}"
  echo ""
  vault status
else
  err "Vault всё ещё sealed после unseal. Возможно неверные ключи."
fi
