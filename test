## 6. Полный all-in-one YAML

```yaml
apiVersion: v1
kind: Namespace
metadata:
  name: monitoring
---
apiVersion: v1
kind: Secret
metadata:
  name: sql-exporter-postgres-secret
  namespace: monitoring
type: Opaque
stringData:
  SQL_EXPORTER_DSN: "postgresql://monitor_exporter:CHANGE_ME_STRONG_PASSWORD@POSTGRES_HOST_OR_VIP:5432/postgres?sslmode=require"
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: sql-exporter-config
  namespace: monitoring
data:
  sql_exporter.yml: |
    global:
      scrape_timeout_offset: 500ms
      min_interval: 30s
      max_connections: 3
      max_idle_connections: 3

    target:
      data_source_name: "{{ env \"SQL_EXPORTER_DSN\" }}"
      collectors: [pg_db_statements, pg_db_database_stats, pg_db_sessions, pg_db_tables, pg_db_statements_info]

    collectors:
      - collector_name: pg_db_statements
        min_interval: 30s
        metrics:
          - metric_name: pg_db_statements_calls_total
            type: counter
            help: "Total SQL calls aggregated by database from pg_stat_statements"
            key_labels: [db]
            values: [calls]
            query: |
              SELECT
                d.datname AS db,
                COALESCE(sum(s.calls), 0)::double precision AS calls
              FROM pg_database d
              LEFT JOIN pg_stat_statements s ON s.dbid = d.oid
              WHERE d.datistemplate = false
              GROUP BY d.datname;

          - metric_name: pg_db_statements_total_exec_time_ms_total
            type: counter
            help: "Total execution time in ms aggregated by database from pg_stat_statements"
            key_labels: [db]
            values: [total_exec_time_ms]
            query: |
              SELECT
                d.datname AS db,
                COALESCE(sum(s.total_exec_time), 0)::double precision AS total_exec_time_ms
              FROM pg_database d
              LEFT JOIN pg_stat_statements s ON s.dbid = d.oid
              WHERE d.datistemplate = false
              GROUP BY d.datname;

          - metric_name: pg_db_statements_rows_total
            type: counter
            help: "Total returned/affected rows aggregated by database from pg_stat_statements"
            key_labels: [db]
            values: [rows_total]
            query: |
              SELECT
                d.datname AS db,
                COALESCE(sum(s.rows), 0)::double precision AS rows_total
              FROM pg_database d
              LEFT JOIN pg_stat_statements s ON s.dbid = d.oid
              WHERE d.datistemplate = false
              GROUP BY d.datname;

          - metric_name: pg_db_statements_avg_exec_time_ms
            type: gauge
            help: "Current weighted average execution time in ms aggregated by database from pg_stat_statements"
            key_labels: [db]
            values: [avg_exec_time_ms]
            query: |
              SELECT
                d.datname AS db,
                CASE
                  WHEN COALESCE(sum(s.calls), 0) = 0 THEN 0::double precision
                  ELSE (sum(s.total_exec_time) / sum(s.calls))::double precision
                END AS avg_exec_time_ms
              FROM pg_database d
              LEFT JOIN pg_stat_statements s ON s.dbid = d.oid
              WHERE d.datistemplate = false
              GROUP BY d.datname;

      - collector_name: pg_db_database_stats
        min_interval: 30s
        metrics:
          - metric_name: pg_db_xact_commit_total
            type: counter
            help: "Committed transactions by database"
            key_labels: [db]
            values: [xact_commit]
            query: |
              SELECT datname AS db, xact_commit::double precision AS xact_commit
              FROM pg_stat_database
              WHERE datname IS NOT NULL;

          - metric_name: pg_db_xact_rollback_total
            type: counter
            help: "Rolled back transactions by database"
            key_labels: [db]
            values: [xact_rollback]
            query: |
              SELECT datname AS db, xact_rollback::double precision AS xact_rollback
              FROM pg_stat_database
              WHERE datname IS NOT NULL;

          - metric_name: pg_db_blks_read_total
            type: counter
            help: "Disk blocks read by database"
            key_labels: [db]
            values: [blks_read]
            query: |
              SELECT datname AS db, blks_read::double precision AS blks_read
              FROM pg_stat_database
              WHERE datname IS NOT NULL;

          - metric_name: pg_db_blks_hit_total
            type: counter
            help: "Buffer hits by database"
            key_labels: [db]
            values: [blks_hit]
            query: |
              SELECT datname AS db, blks_hit::double precision AS blks_hit
              FROM pg_stat_database
              WHERE datname IS NOT NULL;

          - metric_name: pg_db_temp_bytes_total
            type: counter
            help: "Temp bytes by database"
            key_labels: [db]
            values: [temp_bytes]
            query: |
              SELECT datname AS db, temp_bytes::double precision AS temp_bytes
              FROM pg_stat_database
              WHERE datname IS NOT NULL;

          - metric_name: pg_db_deadlocks_total
            type: counter
            help: "Deadlocks by database"
            key_labels: [db]
            values: [deadlocks]
            query: |
              SELECT datname AS db, deadlocks::double precision AS deadlocks
              FROM pg_stat_database
              WHERE datname IS NOT NULL;

          - metric_name: pg_db_checksum_failures_total
            type: counter
            help: "Checksum failures by database"
            key_labels: [db]
            values: [checksum_failures]
            query: |
              SELECT datname AS db, COALESCE(checksum_failures, 0)::double precision AS checksum_failures
              FROM pg_stat_database
              WHERE datname IS NOT NULL;

      - collector_name: pg_db_sessions
        min_interval: 15s
        metrics:
          - metric_name: pg_db_sessions
            type: gauge
            help: "Current sessions by database and state"
            key_labels: [db, state]
            values: [sessions]
            query: |
              SELECT
                COALESCE(datname, 'unknown') AS db,
                COALESCE(state, 'unknown') AS state,
                count(*)::double precision AS sessions
              FROM pg_stat_activity
              GROUP BY COALESCE(datname, 'unknown'), COALESCE(state, 'unknown');

          - metric_name: pg_db_waiting_sessions
            type: gauge
            help: "Current waiting sessions by database and wait event type"
            key_labels: [db, wait_event_type]
            values: [sessions]
            query: |
              SELECT
                COALESCE(datname, 'unknown') AS db,
                COALESCE(wait_event_type, 'none') AS wait_event_type,
                count(*)::double precision AS sessions
              FROM pg_stat_activity
              WHERE wait_event_type IS NOT NULL
              GROUP BY COALESCE(datname, 'unknown'), COALESCE(wait_event_type, 'none');

      - collector_name: pg_db_tables
        min_interval: 60s
        metrics:
          - metric_name: pg_db_table_n_dead_tup
            type: gauge
            help: "Estimated dead tuples by table"
            key_labels: [db, schema, table]
            values: [n_dead_tup]
            query: |
              SELECT
                current_database() AS db,
                schemaname AS schema,
                relname AS table,
                n_dead_tup::double precision AS n_dead_tup
              FROM pg_stat_user_tables;

          - metric_name: pg_db_table_n_live_tup
            type: gauge
            help: "Estimated live tuples by table"
            key_labels: [db, schema, table]
            values: [n_live_tup]
            query: |
              SELECT
                current_database() AS db,
                schemaname AS schema,
                relname AS table,
                n_live_tup::double precision AS n_live_tup
              FROM pg_stat_user_tables;

          - metric_name: pg_db_table_last_autovacuum_age_seconds
            type: gauge
            help: "Seconds since last autovacuum by table"
            key_labels: [db, schema, table]
            values: [seconds_since_last_autovacuum]
            query: |
              SELECT
                current_database() AS db,
                schemaname AS schema,
                relname AS table,
                CASE
                  WHEN last_autovacuum IS NULL THEN -1::double precision
                  ELSE EXTRACT(EPOCH FROM (now() - last_autovacuum))::double precision
                END AS seconds_since_last_autovacuum
              FROM pg_stat_user_tables;

          - metric_name: pg_db_table_last_autoanalyze_age_seconds
            type: gauge
            help: "Seconds since last autoanalyze by table"
            key_labels: [db, schema, table]
            values: [seconds_since_last_autoanalyze]
            query: |
              SELECT
                current_database() AS db,
                schemaname AS schema,
                relname AS table,
                CASE
                  WHEN last_autoanalyze IS NULL THEN -1::double precision
                  ELSE EXTRACT(EPOCH FROM (now() - last_autoanalyze))::double precision
                END AS seconds_since_last_autoanalyze
              FROM pg_stat_user_tables;

      - collector_name: pg_db_statements_info
        min_interval: 60s
        metrics:
          - metric_name: pg_db_statements_dealloc_total
            type: counter
            help: "Total statement deallocations due to pg_stat_statements.max pressure"
            values: [dealloc]
            query: |
              SELECT dealloc::double precision AS dealloc
              FROM pg_stat_statements_info;

          - metric_name: pg_db_statements_stats_reset_epoch_seconds
            type: gauge
            help: "Epoch time of last pg_stat_statements reset"
            values: [stats_reset]
            query: |
              SELECT EXTRACT(EPOCH FROM stats_reset)::double precision AS stats_reset
              FROM pg_stat_statements_info;
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: sql-exporter-postgres
  namespace: monitoring
  labels:
    app.kubernetes.io/name: sql-exporter-postgres
    app.kubernetes.io/component: exporter
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: sql-exporter-postgres
  template:
    metadata:
      labels:
        app.kubernetes.io/name: sql-exporter-postgres
        app.kubernetes.io/component: exporter
    spec:
      containers:
        - name: sql-exporter
          image: burningalchemist/sql_exporter:0.18.6
          imagePullPolicy: IfNotPresent
          args:
            - "-config.file=/etc/sql-exporter/sql_exporter.yml"
            - "-web.listen-address=:9399"
          env:
            - name: SQL_EXPORTER_DSN
              valueFrom:
                secretKeyRef:
                  name: sql-exporter-postgres-secret
                  key: SQL_EXPORTER_DSN
          ports:
            - name: http-metrics
              containerPort: 9399
          readinessProbe:
            httpGet:
              path: /metrics
              port: http-metrics
            initialDelaySeconds: 10
            periodSeconds: 15
          livenessProbe:
            httpGet:
              path: /metrics
              port: http-metrics
            initialDelaySeconds: 20
            periodSeconds: 20
          resources:
            requests:
              cpu: 50m
              memory: 128Mi
            limits:
              cpu: 300m
              memory: 256Mi
          volumeMounts:
            - name: sql-exporter-config
              mountPath: /etc/sql-exporter
              readOnly: true
      volumes:
        - name: sql-exporter-config
          configMap:
            name: sql-exporter-config
---
apiVersion: v1
kind: Service
metadata:
  name: sql-exporter-postgres
  namespace: monitoring
  labels:
    app.kubernetes.io/name: sql-exporter-postgres
    app.kubernetes.io/component: exporter
spec:
  selector:
    app.kubernetes.io/name: sql-exporter-postgres
  ports:
    - name: http-metrics
      port: 9399
      targetPort: http-metrics
---
apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: sql-exporter-postgres
  namespace: monitoring
  labels:
    release: kube-prometheus-stack
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: sql-exporter-postgres
  namespaceSelector:
    matchNames:
      - monitoring
  endpoints:
    - port: http-metrics
      path: /metrics
      interval: 30s
      scrapeTimeout: 25s
---
apiVersion: monitoring.coreos.com/v1
kind: PrometheusRule
metadata:
  name: postgres-pgstats-rules
  namespace: monitoring
  labels:
    release: kube-prometheus-stack
spec:
  groups:
    - name: postgres-pgstats-alerts
      rules:
        - alert: PostgresPgStatStatementsDeallocGrowing
          expr: increase(pg_db_statements_dealloc_total[30m]) > 0
          for: 10m
          labels:
            severity: warning
          annotations:
            summary: "pg_stat_statements deallocations are growing"
            description: "Exporter sees pg_stat_statements entries being evicted. Consider increasing pg_stat_statements.max or resetting stats manually after analysis."

        - alert: PostgresHighAverageSqlLatency
          expr: max by (db) (pg_db_statements_avg_exec_time_ms) > 500
          for: 15m
          labels:
            severity: warning
          annotations:
            summary: "High average SQL latency in database {{ $labels.db }}"
            description: "Weighted average SQL execution time is above 500 ms."

        - alert: PostgresDeadlocksGrowing
          expr: increase(pg_db_deadlocks_total[15m]) > 0
          for: 5m
          labels:
            severity: critical
          annotations:
            summary: "Deadlocks detected in database {{ $labels.db }}"
            description: "Deadlocks increased during the last 15 minutes."

        - alert: PostgresTempBytesGrowingFast
          expr: increase(pg_db_temp_bytes_total[15m]) > 1073741824
          for: 10m
          labels:
            severity: warning
          annotations:
            summary: "High temp file usage in database {{ $labels.db }}"
            description: "More than 1 GiB temp bytes generated during the last 15 minutes."
---
