import boto3
import os
from botocore.config import Config
from urllib.parse import urlsplit, urlunsplit

MINIO_HOST     = "https://dev.host"   # Хост без префикса
MINIO_PREFIX   = "/api/s3minio"                         # Префикс
ACCESS_KEY     = "***"
SECRET_KEY     = "***"
# BUCKET_NAME    = "hotels"

s3 = boto3.client(
    "s3",
    endpoint_url=MINIO_HOST,             # Создаем клиента и считаем подпись для /
    aws_access_key_id=ACCESS_KEY,
    aws_secret_access_key=SECRET_KEY,
    region_name="us-east-1",
    config=Config(
        signature_version="s3v4",
        s3={"addressing_style": "path"},
    ),
)

def create_bucket_and_upload(bucket: str, local_path: str, object_key: str = None):
    """
    Создаёт бакет если не существует, загружает файл с локального ПК.
    
    bucket     — имя бакета
    local_path — путь к файлу на локальном ПК
    object_key — путь внутри бакета (если None — берётся имя файла)
    """
    if not os.path.exists(local_path):
        raise FileNotFoundError(f"Файл не найден: {local_path}")

    # Создаём бакет если его нет
    existing = [b["Name"] for b in s3.list_buckets().get("Buckets", [])]
    if bucket not in existing:
        s3.create_bucket(
            Bucket=bucket,
            CreateBucketConfiguration={"LocationConstraint": "us-east-1"},
        )
        print(f"Бакет создан: {bucket}")
    else:
        print(f"Бакет уже существует: {bucket}")

    # Если object_key не указан — берём имя файла
    if object_key is None:
        object_key = os.path.basename(local_path)

    # Загружаем файл
    file_size = os.path.getsize(local_path)
    print(f"Загружаю: {local_path} ({file_size} bytes) → s3://{bucket}/{object_key}")
    s3.upload_file(local_path, bucket, object_key)
    print(f"Готово")

# После подписания, перед отправкой — добавляем префикс в URL
def add_prefix(request, **kwargs):
    parsed = urlsplit(request.url)
    request.url = urlunsplit((
        parsed.scheme,
        parsed.netloc,
        MINIO_PREFIX + parsed.path,
        parsed.query,
        parsed.fragment,
    ))
    print(f"[before-send] {request.method} {request.url}")

# Регистрируем для всех S3 операций 
s3.meta.events.register("before-send.s3.*", add_prefix)


if __name__ == "__main__":
    response = s3.list_buckets()
    print("Подключение успешно!")
    for bucket in response.get("Buckets", []):
        print(f"  - {bucket['Name']}")
