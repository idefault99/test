.publish_helm:
  stage: publish_helm
  tags:
    - docker
  image:
    name: registry.test.model.svo.aero/dpm/iac/infra/py-publish-charts:latest
    pull_policy: [always, always]
  variables:
    DEFAULT_TARGET: main
  script:
    - echo $CI_COMMIT_TAG | grep -qE '^([a-z]+\-)?[0-9]+\.[0-9]+\.[0-9]+$' || { echo -e "\033[31m[ERROR] Тег '$CI_COMMIT_TAG' не соответствует паттерну [заказчик-]1.2.3\033[0m\nПодробнее https://wiki.yandex.ru/homepage/krap-projects/2131-test-stands/gajjdy/dlja-razrabotchikov/pravila-formirovanija-tegov-v-gitlab/"; exit 1; }
    - if [ -z "$BRANCH" ]; then echo "Переменная BRANCH не задана"; exit 1; fi
    - if [ -z "$TARGET" ]; then TARGET=$DEFAULT_TARGET; fi
    - git config --global http.sslverify false
    - git clone $CHARTS_ORIGIN
    - cd $CHARTS_ROOT_DIR
    - git switch $TARGET
    - git config --global user.name "Helm publishing job"
    - git config --global user.email "ci-cd-bot@cd-it.ru"
    - git fetch origin
    - git switch $BRANCH || git checkout -b $BRANCH # Try checkout to remote, else create local
    - cd ../
    - python3 /app/publish_charts.py $CI_PROJECT_PATH $CHARTS_ROOT_DIR $CHARTS_REGISTRY
    - cd $CHARTS_ROOT_DIR
    - git add .
    - GIT_COMMIT_EXIT_CODE=0
    - git commit -m "Update Helm charts from $CI_PROJECT_NAME" || export GIT_COMMIT_EXIT_CODE=$?
    - if [ $GIT_COMMIT_EXIT_CODE -ne 0 ]; then echo "nothing to change"; exit 1; fi
    - |
      if [ -z "$MR_TITLE" ];
      then git push origin $BRANCH -o merge_request.create -o merge_request.target="$TARGET" -o merge_request.remove_source_branch -o merge_request.squash;
      else git push origin $BRANCH -o merge_request.create -o merge_request.target="$TARGET" -o merge_request.title="$MR_TITLE" -o merge_request.remove_source_branch -o merge_request.squash
      fi
  rules:
    - if: $CI_COMMIT_TAG
      when: manual

