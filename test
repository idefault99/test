OLD_IMAGE="registry.gitlab.com/old-group/project/backend"
NEW_IMAGE="registry.gitlab.com/new-group/project/backend"

for tag in $(curl -s --header "PRIVATE-TOKEN: TOKEN" \
"https://gitlab.com/api/v4/projects/PROJECT_ID/registry/repositories/REPO_ID/tags?per_page=100" \
| jq -r '.[].name'); do

  set -e
  docker pull "$OLD_IMAGE:$tag"
  docker tag "$OLD_IMAGE:$tag" "$NEW_IMAGE:$tag"
  docker push "$NEW_IMAGE:$tag"

  # убрать именно этот локальный тег (и новый тег тоже)
  docker rmi "$OLD_IMAGE:$tag" "$NEW_IMAGE:$tag" >/dev/null 2>&1 || true

  # необязательно, но помогает быстро освобождать место
  docker image prune -f >/dev/null 2>&1 || true
done