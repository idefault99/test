# deploy_tag.py (fixed)

Исправлена проблема: pipeline останавливается в `blocked` после build/test, и manual-джоба не находилась потому что искали слишком рано.

## Что изменилось

- Ждём пока pipeline дойдёт до статуса `blocked` / `manual` / `success` / `failed` (до 5 минут)
- Только после этого ищем manual-джобу `aos_<stand>`
- При поиске джоб подтягиваем **все** через `include_retried=true`
- Показываем прогресс по статусу pipeline каждые 5 секунд
- Если джоба не найдена — выводим полный список всех джоб pipeline с их статусами для диагностики

## Установка

```bash
cat << 'EOF' > deploy_tag.py
#!/usr/bin/env python3
"""
Скрипт для проверки тэгов в GitLab-репозиториях и запуска деплоя.
"""

import argparse
import json
import re
import sys
import time
from urllib.parse import quote as url_quote
from urllib.request import Request, urlopen
from urllib.error import HTTPError


def gitlab_api(base_url, token, endpoint, method="GET", data=None):
    url = f"{base_url}/api/v4{endpoint}"
    headers = {"PRIVATE-TOKEN": token}
    body = None
    if data is not None:
        body = json.dumps(data).encode()
        headers["Content-Type"] = "application/json"
    req = Request(url, headers=headers, method=method, data=body)
    try:
        with urlopen(req) as resp:
            content = resp.read().decode()
            if not content:
                return None
            return json.loads(content)
    except HTTPError as e:
        err_body = ""
        try:
            err_body = e.read().decode()
        except Exception:
            pass
        raise Exception(f"HTTP {e.code}: {err_body or e.reason}")


def gitlab_api_raw(base_url, token, endpoint):
    url = f"{base_url}/api/v4{endpoint}"
    req = Request(url, headers={"PRIVATE-TOKEN": token})
    try:
        with urlopen(req) as resp:
            return resp.read().decode(errors="replace")
    except HTTPError as e:
        return f"[HTTP {e.code}] {e.reason}"


def find_project_id(base_url, token, project_path):
    path = project_path.strip("/")
    encoded = url_quote(path, safe="")
    try:
        result = gitlab_api(base_url, token, f"/projects/{encoded}")
        return result["id"], None
    except Exception as e:
        return None, str(e)


def check_tag_exists(base_url, token, project_id, tag):
    encoded_tag = url_quote(tag, safe="")
    try:
        gitlab_api(base_url, token, f"/projects/{project_id}/repository/tags/{encoded_tag}")
        return True, None
    except Exception as e:
        if "404" in str(e):
            return False, None
        return False, str(e)


def create_pipeline(base_url, token, project_id, ref):
    return gitlab_api(
        base_url, token,
        f"/projects/{project_id}/pipeline",
        method="POST",
        data={"ref": ref}
    )


def get_pipeline(base_url, token, project_id, pipeline_id):
    return gitlab_api(base_url, token, f"/projects/{project_id}/pipelines/{pipeline_id}")


def get_pipeline_jobs(base_url, token, project_id, pipeline_id):
    """Получает ВСЕ джобы pipeline включая manual."""
    return gitlab_api(
        base_url, token,
        f"/projects/{project_id}/pipelines/{pipeline_id}/jobs"
        f"?per_page=100&include_retried=true"
    )


def play_job(base_url, token, project_id, job_id):
    return gitlab_api(
        base_url, token,
        f"/projects/{project_id}/jobs/{job_id}/play",
        method="POST"
    )


def get_job(base_url, token, project_id, job_id):
    return gitlab_api(base_url, token, f"/projects/{project_id}/jobs/{job_id}")


def get_job_trace(base_url, token, project_id, job_id):
    return gitlab_api_raw(base_url, token, f"/projects/{project_id}/jobs/{job_id}/trace")


def parse_input_file(filepath):
    entries = []
    current_display = ""
    with open(filepath, "r", encoding="utf-8") as f:
        for line in f:
            line = line.rstrip("\n")
            if not line.strip() or "не найден" in line:
                continue
            entry = {"display_path": "", "sub_name": "", "image_path": "", "tag": ""}
            segments = line.split("  —  ")
            first = segments[0]
            if first.strip():
                sub_match = re.search(r'\((\S+)\)\s*$', first.strip())
                if sub_match:
                    entry["sub_name"] = sub_match.group(1)
                    path_part = first[:first.rfind("(")].strip()
                    if path_part:
                        current_display = path_part
                else:
                    current_display = first.strip()
            else:
                sub_match = re.search(r'\((\S+)\)', first)
                if sub_match:
                    entry["sub_name"] = sub_match.group(1)
            entry["display_path"] = current_display
            if len(segments) >= 2:
                entry["image_path"] = segments[1].strip()
            if len(segments) >= 3:
                third = segments[2].strip()
                third = re.sub(r'\s*\[.*?\]\s*$', '', third)
                entry["tag"] = third.strip()
            if entry["image_path"] and entry["tag"]:
                entries.append(entry)
    return entries


def strip_bin(tag):
    return tag[:-4] if tag.endswith(".bin") else tag


def stand_to_job_name(stand):
    return f"aos_{stand.replace('-', '_')}"


def show_entries(entries):
    print("\nНайденные app и тэги:")
    print("-" * 80)
    for i, e in enumerate(entries, 1):
        label = f" ({e['sub_name']})" if e["sub_name"] else ""
        print(f"  {i:3}. {e['display_path']}{label}")
        print(f"       {e['image_path']} : {e['tag']}")
    print("-" * 80)


def menu_select_entry(entries):
    show_entries(entries)
    while True:
        choice = input(f"\nВыберите app (1-{len(entries)}) или q для отмены: ").strip()
        if choice.lower() == "q":
            return None
        try:
            idx = int(choice)
            if 1 <= idx <= len(entries):
                return entries[idx - 1]
        except ValueError:
            pass
        print("Неверный ввод.")


def wait_for_manual_stage(base_url, token, project_id, pipeline_id, job_name, timeout=300):
    """Ждёт пока pipeline дойдёт до manual-джобы.
    Возвращает (job_dict | None, все_джобы, финальный_статус_pipeline)."""
    # Терминальные статусы где manual-джоба уже должна быть доступна
    ready_statuses = {"manual", "success", "failed", "canceled", "skipped"}
    # blocked = pipeline остановлен и ждёт ручного ввода — это именно то что нам нужно

    start = time.time()
    last_status = ""
    last_jobs = []

    while time.time() - start < timeout:
        try:
            pipeline = get_pipeline(base_url, token, project_id, pipeline_id)
            pipeline_status = pipeline.get("status", "unknown")
        except Exception as e:
            print(f"  ошибка получения pipeline: {e}")
            time.sleep(5)
            continue

        try:
            jobs = get_pipeline_jobs(base_url, token, project_id, pipeline_id)
            last_jobs = jobs
        except Exception as e:
            print(f"  ошибка получения джоб: {e}")
            time.sleep(5)
            continue

        # Ищем нашу джобу
        target = None
        for j in jobs:
            if j["name"] == job_name:
                target = j
                break

        if pipeline_status != last_status:
            print(f"  pipeline: {pipeline_status}")
            last_status = pipeline_status

        # Pipeline заблокирован ручной джобой — идеально
        if pipeline_status == "manual":
            if target:
                return target, jobs, pipeline_status
            # manual статус но нашей джобы нет — зашли в тупик
            return None, jobs, pipeline_status

        # Pipeline завершился — проверяем есть ли наша джоба
        if pipeline_status in ready_statuses:
            return target, jobs, pipeline_status

        # Pipeline всё ещё работает, но джоба может уже существовать в статусе manual
        if target and target.get("status") == "manual":
            return target, jobs, pipeline_status

        time.sleep(5)

    return None, last_jobs, last_status


def deploy_flow(args, entries):
    entry = menu_select_entry(entries)
    if not entry:
        return

    project_path = entry["image_path"].lstrip("/")
    print(f"\nВыбран: {entry['display_path']}")
    print(f"Путь проекта: /{project_path}")
    print(f"Тэг из репозитория: {entry['tag']}")

    custom = input(f"\nВведите тэг или Enter для '{entry['tag']}': ").strip()
    raw_tag = custom if custom else entry["tag"]
    git_tag = strip_bin(raw_tag)
    print(f"Git tag: {git_tag}")

    print(f"\nПоиск проекта {project_path}...")
    project_id, err = find_project_id(args.gitlab_url, args.token, project_path)
    if err:
        print(f"ОШИБКА: {err}")
        return
    print(f"Project ID: {project_id}")

    print(f"Проверка тэга {git_tag}...")
    exists, err = check_tag_exists(args.gitlab_url, args.token, project_id, git_tag)
    if err:
        print(f"ОШИБКА: {err}")
        return
    if not exists:
        print(f"ОШИБКА: тэг '{git_tag}' не найден в проекте")
        return
    print("Тэг существует.")

    job_name = stand_to_job_name(args.stand)
    print(f"\nPipeline на тэге {git_tag}, джоба: {job_name}")
    if input("Продолжить? (y/n): ").strip().lower() != "y":
        print("Отмена.")
        return

    print(f"\nСоздание pipeline...")
    try:
        pipeline = create_pipeline(args.gitlab_url, args.token, project_id, git_tag)
    except Exception as e:
        print(f"ОШИБКА: {e}")
        return
    pipeline_id = pipeline["id"]
    print(f"Pipeline #{pipeline_id}: {pipeline.get('web_url', '')}")

    # Ждём пока pipeline дойдёт до manual-джобы (после build/test)
    print(f"\nОжидание прохождения build/test и появления {job_name}...")
    print("(таймаут 5 минут)")
    target_job, all_jobs, final_status = wait_for_manual_stage(
        args.gitlab_url, args.token, project_id, pipeline_id, job_name
    )

    if not target_job:
        print(f"\nОШИБКА: джоба {job_name} не найдена или не в статусе manual.")
        print(f"Финальный статус pipeline: {final_status}")
        print(f"\nВсе джобы в pipeline #{pipeline_id}:")
        for j in all_jobs:
            print(f"  [{j['status']:12}] {j['stage']:15} {j['name']}")
        return

    job_id = target_job["id"]
    print(f"\nДжоба найдена: #{job_id}, статус: {target_job['status']}")

    if target_job["status"] != "manual":
        print(f"Джоба не в статусе manual (сейчас: {target_job['status']}), play не требуется.")
    else:
        print("Запуск manual-джобы...")
        try:
            play_job(args.gitlab_url, args.token, project_id, job_id)
        except Exception as e:
            print(f"ОШИБКА запуска: {e}")
            return
        print("Джоба запущена.")

    print("\nОжидание 10 секунд...")
    time.sleep(10)

    try:
        job_info = get_job(args.gitlab_url, args.token, project_id, job_id)
    except Exception as e:
        print(f"ОШИБКА статуса: {e}")
        return

    status = job_info["status"]
    print(f"\nСтатус джобы: {status}")
    print(f"URL: {job_info.get('web_url', '')}")

    print("\n" + "=" * 80)
    print("ЛОГ ДЖОБЫ:")
    print("=" * 80)
    print(get_job_trace(args.gitlab_url, args.token, project_id, job_id))
    print("=" * 80)

    if status == "failed":
        print("\n!!! ОШИБКА: джоба завершилась с failed !!!")
    elif status in ("running", "pending"):
        print(f"\nДжоба ещё работает: {job_info.get('web_url', '')}")
    elif status == "success":
        print("\nУСПЕХ: джоба завершилась success.")


def main():
    parser = argparse.ArgumentParser(description="Проверка тэгов и деплой через GitLab")
    parser.add_argument("--input", required=True, help="Файл с выводом scan_values.py")
    parser.add_argument("--gitlab-url", required=True, help="URL GitLab")
    parser.add_argument("--token", required=True, help="GitLab Private Token")
    parser.add_argument("--stand", required=True, help="Название стенда")
    args = parser.parse_args()
    args.gitlab_url = args.gitlab_url.rstrip("/")

    try:
        entries = parse_input_file(args.input)
    except Exception as e:
        print(f"Ошибка чтения: {e}", file=sys.stderr)
        sys.exit(1)

    if not entries:
        print("Нет валидных записей.")
        sys.exit(0)

    while True:
        print("\n" + "=" * 50)
        print(f"Стенд: {args.stand}  |  Джоба: {stand_to_job_name(args.stand)}")
        print("=" * 50)
        print("  1) Показать найденные тэги")
        print("  2) Деплой тэга на стенд")
        print("  q) Выход")
        choice = input("\nВыбор: ").strip().lower()
        if choice == "1":
            show_entries(entries)
        elif choice == "2":
            deploy_flow(args, entries)
        elif choice == "q":
            break
        else:
            print("Неверный ввод.")


if __name__ == "__main__":
    main()
