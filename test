test:
  image: registry.test/test/dvr/frb/bg/bg:${TAG}
  user: "${RUNNER_UID}:${RUNNER_GID}"
  working_dir: /code/app
  environment:
    - COVERAGE_FILE=/code/app/artifacts/.coverage
  command: >
    bash -c "pytest --junitxml=/code/app/artifacts/report.xml -v --cov --cov-report term --cov-report xml:/code/app/artifacts/coverage.xml"
  volumes:
    - ./.env:/code/.env
    - ./artifacts:/code/app/artifacts
  depends_on:
    db:
      condition: service_healthy
    redis:
      condition: service_healthy
    backend:
      condition: service_healthy
  env_file:
    - .env
  links:
    - backend
