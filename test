# deploy_tag.py (с поддержкой main/fronts)

Добавлена ветка для деплоя фронтов: проверка `projectLabel` из `Helm/values.yaml` проекта, сравнение с `/versions` стенда, polling новой версии после деплоя.

## Установка

```bash
cat << 'EOF' > deploy_tag.py
#!/usr/bin/env python3
"""
Скрипт для проверки тэгов и деплоя через GitLab pipeline.
Поддерживает обычные app и main/fronts/* с проверкой версии на стенде.
"""

import argparse
import json
import re
import sys
import time
from urllib.parse import quote as url_quote, urlparse
from urllib.request import Request, urlopen
from urllib.error import HTTPError, URLError


def gitlab_api(base_url, token, endpoint, method="GET", data=None):
    url = f"{base_url}/api/v4{endpoint}"
    headers = {"PRIVATE-TOKEN": token}
    body = None
    if data is not None:
        body = json.dumps(data).encode()
        headers["Content-Type"] = "application/json"
    req = Request(url, headers=headers, method=method, data=body)
    try:
        with urlopen(req) as resp:
            content = resp.read().decode()
            if not content:
                return None
            return json.loads(content)
    except HTTPError as e:
        err_body = ""
        try:
            err_body = e.read().decode()
        except Exception:
            pass
        raise Exception(f"HTTP {e.code}: {err_body or e.reason}")


def gitlab_api_raw(base_url, token, endpoint):
    url = f"{base_url}/api/v4{endpoint}"
    req = Request(url, headers={"PRIVATE-TOKEN": token})
    try:
        with urlopen(req) as resp:
            return resp.read().decode(errors="replace")
    except HTTPError as e:
        return f"[HTTP {e.code}] {e.reason}"


def http_get_json(url, timeout=30):
    """Простой GET без авторизации для ручки /versions стенда."""
    req = Request(url, headers={"Accept": "application/json"})
    try:
        with urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read().decode()), None
    except HTTPError as e:
        return None, f"HTTP {e.code}: {e.reason}"
    except URLError as e:
        return None, f"Сетевая ошибка: {e.reason}"
    except json.JSONDecodeError as e:
        return None, f"Ошибка парсинга JSON: {e}"
    except Exception as e:
        return None, f"Ошибка: {e}"


def find_project_id(base_url, token, project_path):
    path = project_path.strip("/")
    encoded = url_quote(path, safe="")
    try:
        result = gitlab_api(base_url, token, f"/projects/{encoded}")
        return result, None
    except Exception as e:
        return None, str(e)


def check_tag_exists(base_url, token, project_id, tag):
    encoded_tag = url_quote(tag, safe="")
    try:
        gitlab_api(base_url, token, f"/projects/{project_id}/repository/tags/{encoded_tag}")
        return True, None
    except Exception as e:
        if "404" in str(e):
            return False, None
        return False, str(e)


def create_pipeline(base_url, token, project_id, ref):
    return gitlab_api(
        base_url, token,
        f"/projects/{project_id}/pipeline",
        method="POST",
        data={"ref": ref}
    )


def get_pipeline(base_url, token, project_id, pipeline_id):
    return gitlab_api(base_url, token, f"/projects/{project_id}/pipelines/{pipeline_id}")


def get_pipeline_jobs(base_url, token, project_id, pipeline_id):
    return gitlab_api(
        base_url, token,
        f"/projects/{project_id}/pipelines/{pipeline_id}/jobs"
        f"?per_page=100&include_retried=true"
    )


def play_job(base_url, token, project_id, job_id):
    return gitlab_api(
        base_url, token,
        f"/projects/{project_id}/jobs/{job_id}/play",
        method="POST"
    )


def get_job(base_url, token, project_id, job_id):
    return gitlab_api(base_url, token, f"/projects/{project_id}/jobs/{job_id}")


def get_job_trace(base_url, token, project_id, job_id):
    return gitlab_api_raw(base_url, token, f"/projects/{project_id}/jobs/{job_id}/trace")


def get_file_raw(base_url, token, project_id, file_path, ref):
    """Читает файл из проекта на указанной ветке/тэге."""
    encoded = url_quote(file_path, safe="")
    url = f"{base_url}/api/v4/projects/{project_id}/repository/files/{encoded}/raw?ref={ref}"
    req = Request(url, headers={"PRIVATE-TOKEN": token})
    try:
        with urlopen(req) as resp:
            return resp.read().decode(), None
    except HTTPError as e:
        return None, f"HTTP {e.code}"
    except Exception as e:
        return None, str(e)


def extract_project_label(yaml_content):
    """Извлекает projectLabel из YAML (ключ верхнего уровня)."""
    match = re.search(r'^projectLabel:\s*["\']?([^"\'\n]+)["\']?\s*$', yaml_content, re.MULTILINE)
    if match:
        return match.group(1).strip()
    return None


def parse_input_file(filepath):
    entries = []
    current_display = ""
    with open(filepath, "r", encoding="utf-8") as f:
        for line in f:
            line = line.rstrip("\n")
            if not line.strip() or "не найден" in line:
                continue
            entry = {"display_path": "", "sub_name": "", "image_path": "", "tag": ""}
            segments = line.split("  —  ")
            first = segments[0]
            if first.strip():
                sub_match = re.search(r'\((\S+)\)\s*$', first.strip())
                if sub_match:
                    entry["sub_name"] = sub_match.group(1)
                    path_part = first[:first.rfind("(")].strip()
                    if path_part:
                        current_display = path_part
                else:
                    current_display = first.strip()
            else:
                sub_match = re.search(r'\((\S+)\)', first)
                if sub_match:
                    entry["sub_name"] = sub_match.group(1)
            entry["display_path"] = current_display
            if len(segments) >= 2:
                entry["image_path"] = segments[1].strip()
            if len(segments) >= 3:
                third = segments[2].strip()
                third = re.sub(r'\s*\[.*?\]\s*$', '', third)
                entry["tag"] = third.strip()
            if entry["image_path"] and entry["tag"]:
                entries.append(entry)
    return entries


def strip_bin(tag):
    return tag[:-4] if tag.endswith(".bin") else tag


def stand_to_job_name(stand):
    return f"aos_{stand.replace('-', '_')}"


def build_stand_url(gitlab_url, stand):
    """https://gitlab-test.domen.ru + test-stand -> https://test-stand.domen.ru"""
    parsed = urlparse(gitlab_url)
    host = parsed.hostname or ""
    # Отрезаем первую часть хоста (gitlab-test) и берём домен
    parts = host.split(".", 1)
    if len(parts) < 2:
        return None
    domain = parts[1]
    return f"https://{stand}.{domain}"


def show_entries(entries):
    print("\nНайденные app и тэги:")
    print("-" * 80)
    for i, e in enumerate(entries, 1):
        label = f" ({e['sub_name']})" if e["sub_name"] else ""
        is_front = " [FRONT]" if e["display_path"].startswith("main/fronts/") else ""
        print(f"  {i:3}. {e['display_path']}{label}{is_front}")
        print(f"       {e['image_path']} : {e['tag']}")
    print("-" * 80)


def menu_select_entry(entries):
    show_entries(entries)
    while True:
        choice = input(f"\nВыберите app (1-{len(entries)}) или q: ").strip()
        if choice.lower() == "q":
            return None
        try:
            idx = int(choice)
            if 1 <= idx <= len(entries):
                return entries[idx - 1]
        except ValueError:
            pass
        print("Неверный ввод.")


def wait_for_manual_stage(base_url, token, project_id, pipeline_id, job_name, timeout=300):
    """Ждёт пока pipeline дойдёт до manual-джобы."""
    ready_statuses = {"manual", "success", "failed", "canceled", "skipped"}
    start = time.time()
    last_status = ""
    last_jobs = []

    while time.time() - start < timeout:
        try:
            pipeline = get_pipeline(base_url, token, project_id, pipeline_id)
            pipeline_status = pipeline.get("status", "unknown")
        except Exception as e:
            print(f"  ошибка pipeline: {e}")
            time.sleep(5)
            continue

        try:
            jobs = get_pipeline_jobs(base_url, token, project_id, pipeline_id)
            last_jobs = jobs
        except Exception as e:
            print(f"  ошибка джоб: {e}")
            time.sleep(5)
            continue

        target = next((j for j in jobs if j["name"] == job_name), None)

        if pipeline_status != last_status:
            print(f"  pipeline: {pipeline_status}")
            last_status = pipeline_status

        if pipeline_status == "manual":
            return (target, jobs, pipeline_status) if target else (None, jobs, pipeline_status)

        if pipeline_status in ready_statuses:
            return target, jobs, pipeline_status

        if target and target.get("status") == "manual":
            return target, jobs, pipeline_status

        time.sleep(5)

    return None, last_jobs, last_status


def wait_for_job_completion(base_url, token, project_id, job_id, timeout=600):
    """Ждёт завершения джобы (для фронта — до success/failed)."""
    terminal = {"success", "failed", "canceled", "skipped"}
    start = time.time()
    last_status = ""
    while time.time() - start < timeout:
        try:
            job = get_job(base_url, token, project_id, job_id)
            status = job.get("status", "unknown")
        except Exception as e:
            print(f"  ошибка: {e}")
            time.sleep(5)
            continue
        if status != last_status:
            print(f"  джоба: {status}")
            last_status = status
        if status in terminal:
            return job
        time.sleep(5)
    return None


def run_pipeline_and_play(args, project_id, git_tag, job_name):
    """Создаёт pipeline, ждёт manual-стадию, запускает джобу.
    Возвращает (job_id | None, ошибка)."""
    print(f"\nСоздание pipeline...")
    try:
        pipeline = create_pipeline(args.gitlab_url, args.token, project_id, git_tag)
    except Exception as e:
        return None, f"создание pipeline: {e}"
    pipeline_id = pipeline["id"]
    print(f"Pipeline #{pipeline_id}: {pipeline.get('web_url', '')}")

    print(f"\nОжидание прохождения build/test (до 5 минут)...")
    target_job, all_jobs, final_status = wait_for_manual_stage(
        args.gitlab_url, args.token, project_id, pipeline_id, job_name
    )

    if not target_job:
        print(f"\nОШИБКА: джоба {job_name} не найдена. Статус pipeline: {final_status}")
        print("Все джобы:")
        for j in all_jobs:
            print(f"  [{j['status']:12}] {j['stage']:15} {j['name']}")
        return None, f"джоба {job_name} не найдена"

    job_id = target_job["id"]
    print(f"\nДжоба #{job_id}, статус: {target_job['status']}")

    if target_job["status"] == "manual":
        print("Запуск manual-джобы...")
        try:
            play_job(args.gitlab_url, args.token, project_id, job_id)
        except Exception as e:
            return None, f"play: {e}"
        print("Джоба запущена.")

    return job_id, None


def deploy_regular_flow(args, entry):
    """Обычный деплой: выбор тэга, pipeline, play, лог через 10 сек."""
    project_path = entry["image_path"].lstrip("/")
    print(f"\nОбычный деплой")
    print(f"Проект: /{project_path}")
    print(f"Тэг из репозитория: {entry['tag']}")

    custom = input(f"\nВведите тэг или Enter для '{entry['tag']}': ").strip()
    raw_tag = custom if custom else entry["tag"]
    git_tag = strip_bin(raw_tag)
    print(f"Git tag: {git_tag}")

    print(f"\nПоиск проекта...")
    project, err = find_project_id(args.gitlab_url, args.token, project_path)
    if err:
        print(f"ОШИБКА: {err}")
        return
    project_id = project["id"]
    print(f"Project ID: {project_id}")

    print(f"Проверка тэга {git_tag}...")
    exists, err = check_tag_exists(args.gitlab_url, args.token, project_id, git_tag)
    if err:
        print(f"ОШИБКА: {err}")
        return
    if not exists:
        print(f"ОШИБКА: тэг '{git_tag}' не найден")
        return
    print("Тэг существует.")

    job_name = stand_to_job_name(args.stand)
    print(f"\nДжоба: {job_name}")
    if input("Продолжить? (y/n): ").strip().lower() != "y":
        return

    job_id, err = run_pipeline_and_play(args, project_id, git_tag, job_name)
    if err:
        print(f"ОШИБКА: {err}")
        return

    print("\nОжидание 10 секунд...")
    time.sleep(10)

    try:
        job_info = get_job(args.gitlab_url, args.token, project_id, job_id)
    except Exception as e:
        print(f"ОШИБКА: {e}")
        return

    status = job_info["status"]
    print(f"\nСтатус: {status}")
    print(f"URL: {job_info.get('web_url', '')}")
    print("\n" + "=" * 80)
    print("ЛОГ:")
    print("=" * 80)
    print(get_job_trace(args.gitlab_url, args.token, project_id, job_id))
    print("=" * 80)

    if status == "failed":
        print("\n!!! ОШИБКА джобы !!!")
    elif status == "success":
        print("\nУСПЕХ")


def deploy_frontend_flow(args, entry):
    """Флоу деплоя фронта:
    1. Находим проект, читаем Helm/values.yaml, берём projectLabel
    2. Запрашиваем /versions на стенде, ищем запись по name == projectLabel
    3. Сравниваем version со строкой из входа
    4. Если совпадает — выводим и выходим
    5. Если нет — деплой, потом polling /versions до 5 минут
    """
    project_path = entry["image_path"].lstrip("/")
    current_tag = entry["tag"]

    stand_url = build_stand_url(args.gitlab_url, args.stand)
    if not stand_url:
        print("ОШИБКА: не удалось построить URL стенда из gitlab-url")
        return

    print(f"\nФронт-деплой")
    print(f"Проект: /{project_path}")
    print(f"Тэг: {current_tag}")
    print(f"URL стенда: {stand_url}")

    # 1. Находим проект
    print(f"\nПоиск проекта...")
    project, err = find_project_id(args.gitlab_url, args.token, project_path)
    if err:
        print(f"ОШИБКА: {err}")
        return
    project_id = project["id"]
    default_branch = project.get("default_branch", "main")
    print(f"Project ID: {project_id}, default branch: {default_branch}")

    # 2. Читаем Helm/values.yaml
    print(f"\nЧтение Helm/values.yaml из ветки {default_branch}...")
    content, err = get_file_raw(args.gitlab_url, args.token, project_id,
                                 "Helm/values.yaml", default_branch)
    if err:
        print(f"ОШИБКА чтения Helm/values.yaml: {err}")
        return

    project_label = extract_project_label(content)
    if not project_label:
        print("ОШИБКА: ключ projectLabel не найден в Helm/values.yaml")
        return
    print(f"projectLabel: {project_label}")

    # 3. Запрос /versions на стенде
    versions_url = f"{stand_url}/versions"
    print(f"\nЗапрос {versions_url}...")
    versions, err = http_get_json(versions_url)
    if err:
        print(f"ОШИБКА запроса /versions: {err}")
        return
    if not isinstance(versions, list):
        print(f"ОШИБКА: ожидался список в /versions, получено {type(versions).__name__}")
        return

    # 4. Ищем совпадение по name == projectLabel
    matched = next((v for v in versions if v.get("name") == project_label), None)
    if not matched:
        print(f"ОШИБКА: в /versions нет записи с name='{project_label}'")
        print("Доступные name:")
        for v in versions:
            print(f"  - {v.get('name', '?')}")
        return

    stand_version = matched.get("version", "")
    print(f"\nНа стенде:")
    print(f"  name:    {matched.get('name')}")
    print(f"  version: {stand_version}")
    print(f"  folder:  {matched.get('folder', '')}")

    repo_tag_clean = strip_bin(current_tag)
    print(f"\nТэг из репозитория: {current_tag} (без .bin: {repo_tag_clean})")

    # 5. Сравнение
    if stand_version == current_tag or stand_version == repo_tag_clean:
        print(f"\nВерсия на стенде совпадает с тэгом из репозитория. Деплой не требуется.")
        return

    print(f"\nВерсии различаются: стенд={stand_version}, репо={current_tag}")

    # Выбор тэга для деплоя
    custom = input(f"Введите тэг или Enter для '{current_tag}': ").strip()
    deploy_tag = custom if custom else current_tag
    git_tag = strip_bin(deploy_tag)

    print(f"Проверка тэга {git_tag}...")
    exists, err = check_tag_exists(args.gitlab_url, args.token, project_id, git_tag)
    if err:
        print(f"ОШИБКА: {err}")
        return
    if not exists:
        print(f"ОШИБКА: тэг '{git_tag}' не найден в проекте")
        return

    job_name = stand_to_job_name(args.stand)
    print(f"\nДжоба: {job_name}")
    if input("Запустить деплой? (y/n): ").strip().lower() != "y":
        return

    # Pipeline + play
    job_id, err = run_pipeline_and_play(args, project_id, git_tag, job_name)
    if err:
        print(f"ОШИБКА: {err}")
        return

    # Ждём завершения джобы
    print("\nОжидание завершения джобы (до 10 минут)...")
    job_info = wait_for_job_completion(args.gitlab_url, args.token, project_id, job_id)
    if not job_info:
        print("ОШИБКА: таймаут ожидания джобы")
        return

    status = job_info["status"]
    print(f"\nСтатус джобы: {status}")
    print(f"URL: {job_info.get('web_url', '')}")

    if status != "success":
        print("\n" + "=" * 80)
        print("ЛОГ ДЖОБЫ:")
        print("=" * 80)
        print(get_job_trace(args.gitlab_url, args.token, project_id, job_id))
        print("=" * 80)
        print(f"\n!!! Джоба не success (статус: {status}) !!!")
        return

    print("\nДжоба успешна. Ожидание обновления версии на стенде...")

    # 6. Polling /versions до 5 минут
    start = time.time()
    timeout = 300
    new_version = None
    while time.time() - start < timeout:
        time.sleep(10)
        versions, err = http_get_json(versions_url)
        if err:
            print(f"  ошибка /versions: {err}")
            continue
        entry_v = next((v for v in versions if v.get("name") == project_label), None)
        if not entry_v:
            print(f"  запись {project_label} исчезла из /versions")
            continue
        current = entry_v.get("version", "")
        print(f"  текущая версия: {current}")
        if current != stand_version:
            new_version = current
            break

    if new_version is None:
        print(f"\nОШИБКА: версия на стенде не изменилась за 5 минут (осталась {stand_version})")
        return

    print(f"\nУСПЕХ: версия обновлена: {stand_version} -> {new_version}")

    # Проверяем что новая совпадает с задеплоенным
    if new_version != deploy_tag and new_version != git_tag:
        print(f"ВНИМАНИЕ: новая версия ({new_version}) не совпадает с задеплоенной ({deploy_tag})")


def deploy_flow(args, entries):
    entry = menu_select_entry(entries)
    if not entry:
        return
    if entry["display_path"].startswith("main/fronts/"):
        deploy_frontend_flow(args, entry)
    else:
        deploy_regular_flow(args, entry)


def main():
    parser = argparse.ArgumentParser(description="Проверка тэгов и деплой через GitLab")
    parser.add_argument("--input", required=True)
    parser.add_argument("--gitlab-url", required=True)
    parser.add_argument("--token", required=True)
    parser.add_argument("--stand", required=True)
    args = parser.parse_args()
    args.gitlab_url = args.gitlab_url.rstrip("/")

    try:
        entries = parse_input_file(args.input)
    except Exception as e:
        print(f"Ошибка чтения: {e}", file=sys.stderr)
        sys.exit(1)

    if not entries:
        print("Нет валидных записей.")
        sys.exit(0)

    while True:
        print("\n" + "=" * 50)
        print(f"Стенд: {args.stand}  |  Джоба: {stand_to_job_name(args.stand)}")
        print(f"URL стенда: {build_stand_url(args.gitlab_url, args.stand)}")
        print("=" * 50)
        print("  1) Показать найденные тэги")
        print("  2) Деплой тэга на стенд")
        print("  q) Выход")
        choice = input("\nВыбор: ").strip().lower()
        if choice == "1":
            show_entries(entries)
        elif choice == "2":
            deploy_flow(args, entries)
        elif choice == "q":
            break
        else:
            print("Неверный ввод.")


if __name__ == "__main__":
    main()
EOF
chmod +x deploy_tag.py
