#!/bin/bash
# =============================================================
# Helm вАФ Redeploy all releases via kubectl apply
# –°–Њ–≤–Љ–µ—Б—В–Є–Љ —Б MicroK8s
# =============================================================
set -euo pipefail

# --- –Ю–њ—А–µ–і–µ–ї—П–µ–Љ –Ї–Њ–Љ–∞–љ–і—Л –і–ї—П microk8s ---
if command -v microk8s.helm3 &>/dev/null; then
  HELM="microk8s.helm3"
  KUBECTL="microk8s.kubectl"
elif command -v microk8s &>/dev/null; then
  helm() { microk8s helm "$@"; }
  kubectl() { microk8s kubectl "$@"; }
  export -f helm kubectl
  HELM="helm"
  KUBECTL="kubectl"
elif command -v helm &>/dev/null; then
  HELM="helm"
  KUBECTL="kubectl"
else
  echo "ERROR: helm –љ–µ –љ–∞–є–і–µ–љ"
  exit 1
fi

echo "–Ш—Б–њ–Њ–ї—М–Ј—Г–µ–Љ: $HELM / $KUBECTL"
echo ""

# --- –¶–≤–µ—В–∞ ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# --- –†–µ–Ј—Г–ї—М—В–∞—В—Л ---
DEPLOYED=()   # "namespace|release|revision|chart"
ERRORS=()     # "namespace|release|–њ—А–Є—З–Є–љ–∞"

BACKUP_ROOT="./helm-backup-$(date +%Y%m%d-%H%M%S)"
mkdir -p "$BACKUP_ROOT"

# --- –Я–Њ–ї—Г—З–∞–µ–Љ –≤—Б–µ –љ–µ–є–Љ—Б–њ–µ–є—Б—Л ---
NAMESPACES=$($KUBECTL get namespaces -o jsonpath='{.items[*].metadata.name}')

for NS in $NAMESPACES; do
  echo "--- –Ю–±—А–∞–±–∞—В—Л–≤–∞–µ–Љ namespace: $NS ---"

  # –Я–Њ–ї—Г—З–∞–µ–Љ —А–µ–ї–Є–Ј—Л –≤ –љ–µ–є–Љ—Б–њ–µ–є—Б–µ
  RELEASES=$($HELM list -n "$NS" -q 2>/dev/null || true)

  if [[ -z "$RELEASES" ]]; then
    echo -e "  ${YELLOW}–†–µ–ї–Є–Ј–Њ–≤ –љ–µ—В${NC}"
    ERRORS+=("$NS|вАФ|–Э–µ—В helm —А–µ–ї–Є–Ј–Њ–≤")
    continue
  fi

  for RELEASE in $RELEASES; do
    echo -e "  ${GREEN}–†–µ–ї–Є–Ј: $RELEASE${NC}"

    BACKUP_DIR="$BACKUP_ROOT/$NS/$RELEASE"
    mkdir -p "$BACKUP_DIR"

    # --- Info ---
    RELEASE_JSON=$($HELM list -n "$NS" -o json 2>/dev/null | jq '.[] | select(.name=="'"$RELEASE"'")' || true)
    if [[ -z "$RELEASE_JSON" ]]; then
      echo -e "  ${RED}–Э–µ —Г–і–∞–ї–Њ—Б—М –њ–Њ–ї—Г—З–Є—В—М info${NC}"
      ERRORS+=("$NS|$RELEASE|–Э–µ —Г–і–∞–ї–Њ—Б—М –њ–Њ–ї—Г—З–Є—В—М helm list -o json")
      continue
    fi

    CHART_FULL=$(echo "$RELEASE_JSON" | jq -r '.chart')
    REVISION=$(echo "$RELEASE_JSON" | jq -r '.revision')

    # --- Manifest ---
    if ! $HELM get manifest "$RELEASE" -n "$NS" > "$BACKUP_DIR/manifest.yaml" 2>/dev/null; then
      echo -e "  ${RED}–Э–µ —Г–і–∞–ї–Њ—Б—М –њ–Њ–ї—Г—З–Є—В—М manifest${NC}"
      ERRORS+=("$NS|$RELEASE|–Э–µ —Г–і–∞–ї–Њ—Б—М –њ–Њ–ї—Г—З–Є—В—М helm manifest")
      continue
    fi

    # --- Values ---
    $HELM get values "$RELEASE" -n "$NS" > "$BACKUP_DIR/values.yaml" 2>/dev/null || true

    # --- kubectl apply ---
    if $KUBECTL apply -f "$BACKUP_DIR/manifest.yaml" -n "$NS" > "$BACKUP_DIR/apply.log" 2>&1; then
      echo -e "  ${GREEN}OK${NC}"
      DEPLOYED+=("$NS|$RELEASE|$REVISION|$CHART_FULL")
    else
      ERROR_MSG=$(tail -3 "$BACKUP_DIR/apply.log" | tr '\n' ' ')
      echo -e "  ${RED}–Ю–®–Ш–С–Ъ–Р: $ERROR_MSG${NC}"
      ERRORS+=("$NS|$RELEASE|$ERROR_MSG")
    fi

  done
done

# =============================================================
# --- –Ґ–∞–±–ї–Є—Ж–∞ 1: –£—Б–њ–µ—И–љ–Њ –Ј–∞–і–µ–њ–ї–Њ–µ–љ–Њ ---
# =============================================================
echo ""
echo "=========================================="
echo "  –Ч–Р–Ф–Х–Я–Ы–Ю–Х–Э–Ю"
echo "=========================================="
printf "%-30s %-25s %-10s %-30s\n" "NAMESPACE" "RELEASE" "REVISION" "CHART"
printf "%-30s %-25s %-10s %-30s\n" "------------------------------" "-------------------------" "----------" "------------------------------"

if [[ ${#DEPLOYED[@]} -eq 0 ]]; then
  echo "  –Э–µ—В —Г—Б–њ–µ—И–љ—Л—Е –і–µ–њ–ї–Њ–µ–≤"
else
  for ROW in "${DEPLOYED[@]}"; do
    IFS='|' read -r NS REL REV CHART <<< "$ROW"
    printf "%-30s %-25s %-10s %-30s\n" "$NS" "$REL" "$REV" "$CHART"
  done
fi

# =============================================================
# --- –Ґ–∞–±–ї–Є—Ж–∞ 2: –Ю—И–Є–±–Ї–Є ---
# =============================================================
echo ""
echo "=========================================="
echo "  –Ю–®–Ш–С–Ъ–Ш / –Я–†–Ю–Я–£–©–Х–Э–Ю"
echo "=========================================="
printf "%-30s %-25s %-50s\n" "NAMESPACE" "RELEASE" "–Я–†–Ш–І–Ш–Э–Р"
printf "%-30s %-25s %-50s\n" "------------------------------" "-------------------------" "--------------------------------------------------"

if [[ ${#ERRORS[@]} -eq 0 ]]; then
  echo "  –Ю—И–Є–±–Њ–Ї –љ–µ—В"
else
  for ROW in "${ERRORS[@]}"; do
    IFS='|' read -r NS REL REASON <<< "$ROW"
    printf "%-30s %-25s %-50s\n" "$NS" "$REL" "$REASON"
  done
fi

echo ""
echo "–С—Н–Ї–∞–њ—Л –Љ–∞–љ–Є—Д–µ—Б—В–Њ–≤: $BACKUP_ROOT/"