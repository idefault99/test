# имена контейнеров в поде (увидишь оба: nvidia-device-plugin и *-sidecar/config-manager)
kubectl -n gpu-operator get pod nvidia-device-plugin-daemonset-wtk9z \
  -o jsonpath='{range .spec.containers[*]}{.name}{"\n"}{end}'

# лог предыдущего запуска ПАДАЮЩЕГО контейнера (подставь имя из вывода выше)
kubectl -n gpu-operator logs nvidia-device-plugin-daemonset-wtk9z \
  -c <имя-второго-контейнера> --previous --tail=60

# и причина/код завершения по контейнерам
kubectl -n gpu-operator get pod nvidia-device-plugin-daemonset-wtk9z \
  -o jsonpath='{range .status.containerStatuses[*]}{.name}{": "}{.state}{" last="}{.lastState.terminated.reason}{" exit="}{.lastState.terminated.exitCode}{"\n"}{end}'
