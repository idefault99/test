# =====================================================================
# 20. КРАТКИЙ ИТОГ
# =====================================================================

# Чтобы убрать <none> в ROLES:
#
#   kubectl label node coparking-8 node-role.kubernetes.io/worker= --overwrite
#   kubectl label node coparking-9 node-role.kubernetes.io/worker= --overwrite
#   kubectl label node coparking-10 node-role.kubernetes.io/worker= --overwrite
#
# Чтобы kubectl get pods не давал connection refused на worker:
#
#   mkdir -p /root/.kube
#   скопировать /etc/kubernetes/admin.conf с control-plane в /root/.kube/config на worker
#   проверить, что server: https://k8s-api:6443 или https://172.16.175.20:6443
#
# Сам worker при этом мог быть полностью исправен.
# connection refused относился не к kubelet, а к локально не настроенному kubectl.