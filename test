kubectl delete pod test-dns

kubectl run test-dns \
  --image=registry.test.model.svo.aero/dpm/iac/infra/alpine-netutils:1.0.0 \
  --restart=Never \
  --overrides='{"spec":{"imagePullSecrets":[{"name":"registry-credentials"}]}}' \
  -- sleep 300
---
crictl pull --creds "$(grep registry_user group_vars/all.yml | awk '{print $2}' | tr -d '"'):$(grep registry_password group_vars/all.yml | awk '{print $2}' | tr -d '"')" \
  registry.test.model.svo.aero/dpm/iac/infra/alpine-netutils:1.0.0
