#!/usr/bin/env python3
"""
Скрипт для сравнения тэгов из values.yaml (вывод первого скрипта) с тэгами в Kubernetes.

Использование:
    python3 compare_tags.py --input output.txt --stand test-dfgr --kubectl-cmd k

На вход: файл с выводом scan_values.py
На выход: файл compare_result.txt в текущей директории
"""

import argparse
import subprocess
import re
import sys
from collections import defaultdict


def run_cmd(cmd: str) -> tuple[str, str, int]:
    """Выполняет shell-команду, возвращает (stdout, stderr, returncode)."""
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=60)
    return result.stdout, result.stderr, result.returncode


def get_namespaces(kubectl: str, stand: str) -> list[str]:
    """Получает список неймспейсов, начинающихся с stand-."""
    stdout, stderr, rc = run_cmd(f"{kubectl} get ns -o name")
    if rc != 0:
        return []
    namespaces = []
    for line in stdout.strip().splitlines():
        # формат: namespace/test-dfgr-approvals
        ns = line.strip().removeprefix("namespace/")
        if ns.startswith(f"{stand}-") or ns == stand:
            namespaces.append(ns)
    return namespaces


def get_images_from_ns(kubectl: str, ns: str) -> list[tuple[str, str]]:
    """Делает describe всех deployments и jobs в ns, извлекает image path и tag.
    Возвращает список (image_path, tag) — path без registry."""
    images = []

    for resource in ["deployments", "jobs"]:
        stdout, stderr, rc = run_cmd(
            f"{kubectl} -n {ns} describe {resource} 2>/dev/null | grep -i 'image:'"
        )
        if rc != 0 or not stdout.strip():
            continue
        for line in stdout.strip().splitlines():
            line = line.strip()
            # формат: Image: registry.test/path/to/app:tag
            match = re.search(r'[Ii]mage:\s*[^/\s]+(/\S+):(\S+)', line)
            if match:
                images.append((match.group(1), match.group(2)))
    return images


def parse_input_file(filepath: str) -> list[dict]:
    """Парсит вывод первого скрипта.
    Возвращает список записей с ключами: display_path, sub_name, image_path, tag, tpl_tag, is_error."""
    entries = []
    current_display = ""

    with open(filepath, "r", encoding="utf-8") as f:
        for line in f:
            line = line.rstrip("\n")
            if not line.strip():
                continue

            # Определяем display_path — если строка начинается с пробелов, берём предыдущий
            if line[0] != " ":
                # Новый display_path
                parts = line.split("  —  ", 1)
                left = parts[0] if parts else line
                # left может содержать display_path + (sub_name)
                left_stripped = left.rstrip()
            else:
                left_stripped = line.split("  —  ", 1)[0].rstrip() if "  —  " in line else ""

            entry = {
                "raw": line,
                "display_path": "",
                "sub_name": "",
                "image_path": "",
                "tag": "",
                "tpl_tag": "",
                "is_error": False,
            }

            # Разбиваем по "  —  "
            segments = line.split("  —  ")

            # Первый сегмент — display_path + возможно (sub_name)
            first = segments[0]
            if first.strip():
                # Проверяем есть ли (sub_name)
                sub_match = re.search(r'\((\S+)\)\s*$', first.strip())
                if sub_match:
                    entry["sub_name"] = sub_match.group(1)
                    path_part = first[:first.rfind("(")].strip()
                    if path_part:
                        current_display = path_part
                else:
                    current_display = first.strip()
            else:
                # Строка с пробелами — продолжение предыдущего display_path
                sub_match = re.search(r'\((\S+)\)', first)
                if sub_match:
                    entry["sub_name"] = sub_match.group(1)

            entry["display_path"] = current_display

            # Проверяем ошибки
            if len(segments) >= 2:
                second = segments[1].strip()
                if "не найден" in second or "не найден" in line:
                    entry["is_error"] = True
                    entry["image_path"] = second
                else:
                    entry["image_path"] = second

            if len(segments) >= 3:
                third = segments[2].strip()
                # Может содержать tag + [tpl_tag]
                tpl_match = re.search(r'\[(.*?)\]', third)
                if tpl_match:
                    entry["tpl_tag"] = f"[{tpl_match.group(1)}]"
                    tag_part = third[:third.rfind("[")].strip()
                    entry["tag"] = tag_part
                else:
                    entry["tag"] = third

            entries.append(entry)

    return entries


def extract_module(display_path: str) -> str:
    """Извлекает имя модуля из display_path.
    module/app -> module
    module (без app) -> module"""
    parts = display_path.split("/")
    if parts[0] == "main":
        return ""  # fronts — не обрабатываем
    return parts[0]


def main():
    parser = argparse.ArgumentParser(description="Сравнение тэгов values.yaml с Kubernetes")
    parser.add_argument("--input", required=True, help="Файл с выводом scan_values.py")
    parser.add_argument("--stand", required=True, help="Название стенда (префикс неймспейса)")
    parser.add_argument("--kubectl-cmd", default="k", help="Команда kubectl (по умолчанию: k)")
    parser.add_argument("--output", default="compare_result.txt", help="Файл для вывода (по умолчанию: compare_result.txt)")
    args = parser.parse_args()

    errors = []

    # Парсим входной файл
    try:
        entries = parse_input_file(args.input)
    except Exception as e:
        print(f"Ошибка чтения входного файла: {e}", file=sys.stderr)
        sys.exit(1)

    if not entries:
        print("Входной файл пуст.")
        sys.exit(0)

    # Получаем неймспейсы
    namespaces = get_namespaces(args.kubectl_cmd, args.stand)
    if not namespaces:
        errors.append(f"Не удалось получить неймспейсы с префиксом '{args.stand}'")

    # Собираем уникальные модули из entries
    modules = set()
    for e in entries:
        m = extract_module(e["display_path"])
        if m:
            modules.add(m)

    # Маппинг module -> namespace
    module_to_ns = {}
    for m in modules:
        expected_ns = f"{args.stand}-{m}"
        if expected_ns in namespaces:
            module_to_ns[m] = expected_ns
        elif m == args.stand.split("-")[-1]:
            # Крайний случай: модуль совпадает с частью стенда
            if args.stand in namespaces:
                module_to_ns[m] = args.stand

    # Кэш: namespace -> список (image_path, tag) из k8s
    ns_images_cache: dict[str, list[tuple[str, str]]] = {}

    def get_ns_images(ns: str) -> list[tuple[str, str]]:
        if ns not in ns_images_cache:
            try:
                ns_images_cache[ns] = get_images_from_ns(args.kubectl_cmd, ns)
            except Exception as e:
                errors.append(f"Ошибка получения образов из ns '{ns}': {e}")
                ns_images_cache[ns] = []
        return ns_images_cache[ns]

    # Обрабатываем каждую запись
    results = []  # (entry, k8s_status)

    for entry in entries:
        module = extract_module(entry["display_path"])

        # Пропускаем main/fronts и ошибки
        if not module or entry["is_error"]:
            results.append((entry, ""))
            continue

        ns = module_to_ns.get(module)
        if not ns:
            results.append((entry, "ns не найден"))
            if f"Неймспейс для модуля '{module}' не найден среди {args.stand}-*" not in [e for e in errors]:
                errors.append(f"Неймспейс для модуля '{module}' не найден среди {args.stand}-*")
            continue

        k8s_images = get_ns_images(ns)
        image_path = entry["image_path"].strip()
        tag = entry["tag"].strip()

        if not image_path or not tag:
            results.append((entry, ""))
            continue

        # Ищем совпадение по image path
        found = False
        for k8s_path, k8s_tag in k8s_images:
            if k8s_path == image_path:
                found = True
                if k8s_tag == tag:
                    results.append((entry, ""))  # Совпадает — ничего не пишем
                else:
                    results.append((entry, f"k8s: {k8s_tag}"))
                break

        if not found:
            results.append((entry, "не найден в k8s"))

    # Формируем вывод
    # Вычисляем ширину новой колонки
    k8s_col = max((len(r[1]) for r in results if r[1]), default=0)

    output_lines = []
    for entry, k8s_status in results:
        line = entry["raw"]
        if k8s_status:
            # Выравниваем все строки по длине для новой колонки
            padding = max(0, 100 - len(line))
            line = f"{line}{' ' * padding}  —  {k8s_status}"
        output_lines.append(line)

    # Записываем в файл
    try:
        with open(args.output, "w", encoding="utf-8") as f:
            for line in output_lines:
                f.write(line + "\n")

            # Ошибки в конце
            if errors:
                f.write("\n" + "=" * 80 + "\n")
                f.write("ОШИБКИ:\n")
                f.write("=" * 80 + "\n")
                for err in errors:
                    f.write(f"  • {err}\n")

        print(f"Результат записан в {args.output}")
        if errors:
            print(f"\nОШИБКИ ({len(errors)}):")
            for err in errors:
                print(f"  • {err}")
    except Exception as e:
        print(f"Ошибка записи в файл: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()


