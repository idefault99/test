1.1. Скрипт подготовки дисков
bash
Копировать
#!/bin/bash
# prepare_storage.sh - Подготовка дисков для Longhorn

set -e

echo "=== Подготовка дисков для Longhorn ==="

# Определяем большой диск (18TB)
DISK=$(lsblk -nd -o NAME,SIZE | grep "18.2T" | awk '{print $1}')

if [ -z "$DISK" ]; then
    echo "Ошибка: диск 18TB не найден!"
    exit 1
fi

echo "Найден диск: /dev/$DISK"

# Создаем раздел для Longhorn
echo "Создаем раздел на /dev/$DISK..."
parted /dev/$DISK --script mklabel gpt
parted /dev/$DISK --script mkpart primary ext4 0% 100%

# Получаем имя раздела
PARTITION="${DISK}1"

# Форматируем раздел
echo "Форматируем /dev/$PARTITION в ext4..."
mkfs.ext4 -F /dev/$PARTITION

# Создаем точку монтирования
mkdir -p /var/lib/longhorn

# Получаем UUID раздела
UUID=$(blkid -s UUID -o value /dev/$PARTITION)

# Добавляем в fstab
echo "UUID=$UUID /var/lib/longhorn ext4 defaults,noatime 0 2" >> /etc/fstab

# Монтируем
mount /var/lib/longhorn

echo "=== Диск успешно подготовлен ==="
df -h /var/lib/longhorn
