# deploy_tag.py

Скрипт для проверки тэгов и запуска деплоя через GitLab pipeline.

## Установка

```bash
cat << 'EOF' > deploy_tag.py
#!/usr/bin/env python3
"""
Скрипт для проверки тэгов в GitLab-репозиториях и запуска деплоя.

Использование:
    python3 deploy_tag.py --input scan_output.txt --gitlab-url https://gitlab-inte.test.ru --token GITLAB_TOKEN --stand schedule-dev
"""

import argparse
import json
import re
import sys
import time
from urllib.parse import quote as url_quote
from urllib.request import Request, urlopen
from urllib.error import HTTPError


def gitlab_api(base_url, token, endpoint, method="GET", data=None):
    """Запрос к GitLab API."""
    url = f"{base_url}/api/v4{endpoint}"
    headers = {"PRIVATE-TOKEN": token}
    body = None
    if data is not None:
        body = json.dumps(data).encode()
        headers["Content-Type"] = "application/json"
    req = Request(url, headers=headers, method=method, data=body)
    try:
        with urlopen(req) as resp:
            content = resp.read().decode()
            if not content:
                return None
            return json.loads(content)
    except HTTPError as e:
        err_body = ""
        try:
            err_body = e.read().decode()
        except Exception:
            pass
        raise Exception(f"HTTP {e.code}: {err_body or e.reason}")


def gitlab_api_raw(base_url, token, endpoint):
    """GET запрос, возвращает сырой текст (для trace)."""
    url = f"{base_url}/api/v4{endpoint}"
    req = Request(url, headers={"PRIVATE-TOKEN": token})
    try:
        with urlopen(req) as resp:
            return resp.read().decode(errors="replace")
    except HTTPError as e:
        return f"[HTTP {e.code}] {e.reason}"


def find_project_id(base_url, token, project_path):
    """Находит ID проекта по пути (например test/sys/tr/db/rtg/db)."""
    path = project_path.strip("/")
    encoded = url_quote(path, safe="")
    try:
        result = gitlab_api(base_url, token, f"/projects/{encoded}")
        return result["id"], None
    except Exception as e:
        return None, str(e)


def check_tag_exists(base_url, token, project_id, tag):
    """Проверяет существование тэга в проекте."""
    encoded_tag = url_quote(tag, safe="")
    try:
        gitlab_api(base_url, token, f"/projects/{project_id}/repository/tags/{encoded_tag}")
        return True, None
    except Exception as e:
        if "404" in str(e):
            return False, None
        return False, str(e)


def create_pipeline(base_url, token, project_id, ref):
    """Создаёт новый pipeline на указанном ref."""
    return gitlab_api(
        base_url, token,
        f"/projects/{project_id}/pipeline",
        method="POST",
        data={"ref": ref}
    )


def get_pipeline_jobs(base_url, token, project_id, pipeline_id):
    """Получает список джоб pipeline-а."""
    return gitlab_api(
        base_url, token,
        f"/projects/{project_id}/pipelines/{pipeline_id}/jobs?per_page=100"
    )


def play_job(base_url, token, project_id, job_id):
    """Запускает manual job."""
    return gitlab_api(
        base_url, token,
        f"/projects/{project_id}/jobs/{job_id}/play",
        method="POST"
    )


def get_job(base_url, token, project_id, job_id):
    """Получает состояние джобы."""
    return gitlab_api(base_url, token, f"/projects/{project_id}/jobs/{job_id}")


def get_job_trace(base_url, token, project_id, job_id):
    """Получает лог джобы."""
    return gitlab_api_raw(base_url, token, f"/projects/{project_id}/jobs/{job_id}/trace")


def parse_input_file(filepath):
    """Парсит вывод scan_values.py."""
    entries = []
    current_display = ""

    with open(filepath, "r", encoding="utf-8") as f:
        for line in f:
            line = line.rstrip("\n")
            if not line.strip():
                continue
            if "не найден" in line:
                continue

            entry = {
                "display_path": "",
                "sub_name": "",
                "image_path": "",
                "tag": "",
            }

            segments = line.split("  —  ")
            first = segments[0]

            if first.strip():
                sub_match = re.search(r'\((\S+)\)\s*$', first.strip())
                if sub_match:
                    entry["sub_name"] = sub_match.group(1)
                    path_part = first[:first.rfind("(")].strip()
                    if path_part:
                        current_display = path_part
                else:
                    current_display = first.strip()
            else:
                sub_match = re.search(r'\((\S+)\)', first)
                if sub_match:
                    entry["sub_name"] = sub_match.group(1)

            entry["display_path"] = current_display

            if len(segments) >= 2:
                entry["image_path"] = segments[1].strip()
            if len(segments) >= 3:
                third = segments[2].strip()
                third = re.sub(r'\s*\[.*?\]\s*$', '', third)
                entry["tag"] = third.strip()

            if entry["image_path"] and entry["tag"]:
                entries.append(entry)

    return entries


def strip_bin(tag):
    """Обрезает суффикс .bin если есть."""
    if tag.endswith(".bin"):
        return tag[:-4]
    return tag


def stand_to_job_name(stand):
    """schedule-dev -> aos_schedule_dev"""
    return f"aos_{stand.replace('-', '_')}"


def show_entries(entries):
    """Выводит пронумерованный список app-ов."""
    print("\nНайденные app и тэги:")
    print("-" * 80)
    for i, e in enumerate(entries, 1):
        label = f" ({e['sub_name']})" if e["sub_name"] else ""
        print(f"  {i:3}. {e['display_path']}{label}")
        print(f"       {e['image_path']} : {e['tag']}")
    print("-" * 80)


def menu_select_entry(entries):
    """Позволяет выбрать app из списка."""
    show_entries(entries)
    while True:
        choice = input(f"\nВыберите app (1-{len(entries)}) или q для отмены: ").strip()
        if choice.lower() == "q":
            return None
        try:
            idx = int(choice)
            if 1 <= idx <= len(entries):
                return entries[idx - 1]
        except ValueError:
            pass
        print("Неверный ввод, попробуйте ещё раз.")


def deploy_flow(args, entries):
    """Процесс деплоя одного app."""
    entry = menu_select_entry(entries)
    if not entry:
        return

    project_path = entry["image_path"].lstrip("/")
    print(f"\nВыбран: {entry['display_path']}")
    print(f"Путь проекта: /{project_path}")
    print(f"Тэг из репозитория: {entry['tag']}")

    custom = input(f"\nВведите тэг для деплоя или Enter чтобы использовать '{entry['tag']}': ").strip()
    raw_tag = custom if custom else entry["tag"]
    git_tag = strip_bin(raw_tag)
    print(f"\nБудет использован git tag: {git_tag}")

    # Находим проект
    print(f"\nПоиск проекта {project_path}...")
    project_id, err = find_project_id(args.gitlab_url, args.token, project_path)
    if err:
        print(f"ОШИБКА: не удалось найти проект: {err}")
        return
    print(f"Project ID: {project_id}")

    # Проверяем тэг
    print(f"Проверка тэга {git_tag}...")
    exists, err = check_tag_exists(args.gitlab_url, args.token, project_id, git_tag)
    if err:
        print(f"ОШИБКА проверки тэга: {err}")
        return
    if not exists:
        print(f"ОШИБКА: тэг '{git_tag}' не найден в проекте {project_path}")
        return
    print("Тэг существует.")

    # Подтверждение
    job_name = stand_to_job_name(args.stand)
    print(f"\nБудет создан pipeline на тэге {git_tag} и запущена джоба {job_name}")
    confirm = input("Продолжить? (y/n): ").strip().lower()
    if confirm != "y":
        print("Отмена.")
        return

    # Создаём pipeline
    print(f"\nСоздание pipeline...")
    try:
        pipeline = create_pipeline(args.gitlab_url, args.token, project_id, git_tag)
    except Exception as e:
        print(f"ОШИБКА создания pipeline: {e}")
        return
    pipeline_id = pipeline["id"]
    print(f"Pipeline создан: #{pipeline_id} — {pipeline.get('web_url', '')}")

    # Ждём появления джобы
    print(f"\nОжидание появления джобы {job_name}...")
    target_job = None
    for attempt in range(15):
        time.sleep(2)
        try:
            jobs = get_pipeline_jobs(args.gitlab_url, args.token, project_id, pipeline_id)
        except Exception as e:
            print(f"ОШИБКА получения списка джоб: {e}")
            return
        for j in jobs:
            if j["name"] == job_name:
                target_job = j
                break
        if target_job:
            break
        print(f"  попытка {attempt + 1}/15...")

    if not target_job:
        print(f"ОШИБКА: джоба {job_name} не найдена в pipeline #{pipeline_id}")
        print("Доступные джобы:")
        try:
            jobs = get_pipeline_jobs(args.gitlab_url, args.token, project_id, pipeline_id)
            for j in jobs:
                print(f"  - {j['name']} ({j['status']})")
        except Exception:
            pass
        return

    job_id = target_job["id"]
    print(f"Джоба найдена: #{job_id}, статус: {target_job['status']}")

    # Запускаем manual джобу
    if target_job["status"] == "manual":
        print(f"Запуск джобы...")
        try:
            play_job(args.gitlab_url, args.token, project_id, job_id)
        except Exception as e:
            print(f"ОШИБКА запуска джобы: {e}")
            return
        print("Джоба запущена.")
    else:
        print(f"Джоба уже в статусе {target_job['status']}, пропускаем play.")

    # Ждём 10 секунд и забираем лог
    print("\nОжидание 10 секунд...")
    time.sleep(10)

    try:
        job_info = get_job(args.gitlab_url, args.token, project_id, job_id)
    except Exception as e:
        print(f"ОШИБКА получения статуса: {e}")
        return

    status = job_info["status"]
    print(f"\nСтатус джобы: {status}")
    print(f"URL: {job_info.get('web_url', '')}")

    print("\n" + "=" * 80)
    print("ЛОГ ДЖОБЫ:")
    print("=" * 80)
    trace = get_job_trace(args.gitlab_url, args.token, project_id, job_id)
    print(trace)
    print("=" * 80)

    if status == "failed":
        print("\n!!! Джоба завершилась с ошибкой !!!")
    elif status in ("running", "pending"):
        print(f"\nДжоба ещё выполняется. Смотрите в GitLab: {job_info.get('web_url', '')}")
    elif status == "success":
        print("\nДжоба завершилась успешно.")


def main():
    parser = argparse.ArgumentParser(description="Проверка тэгов и деплой через GitLab")
    parser.add_argument("--input", required=True, help="Файл с выводом scan_values.py")
    parser.add_argument("--gitlab-url", required=True, help="URL GitLab (например https://gitlab-inte.test.ru)")
    parser.add_argument("--token", required=True, help="GitLab Private Token")
    parser.add_argument("--stand", required=True, help="Название стенда (например schedule-dev)")
    args = parser.parse_args()

    args.gitlab_url = args.gitlab_url.rstrip("/")

    try:
        entries = parse_input_file(args.input)
    except Exception as e:
        print(f"Ошибка чтения входного файла: {e}", file=sys.stderr)
        sys.exit(1)

    if not entries:
        print("Нет валидных записей во входном файле.")
        sys.exit(0)

    while True:
        print("\n" + "=" * 50)
        print(f"Стенд: {args.stand}  |  Джоба: {stand_to_job_name(args.stand)}")
        print("=" * 50)
        print("  1) Показать найденные тэги")
        print("  2) Деплой тэга на стенд")
        print("  q) Выход")
        choice = input("\nВыбор: ").strip().lower()

        if choice == "1":
            show_entries(entries)
        elif choice == "2":
            deploy_flow(args, entries)
        elif choice == "q":
            break
        else:
            print("Неверный ввод.")


if __name__ == "__main__":
    main()
EOF
chmod +x deploy_tag.py
```

## Использование

```bash
python3 deploy_tag.py \
    --input scan_output.txt \
    --gitlab-url https://gitlab-inte.test.ru \
    --token glpat-xxx \
    --stand schedule-dev
```

|Параметр      |Описание                                                         |
|--------------|-----------------------------------------------------------------|
|`--input`     |Файл с выводом `scan_values.py`                                  |
|`--gitlab-url`|URL GitLab с репозиториями app (передаётся переменной)           |
|`--token`     |GitLab Private Token                                             |
|`--stand`     |Название стенда (напр. `schedule-dev` → джоба `aos_schedule_dev`)|

## Логика

**Меню:**

1. Показать найденные тэги — выводит пронумерованный список из входного файла
1. Деплой тэга на стенд — интерактивный выбор app и тэга
1. Выход

**Процесс деплоя:**

1. Выбор app из пронумерованного списка
1. Ввод тэга (или Enter — берётся из репозитория)
1. Обрезка суффикса `.bin` → git tag
1. Поиск проекта в GitLab по пути из `image_path`
1. Проверка существования тэга — если нет, выход с ошибкой
1. Подтверждение у пользователя
1. Создание pipeline через `POST /projects/:id/pipeline` с `ref=<tag>`
1. Ожидание появления джобы `aos_<stand>` в pipeline (до 30 сек)
1. Запуск manual-джобы через `POST /jobs/:id/play`
1. Пауза 10 секунд
1. Один раз забирается статус и полный лог через `/jobs/:id/trace`
1. Если статус `failed` — выводится предупреждение