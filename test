#!/bin/bash
set -e

# ==============================================================================
# Установка MinIO Client (mc) с разрешением конфликта
# ==============================================================================

OS=$(uname -s | tr '[:upper:]' '[:lower:]')
ARCH=$(uname -m)

case "$ARCH" in
    x86_64)  ARCH="amd64" ;;
    aarch64) ARCH="arm64" ;;
    arm64)   ARCH="arm64" ;;
    *) echo "Неподдерживаемая архитектура: $ARCH"; exit 1 ;;
esac

case "$OS" in
    linux)  URL="https://dl.min.io/client/mc/release/linux-${ARCH}/mc" ;;
    darwin) URL="https://dl.min.io/client/mc/release/darwin-${ARCH}/mc" ;;
    *) echo "Неподдерживаемая ОС: $OS"; exit 1 ;;
esac

# ==============================================================================
# Найти все mc в PATH и проверить — наш это или чужой
# ==============================================================================

echo "=== Поиск существующих 'mc' в системе ==="

FOUND_PATHS=$(which -a mc 2>/dev/null || true)

if [ -z "$FOUND_PATHS" ]; then
    echo "mc не найден в PATH — чисто, просто ставим."
else
    echo "Найдено:"
    while IFS= read -r MC_PATH; do
        echo -n "  $MC_PATH → "
        VERSION_OUT=$("$MC_PATH" --version 2>&1 || true)
        if echo "$VERSION_OUT" | grep -qi "minio"; then
            echo "это MinIO mc (оставляем)"
        else
            echo "НЕ MinIO (удаляем)"
            sudo rm -f "$MC_PATH"
            echo "  Удалён: $MC_PATH"
        fi
    done <<< "$FOUND_PATHS"
fi

# ==============================================================================
# Скачать и установить MinIO mc
# ==============================================================================

echo ""
echo "=== Установка MinIO mc ==="
echo "Скачиваю с $URL ..."

curl -sSL "$URL" -o /tmp/minio-mc
chmod +x /tmp/minio-mc

# Проверить что скачали именно MinIO mc
VERSION_CHECK=$(/tmp/minio-mc --version 2>&1 || true)
if ! echo "$VERSION_CHECK" | grep -qi "minio"; then
    echo "Ошибка: скачанный бинарник не похож на MinIO mc"
    echo "Вывод: $VERSION_CHECK"
    exit 1
fi

# Установить
if [ -w /usr/local/bin ]; then
    mv /tmp/minio-mc /usr/local/bin/mc
    INSTALL_PATH="/usr/local/bin/mc"
else
    sudo mv /tmp/minio-mc /usr/local/bin/mc
    INSTALL_PATH="/usr/local/bin/mc"
fi

echo "Установлен: $INSTALL_PATH"
mc --version

# ==============================================================================
# Добавить алиас mcli → mc в shell rc файлы
# ==============================================================================

echo ""
echo "=== Добавление алиаса 'mcli' → mc ==="

ALIAS_LINE="alias mcli='mc'"

for RC in "$HOME/.bashrc" "$HOME/.zshrc"; do
    if [ -f "$RC" ]; then
        if grep -q "alias mcli=" "$RC"; then
            echo "  $RC — алиас уже есть, пропускаем"
        else
            echo "$ALIAS_LINE" >> "$RC"
            echo "  $RC — алиас добавлен"
        fi
    fi
done

# ==============================================================================
# Итог
# ==============================================================================

echo ""
echo "=== Готово ==="
echo ""
echo "Чтобы применить алиас в текущей сессии:"
echo "  source ~/.bashrc   # или source ~/.zshrc"
echo ""
echo "Добавить подключение к MinIO:"
echo "  mc alias set myminio http://localhost:9000 your-access-key your-secret-key"
echo ""
echo "Проверка:"
echo "  mc ls myminio"
