kubectl get clusterpolicy -o jsonpath='{.items[0].spec.devicePlugin.config}{"\n"}'
---
kubectl get nodes -L nvidia.com/device-plugin.config coparking-5 coparking-6 coparking-7 coparking-8
---
kubectl -n gpu-operator get cm | grep -Ei 'plugin|slic|device'
# и содержимое подозрительных:
kubectl -n gpu-operator get cm <имя> -o jsonpath='{.data}{"\n"}'
---
POD=$(kubectl -n gpu-operator get pod -l app=nvidia-device-plugin-daemonset \
  --field-selector spec.nodeName=coparking-7 -o jsonpath='{.items[0].metadata.name}')
kubectl -n gpu-operator exec "$POD" -c nvidia-device-plugin -- \
  sh -c 'cat "$CONFIG_FILE" 2>/dev/null || cat /available-configs/* 2>/dev/null'
