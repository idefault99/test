#!/bin/bash
# ============================================================
# Восстановление dump.rdb в Redis Pod через PVC
# Использование: bash redis_restore.sh <namespace> <path/to/dump.rdb>
# Пример:        bash redis_restore.sh dev-devops ./dump.rdb
# ============================================================

NS="${1}"
DUMP_FILE="${2}"
REDIS_POD="redis-deployment-0"
REDIS_DATA_DIR="/data"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ok()   { echo -e "${GREEN}  ✓ $1${NC}"; }
fail() { echo -e "${RED}  ✗ $1${NC}"; exit 1; }
info() { echo -e "${YELLOW}  → $1${NC}"; }

# ============================================================
# Проверка аргументов
# ============================================================
if [ -z "$NS" ] || [ -z "$DUMP_FILE" ]; then
  echo "Использование: $0 <namespace> <path/to/dump.rdb>"
  exit 1
fi

if [ ! -f "$DUMP_FILE" ]; then
  fail "Файл не найден: $DUMP_FILE"
fi

echo ""
echo "============================================"
echo "  ВОССТАНОВЛЕНИЕ REDIS RDB"
echo "  Namespace : $NS"
echo "  Файл      : $DUMP_FILE ($(du -h "$DUMP_FILE" | cut -f1))"
echo "  Pod       : $REDIS_POD"
echo "============================================"
echo ""

# ============================================================
# Шаг 1. Проверяем что под жив
# ============================================================
info "Проверяем под $REDIS_POD..."
POD_STATUS=$(kubectl get pod $REDIS_POD -n $NS --no-headers 2>/dev/null | awk '{print $3}')
if [ "$POD_STATUS" != "Running" ]; then
  fail "Под $REDIS_POD не Running (статус: $POD_STATUS)"
fi
ok "Под Running"

# ============================================================
# Шаг 2. Проверяем текущее состояние
# ============================================================
info "Текущее количество ключей в Redis..."
KEYS_BEFORE=$(kubectl exec -n $NS $REDIS_POD -- redis-cli dbsize 2>/dev/null)
ok "Ключей сейчас: $KEYS_BEFORE"

# ============================================================
# Шаг 3. Останавливаем запись в Redis (BGSAVE может конкурировать)
# ============================================================
info "Отключаем автосохранение на время восстановления..."
kubectl exec -n $NS $REDIS_POD -- redis-cli config set save "" > /dev/null 2>&1
ok "Автосохранение отключено"

# ============================================================
# Шаг 4. Делаем бэкап текущего dump.rdb на случай отката
# ============================================================
info "Бэкапим текущий dump.rdb внутри пода..."
kubectl exec -n $NS $REDIS_POD -- sh -c \
  "[ -f $REDIS_DATA_DIR/dump.rdb ] && cp $REDIS_DATA_DIR/dump.rdb $REDIS_DATA_DIR/dump.rdb.bak || echo 'нет текущего дампа'" \
  2>/dev/null
ok "Текущий дамп сохранён как dump.rdb.bak"

# ============================================================
# Шаг 5. Копируем новый dump.rdb в под
# ============================================================
info "Копируем $DUMP_FILE → $REDIS_POD:$REDIS_DATA_DIR/dump.rdb..."
kubectl cp "$DUMP_FILE" "$NS/$REDIS_POD:$REDIS_DATA_DIR/dump.rdb"
if [ $? -ne 0 ]; then
  fail "kubectl cp завершился с ошибкой"
fi
ok "Файл скопирован"

# ============================================================
# Шаг 6. Перезапускаем под — Redis при старте читает dump.rdb с диска
# ============================================================
info "Перезапускаем под для загрузки дампа..."
kubectl delete pod $REDIS_POD -n $NS
if [ $? -ne 0 ]; then
  fail "Не удалось удалить под"
fi

info "Ждём восстановления пода (до 60 сек)..."
kubectl wait --for=condition=Ready pod/$REDIS_POD -n $NS --timeout=60s
if [ $? -ne 0 ]; then
  fail "Под не поднялся за 60 секунд"
fi
ok "Под снова Running"

# ============================================================
# Шаг 7. Проверяем что данные загрузились
# ============================================================
info "Проверяем количество ключей после восстановления..."
sleep 2  # даём Redis секунду загрузить данные в память
KEYS_AFTER=$(kubectl exec -n $NS $REDIS_POD -- redis-cli dbsize 2>/dev/null)
ok "Ключей после восстановления: $KEYS_AFTER"

# ============================================================
# Шаг 8. Включаем автосохранение обратно
# ============================================================
info "Включаем автосохранение обратно..."
kubectl exec -n $NS $REDIS_POD -- redis-cli config set save "3600 1 300 100 60 10000" > /dev/null 2>&1
ok "Автосохранение включено"

# ============================================================
# Итог
# ============================================================
echo ""
echo "============================================"
if [ "$KEYS_AFTER" -gt 0 ] 2>/dev/null || [ "$KEYS_AFTER" != "$KEYS_BEFORE" ] 2>/dev/null; then
  ok "ВОССТАНОВЛЕНИЕ ЗАВЕРШЕНО"
  echo -e "  Ключей до   : ${YELLOW}$KEYS_BEFORE${NC}"
  echo -e "  Ключей после: ${GREEN}$KEYS_AFTER${NC}"
else
  echo -e "${YELLOW}  ⚠ Ключей после восстановления: $KEYS_AFTER — проверь дамп вручную${NC}"
fi
echo "============================================"
echo ""
echo "  Если что-то пошло не так — откат:"
echo "  kubectl exec -n $NS $REDIS_POD -- sh -c \\"
echo "    'cp $REDIS_DATA_DIR/dump.rdb.bak $REDIS_DATA_DIR/dump.rdb'"
echo "  kubectl delete pod $REDIS_POD -n $NS"
echo ""
