# 1. Добавить longhorn_version (если нет)
grep -q 'longhorn_version' group_vars/all.yml || \
  sed -i '/^calico_version/a longhorn_version:        "1.10.2"' group_vars/all.yml

# 2. Добавить registry_user/password/insecure (если нет)
grep -q 'registry_user' group_vars/all.yml || \
  sed -i '/^local_registry/a registry_user:           "YOUR_REGISTRY_USER"\nregistry_password:       "YOUR_REGISTRY_PASSWORD"\nregistry_insecure:       true' group_vars/all.yml
---
cat > playbooks/02-registry.yml << 'EOF'
---
# Фаза 2-registry: Настройка доступа к локальному registry
#
# Что делает:
#   1. containerd — добавляет TLS skip-verify + credentials для local_registry
#   2. Перезапускает containerd, проверяет pull
#   3. Kubernetes — создаёт imagePullSecret во всех нужных namespaces
#   4. Патчит ServiceAccount default в каждом namespace чтобы секрет подхватывался автоматически
#
# Запуск: ansible-playbook playbooks/02-registry.yml -K

# ─── Play 1: containerd на всех нодах ─────────────────────────────────────────
- name: "1/2 · containerd — доступ к {{ local_registry }}"
  hosts: all_nodes
  become: true
  gather_facts: false
  tasks:

    - name: Создать директорию certs.d для registry
      file:
        path: "/etc/containerd/certs.d/{{ local_registry }}"
        state: directory
        mode: "0755"

    - name: Создать hosts.toml (TLS skip-verify)
      copy:
        dest: "/etc/containerd/certs.d/{{ local_registry }}/hosts.toml"
        mode: "0644"
        content: |
          server = "https://{{ local_registry }}"

          [host."https://{{ local_registry }}"]
            capabilities = ["pull", "resolve", "push"]
            skip_verify = {{ registry_insecure | lower }}
      notify: restart containerd

    - name: Проверить наличие секции [plugins.cri.registry] в config.toml
      command: grep -c 'io.containerd.grpc.v1.cri.*registry' /etc/containerd/config.toml
      register: r_has_registry
      changed_when: false
      failed_when: false

    - name: Добавить config_path в containerd config.toml (если ещё нет)
      blockinfile:
        path: /etc/containerd/config.toml
        marker: "# {mark} ANSIBLE MANAGED — registry config_path"
        insertafter: '\[plugins\."io\.containerd\.grpc\.v1\.cri"\]'
        block: |
            [plugins."io.containerd.grpc.v1.cri".registry]
              config_path = "/etc/containerd/certs.d"
      notify: restart containerd

    - name: Добавить credentials в containerd config.toml
      blockinfile:
        path: /etc/containerd/config.toml
        marker: "# {mark} ANSIBLE MANAGED — registry auth"
        insertafter: '# END ANSIBLE MANAGED — registry config_path'
        block: |
            [plugins."io.containerd.grpc.v1.cri".registry.configs."{{ local_registry }}".auth]
              username = "{{ registry_user }}"
              password = "{{ registry_password }}"
            [plugins."io.containerd.grpc.v1.cri".registry.configs."{{ local_registry }}".tls]
              insecure_skip_verify = {{ registry_insecure | lower }}
      notify: restart containerd

  handlers:
    - name: restart containerd
      systemd:
        name: containerd
        state: restarted
        daemon_reload: true

    - name: wait containerd socket
      wait_for:
        path: /run/containerd/containerd.sock
        timeout: 30

- name: "1/2 · Проверить pull через containerd"
  hosts: first_control_plane
  become: true
  gather_facts: false
  tasks:

    - name: Дождаться containerd после рестарта
      wait_for:
        path: /run/containerd/containerd.sock
        timeout: 30

    - name: "Тест: pull тестового образа с {{ local_registry }}"
      shell: |
        ctr -n k8s.io image pull \
          --user "{{ registry_user }}:{{ registry_password }}" \
          {% if registry_insecure %}--skip-verify{% endif %} \
          {{ local_registry }}/pause:3.10 2>&1 || \
        ctr -n k8s.io image ls | grep -q '{{ local_registry }}' && echo "already exists" || \
        echo "pull failed — проверьте вручную"
      register: r_pull_test
      changed_when: false
      ignore_errors: true

    - name: Результат теста pull
      debug:
        msg: "{{ r_pull_test.stdout }}"

# ─── Play 2: imagePullSecret в K8s ───────────────────────────────────────────
- name: "2/2 · Kubernetes — imagePullSecret для {{ local_registry }}"
  hosts: first_control_plane
  become: true
  gather_facts: false
  environment:
    KUBECONFIG: /root/.kube/config
  vars:
    secret_name: "registry-credentials"
    target_namespaces:
      - default
      - kube-system
      - tigera-operator
      - calico-system
      - longhorn-system
      - gpu-operator
      - monitoring
  tasks:

    - name: Убедиться что namespaces существуют (создать если нет)
      command: "kubectl create namespace {{ item }} --dry-run=client -o yaml | kubectl apply -f -"
      loop: "{{ target_namespaces }}"
      ignore_errors: true
      changed_when: false

    - name: Создать imagePullSecret во всех namespaces
      command: >
        kubectl create secret docker-registry {{ secret_name }}
        --namespace={{ item }}
        --docker-server={{ local_registry }}
        --docker-username={{ registry_user }}
        --docker-password={{ registry_password }}
        --dry-run=client -o yaml | kubectl apply -f -
      loop: "{{ target_namespaces }}"
      register: r_secret
      changed_when: "'created' in r_secret.stdout or 'configured' in r_secret.stdout"

    - name: Добавить imagePullSecret в ServiceAccount default каждого namespace
      shell: |
        kubectl patch serviceaccount default \
          --namespace={{ item }} \
          -p '{"imagePullSecrets": [{"name": "{{ secret_name }}"}]}' 2>&1 || echo "skip"
      loop: "{{ target_namespaces }}"
      ignore_errors: true
      changed_when: false

    - name: Проверить секреты
      command: kubectl get secrets -A | grep {{ secret_name }}
      register: r_secrets_check
      changed_when: false

    - name: imagePullSecrets созданы
      debug:
        msg: "{{ r_secrets_check.stdout }}"
EOF
