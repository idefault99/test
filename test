# Имена контейнеров и статус
kubectl get pod -n longhorn-system longhorn-manager-229mh \
  -o jsonpath='{range .status.containerStatuses[*]}{.name}: ready={.ready} started={.started} {.state}{"\n"}{end}'

# Логи второго контейнера (он не ready)
kubectl logs -n longhorn-system longhorn-manager-229mh --all-containers=true 2>&1 | tail -60

# Проверить есть ли endpoints у longhorn-backend
kubectl get endpoints -n longhorn-system longhorn-backend
---
kubectl delete pods -n longhorn-system -l app=longhorn-ui
---
kubectl get svc,endpoints -n longhorn-system | grep -E 'longhorn-(backend|frontend|manager)'
