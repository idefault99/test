microk8s kubectl get configmap vault-ca -n external-secrets \
  -o jsonpath='{.data.ca\.crt}'

---
cat /opt/vault/tls/ca.crt
---
# На ноде K8s
scp root@vault-vm:/opt/vault/tls/ca.crt ./vault-ca.crt

microk8s kubectl delete configmap vault-ca -n external-secrets

microk8s kubectl create configmap vault-ca \
  --from-file=ca.crt=./vault-ca.crt \
  -n external-secrets

# Рестарт ESO
microk8s kubectl rollout restart deployment external-secrets -n external-secrets
