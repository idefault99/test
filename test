# Проверить что Vault отдаёт секрет
export VAULT_ADDR="https://vault.internal:8200"
export VAULT_CACERT="/opt/vault/tls/ca.crt"
export VAULT_TOKEN="<root_token>"
vault kv get stands/stand-test/infra/minio

# Проверить политику
vault policy read stand-test-infra

# Проверить Kubernetes auth роль
vault read auth/kubernetes/role/stand-test-infra

# Vault недоступен с ноды K8s — проверить резолвинг домена
