# 1. Сокет существует?
ls -la /var/snap/microk8s/8566/var/kubernetes/backend/kine.sock

# 2. Статус dqlite
sudo systemctl status snap.microk8s.daemon-k8s-dqlite

# 3. Логи dqlite — главное что смотреть
sudo journalctl -u snap.microk8s.daemon-k8s-dqlite -n 80 --no-pager

# 4. Запустить dqlite вручную
sudo snap start microk8s.daemon-k8s-dqlite
sleep 5

# 5. Появился ли сокет?
ls -la /var/snap/microk8s/8566/var/kubernetes/backend/kine.sock

# 6. Если сокет появился — стартовать kubelite
sudo snap start microk8s.daemon-kubelite
