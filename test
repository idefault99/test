#!/usr/bin/env bash
set -euo pipefail

PGHOST="${PGHOST:-127.0.0.1}"
PGPORT="${PGPORT:-5000}"
PGUSER="${PGUSER:-postgres}"
PGPASSWORD="${PGPASSWORD:-postgres}"
export PGPASSWORD

DEFAULT_DB="${DEFAULT_DB:-postgres}"
CURRENT_DB="$DEFAULT_DB"
LIMIT_ROWS="${LIMIT_ROWS:-50}"

PSQL_BASE=(psql -h "$PGHOST" -p "$PGPORT" -U "$PGUSER" -X -v ON_ERROR_STOP=1 -P pager=off)

header() {
  echo
  echo "============================================================"
  echo "$1"
  echo "============================================================"
}

run_sql() {
  local db="$1"
  local sql="$2"
  "${PSQL_BASE[@]}" -d "$db" -c "$sql"
}

run_sql_quiet() {
  local db="$1"
  local sql="$2"
  "${PSQL_BASE[@]}" -d "$db" -A -t -c "$sql"
}

pause() {
  echo
  read -r -p "–Э–∞–ґ–Љ–Є Enter –і–ї—П –њ—А–Њ–і–Њ–ї–ґ–µ–љ–Є—П..." _
}

check_connection() {
  header "–Я—А–Њ–≤–µ—А–Ї–∞ –њ–Њ–і–Ї–ї—О—З–µ–љ–Є—П"
  run_sql "$CURRENT_DB" "
    select
      current_user as current_user,
      current_database() as current_database,
      inet_server_addr() as server_ip,
      inet_server_port() as server_port,
      version() as postgres_version,
      pg_is_in_recovery() as is_replica,
      now() as server_time;
  "
}

select_database() {
  header "–Т—Л–±–Њ—А –С–Ф"

  mapfile -t DBS < <(run_sql_quiet postgres "
    select datname
    from pg_database
    where datistemplate = false
    order by datname;
  ")

  if [[ ${#DBS[@]} -eq 0 ]]; then
    echo "–С–∞–Ј—Л –і–∞–љ–љ—Л—Е –љ–µ –љ–∞–є–і–µ–љ—Л."
    return
  fi

  local i=1
  for db in "${DBS[@]}"; do
    echo "  $i) $db"
    ((i++))
  done

  echo
  read -r -p "–Т–≤–µ–і–Є –љ–Њ–Љ–µ—А –С–Ф: " db_num

  if [[ ! "$db_num" =~ ^[0-9]+$ ]]; then
    echo "–Э–µ–Ї–Њ—А—А–µ–Ї—В–љ—Л–є –≤–≤–Њ–і."
    return
  fi

  if (( db_num < 1 || db_num > ${#DBS[@]} )); then
    echo "–Э–µ—В —В–∞–Ї–Њ–≥–Њ –љ–Њ–Љ–µ—А–∞."
    return
  fi

  CURRENT_DB="${DBS[$((db_num-1))]}"
  echo "–Т—Л–±—А–∞–љ–∞ –С–Ф: $CURRENT_DB"
}

show_pg_stats() {
  header "pg_stats | –С–Ф: $CURRENT_DB | limit $LIMIT_ROWS"
  run_sql "$CURRENT_DB" "
    select
      schemaname,
      tablename,
      attname,
      inherited,
      null_frac,
      n_distinct,
      most_common_vals,
      most_common_freqs,
      histogram_bounds,
      correlation
    from pg_stats
    order by schemaname, tablename, attname
    limit ${LIMIT_ROWS};
  "
}

show_pg_stats_table() {
  header "pg_stats –њ–Њ –Ї–Њ–љ–Ї—А–µ—В–љ–Њ–є —В–∞–±–ї–Є—Ж–µ"

  read -r -p "–°—Е–µ–Љ–∞ [public]: " schema
  schema="${schema:-public}"

  read -r -p "–Ш–Љ—П —В–∞–±–ї–Є—Ж—Л: " table

  if [[ -z "${table// }" ]]; then
    echo "–Ш–Љ—П —В–∞–±–ї–Є—Ж—Л –љ–µ –Ј–∞–і–∞–љ–Њ."
    return
  fi

  run_sql "$CURRENT_DB" "
    select
      schemaname,
      tablename,
      attname,
      inherited,
      null_frac,
      n_distinct,
      avg_width,
      correlation,
      most_common_vals,
      most_common_freqs,
      histogram_bounds
    from pg_stats
    where schemaname = '${schema}'
      and tablename = '${table}'
    order by attname;
  "
}

show_pg_stat_activity() {
  header "pg_stat_activity"
  run_sql "$CURRENT_DB" "
    select
      pid,
      usename,
      datname,
      application_name,
      client_addr,
      state,
      wait_event_type,
      wait_event,
      now() - query_start as duration,
      left(query, 250) as query
    from pg_stat_activity
    order by query_start nulls last
    limit ${LIMIT_ROWS};
  "
}

show_pg_stat_database() {
  header "pg_stat_database"
  run_sql "$CURRENT_DB" "
    select
      datname,
      numbackends,
      xact_commit,
      xact_rollback,
      blks_read,
      blks_hit,
      tup_returned,
      tup_fetched,
      tup_inserted,
      tup_updated,
      tup_deleted,
      conflicts,
      temp_files,
      temp_bytes,
      deadlocks,
      checksum_failures,
      blk_read_time,
      blk_write_time,
      stats_reset
    from pg_stat_database
    order by datname;
  "
}

show_pg_stat_user_tables() {
  header "pg_stat_user_tables | –С–Ф: $CURRENT_DB"
  run_sql "$CURRENT_DB" "
    select
      schemaname,
      relname,
      seq_scan,
      seq_tup_read,
      idx_scan,
      idx_tup_fetch,
      n_tup_ins,
      n_tup_upd,
      n_tup_del,
      n_live_tup,
      n_dead_tup,
      vacuum_count,
      autovacuum_count,
      analyze_count,
      autoanalyze_count,
      last_vacuum,
      last_autovacuum,
      last_analyze,
      last_autoanalyze
    from pg_stat_user_tables
    order by n_dead_tup desc nulls last
    limit ${LIMIT_ROWS};
  "
}

show_pg_stat_user_indexes() {
  header "pg_stat_user_indexes | –С–Ф: $CURRENT_DB"
  run_sql "$CURRENT_DB" "
    select
      schemaname,
      relname as table_name,
      indexrelname as index_name,
      idx_scan,
      idx_tup_read,
      idx_tup_fetch
    from pg_stat_user_indexes
    order by idx_scan desc nulls last
    limit ${LIMIT_ROWS};
  "
}

show_pg_statio_user_tables() {
  header "pg_statio_user_tables | –С–Ф: $CURRENT_DB"
  run_sql "$CURRENT_DB" "
    select
      schemaname,
      relname,
      heap_blks_read,
      heap_blks_hit,
      idx_blks_read,
      idx_blks_hit,
      toast_blks_read,
      toast_blks_hit,
      tidx_blks_read,
      tidx_blks_hit
    from pg_statio_user_tables
    order by heap_blks_read desc nulls last
    limit ${LIMIT_ROWS};
  "
}

show_pg_statio_user_indexes() {
  header "pg_statio_user_indexes | –С–Ф: $CURRENT_DB"
  run_sql "$CURRENT_DB" "
    select
      schemaname,
      relname as table_name,
      indexrelname as index_name,
      idx_blks_read,
      idx_blks_hit
    from pg_statio_user_indexes
    order by idx_blks_read desc nulls last
    limit ${LIMIT_ROWS};
  "
}

show_pg_stat_bgwriter() {
  header "pg_stat_bgwriter"
  run_sql "$CURRENT_DB" "
    select *
    from pg_stat_bgwriter;
  "
}

show_pg_stat_wal() {
  header "pg_stat_wal"
  run_sql "$CURRENT_DB" "
    select *
    from pg_stat_wal;
  "
}

show_pg_stat_replication() {
  header "pg_stat_replication"
  run_sql "$CURRENT_DB" "
    select *
    from pg_stat_replication;
  "
}

show_pg_stat_archiver() {
  header "pg_stat_archiver"
  run_sql "$CURRENT_DB" "
    select *
    from pg_stat_archiver;
  "
}

show_pg_stat_ssl() {
  header "pg_stat_ssl"
  run_sql "$CURRENT_DB" "
    select *
    from pg_stat_ssl
    limit ${LIMIT_ROWS};
  "
}

show_pg_stat_statements() {
  header "pg_stat_statements"

  local exists
  exists="$(run_sql_quiet "$CURRENT_DB" "
    select count(*)
    from pg_extension
    where extname = 'pg_stat_statements';
  ")"

  if [[ "${exists:-0}" != "1" ]]; then
    echo "–†–∞—Б—И–Є—А–µ–љ–Є–µ pg_stat_statements –љ–µ —Г—Б—В–∞–љ–Њ–≤–ї–µ–љ–Њ –≤ –С–Ф $CURRENT_DB."
    echo "–Э—Г–ґ–љ–Њ —Б–Њ–Ј–і–∞—В—М extension –Є –Њ–±—Л—З–љ–Њ –і–Њ–±–∞–≤–Є—В—М –µ–≥–Њ –≤ shared_preload_libraries."
    return
  fi

  run_sql "$CURRENT_DB" "
    select
      userid,
      dbid,
      queryid,
      calls,
      total_exec_time,
      mean_exec_time,
      rows,
      shared_blks_hit,
      shared_blks_read,
      temp_blks_written,
      left(query, 250) as query
    from pg_stat_statements
    order by total_exec_time desc
    limit ${LIMIT_ROWS};
  "
}

run_custom_sql() {
  header "–Т—Л–њ–Њ–ї–љ–Є—В—М SQL –≤ –С–Ф: $CURRENT_DB"
  echo "–Т–≤–µ–і–Є SQL –Њ–і–љ–Њ–є —Б—В—А–Њ–Ї–Њ–є."
  echo

  read -r -p "SQL> " user_sql

  if [[ -z "${user_sql// }" ]]; then
    echo "–Я—Г—Б—В–Њ–є –Ј–∞–њ—А–Њ—Б."
    return
  fi

  run_sql "$CURRENT_DB" "$user_sql"
}

change_limit() {
  echo
  read -r -p "–Э–Њ–≤—Л–є LIMIT_ROWS (—В–µ–Ї—Г—Й–µ–µ: $LIMIT_ROWS): " new_limit
  if [[ "$new_limit" =~ ^[0-9]+$ ]] && (( new_limit > 0 )); then
    LIMIT_ROWS="$new_limit"
    echo "–Э–Њ–≤–Њ–µ –Ј–љ–∞—З–µ–љ–Є–µ LIMIT_ROWS: $LIMIT_ROWS"
  else
    echo "–Э–µ–Ї–Њ—А—А–µ–Ї—В–љ–Њ–µ —З–Є—Б–ї–Њ."
  fi
}

main_menu() {
  while true; do
    header "Postgres stats menu | host=$PGHOST port=$PGPORT user=$PGUSER current_db=$CURRENT_DB limit=$LIMIT_ROWS"
    echo "1) –Я—А–Њ–≤–µ—А–Є—В—М –њ–Њ–і–Ї–ї—О—З–µ–љ–Є–µ"
    echo "2) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stats"
    echo "3) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stats –њ–Њ –Ї–Њ–љ–Ї—А–µ—В–љ–Њ–є —В–∞–±–ї–Є—Ж–µ"
    echo "4) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stat_activity"
    echo "5) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stat_database"
    echo "6) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stat_user_tables"
    echo "7) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stat_user_indexes"
    echo "8) –Я–Њ–Ї–∞–Ј–∞—В—М pg_statio_user_tables"
    echo "9) –Я–Њ–Ї–∞–Ј–∞—В—М pg_statio_user_indexes"
    echo "10) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stat_bgwriter"
    echo "11) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stat_wal"
    echo "12) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stat_replication"
    echo "13) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stat_archiver"
    echo "14) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stat_ssl"
    echo "15) –Я–Њ–Ї–∞–Ј–∞—В—М pg_stat_statements"
    echo "16) –Т—Л–њ–Њ–ї–љ–Є—В—М SQL"
    echo "17) –°–Љ–µ–љ–Є—В—М –С–Ф"
    echo "18) –Ш–Ј–Љ–µ–љ–Є—В—М LIMIT"
    echo "0) –Т—Л—Е–Њ–і"
    echo

    read -r -p "–Т—Л–±–µ—А–Є –њ—Г–љ–Ї—В –Љ–µ–љ—О: " choice

    case "$choice" in
      1) check_connection; pause ;;
      2) show_pg_stats; pause ;;
      3) show_pg_stats_table; pause ;;
      4) show_pg_stat_activity; pause ;;
      5) show_pg_stat_database; pause ;;
      6) show_pg_stat_user_tables; pause ;;
      7) show_pg_stat_user_indexes; pause ;;
      8) show_pg_statio_user_tables; pause ;;
      9) show_pg_statio_user_indexes; pause ;;
      10) show_pg_stat_bgwriter; pause ;;
      11) show_pg_stat_wal; pause ;;
      12) show_pg_stat_replication; pause ;;
      13) show_pg_stat_archiver; pause ;;
      14) show_pg_stat_ssl; pause ;;
      15) show_pg_stat_statements; pause ;;
      16) run_custom_sql; pause ;;
      17) select_database; pause ;;
      18) change_limit; pause ;;
      0) echo "–Т—Л—Е–Њ–і."; exit 0 ;;
      *) echo "–Э–µ–Є–Ј–≤–µ—Б—В–љ—Л–є –њ—Г–љ–Ї—В –Љ–µ–љ—О."; pause ;;
    esac
  done
}

main_menu