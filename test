# =====================================================================
# FIX LONGHORN UI: host not found in upstream "longhorn-backend"
# =====================================================================

# Выполнять на control-plane, например coparking-5 или где есть kubectl.

export KUBECONFIG=/etc/kubernetes/admin.conf
NS=longhorn-system


# =====================================================================
# 1. Посмотреть общее состояние Longhorn
# =====================================================================

kubectl -n $NS get all -o wide

kubectl -n $NS get pods -o wide

kubectl -n $NS get svc -o wide

kubectl -n $NS get endpoints -o wide

kubectl -n $NS get events --sort-by='.lastTimestamp' | tail -n 120


# =====================================================================
# 2. Проверить, существует ли service longhorn-backend
# =====================================================================

kubectl -n $NS get svc longhorn-backend -o yaml

kubectl -n $NS get endpoints longhorn-backend -o yaml


# Нормально, если service есть примерно такой:
#
# kind: Service
# metadata:
#   name: longhorn-backend
# spec:
#   ports:
#   - port: 9500
#   selector:
#     app: longhorn-manager
#
# Если service longhorn-backend отсутствует — это причина падения UI.


# =====================================================================
# 3. Проверить longhorn-manager
# =====================================================================

kubectl -n $NS get ds longhorn-manager -o wide

kubectl -n $NS get pods -l app=longhorn-manager -o wide

kubectl -n $NS describe ds longhorn-manager


# Логи всех longhorn-manager pod'ов:

for p in $(kubectl -n $NS get pods -l app=longhorn-manager -o name); do
  echo
  echo "===== $p ====="
  kubectl -n $NS logs "$p" --all-containers --tail=200
done


# Если longhorn-manager pod'ов нет или они не Running,
# UI и driver-deployer нормально не поднимутся.


# =====================================================================
# 4. Проверить init-container driver-deployer
# =====================================================================

kubectl -n $NS describe pod longhorn-driver-deployer-79888b698b-p5b9n

kubectl -n $NS logs longhorn-driver-deployer-79888b698b-p5b9n -c wait-longhorn-manager --tail=200

kubectl -n $NS logs longhorn-driver-deployer-79888b698b-p5b9n -c longhorn-driver-deployer --tail=200


# Если wait-longhorn-manager ждёт endpoint/service longhorn-backend —
# сначала чинить longhorn-manager / service.


# =====================================================================
# 5. Проверить DNS внутри namespace
# =====================================================================

# Используй образ, который точно есть в закрытом контуре.
# Если docker.io/library/busybox:1.36 у тебя нет, замени на свой net-debug/minimal.

kubectl -n $NS run dns-test \
  --image=docker.io/library/busybox:1.36 \
  --image-pull-policy=IfNotPresent \
  --restart=Never \
  --command -- sleep 3600

kubectl -n $NS wait pod/dns-test --for=condition=Ready --timeout=60s || true

kubectl -n $NS get pod dns-test -o wide

kubectl -n $NS exec dns-test -- nslookup kubernetes.default.svc.cluster.local

kubectl -n $NS exec dns-test -- nslookup longhorn-backend

kubectl -n $NS exec dns-test -- nslookup longhorn-backend.longhorn-system.svc.cluster.local

kubectl -n $NS exec dns-test -- wget -qO- http://longhorn-backend:9500/v1 || true

kubectl -n $NS delete pod dns-test --ignore-not-found


# Если kubernetes.default.svc.cluster.local не резолвится —
# проблема в CoreDNS/Calico/DNSPolicy.
#
# Если kubernetes резолвится, а longhorn-backend нет —
# service longhorn-backend отсутствует или не создан.


# =====================================================================
# 6. Проверить CoreDNS
# =====================================================================

kubectl -n kube-system get pods -l k8s-app=kube-dns -o wide

kubectl -n kube-system logs deploy/coredns --tail=100

kubectl -n kube-system get svc kube-dns -o wide

kubectl -n kube-system get endpoints kube-dns -o wide


# =====================================================================
# 7. Если service longhorn-backend отсутствует — создать вручную
# =====================================================================

# Сначала проверить labels у manager pod'ов:

kubectl -n $NS get pods --show-labels | grep longhorn-manager || true


# Если у manager pod'ов label app=longhorn-manager,
# создать service:

cat <<'EOF' | kubectl apply -f -
apiVersion: v1
kind: Service
metadata:
  name: longhorn-backend
  namespace: longhorn-system
  labels:
    app: longhorn-manager
spec:
  type: ClusterIP
  selector:
    app: longhorn-manager
  ports:
    - name: manager
      port: 9500
      targetPort: 9500
      protocol: TCP
EOF


# Проверить:

kubectl -n $NS get svc longhorn-backend -o wide

kubectl -n $NS get endpoints longhorn-backend -o wide


# Если endpoints пустые — service есть, но manager pod'ы не подходят под selector
# или manager pod'ы не Ready.


# =====================================================================
# 8. Если selector не совпал — посмотреть реальные labels manager pod'ов
# =====================================================================

kubectl -n $NS get pods -l app=longhorn-manager --show-labels

kubectl -n $NS get pods --show-labels | grep manager


# Если label другой, например app.kubernetes.io/name=longhorn-manager,
# поправить service selector:

kubectl -n $NS edit svc longhorn-backend


# Должно совпадать с labels pod'ов longhorn-manager.


# =====================================================================
# 9. Проверить, что manager слушает 9500
# =====================================================================

MANAGER_POD=$(kubectl -n $NS get pods -l app=longhorn-manager -o jsonpath='{.items[0].metadata.name}')

echo $MANAGER_POD

kubectl -n $NS exec "$MANAGER_POD" -- ss -tulpen || true

kubectl -n $NS exec "$MANAGER_POD" -- wget -qO- http://127.0.0.1:9500/v1 || true


# Если внутри manager нет ss/wget — это не критично.
# Можно проверить через temporary pod:

kubectl -n $NS run backend-test \
  --image=docker.io/library/busybox:1.36 \
  --image-pull-policy=IfNotPresent \
  --restart=Never \
  --command -- sleep 3600

kubectl -n $NS wait pod/backend-test --for=condition=Ready --timeout=60s || true

kubectl -n $NS exec backend-test -- wget -qO- http://longhorn-backend:9500/v1 || true

kubectl -n $NS delete pod backend-test --ignore-not-found


# =====================================================================
# 10. Перезапустить UI после появления longhorn-backend
# =====================================================================

kubectl -n $NS rollout restart deploy/longhorn-ui

kubectl -n $NS rollout status deploy/longhorn-ui --timeout=180s

kubectl -n $NS get pods -o wide | grep longhorn-ui

kubectl -n $NS logs deploy/longhorn-ui --tail=100


# =====================================================================
# 11. Перезапустить driver-deployer после manager/backend
# =====================================================================

kubectl -n $NS rollout restart deploy/longhorn-driver-deployer

kubectl -n $NS rollout status deploy/longhorn-driver-deployer --timeout=300s

kubectl -n $NS get pods -o wide | grep longhorn-driver-deployer

kubectl -n $NS logs deploy/longhorn-driver-deployer --all-containers --tail=200


# =====================================================================
# 12. Если longhorn-manager падает из-за отсутствующих images
# =====================================================================

kubectl -n $NS get pods -o wide | grep -E 'ImagePullBackOff|ErrImagePull|ContainerCreating|CrashLoopBackOff' || true

kubectl -n $NS get pods -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{range .spec.containers[*]}{"  "}{.image}{"\n"}{end}{range .spec.initContainers[*]}{"  init: "}{.image}{"\n"}{end}{"\n"}{end}'


# Сравнить images с тем, что есть на ноде, где pod запланирован:
#
# kubectl -n longhorn-system get pod <pod> -o wide
# ssh root@<node> "crictl images | grep '<image-part>'"


# =====================================================================
# 13. Проверить основные Longhorn CRD
# =====================================================================

kubectl get crd | grep longhorn

kubectl -n $NS get nodes.longhorn.io || true

kubectl -n $NS get settings.longhorn.io || true

kubectl -n $NS get engineimages.longhorn.io || true

kubectl -n $NS get instanceengines.longhorn.io || true


# =====================================================================
# 14. Финальная проверка
# =====================================================================

kubectl -n $NS get pods -o wide

kubectl -n $NS get svc -o wide

kubectl -n $NS get endpoints -o wide

kubectl -n $NS get pods | grep -Ev 'Running|Completed|NAME' || true

kubectl -n $NS get events --sort-by='.lastTimestamp' | tail -n 100


# Ожидаемо:
#
# longhorn-manager-*             Running
# longhorn-ui-*                  Running
# longhorn-driver-deployer-*     Running или Completed после работы
# longhorn-backend service       есть
# longhorn-backend endpoints     не пустые
#
# Если longhorn-backend endpoints пустые — чинить longhorn-manager.
# Если endpoints есть, а UI всё равно падает — проверить CoreDNS.
# =====================================================================