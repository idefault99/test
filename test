kind: Ingress
apiVersion: networking.k8s.io/v1
metadata:
  name: trip-dev.code-discovery.ru-ingress-s3minio
  namespace: trip-dev
  labels:
    app.kubernetes.io/managed-by: Helm
    k8slens-edit-resource-version: v1
  annotations:
    meta.helm.sh/release-name: infra
    meta.helm.sh/release-namespace: trip-dev
    nginx.ingress.kubernetes.io/proxy-body-size: 500m
    nginx.ingress.kubernetes.io/proxy-buffer-size: 128k
    nginx.ingress.kubernetes.io/proxy-buffers: 4 256k
    nginx.ingress.kubernetes.io/proxy-busy-buffers-size: 256k
    nginx.ingress.kubernetes.io/rewrite-target: /$2
    nginx.ingress.kubernetes.io/use-regex: 'true'
    nginx.ingress.kubernetes.io/proxy-request-buffering: "off"  # важно для upload
spec:
  ingressClassName: nginx
  tls:
    - hosts:
        - trip-dev.code-discovery.ru
      secretName: trip-dev.code-discovery.ru-tls-secret
  rules:
    - host: trip-dev.code-discovery.ru
      http:
        paths:
          - path: /api/s3minio(/|$)(.*)
            pathType: ImplementationSpecific
            backend:
              service:
                name: s3minio-api-service
                port:
                  number: 9000
          - path: /s3minio(/|$)(.*)
            pathType: ImplementationSpecific
            backend:
              service:
                name: s3minio-console-service
                port:
                  number: 9001
