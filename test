# 1. Скопировать полный CA с Vault VM
scp root@vault-vm:/tmp/vault-ca-full.pem ./vault-ca-full.pem

# 2. Создать Secret (не ConfigMap) с CA cert
microk8s kubectl delete secret vault-ca-secret -n external-secrets 2>/dev/null || true
microk8s kubectl create secret generic vault-ca-secret \
  --from-file=ca.crt=./vault-ca-full.pem \
  -n external-secrets

# 3. Убедиться что ClusterSecretStore ссылается на правильный ресурс
microk8s kubectl get clustersecretstore vault-cluster-store-dev-devops \
  -o jsonpath='{.spec.provider.vault.caProvider}'

microk8s kubectl rollout restart deployment external-secrets -n external-secrets

# Через 15 сек
microk8s kubectl get clustersecretstore vault-cluster-store-dev-devops
