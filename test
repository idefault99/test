---
# Запуск: ansible-playbook playbooks/00-audit.yml -K
# Показывает текущее состояние всех нод без изменений

- name: Audit — состояние всех нод
  hosts: all_nodes
  become: true
  gather_facts: true
  tasks:

    - name: Check SELinux mode
      command: getenforce
      register: r_selinux
      changed_when: false
      failed_when: false

    - name: Check swap
      command: swapon --show
      register: r_swap
      changed_when: false
      failed_when: false

    - name: Check zram service
      command: systemctl is-active dev-zram0.swap
      register: r_zram
      changed_when: false
      failed_when: false

    - name: Check chronyd
      command: systemctl is-active chronyd
      register: r_chrony
      changed_when: false
      failed_when: false

    - name: Check containerd
      command: systemctl is-active containerd
      register: r_containerd_svc
      changed_when: false
      failed_when: false

    - name: Get containerd version
      command: ctr version
      register: r_containerd_ver
      changed_when: false
      failed_when: false

    - name: Check kubelet
      command: systemctl is-active kubelet
      register: r_kubelet
      changed_when: false
      failed_when: false

    - name: Check kubeadm version
      command: kubeadm version -o short
      register: r_kubeadm
      changed_when: false
      failed_when: false

    - name: Check kubectl version
      command: kubectl version --client -o short
      register: r_kubectl
      changed_when: false
      failed_when: false

    - name: Check admin.conf (cluster initialized on this node)
      stat:
        path: /etc/kubernetes/admin.conf
      register: r_admin_conf

    - name: Check kubelet.conf (node joined cluster)
      stat:
        path: /etc/kubernetes/kubelet.conf
      register: r_kubelet_conf

    - name: Check kube-vip manifest
      stat:
        path: /etc/kubernetes/manifests/kube-vip.yaml
      register: r_kubevip

    - name: Get eno1 IP
      shell: "ip -4 addr show {{ vip_interface }} | awk '/inet /{print $2}'"
      register: r_eno1_ip
      changed_when: false
      failed_when: false

    - name: Check /etc/hosts k8s entries
      command: grep -cE 'coparking|k8s-api' /etc/hosts
      register: r_hosts_count
      changed_when: false
      failed_when: false

    - name: Check /var/lib/longhorn mount
      command: "df -hT {{ longhorn_data_path }}"
      register: r_longhorn
      changed_when: false
      failed_when: false

    - name: Check iscsid
      command: systemctl is-active iscsid
      register: r_iscsi
      changed_when: false
      failed_when: false

    - name: Check nouveau module
      command: lsmod
      register: r_lsmod
      changed_when: false
      failed_when: false

    - name: Check nvidia-smi
      command: nvidia-smi --query-gpu=name,driver_version,memory.total --format=csv,noheader
      register: r_nvidia
      changed_when: false
      failed_when: false

    - name: Check nvidia-persistenced
      command: systemctl is-active nvidia-persistenced
      register: r_persistenced
      changed_when: false
      failed_when: false

    - name: Check dkms nvidia
      command: dkms status
      register: r_dkms
      changed_when: false
      failed_when: false

    - name: Print node report
      debug:
        msg: |
          ╔══════════════════════════════════════════════════════════════╗
          ║  {{ inventory_hostname }}  ({{ ansible_host }})
          ╠══ ОС и ядро ═════════════════════════════════════════════════╣
          ║  OS:      {{ ansible_distribution }} {{ ansible_distribution_version }}
          ║  Kernel:  {{ ansible_kernel }}
          ║  SELinux: {{ r_selinux.stdout | default('?') }}   (ожидается: Permissive)
          ║  Swap:    {{ 'NONE ✓' if (r_swap.stdout | default('')) == '' else 'ACTIVE ✗ → ' + r_swap.stdout }}
          ║  zram:    {{ r_zram.stdout | default('?') }}   (ожидается: inactive/failed/masked)
          ║  chronyd: {{ r_chrony.stdout | default('?') }}
          ╠══ Kubernetes ════════════════════════════════════════════════╣
          ║  containerd: {{ r_containerd_svc.stdout | default('?') }}
          ║  containerd ver: {{ (r_containerd_ver.stdout_lines | first | default('?')) }}
          ║  kubelet:    {{ r_kubelet.stdout | default('?') }}
          ║  kubeadm:    {{ r_kubeadm.stdout | default('NOT FOUND') }}
          ║  kubectl:    {{ r_kubectl.stdout | default('NOT FOUND') }}
          ║  admin.conf: {{ 'EXISTS ✓ (кластер инициализирован)' if r_admin_conf.stat.exists else 'НЕТ (кластер не инициализирован)' }}
          ║  kubelet.conf: {{ 'EXISTS ✓ (нода в кластере)' if r_kubelet_conf.stat.exists else 'НЕТ (нода не присоединена)' }}
          ║  kube-vip:   {{ 'EXISTS ✓' if r_kubevip.stat.exists else 'НЕТ' }}
          ╠══ Сеть ══════════════════════════════════════════════════════╣
          ║  {{ vip_interface }} IP:    {{ r_eno1_ip.stdout | default('?') }}
          ║  /etc/hosts: {{ r_hosts_count.stdout | default('0') }} k8s записей
          ╠══ Хранилище ════════════════════════════════════════════════╣
          ║  longhorn:  {{ r_longhorn.stdout_lines | last | default('НЕ СМОНТИРОВАН ✗') }}
          ║  iscsid:    {{ r_iscsi.stdout | default('?') }}
          ╠══ NVIDIA ════════════════════════════════════════════════════╣
          ║  nouveau: {{ 'ЗАГРУЖЕН ✗' if 'nouveau' in r_lsmod.stdout else 'не загружен ✓' }}
          ║  GPU:     {{ r_nvidia.stdout | default('nvidia-smi недоступен') }}
          ║  persistenced: {{ r_persistenced.stdout | default('?') }}
          ║  dkms:    {{ r_dkms.stdout_lines | select('search', 'nvidia') | list | join(', ') | default('нет записей nvidia') }}
          ╚══════════════════════════════════════════════════════════════╝

# Play 2: статус кластера (только если инициализирован)
- name: Audit — статус кластера K8s
  hosts: first_control_plane
  become: true
  gather_facts: false
  tasks:

    - name: Check if cluster is initialized
      stat:
        path: /etc/kubernetes/admin.conf
      register: r_admin

    - name: Get nodes
      command: kubectl get nodes -o wide
      environment:
        KUBECONFIG: /root/.kube/config
      register: r_nodes
      changed_when: false
      when: r_admin.stat.exists

    - name: Get non-running pods
      shell: "kubectl get pods -A | grep -Ev 'Running|Completed|NAME' || true"
      environment:
        KUBECONFIG: /root/.kube/config
      register: r_bad_pods
      changed_when: false
      when: r_admin.stat.exists

    - name: Get StorageClasses
      command: kubectl get storageclass
      environment:
        KUBECONFIG: /root/.kube/config
      register: r_sc
      changed_when: false
      failed_when: false
      when: r_admin.stat.exists

    - name: Get GPU capacity
      shell: |
        kubectl get nodes -o json \
          | python3 -c "
        import json,sys
        nodes=json.load(sys.stdin)['items']
        for n in nodes:
          gpu=n['status']['capacity'].get('nvidia.com/gpu','0')
          print(n['metadata']['name']+': '+gpu+' GPU')
        "
      environment:
        KUBECONFIG: /root/.kube/config
      register: r_gpu
      changed_when: false
      failed_when: false
      when: r_admin.stat.exists

    - name: Print cluster summary
      debug:
        msg: |
          ╔══════════════════════════════════════════════════════════════╗
          ║  КЛАСТЕР K8S                                                 ║
          ╠══ Ноды ══════════════════════════════════════════════════════╣
          {{ r_nodes.stdout | default('Кластер не инициализирован') }}
          ╠══ Проблемные поды ═══════════════════════════════════════════╣
          {{ r_bad_pods.stdout | default('нет (всё Ok)') if r_admin.stat.exists else '' }}
          ╠══ StorageClass ══════════════════════════════════════════════╣
          {{ r_sc.stdout | default('нет') if r_admin.stat.exists else '' }}
          ╠══ GPU capacity ══════════════════════════════════════════════╣
          {{ r_gpu.stdout | default('нет данных') if r_admin.stat.exists else '' }}
          ╚══════════════════════════════════════════════════════════════╝
      when: true
