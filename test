# https://gitlab.test.model.svo.aero/dpm/airport_digital_ecosystem/aodb/mail-service
include:
  - project: 'dpm/iac/infra'
    ref: develop
    file: 'cicd/basic.gitlab-ci.yml'

variables:
  RELEASE_NAME: mailservice
  REGISTRY_PATH: mailservice/mailservice

.buildkit_bin:
  script:
    - |
      docker buildx build ./ -f ${CI_PROJECT_DIR}/Docker/Dockerfile \
      --tag ${CI_REGISTRY_IMAGE}:${TAG}.bin \
      --tag $CI_REGISTRY_IMAGE:latest \
      --cache-to type=registry,ref=$CI_REGISTRY_IMAGE/cache,mode=max \
      --cache-from type=registry,ref=$CI_REGISTRY_IMAGE/cache \
      --target ${TARGET} \
      --build-arg POETRY_PACKAGE_GROUPS=${PACKAGE_GROUPS} \
      --build-arg PROJECT_REVISION=${TAG} \
      --build-arg GITLAB_USERNAME=gitlab-ci-token \
      --build-arg GITLAB_TOKEN=${CI_JOB_TOKEN} \
      --build-arg NEXUS_PYPI_URL=${NEXUS_PYPI_URL} \
      --build-arg NEXUS_USERNAME=${NEXUS_USERNAME} \
      --build-arg NEXUS_PASSWORD=${NEXUS_PASSWORD} \
      --build-arg http_proxy=$http_proxy \
      --build-arg https_proxy=$https_proxy \
      --build-arg no_proxy=$no_proxy \
      --push=true

build_bin:
  extends: .buildkit_bin
  variables:
    TARGET: production
    PACKAGE_GROUPS: main,dev,test

.buildkit_source:
  script:
    - |
      docker buildx build ./ -f ${CI_PROJECT_DIR}/Docker/Dockerfile \
      --tag ${CI_REGISTRY_IMAGE}:${TAG} \
      --tag $CI_REGISTRY_IMAGE:latest \
      --cache-to type=registry,ref=$CI_REGISTRY_IMAGE/cache,mode=max \
      --cache-from type=registry,ref=$CI_REGISTRY_IMAGE/cache \
      --target ${TARGET} \
      --build-arg POETRY_PACKAGE_GROUPS=${PACKAGE_GROUPS} \
      --build-arg PROJECT_REVISION=${TAG} \
      --build-arg GITLAB_USERNAME=gitlab-ci-token \
      --build-arg GITLAB_TOKEN=${CI_JOB_TOKEN} \
      --build-arg NEXUS_PYPI_URL=${NEXUS_PYPI_URL} \
      --build-arg NEXUS_USERNAME=${NEXUS_USERNAME} \
      --build-arg NEXUS_PASSWORD=${NEXUS_PASSWORD} \
      --build-arg http_proxy=$http_proxy \
      --build-arg https_proxy=$https_proxy \
      --build-arg no_proxy=$no_proxy \
      --push=true

build_source:
  extends: .buildkit_source
  variables:
    TARGET: source
    PACKAGE_GROUPS: main,dev,test

build_migrations:
  extends: .buildkit_migrations
  script:
    - |
      docker buildx build ./ -f ${CI_PROJECT_DIR}/Docker/migrations.Dockerfile \
      --tag ${CI_REGISTRY_IMAGE}:${TAG}.migrations \
      --tag $CI_REGISTRY_IMAGE:latest \
      --cache-to type=registry,ref=$CI_REGISTRY_IMAGE/cache,mode=max \
      --cache-from type=registry,ref=$CI_REGISTRY_IMAGE/cache \
      --build-arg NEXUS_PYPI_URL=${NEXUS_PYPI_URL} \
      --build-arg NEXUS_USERNAME=${NEXUS_USERNAME} \
      --build-arg NEXUS_PASSWORD=${NEXUS_PASSWORD} \
      --build-arg http_proxy=$http_proxy \
      --build-arg https_proxy=$https_proxy \
      --build-arg no_proxy=$no_proxy \
      --push=true

.test:
  script:
    - touch ./report.xml
    - touch ./coverage.xml
    - export TAG=$(eval $TAG_SCRIPT)
    # Строка ниже явно не нужна, при поднятии test он поднимит все сервисы в depends on
    # - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} up -d --renew-anon-volumes --force-recreate --remove-orphans redis db web
    - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} up --remove-orphans --renew-anon-volumes --force-recreate --exit-code-from test test
  coverage: '/(?i)total.*? (100(?:\.0+)?\%|[1-9]?\d(?:\.\d+)?\%)$/'
  artifacts:
    when: always
    reports:
      junit: ./report.xml
      coverage_report:
        coverage_format: cobertura
        path: ./coverage.xml
  after_script:
    - >
      if [ $CI_JOB_STATUS == 'failed' ]; then
        docker compose -p ${CI_JOB_ID} logs $(docker compose -p ${CI_JOB_ID} ps --format json --status=exited | jq -r 'select(.ExitCode!=0) | .Service')
      fi
    - export TAG=$(eval $TAG_SCRIPT)
    - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} down
    - docker volume prune -f

test:
  extends: .test

linter:
  extends: .linter

.deploy:
  script:
    - |
      helm upgrade -i -n $NAMESPACE ${RELEASE_NAME} ./Helm -f $VALUES \
        --set "images.main=${REGISTRY}:${TAG}.bin" \
        --set "images.migrations=${REGISTRY}:${TAG}.migrations"

.base_publish_image:
  script:
    - echo $CI_JOB_TOKEN | docker login -u $CI_REGISTRY_USER $CI_REGISTRY --password-stdin
    - echo ${REGISTRY_PASSWORD} | docker login -u ${REGISTRY_LOGIN} $EXTERNAL_REGISTRY --password-stdin
    - docker pull ${CI_REGISTRY_IMAGE}:${TAG}.bin
    - docker pull ${CI_REGISTRY_IMAGE}:${TAG}.migrations
    - docker tag ${CI_REGISTRY_IMAGE}:${TAG}.bin ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH}:${TAG}.bin
    - docker tag ${CI_REGISTRY_IMAGE}:${TAG}.migrations ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH}:${TAG}.migrations
    - docker push ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH}:${TAG}.bin
    - docker push ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH}:${TAG}.migrations
    - docker image rm ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH}:${TAG}.bin || exit 0
    - docker image rm ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH}:${TAG}.migrations || exit 0
    - docker image rm ${CI_REGISTRY_IMAGE}:${TAG}.bin || exit 0
    - docker image rm ${CI_REGISTRY_IMAGE}:${TAG}.migrations || exit 0

# Задача DEVOPS-310
