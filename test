## Просмотр релизов

```bash
# Список всех релизов в текущем namespace
helm list
helm ls

# Список релизов во всех namespace
helm list -A
helm list --all-namespaces

# Список релизов в конкретном namespace
helm list -n production

# Показать все релизы, включая failed и uninstalled
helm list --all

# Показать только failed релизы
helm list --failed

# Показать только pending релизы
helm list --pending

# Показать только deployed релизы
helm list --deployed

# Статус релиза (состояние, namespace, revision, notes)
helm status <release-name>
helm status my-nginx -n production

# История ревизий релиза
helm history <release-name>
helm history my-nginx

# История с ограничением количества записей
helm history my-nginx --max 5

# Получить манифесты всех ресурсов релиза (итоговый YAML)
helm get manifest <release-name>
helm get manifest my-nginx -n production

# Получить values, с которыми был задеплоен релиз (только пользовательские)
helm get values <release-name>
helm get values my-nginx

# Получить все values (включая дефолтные из чарта)
helm get values my-nginx --all

# Получить values конкретной ревизии
helm get values my-nginx --revision 3

# Получить notes (из NOTES.txt чарта)
helm get notes <release-name>
helm get notes my-nginx

# Получить хуки релиза
helm get hooks <release-name>
helm get hooks my-nginx

# Получить всё сразу (манифесты + values + notes + хуки)
helm get all <release-name>
helm get all my-nginx
```

