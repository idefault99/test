import asyncio
import time
from redis.asyncio import Redis

async def main():
    client = Redis.from_url(
        "redis://redis-service:6379",
        encoding="utf-8",
        decode_responses=True,
    )

    i = 0
    while True:
        i += 1
        ts = time.strftime("%H:%M:%S")
        try:
            await client.set(f"test:key:{i}", f"value-{i}")
            val = await client.get(f"test:key:{i}")
            print(f"{ts} | OK  | SET test:key:{i} → GET {val}")
        except Exception as e:
            print(f"{ts} | ERR | {type(e).__name__}: {e}")
        await asyncio.sleep(1)

asyncio.run(main())
EOF