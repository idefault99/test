## Шаг 3. Кастомные queries для pg_stat_*

Создай файл `/etc/postgres_exporter/queries.yaml` — это главный файл с метриками:

```bash
sudo tee /etc/postgres_exporter/queries.yaml > /dev/null <<'YAML'
# =============================================================================
# pg_stat_database — статистика по каждой БД (основа для multi-line графика)
# =============================================================================
pg_stat_database:
  query: |
    SELECT
      datname,
      numbackends,
      xact_commit,
      xact_rollback,
      blks_read,
      blks_hit,
      CASE WHEN (blks_hit + blks_read) = 0 THEN 0
           ELSE round(blks_hit * 100.0 / (blks_hit + blks_read), 2)
      END AS cache_hit_ratio,
      tup_returned,
      tup_fetched,
      tup_inserted,
      tup_updated,
      tup_deleted,
      conflicts,
      temp_files,
      temp_bytes,
      deadlocks,
      checksum_failures,
      blk_read_time,
      blk_write_time,
      stats_reset
    FROM pg_stat_database
    WHERE datname NOT IN ('template0', 'template1')
      AND datname IS NOT NULL
  metrics:
    - datname:
        usage: LABEL
        description: "Имя базы данных"
    - numbackends:
        usage: GAUGE
        description: "Активные подключения к БД"
    - xact_commit:
        usage: COUNTER
        description: "Количество зафиксированных транзакций"
    - xact_rollback:
        usage: COUNTER
        description: "Количество откатов транзакций"
    - blks_read:
        usage: COUNTER
        description: "Прочитано блоков с диска"
    - blks_hit:
        usage: COUNTER
        description: "Найдено блоков в кэше"
    - cache_hit_ratio:
        usage: GAUGE
        description: "Процент попаданий в кэш буферов (%)"
    - tup_returned:
        usage: COUNTER
        description: "Строк возвращено запросами"
    - tup_fetched:
        usage: COUNTER
        description: "Строк получено (index scan)"
    - tup_inserted:
        usage: COUNTER
        description: "Строк вставлено"
    - tup_updated:
        usage: COUNTER
        description: "Строк обновлено"
    - tup_deleted:
        usage: COUNTER
        description: "Строк удалено"
    - conflicts:
        usage: COUNTER
        description: "Конфликты восстановления (реплика)"
    - temp_files:
        usage: COUNTER
        description: "Временных файлов создано"
    - temp_bytes:
        usage: COUNTER
        description: "Байт записано во временные файлы"
    - deadlocks:
        usage: COUNTER
        description: "Взаимоблокировки (deadlocks)"
    - blk_read_time:
        usage: COUNTER
        description: "Время чтения блоков (мс)"
    - blk_write_time:
        usage: COUNTER
        description: "Время записи блоков (мс)"

# =============================================================================
# pg_stat_statements — топ запросов по нагрузке
# =============================================================================
pg_stat_statements_top:
  query: |
    SELECT
      pg_database.datname,
      pg_stat_statements.queryid::text AS queryid,
      left(regexp_replace(query, '\s+', ' ', 'g'), 100) AS query_short,
      calls,
      total_exec_time / 1000.0 AS total_exec_time_seconds,
      mean_exec_time / 1000.0  AS mean_exec_time_seconds,
      min_exec_time  / 1000.0  AS min_exec_time_seconds,
      max_exec_time  / 1000.0  AS max_exec_time_seconds,
      stddev_exec_time / 1000.0 AS stddev_exec_time_seconds,
      rows,
      shared_blks_hit,
      shared_blks_read,
      shared_blks_dirtied,
      shared_blks_written,
      local_blks_hit,
      local_blks_read,
      temp_blks_read,
      temp_blks_written,
      blk_read_time / 1000.0 AS blk_read_time_seconds,
      blk_write_time / 1000.0 AS blk_write_time_seconds
    FROM pg_stat_statements
    JOIN pg_database ON pg_database.oid = pg_stat_statements.dbid
    WHERE pg_database.datname NOT IN ('template0', 'template1')
      AND calls > 5
    ORDER BY total_exec_time DESC
    LIMIT 50
  metrics:
    - datname:
        usage: LABEL
        description: "Имя базы данных"
    - queryid:
        usage: LABEL
        description: "ID запроса"
    - query_short:
        usage: LABEL
        description: "Начало текста запроса"
    - calls:
        usage: COUNTER
        description: "Кол-во вызовов запроса"
    - total_exec_time_seconds:
        usage: COUNTER
        description: "Суммарное время выполнения (сек)"
    - mean_exec_time_seconds:
        usage: GAUGE
        description: "Среднее время выполнения (сек)"
    - min_exec_time_seconds:
        usage: GAUGE
        description: "Минимальное время выполнения (сек)"
    - max_exec_time_seconds:
        usage: GAUGE
        description: "Максимальное время выполнения (сек)"
    - stddev_exec_time_seconds:
        usage: GAUGE
        description: "Стандартное отклонение времени выполнения (сек)"
    - rows:
        usage: COUNTER
        description: "Строк обработано"
    - shared_blks_hit:
        usage: COUNTER
        description: "Попаданий в shared buffer"
    - shared_blks_read:
        usage: COUNTER
        description: "Блоков прочитано с диска"
    - shared_blks_dirtied:
        usage: COUNTER
        description: "Блоков помечено как dirty"
    - shared_blks_written:
        usage: COUNTER
        description: "Блоков записано"
    - temp_blks_read:
        usage: COUNTER
        description: "Temp блоков прочитано"
    - temp_blks_written:
        usage: COUNTER
        description: "Temp блоков записано"
    - blk_read_time_seconds:
        usage: COUNTER
        description: "Время чтения блоков (сек)"
    - blk_write_time_seconds:
        usage: COUNTER
        description: "Время записи блоков (сек)"

# =============================================================================
# pg_stat_activity — активные соединения и запросы в реальном времени
# =============================================================================
pg_stat_activity_detail:
  query: |
    SELECT
      datname,
      state,
      wait_event_type,
      wait_event,
      count(*) AS count
    FROM pg_stat_activity
    WHERE datname IS NOT NULL
      AND datname NOT IN ('template0', 'template1')
    GROUP BY datname, state, wait_event_type, wait_event
  metrics:
    - datname:
        usage: LABEL
        description: "Имя БД"
    - state:
        usage: LABEL
        description: "Состояние соединения (active, idle, idle in transaction...)"
    - wait_event_type:
        usage: LABEL
        description: "Тип ожидания"
    - wait_event:
        usage: LABEL
        description: "Событие ожидания"
    - count:
        usage: GAUGE
        description: "Кол-во соединений в данном состоянии"

# =============================================================================
# pg_stat_activity — долгие запросы (> 30 секунд)
# =============================================================================
pg_long_running_queries:
  query: |
    SELECT
      datname,
      usename,
      state,
      count(*) AS count,
      max(extract(epoch from (now() - query_start)))::int AS max_duration_seconds
    FROM pg_stat_activity
    WHERE state != 'idle'
      AND query_start IS NOT NULL
      AND (now() - query_start) > interval '30 seconds'
      AND datname IS NOT NULL
    GROUP BY datname, usename, state
  metrics:
    - datname:
        usage: LABEL
        description: "Имя БД"
    - usename:
        usage: LABEL
        description: "Пользователь"
    - state:
        usage: LABEL
        description: "Состояние запроса"
    - count:
        usage: GAUGE
        description: "Кол-во долгих запросов"
    - max_duration_seconds:
        usage: GAUGE
        description: "Максимальная длительность долгого запроса (сек)"

# =============================================================================
# pg_stat_bgwriter — checkpoint и background writer статистика
# =============================================================================
pg_stat_bgwriter:
  query: |
    SELECT
      checkpoints_timed,
      checkpoints_req,
      checkpoint_write_time,
      checkpoint_sync_time,
      buffers_checkpoint,
      buffers_clean,
      maxwritten_clean,
      buffers_backend,
      buffers_backend_fsync,
      buffers_alloc,
      stats_reset
    FROM pg_stat_bgwriter
  metrics:
    - checkpoints_timed:
        usage: COUNTER
        description: "Checkpoint по расписанию"
    - checkpoints_req:
        usage: COUNTER
        description: "Checkpoint по требованию"
    - checkpoint_write_time:
        usage: COUNTER
        description: "Время записи при checkpoint (мс)"
    - checkpoint_sync_time:
        usage: COUNTER
        description: "Время синхронизации при checkpoint (мс)"
    - buffers_checkpoint:
        usage: COUNTER
        description: "Буферов записано при checkpoint"
    - buffers_clean:
        usage: COUNTER
        description: "Буферов записано bgwriter"
    - maxwritten_clean:
        usage: COUNTER
        description: "Раз bgwriter остановлен из-за превышения лимита"
    - buffers_backend:
        usage: COUNTER
        description: "Буферов записано напрямую backend"
    - buffers_alloc:
        usage: COUNTER
        description: "Буферов выделено"

# =============================================================================
# pg_stat_user_tables — статистика по таблицам (seq scan vs index scan)
# =============================================================================
pg_stat_user_tables:
  query: |
    SELECT
      schemaname,
      relname,
      seq_scan,
      seq_tup_read,
      idx_scan,
      idx_tup_fetch,
      n_tup_ins,
      n_tup_upd,
      n_tup_del,
      n_tup_hot_upd,
      n_live_tup,
      n_dead_tup,
      n_mod_since_analyze,
      vacuum_count,
      autovacuum_count,
      analyze_count,
      autoanalyze_count
    FROM pg_stat_user_tables
    WHERE schemaname NOT IN ('pg_catalog', 'information_schema')
  metrics:
    - schemaname:
        usage: LABEL
        description: "Схема"
    - relname:
        usage: LABEL
        description: "Таблица"
    - seq_scan:
        usage: COUNTER
        description: "Sequential scan"
    - seq_tup_read:
        usage: COUNTER
        description: "Строк прочитано seq scan"
    - idx_scan:
        usage: COUNTER
        description: "Index scan"
    - idx_tup_fetch:
        usage: COUNTER
        description: "Строк получено через индекс"
    - n_tup_ins:
        usage: COUNTER
        description: "Строк вставлено"
    - n_tup_upd:
        usage: COUNTER
        description: "Строк обновлено"
    - n_tup_del:
        usage: COUNTER
        description: "Строк удалено"
    - n_live_tup:
        usage: GAUGE
        description: "Живых строк в таблице"
    - n_dead_tup:
        usage: GAUGE
        description: "Мёртвых строк (требуют VACUUM)"
    - vacuum_count:
        usage: COUNTER
        description: "Ручных VACUUM"
    - autovacuum_count:
        usage: COUNTER
        description: "Авто VACUUM"
    - analyze_count:
        usage: COUNTER
        description: "Ручных ANALYZE"
    - autoanalyze_count:
        usage: COUNTER
        description: "Авто ANALYZE"

# =============================================================================
# pg_locks — блокировки
# =============================================================================
pg_locks_detail:
  query: |
    SELECT
      pg_database.datname,
      pg_locks.mode,
      count(*) AS count
    FROM pg_locks
    LEFT JOIN pg_database ON pg_locks.database = pg_database.oid
    WHERE pg_database.datname IS NOT NULL
    GROUP BY pg_database.datname, pg_locks.mode
  metrics:
    - datname:
        usage: LABEL
        description: "Имя БД"
    - mode:
        usage: LABEL
        description: "Тип блокировки"
    - count:
        usage: GAUGE
        description: "Кол-во блокировок данного типа"

# =============================================================================
# pg_replication — лаг репликации (если есть реплики)
# =============================================================================
pg_replication_lag:
  query: |
    SELECT
      client_addr::text AS client_addr,
      application_name,
      state,
      sync_state,
      CASE WHEN pg_is_in_recovery() THEN 0
           ELSE COALESCE(extract(epoch from (now() - pg_last_xact_replay_timestamp()))::int, 0)
      END AS replication_lag_seconds,
      CASE WHEN sent_lsn IS NOT NULL AND replay_lsn IS NOT NULL
           THEN (sent_lsn - replay_lsn)::bigint
           ELSE 0
      END AS replication_lag_bytes
    FROM pg_stat_replication
  metrics:
    - client_addr:
        usage: LABEL
        description: "Адрес реплики"
    - application_name:
        usage: LABEL
        description: "Имя приложения реплики"
    - state:
        usage: LABEL
        description: "Состояние репликации"
    - sync_state:
        usage: LABEL
        description: "Режим синхронизации"
    - replication_lag_seconds:
        usage: GAUGE
        description: "Лаг репликации (сек)"
    - replication_lag_bytes:
        usage: GAUGE
        description: "Лаг репликации (байт)"

# =============================================================================
# pg_database_size — размер баз данных
# =============================================================================
pg_database_size:
  query: |
    SELECT
      datname,
      pg_database_size(datname) AS size_bytes
    FROM pg_database
    WHERE datname NOT IN ('template0', 'template1')
      AND datname IS NOT NULL
  metrics:
    - datname:
        usage: LABEL
        description: "Имя БД"
    - size_bytes:
        usage: GAUGE
        description: "Размер БД в байтах"

# =============================================================================
# pg_connections_limit — утилизация лимита подключений
# =============================================================================
pg_connections_limit:
  query: |
    SELECT
      datname,
      datconnlimit AS connection_limit,
      count(pid) AS active_connections,
      CASE WHEN datconnlimit = -1 THEN 0
           ELSE round(count(pid) * 100.0 / datconnlimit, 2)
      END AS connection_usage_pct
    FROM pg_database
    LEFT JOIN pg_stat_activity USING (datname)
    WHERE datname NOT IN ('template0', 'template1')
      AND datname IS NOT NULL
    GROUP BY datname, datconnlimit
  metrics:
    - datname:
        usage: LABEL
        description: "Имя БД"
    - connection_limit:
        usage: GAUGE
        description: "Лимит подключений (-1 = unlimited)"
    - active_connections:
        usage: GAUGE
        description: "Активных подключений"
    - connection_usage_pct:
        usage: GAUGE
        description: "Процент использования лимита подключений"
YAML

sudo chown postgres_exporter:postgres_exporter /etc/postgres_exporter/queries.yaml
```

