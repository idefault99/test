def add_prefix(request, **kwargs):
    parsed = urlsplit(request.url)
    new_path = MINIO_PREFIX + parsed.path
    print(f"[before-send] path before: {parsed.path}")
    print(f"[before-send] path after:  {new_path}")
    request.url = urlunsplit((
        parsed.scheme, parsed.netloc,
        new_path, parsed.query, parsed.fragment,
    ))
    print(f"[before-send] {request.method} {request.url}")
