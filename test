for node in coparking-5 coparking-6 coparking-7 coparking-8 coparking-9 coparking-10; do
  echo "=== $node ==="
  ssh ikbelykh@$node sudo bash << 'EOF'
    mkdir -p /etc/containerd/certs.d/registry.test.model.svo.aero
    cat > /etc/containerd/certs.d/registry.test.model.svo.aero/hosts.toml << 'TOML'
server = "https://registry.test.model.svo.aero"

[host."https://registry.test.model.svo.aero"]
  capabilities = ["pull", "resolve", "push"]
  skip_verify = true
TOML
    grep -q 'config_path' /etc/containerd/config.toml || \
      sed -i '/^\[plugins\."io\.containerd\.grpc\.v1\.cri"\]$/a\  config_path = "/etc/containerd/certs.d"' \
        /etc/containerd/config.toml
    systemctl restart containerd
    sleep 2
    systemctl is-active containerd && echo "OK: $(grep config_path /etc/containerd/config.toml)"
EOF
done
