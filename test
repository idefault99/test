stages:
  - dump
  - upload

dump:
  stage: dump
  image: python:3.12
  before_script:
    - pip install ansible
  script:
    - ansible-playbook ansible/backup_probegi.yml
  artifacts:
    expire_in: 7 days
    paths:
      - dump/*.sql.gz

upload:
  stage: upload
  image: minio/mc
  script:
    - mc alias set minio $MINIO_ENDPOINT $MINIO_ACCESS_KEY $MINIO_SECRET_KEY
    - mc cp dump/*.sql.gz minio/$MINIO_BUCKET/