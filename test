apiVersion: v1
kind: ConfigMap
metadata:
  name: nvidia-plugin-config
  namespace: gpu-operator
data:
  tesla-t4: |
    version: v1
    flags:
      migStrategy: none
    sharing:
      timeSlicing:
        renameByDefault: false
        resources:
          - name: nvidia.com/gpu
            replicas: 16
---
kubectl apply -f nvidia-plugin-config.yaml

kubectl patch clusterpolicy $(kubectl get clusterpolicy -o jsonpath='{.items[0].metadata.name}') \
  --type merge \
  -p '{"spec":{"devicePlugin":{"config":{"name":"nvidia-plugin-config","default":"tesla-t4"}}}}'
---
kubectl -n gpu-operator rollout restart ds/nvidia-device-plugin-daemonset
kubectl -n gpu-operator rollout restart ds/gpu-feature-discovery
