variables:
  RELEASE_NAME: audit
  REGISTRY_PATH: audit/audit
  # убираем KUBECONFIG: $KUBE_CONF_2

.deploy:
  script:
    - |
      helm upgrade --kubeconfig $KUBE_CONF_2 -i -n $NAMESPACE ${RELEASE_NAME} ./Helm -f $VALUES \
        --set "images.main=${CI_REGISTRY_IMAGE}:${TAG}.bin" \
        --set "images.migrations=${CI_REGISTRY_IMAGE}:${TAG}.migrations"
