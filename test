{{ if eq .Release.Namespace "default" }}
{{- fail "Default namespace not available for this helm chart"}}
{{ end }}
{{ if empty .Values.ingressDomain }}
{{- fail ".Values.ingressDomain should be present, cannot be empty. Use --set for this"}}
{{ end }}

############### Protected Endpoints (with auth) ###############
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ .Values.ingressDomain }}-ingress-not-free
  namespace: {{ .Release.Namespace }}
  annotations:
    nginx.ingress.kubernetes.io/proxy-body-size: {{ .Values.ingressSettings.maxBodySize }}
    nginx.ingress.kubernetes.io/proxy-buffer-size: "128k"
    nginx.ingress.kubernetes.io/proxy-buffers: "4 256k"
    nginx.ingress.kubernetes.io/proxy-busy-buffers-size: "256k"
    nginx.ingress.kubernetes.io/cors-allow-origin: '*'
    # Проверка токена через keycloak userinfo
    nginx.ingress.kubernetes.io/auth-url: http://{{ .Values.labels.keycloak }}-service.{{ .Release.Namespace }}.svc.{{ .Values.localK8sDomain }}:{{ .Values.ports.internal.back }}/keycloak/realms/{{ .Values.realmName }}/protocol/openid-connect/userinfo
    # Кэш по токену из cookie или заголовка
    nginx.ingress.kubernetes.io/auth-cache-key: "$cookie_access_token$http_authorization"
    # При 401 — редирект на /auth с возвратом на исходный URL
    nginx.ingress.kubernetes.io/auth-signin: https://{{ .Values.ingressDomain }}/auth?redirect=$escaped_request_uri
    nginx.ingress.kubernetes.io/auth-snippet: |
      # Пробрасываем токен из cookie или заголовка
      set $access_token "";
      if ($cookie_access_token) {
        set $access_token "$cookie_token_type $cookie_access_token";
      }
      if ($http_authorization) {
        set $access_token "$http_authorization";
      }
      proxy_set_header Authorization $access_token;
spec:
  ingressClassName: {{ .Values.ingressClassName }}
  {{ if eq .Values.TLS.enable true }}
  tls:
    - hosts:
        - {{ .Values.ingressDomain }}
      secretName: {{ tpl .Values.TLS.secret . }}
  {{ end }}
  rules:
  - host: {{ .Values.ingressDomain }}
    http:
      paths:
      # ── 4 бэкенда через external-сервис ──────────────────────────────────
      - path: /api/backone
        pathType: Prefix
        backend:
          service:
            name: {{ .Values.labels.external }}-service
            port:
              number: {{ .Values.ports.internal.back }}
      - path: /api/backtwo
        pathType: Prefix
        backend:
          service:
            name: {{ .Values.labels.external }}-service
            port:
              number: {{ .Values.ports.internal.back }}
      - path: /api/backthree
        pathType: Prefix
        backend:
          service:
            name: {{ .Values.labels.external }}-service
            port:
              number: {{ .Values.ports.internal.back }}
      - path: /api/backfour
        pathType: Prefix
        backend:
          service:
            name: {{ .Values.labels.external }}-service
            port:
              number: {{ .Values.ports.internal.back }}
{{ if eq .Values.enableModules.mapserver true }}
      # ── Mapserver ─────────────────────────────────────────────────────────
      - path: /api/v1/{{ .Values.labels.mapserver.share }}
        pathType: Prefix
        backend:
          service:
            name: {{ .Release.Namespace }}-{{ .Values.labels.mapserver.share }}-cs
            port:
              number: {{ .Values.ports.internal.back }}
{{ end }}

---
############### S3 Minio Endpoints ###############
{{ if eq .Values.enableService.s3minio true }}
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ .Values.ingressDomain }}-ingress-s3minio
  namespace: {{ .Release.Namespace }}
  annotations:
    nginx.ingress.kubernetes.io/proxy-body-size: {{ .Values.ingressSettings.maxBodySize }}
    nginx.ingress.kubernetes.io/proxy-buffer-size: "128k"
    nginx.ingress.kubernetes.io/proxy-buffers: "4 256k"
    nginx.ingress.kubernetes.io/proxy-busy-buffers-size: "256k"
    nginx.ingress.kubernetes.io/rewrite-target: /$2
    nginx.ingress.kubernetes.io/use-regex: 'true'
    nginx.ingress.kubernetes.io/proxy-request-buffering: "off"
spec:
  ingressClassName: {{ .Values.ingressClassName }}
  {{ if eq .Values.TLS.enable true }}
  tls:
    - hosts:
        - {{ .Values.ingressDomain }}
      secretName: {{ tpl .Values.TLS.secret . }}
  {{ end }}
  rules:
  - host: {{ .Values.ingressDomain }}
    http:
      paths:
      - path: /api/s3minio(/|$)(.*)
        pathType: ImplementationSpecific
        backend:
          service:
            name: {{ .Values.labels.s3minio }}-api-service
            port:
              number: {{ .Values.ports.internal.s3minioAPI }}
      - path: /s3minio(/|$)(.*)
        pathType: ImplementationSpecific
        backend:
          service:
            name: {{ .Values.labels.s3minio }}-console-service
            port:
              number: {{ .Values.ports.internal.s3minioConsole }}
{{ end }}

---
############### Free (unprotected) Endpoints ###############
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ .Values.ingressDomain }}-ingress-free
  namespace: {{ .Release.Namespace }}
  annotations:
    nginx.ingress.kubernetes.io/proxy-body-size: {{ .Values.ingressSettings.maxBodySize }}
    nginx.ingress.kubernetes.io/proxy-buffer-size: "128k"
    nginx.ingress.kubernetes.io/proxy-buffers: "4 256k"
    nginx.ingress.kubernetes.io/proxy-busy-buffers-size: "256k"
    nginx.ingress.kubernetes.io/cors-allow-origin: '*'
spec:
  ingressClassName: {{ .Values.ingressClassName }}
  {{ if eq .Values.TLS.enable true }}
  tls:
    - hosts:
        - {{ .Values.ingressDomain }}
      secretName: {{ tpl .Values.TLS.secret . }}
  {{ end }}
  rules:
  - host: {{ .Values.ingressDomain }}
    http:
      paths:
      # ── Auth-страница (логин) — открытая ──────────────────────────────────
      # Фронт редиректит сюда неаутентифицированных: /auth?redirect=%2F
      # После входа фронт сам делает redirect обратно на /
      - path: /auth
        pathType: Prefix
        backend:
          service:
            name: {{ .Release.Namespace }}-{{ .Values.labels.auth.share }}-cs
            port:
              number: {{ .Values.ports.internal.back }}
      # ── /login — алиас для совместимости (опционально) ───────────────────
      - path: /login
        pathType: Prefix
        backend:
          service:
            name: {{ .Release.Namespace }}-{{ .Values.labels.auth.share }}-cs
            port:
              number: {{ .Values.ports.internal.back }}
      # ── Фронтенд — защищён через auth-url выше ───────────────────────────
      # ВАЖНО: этот путь должен быть ПОСЛЕ /auth и /login,
      # иначе Prefix "/" перехватит всё
      - path: /
        pathType: Prefix
        backend:
          service:
            name: {{ .Values.labels.front }}-service
            port:
              number: {{ .Values.ports.internal.front }}

---
############### Auth module protected endpoints ###############
{{ if eq .Values.enableModules.auth true }}
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ .Values.ingressDomain }}-ingress-auth-not-free
  namespace: {{ .Release.Namespace }}
  annotations:
    nginx.ingress.kubernetes.io/proxy-body-size: {{ .Values.ingressSettings.maxBodySize }}
    nginx.ingress.kubernetes.io/proxy-buffer-size: "128k"
    nginx.ingress.kubernetes.io/proxy-buffers: "4 256k"
    nginx.ingress.kubernetes.io/proxy-busy-buffers-size: "256k"
    nginx.ingress.kubernetes.io/rewrite-target: /$1
    nginx.ingress.kubernetes.io/use-regex: "true"
    nginx.ingress.kubernetes.io/cors-allow-origin: '*'
spec:
  ingressClassName: {{ .Values.ingressClassName }}
  {{ if eq .Values.TLS.enable true }}
  tls:
    - hosts:
        - {{ .Values.ingressDomain }}
      secretName: {{ tpl .Values.TLS.secret . }}
  {{ end }}
  rules:
  - host: {{ .Values.ingressDomain }}
    http:
      paths:
      - path: /api/auth/(.*)
        pathType: ImplementationSpecific
        backend:
          service:
            name: {{ .Release.Namespace }}-{{ .Values.labels.auth.share }}-cs
            port:
              number: {{ .Values.ports.internal.back }}
{{ end }}
