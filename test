## Шаг 5 — Установка ESO в MicroK8s

**Где:** MicroK8s нода.

**Запуск:**

```bash
# Скопировать CA cert с Vault VM
scp root@vault-vm:/opt/vault/tls/ca.crt ./vault-ca.crt

# Запустить
bash install-eso.sh https://vault.test.ru:8200 ./vault-ca.crt
```

**Что делает:** создаёт namespace `external-secrets`, устанавливает ESO через Helm, создаёт `ServiceAccount external-secrets` с long-lived токеном, прокидывает Vault CA cert как `ConfigMap`, создаёт `ClusterRole` и `ClusterRoleBinding`.

```bash
#!/bin/bash
# install-eso.sh — Установка External Secrets Operator в MicroK8s (без ClusterSecretStore)
# Запускать на ноде MicroK8s один раз для всего кластера.
#
# Использование:
#   bash install-eso.sh [CHART_PATH]
#
# Пример:
#   bash install-eso.sh                      # установка из репозитория
#   bash install-eso.sh ./external-secrets-0.10.5.tgz
set -euo pipefail

CHART_PATH="${1:-}"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
log()     { echo -e "${GREEN}[INFO]${NC}  $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()     { echo -e "${RED}[ERR]${NC}   $*"; exit 1; }
section() { echo -e "\n${CYAN}══════ $* ══════${NC}"; }

KUBECTL="microk8s kubectl"
HELM="microk8s helm3"

command -v microk8s > /dev/null || err "microk8s не найден"
${KUBECTL} cluster-info > /dev/null 2>&1 || err "MicroK8s кластер недоступен"

section "1. Namespace external-secrets"
${KUBECTL} create namespace external-secrets --dry-run=client -o yaml | ${KUBECTL} apply -f -
log "Namespace external-secrets готов"

section "2. Установка External Secrets Operator"

if [[ -n "${CHART_PATH}" && -f "${CHART_PATH}" ]]; then
  log "Установка из локального чарта: ${CHART_PATH}"
  ${HELM} upgrade --install external-secrets \
    "${CHART_PATH}" \
    --namespace external-secrets \
    --set installCRDs=true \
    --set webhook.port=9443 \
    --wait --timeout=3m
elif [[ -n "${CHART_PATH}" ]]; then
  err "Указан путь к чарту, но файл не найден: ${CHART_PATH}"
else
  log "Локальный чарт не задан, устанавливаю из репозитория external-secrets"
  ${HELM} repo add external-secrets https://charts.external-secrets.io 2>/dev/null || true
  ${HELM} repo update
  ${HELM} upgrade --install external-secrets \
    external-secrets/external-secrets \
    --namespace external-secrets \
    --set installCRDs=true \
    --set webhook.port=9443 \
    --wait --timeout=3m
fi

log "ESO установлен, ожидаем готовности подов..."
${KUBECTL} wait --for=condition=available deployment external-secrets -n external-secrets --timeout=120s
${KUBECTL} wait --for=condition=available deployment external-secrets-webhook -n external-secrets --timeout=120s
log "ESO поды работают"

section "3. ServiceAccount для Vault Kubernetes Auth"
${KUBECTL} apply -f - <<EOF
apiVersion: v1
kind: ServiceAccount
metadata:
  name: external-secrets
  namespace: external-secrets
---
apiVersion: v1
kind: Secret
metadata:
  name: external-secrets-token
  namespace: external-secrets
  annotations:
    kubernetes.io/service-account.name: external-secrets
type: kubernetes.io/service-account-token
EOF

log "Ожидаем SA token..."
TOKEN=""
for i in $(seq 1 30); do
  TOKEN=$(${KUBECTL} get secret external-secrets-token -n external-secrets \
    -o jsonpath='{.data.token}' 2>/dev/null | base64 -d 2>/dev/null || true)
  if [[ -n "${TOKEN}" ]]; then break; fi
  sleep 2
done

[[ -n "${TOKEN:-}" ]] || err "SA token не получен за 60 сек"
log "SA token получен (длина: ${#TOKEN} символов)"

section "4. ClusterRole для ESO"
${KUBECTL} apply -f - <<EOF
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: external-secrets-controller
rules:
  # Права на обычные Secret'ы
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  # Права на создание ServiceAccount token (если нужно)
  - apiGroups: [""]
    resources: ["serviceaccounts/token"]
    verbs: ["create"]
  # Права на чтение namespace (необходимо для ClusterSecretStore)
  - apiGroups: [""]
    resources: ["namespaces"]
    verbs: ["get", "list", "watch"]
  # Права на все ресурсы external-secrets.io (включая ClusterSecretStore, ExternalSecret и др.)
  - apiGroups: ["external-secrets.io"]
    resources: ["*"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
EOF
log "ClusterRole и ClusterRoleBinding созданы"

section "Готово! ESO установлен, можно создавать ClusterSecretStore для каждого стенда."
echo ""
echo -e "${CYAN}Далее для каждого стенда запустите:${NC}"
echo "  bash create-clustersecretstore.sh <VAULT_ADDR> <VAULT_CA_FILE> <STAND_NAME> <VAULT_ROLE>"
echo ""
echo "Пример:"
echo "  bash create-clustersecretstore.sh https://vault.test.ru:8200 ./vault-ca.crt test-stand test-stand"
```
## Шаг 5.1 — создание ClusterSecretStore для конкретного стенда в MicroK8s

**Где:** MicroK8s нода.

**Запуск:**

```bash
#!/bin/bash
# create-clustersecretstore.sh — Создание ClusterSecretStore для одного стенда
# Запускать после install-eso.sh, для каждого стенда отдельно.
#
# Использование:
#   bash create-clustersecretstore.sh <VAULT_ADDR> <VAULT_CA_CERT_PATH> <STAND_NAME> <VAULT_ROLE>
#
# Пример:
#   bash create-clustersecretstore.sh https://vault.test.ru ./vault-ca.crt test-stand test-stand
set -euo pipefail

VAULT_ADDR="${1:?Укажи VAULT_ADDR, например https://vault.test.ru:8200}"
VAULT_CA_FILE="${2:?Укажи путь к ca.crt от Vault, например ./vault-ca.crt}"
STAND_NAME="${3:?Укажи имя стенда (например, test-stand)}"
VAULT_ROLE="${4:?Укажи Vault роль, созданную в setup-vault.sh (например, test-stand)}"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
log()     { echo -e "${GREEN}[INFO]${NC}  $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()     { echo -e "${RED}[ERR]${NC}   $*"; exit 1; }
section() { echo -e "\n${CYAN}══════ $* ══════${NC}"; }

KUBECTL="microk8s kubectl"

[[ -f "${VAULT_CA_FILE}" ]] || err "CA cert не найден: ${VAULT_CA_FILE}"
command -v microk8s > /dev/null || err "microk8s не найден"
${KUBECTL} cluster-info > /dev/null 2>&1 || err "MicroK8s кластер недоступен"

section "Создание ConfigMap с CA сертификатом Vault (в namespace external-secrets)"
${KUBECTL} create configmap vault-ca \
  --from-file=ca.crt="${VAULT_CA_FILE}" \
  -n external-secrets \
  --dry-run=client -o yaml | ${KUBECTL} apply -f -
log "ConfigMap vault-ca создан (или уже существует)"

section "Создание ClusterSecretStore для стенда ${STAND_NAME}"
CLUSTER_STORE_NAME="vault-cluster-store-${STAND_NAME}"

${KUBECTL} apply -f - <<EOF
apiVersion: external-secrets.io/v1beta1
kind: ClusterSecretStore
metadata:
  name: ${CLUSTER_STORE_NAME}
spec:
  provider:
    vault:
      server: ${VAULT_ADDR}
      path: "stands"
      version: v2
      auth:
        kubernetes:
          mountPath: "kubernetes"
          role: ${VAULT_ROLE}
          serviceAccountRef:
            name: external-secrets
            namespace: external-secrets
      caProvider:
        type: ConfigMap
        name: vault-ca
        key: ca.crt
        namespace: external-secrets
EOF

log "Ожидаем, что ClusterSecretStore станет Valid..."
sleep 5
STATUS=$(${KUBECTL} get clustersecretstore "${CLUSTER_STORE_NAME}" -o jsonpath='{.status.conditions[?(@.type=="Ready")].status}' 2>/dev/null || echo "False")
if [[ "${STATUS}" == "True" ]]; then
  log "ClusterSecretStore ${CLUSTER_STORE_NAME} готов"
else
  warn "ClusterSecretStore пока не готов, проверьте: kubectl describe clustersecretstore ${CLUSTER_STORE_NAME}"
fi

section "Готово!"
echo ""
echo -e "${GREEN}╔══════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║   ClusterSecretStore для ${STAND_NAME} создан  ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${CYAN}Имя ClusterSecretStore: ${CLUSTER_STORE_NAME}${NC}"
echo -e "${CYAN}Теперь можно деплоить Helm чарт для этого стенда, указав в values.yaml:${NC}"
echo ""
echo "  secretStoreRef:"
echo "    kind: ClusterSecretStore"
echo "    name: ${CLUSTER_STORE_NAME}"
```

