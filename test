ssh root@coparking-5

export KUBECONFIG=/etc/kubernetes/admin.conf


# =====================================================================
# 1. БАЗОВАЯ ПРОВЕРКА КЛАСТЕРА
# =====================================================================

kubectl get nodes -o wide

kubectl get pods -A -o wide

kubectl get pods -A | grep -Ev 'Running|Completed|NAMESPACE' || true

kubectl get --raw='/readyz?verbose' | tail -n 30

curl -k --max-time 5 https://k8s-api:6443/healthz

curl -k --max-time 5 https://172.16.175.20:6443/healthz


# Ожидаемо:
#
# kubectl get nodes:
#   все 6 нод Ready
#
# curl:
#   ok
#
# get pods проблемных:
#   пусто


# =====================================================================
# 2. ДОБАВИТЬ РОЛИ И ЛЕЙБЛЫ НОД
# =====================================================================

# Worker role, чтобы вместо <none> было worker.
# Это косметический label, на работу кластера не влияет.

for n in coparking-8 coparking-9 coparking-10; do
  kubectl label node $n node-role.kubernetes.io/worker= --overwrite
done


# Control-plane ноды будут также использоваться как worker-ноды.
# Поэтому снимаем NoSchedule taint.

kubectl taint nodes coparking-5 coparking-6 coparking-7 \
  node-role.kubernetes.io/control-plane:NoSchedule- 2>/dev/null || true


# GPU-ноды:
# coparking-5, coparking-6, coparking-7, coparking-8

for n in coparking-5 coparking-6 coparking-7 coparking-8; do
  kubectl label node $n gpu=true --overwrite
done


# Ноды под stateful/workload storage placement:
# Kafka/MongoDB будем сажать преимущественно на coparking-9/10.
# Лучше не использовать общий label storage=true, чтобы не путать с Longhorn.

for n in coparking-9 coparking-10; do
  kubectl label node $n workload.storage=true --overwrite
done


# Longhorn-диски будут на всех 6 нодах.

for n in coparking-5 coparking-6 coparking-7 coparking-8 coparking-9 coparking-10; do
  kubectl label node $n node.longhorn.io/create-default-disk=true --overwrite
done


# Проверка labels/roles:

kubectl get nodes

kubectl get nodes --show-labels | grep -E 'coparking-|gpu=true|workload.storage=true|node.longhorn.io/create-default-disk=true'


# =====================================================================
# 3. ПРОВЕРИТЬ kube-vip
# =====================================================================

kubectl -n kube-system get pods -o wide | grep kube-vip

kubectl -n kube-system get lease plndr-cp-lock -o yaml | grep holderIdentity


# Проверить, на какой control-plane сейчас висит VIP.
# VIP должен быть только на одной CP-ноде.

for n in coparking-5 coparking-6 coparking-7; do
  echo "===== $n ====="
  ssh root@$n "ip -br a | grep 172.16.175.20 || true"
done


# Проверить kube-vip manifest на всех CP.
# Важно:
#   - есть env name: kubeconfig
#   - hostPath уже лучше вернуть на /etc/kubernetes/admin.conf
#   - mountPath /etc/kubernetes/admin.conf
#   - interface eno1
#   - address 172.16.175.20

for n in coparking-5 coparking-6 coparking-7; do
  echo "===== $n ====="
  ssh root@$n "grep -nE 'kubeconfig|admin.conf|super-admin.conf|vip_interface|address|leader|hostPath|mountPath|type:' /etc/kubernetes/manifests/kube-vip.yaml"
done


# Если где-то всё ещё используется super-admin.conf, лучше перевести на admin.conf.
# Делать только если /etc/kubernetes/admin.conf существует на всех CP.

for n in coparking-5 coparking-6 coparking-7; do
  echo "===== $n ====="
  ssh root@$n "ls -lah /etc/kubernetes/admin.conf"
done


# Перевод kube-vip с super-admin.conf на admin.conf:

for n in coparking-5 coparking-6 coparking-7; do
  ssh root@$n "cp /etc/kubernetes/manifests/kube-vip.yaml /etc/kubernetes/manifests/kube-vip.yaml.bak.$(date +%F-%H%M%S)"
  ssh root@$n "sed -i 's#path: /etc/kubernetes/super-admin.conf#path: /etc/kubernetes/admin.conf#g' /etc/kubernetes/manifests/kube-vip.yaml"
  ssh root@$n "systemctl restart kubelet"
done


# Проверка после перевода:

sleep 20

kubectl -n kube-system get pods -o wide | grep kube-vip

curl -k --max-time 5 https://k8s-api:6443/healthz

curl -k --max-time 5 https://172.16.175.20:6443/healthz


