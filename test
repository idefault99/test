# Сколько реально занимает в мегабайтах
sudo cat /proc/$(pgrep kubelite)/status | grep -E "VmRSS|VmPeak|VmSize"

# Детально по cgroup
sudo systemd-cgtop -m | head -20

# Лог — смотрим что происходит прямо сейчас
sudo journalctl -f -u snap.microk8s.daemon-kubelite --no-pager | head -50

# Размер базы dqlite
sudo du -sh /var/snap/microk8s/current/var/kubernetes/backend/

# Лог dqlite — ищем "compaction lag"
sudo journalctl -u snap.microk8s.daemon-k8s-dqlite --no-pager | tail -30

# Кол-во записей в базе (должно быть десятки тысяч, не сотни тысяч)
sudo /snap/microk8s/current/bin/dqlite \
  -s $(hostname -I | awk '{print $1}'):19001 \
  -c /var/snap/microk8s/current/var/kubernetes/backend/cluster.crt \
  -k /var/snap/microk8s/current/var/kubernetes/backend/cluster.key \
  k8s <<< "SELECT COUNT(*) FROM kine;"


# Проверить версию
snap info microk8s | grep installed

# Обновить до последнего стабильного
sudo snap refresh microk8s --channel=1.32/stable


# Проверить диск под dqlite
sudo hdparm -Tt /dev/sda   # или nvme0n1

# dd тест записи
sudo dd if=/dev/zero of=/tmp/test.img bs=1G count=1 oflag=dsync 2>&1
rm /tmp/test.img

# Смотреть медленные записи в логе
sudo journalctl -u snap.microk8s.daemon-kubelite --no-pager | \
  grep -i "stored in database\|slow\|timeout" | tail -20
