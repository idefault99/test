curl -s --header "PRIVATE-TOKEN: $TOKEN" \
"https://gitlab.com/api/v4/projects/$OLD_PROJECT_ID/variables?per_page=100" \
| jq -c '.[]' | while read var; do

  payload=$(echo "$var" | jq '{
    key: .key,
    value: .value,
    protected: .protected,
    masked: .masked,
    environment_scope: .environment_scope
  }')

  curl --request POST \
    --header "PRIVATE-TOKEN: $TOKEN" \
    --header "Content-Type: application/json" \
    --data "$payload" \
    "https://gitlab.com/api/v4/projects/$NEW_PROJECT_ID/variables"

done