[tool.poetry]
name = "minio-client"
version = "0.1.0"
description = "MinIO S3 client с поддержкой nginx subpath rewrite"
authors = ["Your Name <you@example.com>"]
packages = [{ include = "minio_client" }]

[tool.poetry.dependencies]
python = "^3.10"
boto3 = "^1.28"

[tool.poetry.group.dev.dependencies]
pytest = "^7.0"
pytest-mock = "^3.0"

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"



---
publish:
  stage: publish
  image: python:3.12
  script:
    - pip install poetry
    - poetry config repositories.nexus https://nexus.example.com/repository/pypi-hosted/
    - poetry config http-basic.nexus $NEXUS_USER $NEXUS_PASSWORD
    - poetry build
    - poetry publish --repository nexus
  only:
    - tags
