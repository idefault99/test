## Шаг 6 — Helm chart

**Где:** MicroK8s нода.

### Структура chart

```
charts/stand-secrets/
├── Chart.yaml
├── values.yaml
└── templates/
    ├── vault-ca-configmap.yaml
    ├── secret-store.yaml
    └── external-secret.yaml
```

### Что поправить в values.yaml

|Параметр               |Что изменить                    |
|-----------------------|--------------------------------|
|`vault.address`        |Домен или IP Vault VM           |
|`stand.name`           |Имя стенда (`stand-test`)       |
|`stand.infra.services` |Список инфра-сервисов и их ключи|
|`stand.apps[].suffix`  |Суффиксы app namespace-ов       |
|`stand.apps[].services`|Сервисы в каждом app namespace  |


> ⚠ Ключи в `values.yaml` должны совпадать с ключами в Vault. Например, если в Vault `vault kv put ... access-key=...`, то в values тоже `- access-key`.

### Деплой

```bash
# Скопировать CA cert (если ещё не скопировал)
scp root@vault-vm:/opt/vault/tls/ca.crt ./vault-ca.crt

# Деплой
helm upgrade --install stand-secrets ./charts/stand-secrets \
  --namespace stand-test \
  --values charts/stand-secrets/values.yaml \
  --set-file vault.caCert=./vault-ca.crt
```

### Chart.yaml

```yaml
apiVersion: v2
name: stand-secrets
description: |
  Vault ExternalSecrets для стенда.
  Деплоит SecretStore и ExternalSecret в каждый namespace стенда.
  Каждый сервис (deployment/statefulset) получает свой отдельный K8s Secret.
version: 1.0.0
keywords:
  - vault
  - external-secrets
  - secrets
```

### values.yaml

```yaml
# values.yaml — Настройки Vault + стенда
# Деплоить: helm upgrade --install stand-secrets ./charts/stand-secrets \
#             --namespace stand-test \
#             --values values.yaml \
#             --set-file vault.caCert=./vault-ca.crt

vault:
  # ⚠ ПОПРАВИТЬ: домен или IP твоей Vault VM
  address: "https://vault.internal:8200"

  # Mount KV v2 в Vault (создаётся в setup-vault.sh)
  kvMount: "stands"

  # Путь к kubernetes auth методу в Vault
  authPath: "kubernetes"

  # Имя ConfigMap с CA cert Vault (создаётся автоматически chart-ом)
  caConfigMap: "vault-ca"

  # CA cert — передавать через --set-file vault.caCert=./vault-ca.crt
  # Здесь оставить пустым
  caCert: ""

  # ServiceAccount ESO (создаётся в install-eso.sh)
  serviceAccount:
    name: "external-secrets"
    namespace: "external-secrets"

  # Как часто ESO синхронизирует секреты из Vault
  refreshInterval: "1h"

stand:
  # ⚠ ПОПРАВИТЬ: имя стенда
  # Определяет:
  #   - namespace инфры: stand.name (= "stand-test")
  #   - namespace приложений: stand.name + "-" + suffix (= "stand-test-appone")
  #   - путь в Vault: stands/stand.name/suffix/service
  name: "stand-test"

  # Инфра-namespace (= stand.name, без суффикса)
  # Путь в Vault: stands/stand-test/infra/<service>
  # Vault роль: stand-test-infra
  infra:
    services:
      # ⚠ ПОПРАВИТЬ: список инфра-сервисов и их ключи
      # Каждый сервис → отдельный K8s Secret в namespace stand-test

      - name: minio                          # vault path: stands/stand-test/infra/minio
        secretName: minio-vault-secret       # имя K8s Secret в namespace stand-test
        keys:
          - access-key
          - secret-key
          - endpoint

      - name: kafka                          # vault path: stands/stand-test/infra/kafka
        secretName: kafka-vault-secret
        keys:
          - bootstrap-servers
          - username
          - password

      - name: postgres                       # vault path: stands/stand-test/infra/postgres
        secretName: postgres-vault-secret
        keys:
          - host
          - port
          - username
          - password
          - database

      # Добавляй новые инфра-сервисы по аналогии:
      # - name: redis
      #   secretName: redis-vault-secret
      #   keys:
      #     - host
      #     - port
      #     - password

  # App namespace-ы
  apps:
    - suffix: "appone"                       # namespace: stand-test-appone
      services:
        - name: backend                      # vault path: stands/stand-test/appone/backend
          secretName: backend-vault-secret
          keys:
            - db-password
            - api-key
            - jwt-secret

        - name: worker                       # vault path: stands/stand-test/appone/worker
          secretName: worker-vault-secret
          keys:
            - db-password
            - queue-url

    - suffix: "apptwo"                       # namespace: stand-test-apptwo
      services:
        - name: backend
          secretName: backend-vault-secret
          keys:
            - db-password
            - api-key
            - jwt-secret

        - name: worker
          secretName: worker-vault-secret
          keys:
            - db-password
            - queue-url

    # Добавляй новые app namespace-ы по аналогии:
    # - suffix: "appthree"
    #   services:
    #     - name: backend
    #       secretName: backend-vault-secret
    #       keys:
    #         - db-password
```

### templates/vault-ca-configmap.yaml

```yaml
{{/*
  Прокидывает CA cert Vault в каждый namespace стенда.
  SecretStore ссылается на этот ConfigMap через caProvider.
*/}}
{{- $root := . }}
{{- $stand := .Values.stand.name }}
{{- $caCert := .Values.vault.caCert }}
{{- $caConfigMap := .Values.vault.caConfigMap }}

{{- if not $caCert }}
  {{- fail "vault.caCert не задан. Передай через: --set-file vault.caCert=./vault-ca.crt" }}
{{- end }}

{{/* ConfigMap в infra namespace (= stand.name) */}}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ $caConfigMap }}
  namespace: {{ $stand }}
  labels:
    app.kubernetes.io/managed-by: stand-secrets
    stand: {{ $stand }}
data:
  ca.crt: |
{{ $caCert | indent 4 }}

{{/* ConfigMap в каждом app namespace */}}
{{- range .Values.stand.apps }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ $caConfigMap }}
  namespace: {{ $stand }}-{{ .suffix }}
  labels:
    app.kubernetes.io/managed-by: stand-secrets
    stand: {{ $stand }}
data:
  ca.crt: |
{{ $caCert | indent 4 }}
{{- end }}
```

### templates/secret-store.yaml

```yaml
{{/*
  Создаёт SecretStore в каждом namespace стенда.
  Каждый SecretStore использует отдельную Vault роль →
  доступ только к своему пути в Vault.
*/}}
{{- $root := . }}
{{- $stand := .Values.stand.name }}
{{- $vault := .Values.vault }}

{{/* SecretStore для infra namespace */}}
---
apiVersion: external-secrets.io/v1beta1
kind: SecretStore
metadata:
  name: vault-backend
  namespace: {{ $stand }}
  labels:
    app.kubernetes.io/managed-by: stand-secrets
    stand: {{ $stand }}
    vault-role: {{ $stand }}-infra
spec:
  provider:
    vault:
      server: {{ $vault.address }}
      path: {{ $vault.kvMount }}
      version: v2
      auth:
        kubernetes:
          mountPath: {{ $vault.authPath }}
          role: {{ $stand }}-infra
          serviceAccountRef:
            name: {{ $vault.serviceAccount.name }}
            namespace: {{ $vault.serviceAccount.namespace }}
      caProvider:
        type: ConfigMap
        name: {{ $vault.caConfigMap }}
        key: ca.crt
        namespace: {{ $stand }}

{{/* SecretStore для каждого app namespace */}}
{{- range .Values.stand.apps }}
---
apiVersion: external-secrets.io/v1beta1
kind: SecretStore
metadata:
  name: vault-backend
  namespace: {{ $stand }}-{{ .suffix }}
  labels:
    app.kubernetes.io/managed-by: stand-secrets
    stand: {{ $stand }}
    vault-role: {{ $stand }}-{{ .suffix }}
spec:
  provider:
    vault:
      server: {{ $vault.address }}
      path: {{ $vault.kvMount }}
      version: v2
      auth:
        kubernetes:
          mountPath: {{ $vault.authPath }}
          role: {{ $stand }}-{{ .suffix }}
          serviceAccountRef:
            name: {{ $vault.serviceAccount.name }}
            namespace: {{ $vault.serviceAccount.namespace }}
      caProvider:
        type: ConfigMap
        name: {{ $vault.caConfigMap }}
        key: ca.crt
        namespace: {{ $stand }}-{{ .suffix }}
{{- end }}
```

### templates/external-secret.yaml

```yaml
{{/*
  Создаёт ExternalSecret для каждого сервиса в каждом namespace.

  Маппинг:
    Vault path: stands/<stand>/<suffix>/<service>
    K8s Secret: <secretName> в namespace <stand>-<suffix>
*/}}
{{- $root := . }}
{{- $stand := .Values.stand.name }}
{{- $vault := .Values.vault }}

{{/* ExternalSecrets для infra namespace */}}
{{- range .Values.stand.infra.services }}
{{- $svc := . }}
---
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{ $svc.secretName }}
  namespace: {{ $stand }}
  labels:
    app.kubernetes.io/managed-by: stand-secrets
    stand: {{ $stand }}
    vault-section: infra
    vault-service: {{ $svc.name }}
spec:
  refreshInterval: {{ $vault.refreshInterval }}
  secretStoreRef:
    name: vault-backend
    kind: SecretStore
  target:
    name: {{ $svc.secretName }}
    creationPolicy: Owner
    deletionPolicy: Retain
  data:
  {{- range $svc.keys }}
    - secretKey: {{ . }}
      remoteRef:
        key: {{ $stand }}/infra/{{ $svc.name }}
        property: {{ . }}
  {{- end }}
{{- end }}

{{/* ExternalSecrets для каждого app namespace */}}
{{- range .Values.stand.apps }}
{{- $app := . }}
{{- $appNs := printf "%s-%s" $stand $app.suffix }}

{{- range $app.services }}
{{- $svc := . }}
---
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{ $svc.secretName }}
  namespace: {{ $appNs }}
  labels:
    app.kubernetes.io/managed-by: stand-secrets
    stand: {{ $stand }}
    vault-section: {{ $app.suffix }}
    vault-service: {{ $svc.name }}
spec:
  refreshInterval: {{ $vault.refreshInterval }}
  secretStoreRef:
    name: vault-backend
    kind: SecretStore
  target:
    name: {{ $svc.secretName }}
    creationPolicy: Owner
    deletionPolicy: Retain
  data:
  {{- range $svc.keys }}
    - secretKey: {{ . }}
      remoteRef:
        key: {{ $stand }}/{{ $app.suffix }}/{{ $svc.name }}
        property: {{ . }}
  {{- end }}
{{- end }}
{{- end }}
```

