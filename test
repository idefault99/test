import boto3
from botocore.client import Config

# ==============================================================================
# ПЕРЕМЕННЫЕ ПОДКЛЮЧЕНИЯ
# ==============================================================================

# Адрес твоего MinIO сервера
# Берётся из конфига MinIO — это тот хост+порт, на котором запущен MinIO
# Пример: http://192.168.1.100:9000 или https://minio.example.com
MINIO_ENDPOINT = "http://localhost:9000"

# Access Key (логин)
# MinIO Console → Identity → Users → выбрать пользователя → Service Accounts
# Либо из переменной окружения при запуске MinIO: MINIO_ROOT_USER
MINIO_ACCESS_KEY = "your-access-key"

# Secret Key (пароль)
# Там же, где Access Key — генерируется при создании Service Account
# Либо из переменной окружения: MINIO_ROOT_PASSWORD
MINIO_SECRET_KEY = "your-secret-key"

# Регион — для MinIO не важен, но boto3 требует указать хоть что-то
MINIO_REGION = "us-east-1"

# Имя бакета с которым будем работать
# MinIO Console → Buckets — список доступных бакетов
BUCKET_NAME = "my-bucket"

# ==============================================================================
# КЛИЕНТ
# ==============================================================================

s3 = boto3.client(
    "s3",
    endpoint_url=MINIO_ENDPOINT,
    aws_access_key_id=MINIO_ACCESS_KEY,
    aws_secret_access_key=MINIO_SECRET_KEY,
    region_name=MINIO_REGION,
    config=Config(
        signature_version="s3v4",   # MinIO требует именно v4
        connect_timeout=10,
        read_timeout=30,
        retries={"max_attempts": 3},
    ),
)

# ==============================================================================
# ПРИМЕРЫ ОПЕРАЦИЙ
# ==============================================================================

def list_buckets():
    """Список всех бакетов"""
    response = s3.list_buckets()
    print("Бакеты:")
    for bucket in response.get("Buckets", []):
        print(f"  - {bucket['Name']} (создан: {bucket['CreationDate']})")


def list_objects(bucket: str, prefix: str = ""):
    """Список объектов в бакете (с опциональным префиксом/папкой)"""
    paginator = s3.get_paginator("list_objects_v2")
    pages = paginator.paginate(Bucket=bucket, Prefix=prefix)
    print(f"Объекты в '{bucket}/{prefix}':")
    for page in pages:
        for obj in page.get("Contents", []):
            print(f"  {obj['Key']}  ({obj['Size']} bytes)")


def upload_file(local_path: str, bucket: str, object_key: str):
    """Загрузить файл в MinIO"""
    s3.upload_file(local_path, bucket, object_key)
    print(f"Загружено: {local_path} → s3://{bucket}/{object_key}")


def download_file(bucket: str, object_key: str, local_path: str):
    """Скачать файл из MinIO"""
    s3.download_file(bucket, object_key, local_path)
    print(f"Скачано: s3://{bucket}/{object_key} → {local_path}")


def upload_bytes(data: bytes, bucket: str, object_key: str, content_type: str = "application/octet-stream"):
    """Загрузить bytes-объект без сохранения на диск"""
    import io
    s3.upload_fileobj(io.BytesIO(data), bucket, object_key,
                      ExtraArgs={"ContentType": content_type})
    print(f"Загружено в памяти → s3://{bucket}/{object_key}")


def delete_object(bucket: str, object_key: str):
    """Удалить объект"""
    s3.delete_object(Bucket=bucket, Key=object_key)
    print(f"Удалено: s3://{bucket}/{object_key}")


def generate_presigned_url(bucket: str, object_key: str, expires_in: int = 3600) -> str:
    """Получить временную ссылку на скачивание (по умолчанию 1 час)"""
    url = s3.generate_presigned_url(
        "get_object",
        Params={"Bucket": bucket, "Key": object_key},
        ExpiresIn=expires_in,
    )
    print(f"Presigned URL: {url}")
    return url


def create_bucket(bucket: str):
    """Создать новый бакет"""
    s3.create_bucket(Bucket=bucket)
    print(f"Бакет создан: {bucket}")


