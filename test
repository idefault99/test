FROM registry.test:443/test:base-py-3.11 as base

ENV PYTHONWARNINGS="ignore:Unverified HTTPS request"
ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1

WORKDIR /app

COPY ./dev-requirements.txt /app
RUN python -m pip install --trusted-host pypi.org --trusted-host pypi.python.org --trusted-host files.pythonhosted.org -r dev-requirements.txt
RUN python -m pip install Nuitka==2.1.1 --trusted-host pypi.org --trusted-host files.pythonhosted.org

# Only for local useage for VSCode
FROM registry.test:443/test/python_dev_3.11:latest as base_develop

ARG UID
ARG GID
ARG USER_PASSWORD
ARG USER_NAME
ARG DEV_FOLDER

USER ${USER_NAME}
WORKDIR /home/${USER_NAME}/${DEV_FOLDER}
COPY --chown=${UID}:${GID} ./dev-requirements.txt .
RUN pip install --trusted-host pypi.org --trusted-host pypi.python.org --trusted-host files.pythonhosted.org -r dev-requirements.txt
# End of local useage for VSCode

FROM base as source

WORKDIR /app/code
COPY src src/

FROM source as build

RUN python -m nuitka --nofollow-imports --static-libpython=no --remove-output --no-pyi-file --output-dir=/app/code/ --jobs=4 \
    --include-package=src \
    src/main.py

FROM base as production
WORKDIR /app/code
COPY --from=build /app/code/main.bin .
