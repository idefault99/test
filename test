# В namespace: infra
apiVersion: v1
kind: Service
metadata:
  name: app-proxy
  namespace: infra
spec:
  type: ExternalName
  externalName: app-service.app-namespace.svc.cluster.local
  ports:
    - port: 80
      targetPort: 8080  # порт сервиса в app-namespace


apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: infra-ingress
  namespace: infra
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /app/$2
spec:
  rules:
    - host: your-host.example.com
      http:
        paths:
          - path: /api/v1/app(/|$)(.*)
            pathType: Prefix
            backend:
              service:
                name: app-proxy
                port:
                  number: 80
