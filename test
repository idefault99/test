# На ноде K8s — скопировать с Vault VM
scp root@vault-vm:/tmp/vault-ca-full.pem ./vault-ca-full.pem

# Пересоздать ConfigMap
microk8s kubectl delete configmap vault-ca -n external-secrets
microk8s kubectl create configmap vault-ca \
  --from-file=ca.crt=./vault-ca-full.pem \
  -n external-secrets

# Рестарт ESO
microk8s kubectl rollout restart deployment external-secrets -n external-secrets
microk8s kubectl rollout status deployment external-secrets -n external-secrets

# Проверить через 15 сек
microk8s kubectl get clustersecretstore vault-cluster-store-dev-devops
