## Управление чартами

```bash
# Создать новый чарт (scaffold структуры)
helm create <chart-name>
helm create my-app
# Создаёт директорию: Chart.yaml, values.yaml, templates/, charts/

# Запаковать чарт в .tgz архив
helm package <chart-dir>
helm package ./my-app/

# Запаковать с указанием версии
helm package ./my-app/ --version 1.2.0

# Запаковать с app version
helm package ./my-app/ --app-version v2.0.0

# Запаковать в конкретную директорию
helm package ./my-app/ -d ./releases/

# Подписать чарт при упаковке (требует GPG)
helm package ./my-app/ --sign --key "My Key" --keyring ~/.gnupg/secring.gpg

# Верифицировать подписанный чарт
helm verify my-app-1.0.0.tgz

# Загрузить зависимости (charts/) из Chart.yaml dependencies
helm dependency update <chart-dir>
helm dep update ./my-app/

# Собрать зависимости (без обращения к репозиториям, только из кэша)
helm dependency build ./my-app/

# Список зависимостей чарта
helm dependency list ./my-app/
```

