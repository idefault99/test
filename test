## Шаг 3 — Настройка Vault (политики, KV, Kubernetes Auth)

**Где:** Vault VM, от root.

**Что поправить перед запуском:**

|Переменная    |Что поставить                          |
|--------------|---------------------------------------|
|`K8S_HOST`    |URL API-сервера из шага 2              |
|`STANDS`      |Список стендов и их namespace-суффиксов|
|`SERVICES_MAP`|Сервисы для каждого суффикса           |

**Запуск:**

```bash
export VAULT_ADDR="https://vault.internal:8200"
export VAULT_CACERT="/opt/vault/tls/ca.crt"
export VAULT_TOKEN="<root_token из /root/vault-init.json>"

bash setup-vault.sh
```

**Что делает:** включает KV v2 на пути `stands/`, создаёт placeholder-секреты для каждого сервиса, создаёт Vault-политики (read only на свой путь), включает Kubernetes auth, создаёт роли для каждого namespace.

```bash
#!/bin/bash
# setup-vault.sh — Настройка Vault: KV v2, политики, Kubernetes auth
# Запускать на Vault VM от root после install-vault.sh
set -euo pipefail

# ══════════════════════════════════════════════════════════════
#   НАСТРОЙ ЭТИ ПЕРЕМЕННЫЕ ПОД СЕБЯ
# ══════════════════════════════════════════════════════════════

# Путь к CA cert кластера MicroK8s (скопирован в шаге 2)
K8S_CA_FILE="/root/k8s-ca.crt"

# URL API-сервера MicroK8s (из шага 2)
K8S_HOST="https://192.168.1.20:16443"    # ← поправь

# ServiceAccount ESO — создаётся в install-eso.sh
ESO_SA_NAME="external-secrets"
ESO_SA_NAMESPACE="external-secrets"

# Стенды и их namespace-суффиксы
# Формат: "имя_стенда:суффикс1 суффикс2 суффикс3"
# infra = сам неймспейс стенда (stand-test)
# остальные = stand-test-<суффикс>
STANDS=(
  "stand-test:infra appone apptwo"
  # "stand-prod:infra appone apptwo"   # ← добавляй новые стенды сюда
)

# Сервисы для каждого суффикса
# Формат: "суффикс:сервис1 сервис2 сервис3"
SERVICES_MAP=(
  "infra:minio kafka postgres"
  "appone:backend worker"
  "apptwo:backend worker"
)

# ══════════════════════════════════════════════════════════════

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
log()     { echo -e "${GREEN}[INFO]${NC}  $*"; }
err()     { echo -e "${RED}[ERR]${NC}   $*"; exit 1; }
section() { echo -e "\n${CYAN}══════ $* ══════${NC}"; }

: "${VAULT_ADDR:?Нужен VAULT_ADDR}"
: "${VAULT_TOKEN:?Нужен VAULT_TOKEN}"
: "${VAULT_CACERT:?Нужен VAULT_CACERT}"
[[ -f "${K8S_CA_FILE}" ]] || err "Файл ${K8S_CA_FILE} не найден"

vault status > /dev/null 2>&1 || err "Vault недоступен на ${VAULT_ADDR}"
log "Vault доступен"

get_services() {
  local suffix="$1"
  for entry in "${SERVICES_MAP[@]}"; do
    local key="${entry%%:*}"
    if [[ "${key}" == "${suffix}" ]]; then
      echo "${entry#*:}"
      return
    fi
  done
  echo ""
}

section "1. KV v2 на пути 'stands/'"
vault secrets enable -path=stands kv-v2 2>/dev/null \
  && log "KV v2 включён на stands/" \
  || log "KV v2 уже включён на stands/"

section "2. Placeholder-секреты, политики и роли Kubernetes"

for stand_entry in "${STANDS[@]}"; do
  STAND="${stand_entry%%:*}"
  SUFFIXES="${stand_entry#*:}"

  echo -e "\n${YELLOW}  Стенд: ${STAND}${NC}"

  for SUFFIX in ${SUFFIXES}; do

    if [[ "${SUFFIX}" == "infra" ]]; then
      K8S_NS="${STAND}"
    else
      K8S_NS="${STAND}-${SUFFIX}"
    fi

    POLICY_NAME="${STAND}-${SUFFIX}"
    ROLE_NAME="${STAND}-${SUFFIX}"
    SERVICES=$(get_services "${SUFFIX}")

    log "  namespace=${K8S_NS}, vault-path=stands/${STAND}/${SUFFIX}/"

    # Placeholder-секреты (не перезаписывают существующие)
    for SVC in ${SERVICES}; do
      VAULT_PATH="stands/${STAND}/${SUFFIX}/${SVC}"
      if ! vault kv get "${VAULT_PATH}" > /dev/null 2>&1; then
        vault kv put "${VAULT_PATH}" placeholder="REPLACE_ME" > /dev/null
        log "    Создан placeholder: ${VAULT_PATH}"
      else
        log "    Уже существует: ${VAULT_PATH} (не перезаписан)"
      fi
    done

    # Политика: только чтение своего пути
    vault policy write "${POLICY_NAME}" - <<EOF
# Политика для namespace ${K8S_NS}
# Доступ ТОЛЬКО к stands/${STAND}/${SUFFIX}/*

path "stands/data/${STAND}/${SUFFIX}/*" {
  capabilities = ["read"]
}

path "stands/metadata/${STAND}/${SUFFIX}/*" {
  capabilities = ["read", "list"]
}
EOF
    log "    Политика: ${POLICY_NAME}"

    # Kubernetes auth роль
    vault write "auth/kubernetes/role/${ROLE_NAME}" \
      bound_service_account_names="${ESO_SA_NAME}" \
      bound_service_account_namespaces="${ESO_SA_NAMESPACE}" \
      policies="${POLICY_NAME}" \
      ttl=1h \
      max_ttl=24h
    log "    Роль: ${ROLE_NAME} → SA ${ESO_SA_NAMESPACE}/${ESO_SA_NAME}"

  done
done

section "3. Kubernetes Auth"
vault auth enable kubernetes 2>/dev/null \
  && log "Kubernetes auth включён" \
  || log "Kubernetes auth уже включён"

K8S_CA=$(cat "${K8S_CA_FILE}")
vault write auth/kubernetes/config \
  kubernetes_host="${K8S_HOST}" \
  kubernetes_ca_cert="${K8S_CA}" \
  disable_iss_validation=true \
  disable_local_ca_jwt=false

log "Kubernetes auth настроен на ${K8S_HOST}"

section "Готово!"
echo ""
echo -e "${GREEN}╔══════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║         Vault настроен!                     ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${CYAN}Пути для заполнения реальными значениями:${NC}"
for stand_entry in "${STANDS[@]}"; do
  STAND="${stand_entry%%:*}"
  SUFFIXES="${stand_entry#*:}"
  for SUFFIX in ${SUFFIXES}; do
    SERVICES=$(get_services "${SUFFIX}")
    for SVC in ${SERVICES}; do
      echo "  vault kv put stands/${STAND}/${SUFFIX}/${SVC} key=value ..."
    done
  done
done
echo ""
echo -e "${CYAN}Следующий шаг:${NC}"
echo "  scp root@vault-vm:/opt/vault/tls/ca.crt ./vault-ca.crt"
echo "  bash install-eso.sh https://vault.internal:8200 ./vault-ca.crt"
```

