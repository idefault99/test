# 1. CoreDNS в порядке?
kubectl get pods -n kube-system | grep coredns

# 2. DNS работает из любого другого пода
kubectl run -it --rm dns-test --image=busybox:1.35 --restart=Never -- \
  sh -c "nslookup longhorn-backend.longhorn-system.svc.cluster.local && nslookup longhorn-backend.longhorn-system"

# 3. Что именно в nginx.conf longhorn-ui
kubectl get configmap -n longhorn-system | grep nginx
kubectl get configmap -n longhorn-system longhorn-ui -o yaml 2>/dev/null || \
  kubectl describe pod -n longhorn-system longhorn-ui-75779c679-9tdfv | grep -A5 "Volumes\|ConfigMap"

# 4. Успевает ли под запуститься — поймать логи до краша
kubectl logs -n longhorn-system -l app=longhorn-ui --previous 2>&1 | head -20
