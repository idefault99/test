# 1. Поднять MinIO как Pod или docker-контейнер на ноде
docker run -d --name minio \
  -p 9000:9000 -p 9001:9001 \
  -e MINIO_ROOT_USER=minioadmin \
  -e MINIO_ROOT_PASSWORD=minioadmin \
  -v /opt/minio-data:/data \
  quay.io/minio/minio server /data --console-address ":9001"

# 2. Создать bucket и залить туда содержимое архива
mc alias set local http://localhost:9000 minioadmin minioadmin
mc mb local/velero
# Распаковать архив в bucket (структура должна быть: velero/backups/<backup-name>/...)
mc cp --recursive ./velero-backup-extracted/ local/velero/

# 3. Указать Velero использовать этот MinIO
velero backup-location create local-minio \
  --provider aws \
  --bucket velero \
  --config region=minio,s3ForcePathStyle=true,s3Url=http://<NODE-IP>:9000 \
  --credential-key-file ./credentials-velero

# 4. Подождать sync (30 сек) и проверить
velero backup get
velero restore create --from-backup <backup-name>
