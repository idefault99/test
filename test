# Добавь эту функцию и пункт 18 в меню

interactive_psql() {
  header "Интерактивный psql | БД: $CURRENT_DB"
  echo "Запускается интерактивная сессия psql."
  echo "Для выхода введи \\q или нажми Ctrl+D"
  echo

  psql -h "$PGHOST" -p "$PGPORT" -U "$PGUSER" -d "$CURRENT_DB"
}


18) interactive_psql; pause ;;


echo "18) Интерактивный psql"
