## Шаг 3 — Настройка Vault (политики, KV, Kubernetes Auth)

**Где:** Vault VM, от root.

**Что поправить перед запуском:**

|Переменная    |Что поставить                          |
|--------------|---------------------------------------|
|`K8S_HOST`    |URL API-сервера из шага 2              |
|`STANDS`      |Список стендов и их namespace-суффиксов|
|`SERVICES_MAP`|Сервисы для каждого суффикса           |

**Запуск:**

```bash
export VAULT_ADDR="https://vault.test.ru:8200"
export VAULT_CACERT="/opt/vault/tls/ca.crt"
export VAULT_TOKEN="<root_token из /root/vault-init.json>"

bash setup-vault.sh
```

**Что делает:** включает KV v2 на пути `stands/`, создаёт placeholder-секреты для каждого сервиса, создаёт Vault-политики (read only на свой путь), включает Kubernetes auth, создаёт роли для каждого namespace.

```bash
#!/bin/bash
# setup-vault.sh — Настройка Vault: KV v2, политики, Kubernetes auth
# Идемпотентный, совместим с ClusterSecretStore (одна роль на стенд)
set -euo pipefail

# Путь к CA cert кластера MicroK8s (скопирован в шаге 2)
K8S_CA_FILE="/root/k8s-ca.crt"
K8S_HOST="https://192.168.0.137:16443"

# ServiceAccount ESO — создаётся в install-eso.sh
ESO_SA_NAME="external-secrets"
ESO_SA_NAMESPACE="external-secrets"

# Стенды и их namespace-суффиксы (только для создания placeholder'ов)
STANDS=(
  "test-stand:infra approvals audit"
)

# Сервисы для каждого суффикса (placeholder'ы)
SERVICES_MAP=(
  "infra:auth front kafka keycloak redis s3minio"
  "approvals:approvals redis"
  "audit:audit redis"
)

# ══════════════════════════════════════════════════════════════

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
log()     { echo -e "${GREEN}[INFO]${NC}  $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()     { echo -e "${RED}[ERR]${NC}   $*"; exit 1; }
section() { echo -e "\n${CYAN}══════ $* ══════${NC}"; }

# Проверка переменных окружения
: "${VAULT_ADDR:?Нужен VAULT_ADDR (например, export VAULT_ADDR=https://127.0.0.1:8200)}"
: "${VAULT_TOKEN:?Нужен VAULT_TOKEN}"
: "${VAULT_CACERT:?Нужен VAULT_CACERT}"

[[ -f "${K8S_CA_FILE}" ]] || err "Файл ${K8S_CA_FILE} не найден. Скопируйте CA кластера в /root/k8s-ca.crt"

# Проверяем доступность Vault и ждём, пока он станет активным (не sealed)
wait_vault_active() {
  log "Ожидаем активного состояния Vault..."
  for i in $(seq 1 30); do
    if vault status > /dev/null 2>&1; then
      local sealed=$(vault status -format=json | jq -r '.sealed')
      if [[ "${sealed}" == "false" ]]; then
        log "Vault активен и распечатан"
        return 0
      fi
    fi
    sleep 2
  done
  err "Vault не стал активным за 60 секунд"
}

wait_vault_active
log "Vault доступен"

# Helper: получить список сервисов для суффикса
get_services() {
  local suffix="$1"
  for entry in "${SERVICES_MAP[@]}"; do
    local key="${entry%%:*}"
    if [[ "${key}" == "${suffix}" ]]; then
      echo "${entry#*:}"
      return
    fi
  done
  echo ""
}

# ========== 1. Включение KV v2 ==========
section "1. KV v2 на пути 'stands/'"
vault secrets enable -path=stands kv-v2 2>/dev/null \
  && log "KV v2 включён на stands/" \
  || log "KV v2 уже включён на stands/"

# ========== 2. Настройка Kubernetes Auth ==========
section "2. Kubernetes Auth"
vault auth enable kubernetes 2>/dev/null \
  && log "Kubernetes auth включён" \
  || log "Kubernetes auth уже включён"

K8S_CA=$(cat "${K8S_CA_FILE}")
vault write auth/kubernetes/config \
  kubernetes_host="${K8S_HOST}" \
  kubernetes_ca_cert="${K8S_CA}" \
  disable_iss_validation=true \
  disable_local_ca_jwt=false > /dev/null
log "Kubernetes auth настроен на ${K8S_HOST}"

# ========== 3. Placeholder-секреты + единая политика и роль на стенд ==========
section "3. Placeholder-секреты, политика и роль Kubernetes"

for stand_entry in "${STANDS[@]}"; do
  STAND="${stand_entry%%:*}"
  SUFFIXES="${stand_entry#*:}"

  echo -e "\n${YELLOW}  Стенд: ${STAND}${NC}"

  # ---- Создаём placeholder-секреты для каждого суффикса/сервиса ----
  for SUFFIX in ${SUFFIXES}; do
    SERVICES=$(get_services "${SUFFIX}")
    for SVC in ${SERVICES}; do
      VAULT_PATH="stands/${STAND}/${SUFFIX}/${SVC}"
      if ! vault kv get "${VAULT_PATH}" > /dev/null 2>&1; then
        vault kv put "${VAULT_PATH}" placeholder="REPLACE_ME" > /dev/null
        log "    Создан placeholder: ${VAULT_PATH}"
      else
        log "    Уже существует: ${VAULT_PATH} (не перезаписан)"
      fi
    done
  done

  # ---- Одна политика на весь стенд (доступ ко всем путям stands/<stand>/*) ----
  POLICY_NAME="${STAND}"
  vault policy write "${POLICY_NAME}" - <<EOF
# Политика для стенда ${STAND}
# Доступ ко всем секретам stands/${STAND}/*
path "stands/data/${STAND}/*" {
  capabilities = ["read"]
}
path "stands/metadata/${STAND}/*" {
  capabilities = ["read", "list"]
}
EOF
  log "    Политика: ${POLICY_NAME} (доступ ко всему стенду)"

  # ---- Одна Kubernetes auth роль для всего стенда ----
  ROLE_NAME="${STAND}"
  vault write "auth/kubernetes/role/${ROLE_NAME}" \
    bound_service_account_names="${ESO_SA_NAME}" \
    bound_service_account_namespaces="${ESO_SA_NAMESPACE}" \
    policies="${POLICY_NAME}" \
    ttl=1h \
    max_ttl=24h > /dev/null
  log "    Роль: ${ROLE_NAME} → SA ${ESO_SA_NAMESPACE}/${ESO_SA_NAME}"
done

# ========== Готово ==========
section "Готово!"
echo ""
echo -e "${GREEN}╔══════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║         Vault настроен!                     ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${CYAN}Созданные placeholder-пути (заполните реальными значениями):${NC}"
for stand_entry in "${STANDS[@]}"; do
  STAND="${stand_entry%%:*}"
  SUFFIXES="${stand_entry#*:}"
  for SUFFIX in ${SUFFIXES}; do
    SERVICES=$(get_services "${SUFFIX}")
    for SVC in ${SERVICES}; do
      echo "  vault kv put stands/${STAND}/${SUFFIX}/${SVC} key=value ..."
    done
  done
done
echo ""
echo -e "${CYAN}Роль для ClusterSecretStore: ${YELLOW}${STAND}${NC} (имя стенда)"
echo -e "${CYAN}Пример запуска install-eso.sh:${NC}"
echo "  bash install-eso.sh https://vault.test.ru:8200 ./vault-ca.crt ${STAND}"
```

