{{- if and (eq .Values.enableService.redis.enable true) (eq .Values.enableService.redis.type "cluster") }}
{{- $modules := .Files.Get "files/redis_module.yaml" | fromYaml -}}
{{- range $module := $modules.main }}
{{- if or (index $.Values.enableModules $module) (eq $module "")}}
{{- $ns := printf "%s%s" $.Release.Namespace (ternary "" (printf "-%s" $module) (eq $module "")) }}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ $.Values.labels.redis }}-waiter-sa
  namespace: {{ $ns }}
automountServiceAccountToken: true
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: {{ $.Values.labels.redis }}-waiter-role
  namespace: {{ $ns }}
rules:
  - apiGroups: [""]
    resources: ["pods", "pods/status"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["apps"]
    resources: ["statefulsets"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ $.Values.labels.redis }}-waiter-rolebinding
  namespace: {{ $ns }}
subjects:
  - kind: ServiceAccount
    name: {{ $.Values.labels.redis }}-waiter-sa
    namespace: {{ $ns }}
roleRef:
  kind: Role
  name: {{ $.Values.labels.redis }}-waiter-role
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: batch/v1
kind: Job
metadata:
  name: {{ $.Values.labels.redis }}-job-{{ $.Release.Revision }}
  labels:
    app: {{ $.Values.labels.redis }}
  namespace: {{ $ns }}
  annotations:
    "helm.sh/hook": post-install,post-upgrade
    "helm.sh/hook-weight": "5"
    "helm.sh/hook-delete-policy": before-hook-creation
spec:
  backoffLimit: 3
  activeDeadlineSeconds: 600
  ttlSecondsAfterFinished: 300
  template:
    spec:
      serviceAccountName: {{ $.Values.labels.redis }}-waiter-sa
      restartPolicy: Never
      imagePullSecrets:
        - name: {{ $.Values.imagePullSecret }}
      initContainers:
        - name: wait-for-redis-nodes
          image: registry.test.model.svo.aero/dpm/iac/infra:kubectl
          command: ['sh', '-c']
          args:
            - |
              NS="{{ $ns }}"
              PREFIX="{{ $.Values.labels.redis }}-deployment"

              echo "==> Проверяем права..."
              kubectl auth can-i get pods -n $NS

              echo "==> Ждём появления и готовности всех 3 подов..."

              # StatefulSet создаёт поды по очереди: 0 → 1 → 2
              # Поэтому сначала ждём появления пода, потом его Ready
              for INDEX in 0 1 2; do
                POD="${PREFIX}-${INDEX}"
                echo "--- Ожидаем появления ${POD}..."

                # Ждём до 5 минут пока под появится
                ATTEMPTS=0
                until kubectl get pod $POD -n $NS > /dev/null 2>&1; do
                  ATTEMPTS=$((ATTEMPTS + 1))
                  if [ $ATTEMPTS -ge 60 ]; then
                    echo "ОШИБКА: ${POD} не появился за 5 минут"
                    exit 1
                  fi
                  echo "  Попытка ${ATTEMPTS}/60: ${POD} ещё не создан, жду 5с..."
                  sleep 5
                done

                echo "  ${POD} найден, ждём Ready..."
                kubectl wait --for=condition=Ready \
                  -n $NS \
                  pod/$POD --timeout=300s

                echo "  ${POD}: Ready ✓"
              done

              echo "==> Все 3 пода готовы"
      containers:
        - name: {{ $.Values.labels.redis }}
          image: {{ $.Values.images.redis }}
          imagePullPolicy: "IfNotPresent"
          command: ["sh", "-c"]
          args:
            - |
              POD0="{{ $.Values.labels.redis }}-deployment-0.{{ $.Values.labels.redis }}-headless.{{ $ns }}.svc.{{ $.Values.localK8sDomain }}"
              POD1="{{ $.Values.labels.redis }}-deployment-1.{{ $.Values.labels.redis }}-headless.{{ $ns }}.svc.{{ $.Values.localK8sDomain }}"
              POD2="{{ $.Values.labels.redis }}-deployment-2.{{ $.Values.labels.redis }}-headless.{{ $ns }}.svc.{{ $.Values.localK8sDomain }}"
              PORT="{{ $.Values.ports.internal.redis.client }}"

              echo "==> Проверяем состояние кластера..."
              CLUSTER_STATE=$(redis-cli -h $POD0 -p $PORT cluster info 2>/dev/null \
                | grep cluster_state | cut -d: -f2 | tr -d '[:space:]')
              CLUSTER_NODES=$(redis-cli -h $POD0 -p $PORT cluster info 2>/dev/null \
                | grep cluster_known_nodes | cut -d: -f2 | tr -d '[:space:]')

              echo "  state=${CLUSTER_STATE} known_nodes=${CLUSTER_NODES}"

              if [ "$CLUSTER_STATE" = "ok" ] && [ "${CLUSTER_NODES:-0}" -ge "3" ]; then
                echo "==> Кластер уже инициализирован. Пропускаем."
                exit 0
              fi

              echo "==> Кластер не инициализирован — выполняем сброс и создание"

              # Сбрасываем состояние на всех нодах
              # Это необходимо при переключении single→cluster:
              # поды могут содержать старый nodes.conf или данные
              for POD in $POD0 $POD1 $POD2; do
                echo "  Сбрасываем ${POD}..."
                redis-cli -h $POD -p $PORT flushall 2>/dev/null || true
                redis-cli -h $POD -p $PORT cluster reset hard 2>/dev/null || true
                echo "  OK"
              done

              echo "==> Пауза 3 секунды после сброса..."
              sleep 3

              echo "==> Создаём Redis Cluster..."
              redis-cli --cluster create \
                $POD0:$PORT \
                $POD1:$PORT \
                $POD2:$PORT \
                --cluster-replicas 0 \
                --cluster-yes

              if [ $? -ne 0 ]; then
                echo "==> ОШИБКА: не удалось создать кластер"
                exit 1
              fi

              echo "==> Ждём стабилизации кластера..."
              sleep 3

              echo "==> Итоговое состояние:"
              redis-cli -h $POD0 -p $PORT cluster info
              echo ""
              redis-cli -h $POD0 -p $PORT cluster nodes
              echo "==> Готово!"
{{- end }}
{{- end }}
{{- end }}
