## Полезные комбинации

```bash
# Обновить репо и задеплоить последнюю версию
helm repo update && helm upgrade --install my-nginx bitnami/nginx -n production --create-namespace

# Получить только rendered YAML деплоймента для отладки
helm template my-app ./chart/ -f prod-values.yaml -s templates/deployment.yaml

# Сравнить текущие values с дефолтными (через diff)
helm get values my-nginx --all > current.yaml
helm show values bitnami/nginx > defaults.yaml
diff defaults.yaml current.yaml

# Экспортировать манифесты деплоя в файл
helm get manifest my-nginx -n production > manifests.yaml

# Установить/обновить без интерактивности (для CI/CD)
helm upgrade --install my-nginx bitnami/nginx \
  -n production \
  --create-namespace \
  --wait \
  --timeout 5m \
  --atomic \
  -f values.yaml \
  --set image.tag=${IMAGE_TAG}

# Проверить что будет при апгрейде (dry-run + debug)
helm upgrade my-nginx bitnami/nginx -f values.yaml --dry-run --debug

# Удалить всё в namespace, перечислив релизы
helm list -n staging -q | xargs -I{} helm uninstall {} -n staging
```

