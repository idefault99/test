## Установка и обновление

```bash
# Установить чарт (релиз создаётся в текущем namespace)
helm install <release-name> <chart>
helm install my-nginx bitnami/nginx

# Установить с указанием namespace
helm install my-nginx bitnami/nginx -n production

# Установить с автосозданием namespace
helm install my-nginx bitnami/nginx -n production --create-namespace

# Установить конкретную версию чарта
helm install my-nginx bitnami/nginx --version 13.2.0

# Установить из локальной директории
helm install my-app ./my-chart/

# Установить из архива .tgz
helm install my-app ./my-chart-1.0.0.tgz

# Установить из URL
helm install my-app https://example.com/charts/my-chart-1.0.0.tgz

# Установить с переопределением values через флаг
helm install my-nginx bitnami/nginx --set service.type=NodePort

# Установить с переопределением нескольких values
helm install my-nginx bitnami/nginx \
  --set replicaCount=2 \
  --set service.type=LoadBalancer

# Установить с кастомным values.yaml
helm install my-nginx bitnami/nginx -f custom-values.yaml

# Установить с несколькими values-файлами (правый перекрывает левый)
helm install my-nginx bitnami/nginx -f base.yaml -f override.yaml

# Установить и ждать готовности всех ресурсов
helm install my-nginx bitnami/nginx --wait

# Установить с таймаутом ожидания готовности
helm install my-nginx bitnami/nginx --wait --timeout 5m0s

# Dry-run: симуляция установки без реального деплоя
helm install my-nginx bitnami/nginx --dry-run

# Dry-run с подробным выводом (как server-side)
helm install my-nginx bitnami/nginx --dry-run --debug

# Установить с генерацией имени релиза автоматически
helm install bitnami/nginx --generate-name

# Обновить существующий релиз
helm upgrade <release-name> <chart>
helm upgrade my-nginx bitnami/nginx

# Обновить с переопределением values
helm upgrade my-nginx bitnami/nginx --set replicaCount=3

# Обновить с values-файлом
helm upgrade my-nginx bitnami/nginx -f values.yaml

# Обновить до конкретной версии чарта
helm upgrade my-nginx bitnami/nginx --version 13.2.0

# Установить если нет, обновить если есть (install or upgrade)
helm upgrade --install my-nginx bitnami/nginx

# Обновить и ждать готовности
helm upgrade my-nginx bitnami/nginx --wait

# Обновить — откатиться автоматически при ошибке
helm upgrade my-nginx bitnami/nginx --atomic

# Принудительно пересоздать поды при обновлении
helm upgrade my-nginx bitnami/nginx --force

# Сбросить values к дефолтным из чарта при апгрейде
helm upgrade my-nginx bitnami/nginx --reset-values

# Переиспользовать текущие values при апгрейде (если -f не указан)
helm upgrade my-nginx bitnami/nginx --reuse-values

# Сохранить history (по умолчанию 10 ревизий, можно задать лимит)
helm upgrade my-nginx bitnami/nginx --history-max 5
```

