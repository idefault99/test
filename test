# Проверить секрет
kubectl get secret registry-credentials -n default

# Если нет — создать вручную (замени USER и PASS)
kubectl create secret docker-registry registry-credentials \
  --docker-server=registry.test.model.svo.aero \
  --docker-username=USER \
  --docker-password=PASS \
  -n default

# Удалить старый под
kubectl delete pod test-dns

# Создать через yaml (надёжнее чем --overrides)
kubectl apply -f - << 'EOF'
apiVersion: v1
kind: Pod
metadata:
  name: test-dns
  namespace: default
spec:
  imagePullSecrets:
    - name: registry-credentials
  containers:
    - name: test-dns
      image: registry.test.model.svo.aero/dpm/iac/infra/alpine-netutils:1.0.0
      command: ["sleep", "300"]
  restartPolicy: Never
EOF

kubectl get pod test-dns -w
