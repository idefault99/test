#!/bin/bash
# install-eso.sh — установка External Secrets Operator в MicroK8s
set -euo pipefail

VAULT_ADDR="${1:?Укажи VAULT_ADDR, например https://192.168.1.10:8200}"
VAULT_CA_FILE="${2:?Укажи путь к ca.crt от Vault}"

GREEN='\033[0;32m'; CYAN='\033[0;36m'; NC='\033[0m'
log()     { echo -e "${GREEN}[INFO]${NC} $*"; }
section() { echo -e "\n${CYAN}══ $* ══${NC}"; }

# ── 1. Helm ───────────────────────────────────────────────────
section "Проверяем Helm"
if ! command -v helm &>/dev/null; then
  log "Устанавливаем Helm..."
  curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
fi

# ── 2. ESO namespace ──────────────────────────────────────────
section "Создаём namespace external-secrets"
microk8s kubectl create namespace external-secrets --dry-run=client -o yaml | microk8s kubectl apply -f -

# ── 3. CA cert Vault → ConfigMap в external-secrets ──────────
section "Прокидываем CA cert Vault в кластер"
microk8s kubectl create configmap vault-ca \
  --from-file=ca.crt="${VAULT_CA_FILE}" \
  -n external-secrets \
  --dry-run=client -o yaml | microk8s kubectl apply -f -

# ── 4. Устанавливаем ESO ──────────────────────────────────────
section "Устанавливаем External Secrets Operator"
helm repo add external-secrets https://charts.external-secrets.io
helm repo update

microk8s helm3 upgrade --install external-secrets \
  external-secrets/external-secrets \
  --namespace external-secrets \
  --set installCRDs=true \
  --set webhook.port=9443 \
  --wait

log "ESO установлен: $(microk8s kubectl get pods -n external-secrets --no-headers | grep -c Running) pods running"

# ── 5. ServiceAccount для ESO (один на кластер) ───────────────
section "Создаём ServiceAccount для Vault auth"
cat <<EOF | microk8s kubectl apply -f -
apiVersion: v1
kind: ServiceAccount
metadata:
  name: external-secrets
  namespace: external-secrets
---
apiVersion: v1
kind: Secret
metadata:
  name: external-secrets-token
  namespace: external-secrets
  annotations:
    kubernetes.io/service-account.name: external-secrets
type: kubernetes.io/service-account-token
EOF

# Ждём токен
sleep 3
SA_TOKEN=$(microk8s kubectl get secret external-secrets-token -n external-secrets -o jsonpath='{.data.token}' | base64 -d)
log "SA token получен (${#SA_TOKEN} символов)"

echo ""
echo -e "${GREEN}════════════════════════════════════════════${NC}"
echo -e "${GREEN}  ESO установлен!${NC}"
echo -e "${GREEN}════════════════════════════════════════════${NC}"
echo ""
echo -e "Следующий шаг: создание ClusterSecretStore и Helm chart"
echo ""
echo -e "SA Token для Vault (если нужен для ручной отладки):"
echo "${SA_TOKEN}" | head -c 50
echo "..."



