def rotate_backups(s3, bucket: str, folder: str, keep: int):
    """Оставить только keep последних файлов в папке бакета."""
    if keep <= 0:
        return

    paginator = s3.get_paginator("list_objects_v2")
    objects = []
    for page in paginator.paginate(Bucket=bucket, Prefix=f"{folder}/"):
        for obj in page.get("Contents", []):
            objects.append(obj)

    if len(objects) <= keep:
        print(f"Файлов в бакете: {len(objects)} — ротация не нужна")
        return

    # Сортируем по дате — старые первые
    objects.sort(key=lambda x: x["LastModified"])
    to_delete = objects[:len(objects) - keep]

    print(f"Удаляю старых файлов: {len(to_delete)}")
    s3.delete_objects(
        Bucket=bucket,
        Delete={"Objects": [{"Key": obj["Key"]} for obj in to_delete]},
    )
    for obj in to_delete:
        print(f"  Удалён: {obj['Key']}")

