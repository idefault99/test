    - docker tag ${CI_REGISTRY_IMAGE}:${TAG}.bin ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH}:${TAG}.bin
    - docker tag ${CI_REGISTRY_IMAGE}:${TAG}.migrations ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH}:${TAG}.migrations
    - docker tag ${CI_REGISTRY_IMAGE}:${TAG}.bin ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH_TO_REP_IMAGE}:${TAG}.bin
    - docker tag ${CI_REGISTRY_IMAGE}:${TAG}.migrations ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH_TO_REP_IMAGE}:${TAG}.migrations
