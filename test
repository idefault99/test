#!/bin/bash
# Удаляет StatefulSet во всех namespace с redis, затем запускает helm upgrade

CHART_PATH="./path/to/chart"
VALUES_FILE="values.yaml"

for NS in $(kubectl get pods -A --no-headers | grep "redis-deployment-0" | awk '{print $1}' | sort -u); do
  echo "==> $NS: удаляем StatefulSet..."
  kubectl delete statefulset redis-deployment -n $NS --cascade=orphan --ignore-not-found

  echo "==> $NS: helm upgrade..."
  helm upgrade infra $CHART_PATH -n $NS -f $VALUES_FILE

  echo "==> $NS: готово"
  echo ""
done
