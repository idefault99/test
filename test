enableService:
  vault:
    enable: false

# Базовый namespace стенда — используется везде вместо дублирования
baseNs: test-dev

vault:
  address: "https://vault.test.ru"
  token: "example"                     # ⚠ root token — только для vault-job
  kvMount: "stands"
  authPath: "kubernetes"
  # roleName: "custom-role"            # опционально, по умолчанию = baseNs
  serviceAccount:
    name: "external-secrets"
    namespace: "external-secrets"
  caSecretName: "vault-ca-secret"
  refreshInterval: "5m"

kubernetes:
  host: "https://192.168.0.111:16443"

imagePullSecret: "registry-secret"
images:
  vault: "registry.example.com/vault-setup:latest"

stand:
  # Автоматически подставляется из baseNs в шаблонах через printf
  # name здесь не нужен — используй baseNs

  infra:
    services:
      # Каждый сервис — отдельный путь в Vault: stands/<baseNs>/infra/<name>
      # Если сервис не указан здесь — ExternalSecret для него не создаётся
      # Приложение продолжает работать с ConfigMap

      - name: redis
        secretName: redis-vault-secret

      - name: kafka
        secretName: kafka-vault-secret

      - name: mongodb
        secretName: mongodb-vault-secret

      - name: elasticsearch
        secretName: elasticsearch-vault-secret

      - name: postgresql
        secretName: postgresql-vault-secret

      - name: s3minio
        secretName: s3minio-vault-secret

  # App namespace-ы стенда (используются vault-job для создания политик)
  apps: []
  # apps:
  #   - suffix: "approvals"
  #   - suffix: "audit"
---
{{- if eq .Values.enableService.vault.enable true }}
{{- $vault := .Values.vault }}
{{- $stand := .Values.baseNs }}
{{- $vaultRole := .Values.vault.roleName | default $stand }}

{{/* ── Secret с переменными для vault-job ─────────────────────────────── */}}
{{- $suffixes := list "infra" }}
{{- range .Values.stand.apps }}
  {{- $suffixes = concat $suffixes (list .suffix) }}
{{- end }}
{{- $standsStr := printf "%s:%s" $stand (join "," $suffixes) }}
---
apiVersion: v1
kind: Secret
metadata:
  name: vault-env
  namespace: {{ .Release.Namespace }}
  annotations:
    "helm.sh/hook": pre-install,pre-upgrade
    "helm.sh/hook-weight": "-50"
    "helm.sh/hook-delete-policy": before-hook-creation
stringData:
  VAULT_ADDR: {{ $vault.address | quote }}
  VAULT_TOKEN: {{ $vault.token | quote }}
  K8S_HOST: {{ .Values.kubernetes.host | quote }}
  ESO_SA_NAME: {{ $vault.serviceAccount.name | quote }}
  ESO_SA_NAMESPACE: {{ $vault.serviceAccount.namespace | quote }}
  STANDS: {{ $standsStr | quote }}

{{/* ── Job: настраивает политики и роли в Vault ───────────────────────── */}}
---
apiVersion: batch/v1
kind: Job
metadata:
  name: vault-setup
  namespace: {{ .Release.Namespace }}
  annotations:
    "helm.sh/hook": pre-install,pre-upgrade
    "helm.sh/hook-weight": "-40"
    "helm.sh/hook-delete-policy": before-hook-creation,hook-succeeded
spec:
  template:
    spec:
      restartPolicy: Never
      imagePullSecrets:
        - name: {{ .Values.imagePullSecret | quote }}
      containers:
        - name: vault
          image: {{ .Values.images.vault | quote }}
          envFrom:
            - secretRef:
                name: vault-env

{{/* ── ClusterSecretStore: один на стенд ─────────────────────────────── */}}
---
apiVersion: external-secrets.io/v1beta1
kind: ClusterSecretStore
metadata:
  name: {{ printf "vault-cluster-store-%s" $stand }}
  annotations:
    "helm.sh/hook": pre-install,pre-upgrade
    "helm.sh/hook-weight": "-30"
    "helm.sh/hook-delete-policy": before-hook-creation
spec:
  provider:
    vault:
      server: {{ $vault.address }}
      path: {{ $vault.kvMount }}
      version: v2
      auth:
        kubernetes:
          mountPath: {{ $vault.authPath }}
          role: {{ $vaultRole }}
          serviceAccountRef:
            name: {{ $vault.serviceAccount.name }}
            namespace: {{ $vault.serviceAccount.namespace }}
      caProvider:
        type: Secret
        name: {{ $vault.caSecretName }}
        key: ca.crt
        namespace: {{ $vault.serviceAccount.namespace }}
{{- end }}
---
{{- if eq .Values.enableService.vault.enable true }}
{{- $stand := .Values.baseNs }}
{{- $vault := .Values.vault }}
{{- $storeName := printf "vault-cluster-store-%s" $stand }}

{{/*
  Ищем конфигурацию redis в .Values.stand.infra.services
  Если сервис не найден или vault.enable=false — ExternalSecret не создаётся,
  приложение продолжает работать с ConfigMap
*/}}
{{- $svc := dict }}
{{- range .Values.stand.infra.services }}
  {{- if eq .name "redis" }}
    {{- $svc = . }}
  {{- end }}
{{- end }}

{{- if $svc.secretName }}
---
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{ $svc.secretName }}
  namespace: {{ $stand }}
  annotations:
    "helm.sh/hook": pre-install,pre-upgrade
    "helm.sh/hook-weight": "-20"
    "helm.sh/hook-delete-policy": before-hook-creation
  labels:
    vault-section: infra
    vault-service: redis
spec:
  refreshInterval: {{ $vault.refreshInterval }}
  secretStoreRef:
    name: {{ $storeName }}
    kind: ClusterSecretStore
  target:
    name: {{ $svc.secretName }}
    creationPolicy: Owner
    deletionPolicy: Retain
  dataFrom:
    - extract:
        key: {{ $stand }}/infra/redis
{{- end }}
{{- end }}
