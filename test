#!/bin/bash
# ============================================================
# Диагностика и восстановление мастер-ноды microk8s
# Запускать на самой упавшей ноде
#
# Использование:
#   bash microk8s_recovery.sh check    — только диагностика
#   bash microk8s_recovery.sh recover  — попытка восстановления
# ============================================================

ACTION="${1:-check}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

ok()   { echo -e "${GREEN}  ✓ $1${NC}"; }
fail() { echo -e "${RED}  ✗ $1${NC}"; }
info() { echo -e "${YELLOW}  → $1${NC}"; }
head() { echo -e "${CYAN}$1${NC}"; }

# ============================================================
# ДИАГНОСТИКА
# ============================================================
do_check() {
  head ""
  head "============================================"
  head "  ДИАГНОСТИКА МАСТЕР-НОДЫ microk8s"
  head "  $(hostname) | $(date)"
  head "============================================"

  # 1. Состояние microk8s сервисов
  echo ""
  head "==> [1] Состояние microk8s сервисов"
  systemctl list-units "snap.microk8s.*" --all --no-legend 2>/dev/null \
    | while read UNIT LOAD ACTIVE SUB REST; do
        if [ "$ACTIVE" = "active" ]; then
          ok "$UNIT ($SUB)"
        else
          fail "$UNIT ($ACTIVE/$SUB)"
        fi
      done

  # 2. Главный сервис kubelite
  echo ""
  head "==> [2] Статус kubelite (apiserver + controller + scheduler)"
  KUBELITE_STATUS=$(systemctl is-active snap.microk8s.daemon-kubelite 2>/dev/null)
  if [ "$KUBELITE_STATUS" = "active" ]; then
    ok "kubelite: active"
  else
    fail "kubelite: $KUBELITE_STATUS"
    info "Последние логи kubelite:"
    journalctl -u snap.microk8s.daemon-kubelite --no-pager -n 20 2>/dev/null \
      | while read L; do echo "    $L"; done
  fi

  # 3. dqlite (встроенный etcd microk8s)
  echo ""
  head "==> [3] Статус dqlite (хранилище состояния кластера)"
  DQLITE_STATUS=$(systemctl is-active snap.microk8s.daemon-k8s-dqlite 2>/dev/null)
  if [ "$DQLITE_STATUS" = "active" ]; then
    ok "dqlite: active"
  else
    fail "dqlite: $DQLITE_STATUS"
    info "Последние логи dqlite:"
    journalctl -u snap.microk8s.daemon-k8s-dqlite --no-pager -n 20 2>/dev/null \
      | while read L; do echo "    $L"; done
  fi

  # 4. containerd
  echo ""
  head "==> [4] Статус containerd"
  CONTAINERD_STATUS=$(systemctl is-active snap.microk8s.daemon-containerd 2>/dev/null)
  if [ "$CONTAINERD_STATUS" = "active" ]; then
    ok "containerd: active"
  else
    fail "containerd: $CONTAINERD_STATUS"
  fi

  # 5. microk8s status
  echo ""
  head "==> [5] microk8s status"
  microk8s status 2>/dev/null || fail "microk8s status недоступен"

  # 6. kubectl доступен ли apiserver
  echo ""
  head "==> [6] Доступность API сервера"
  if microk8s kubectl cluster-info 2>/dev/null | grep -q "running"; then
    ok "API сервер доступен"
    microk8s kubectl get nodes 2>/dev/null
  else
    fail "API сервер недоступен"
    info "Проверяем порт 16443..."
    ss -tlnp | grep 16443 && ok "Порт 16443 слушается" || fail "Порт 16443 не слушается"
  fi

  # 7. Дисковое пространство
  echo ""
  head "==> [7] Дисковое пространство"
  df -h / /var/snap/microk8s 2>/dev/null | while read L; do echo "  $L"; done
  DISK_USAGE=$(df / | tail -1 | awk '{print $5}' | tr -d '%')
  if [ "${DISK_USAGE:-0}" -gt 90 ]; then
    fail "Диск заполнен на ${DISK_USAGE}% — это может быть причиной падения!"
  else
    ok "Диск: ${DISK_USAGE}% использовано"
  fi

  # 8. Память
  echo ""
  head "==> [8] Память"
  free -h | while read L; do echo "  $L"; done
  MEM_AVAIL=$(free | grep Mem | awk '{print int($7/$2*100)}')
  if [ "${MEM_AVAIL:-100}" -lt 10 ]; then
    fail "Памяти меньше 10% — возможна OOM"
  else
    ok "Доступно памяти: ~${MEM_AVAIL}%"
  fi

  # 9. OOM killer — был ли
  echo ""
  head "==> [9] OOM killer за последние 24 часа"
  OOM=$(journalctl --since "24 hours ago" 2>/dev/null | grep -i "oom\|killed process\|out of memory" | tail -5)
  if [ -n "$OOM" ]; then
    fail "Найдены OOM события:"
    echo "$OOM" | while read L; do echo "    $L"; done
  else
    ok "OOM событий не найдено"
  fi

  # 10. Сертификаты
  echo ""
  head "==> [10] Срок действия сертификатов microk8s"
  CERT_DIR="/var/snap/microk8s/current/certs"
  if [ -d "$CERT_DIR" ]; then
    for CERT in "$CERT_DIR"/*.crt; do
      [ -f "$CERT" ] || continue
      EXPIRY=$(openssl x509 -enddate -noout -in "$CERT" 2>/dev/null | cut -d= -f2)
      EXPIRY_EPOCH=$(date -d "$EXPIRY" +%s 2>/dev/null)
      NOW_EPOCH=$(date +%s)
      DAYS_LEFT=$(( (EXPIRY_EPOCH - NOW_EPOCH) / 86400 ))
      if [ "$DAYS_LEFT" -lt 30 ] 2>/dev/null; then
        fail "$(basename $CERT): истекает через $DAYS_LEFT дней ($EXPIRY)"
      else
        ok "$(basename $CERT): действителен ещё $DAYS_LEFT дней"
      fi
    done
  else
    info "Директория сертификатов не найдена: $CERT_DIR"
  fi

  # 11. Последние ошибки в kubelite
  echo ""
  head "==> [11] Последние ошибки в kubelite (последние 30 мин)"
  journalctl -u snap.microk8s.daemon-kubelite --since "30 minutes ago" --no-pager 2>/dev/null \
    | grep -iE "^.*error|fatal|panic|crash|failed" \
    | grep -v "leader\|timeout.*warning" \
    | tail -20 \
    | while read L; do echo "    $L"; done || info "Ошибок не найдено"

  echo ""
  head "============================================"
  info "Для восстановления запусти: bash $0 recover"
  head "============================================"
  echo ""
}

# ============================================================
# ВОССТАНОВЛЕНИЕ
# ============================================================
do_recover() {
  head ""
  head "============================================"
  head "  ВОССТАНОВЛЕНИЕ МАСТЕР-НОДЫ microk8s"
  head "  $(hostname) | $(date)"
  head "============================================"
  echo ""

  # Шаг 1: Останавливаем microk8s полностью
  head "==> [1] Останавливаем microk8s..."
  microk8s stop 2>/dev/null
  sleep 5
  ok "Остановлен"

  # Шаг 2: Проверяем диск
  head "==> [2] Проверяем дисковое пространство..."
  DISK_USAGE=$(df / | tail -1 | awk '{print $5}' | tr -d '%')
  if [ "${DISK_USAGE:-0}" -gt 90 ]; then
    fail "Диск заполнен на ${DISK_USAGE}%!"
    info "Очищаем старые образы контейнеров..."
    microk8s ctr images prune --all 2>/dev/null || true
    info "Очищаем journald логи старше 3 дней..."
    journalctl --vacuum-time=3d 2>/dev/null || true
    df -h / | tail -1
  else
    ok "Диск: ${DISK_USAGE}% — норма"
  fi

  # Шаг 3: Запускаем microk8s
  head "==> [3] Запускаем microk8s..."
  microk8s start
  info "Ждём 30 секунд пока поднимутся сервисы..."
  sleep 30

  # Шаг 4: Проверяем статус
  head "==> [4] Проверяем статус..."
  microk8s status --wait-ready --timeout 60 2>/dev/null
  if [ $? -eq 0 ]; then
    ok "microk8s запустился"
  else
    fail "microk8s не запустился за 60 секунд"
    info "Проверяем сервисы..."
    systemctl is-active snap.microk8s.daemon-kubelite
    systemctl is-active snap.microk8s.daemon-k8s-dqlite
    info "Смотрим логи kubelite:"
    journalctl -u snap.microk8s.daemon-kubelite --no-pager -n 30
  fi

  # Шаг 5: Проверяем ноды
  head "==> [5] Состояние нод кластера..."
  microk8s kubectl get nodes -o wide 2>/dev/null \
    || fail "kubectl недоступен — API сервер не поднялся"

  # Шаг 6: Если сертификаты истекли — обновляем
  head "==> [6] Проверяем сертификаты..."
  CERT_EXPIRED=0
  CERT_DIR="/var/snap/microk8s/current/certs"
  for CERT in "$CERT_DIR"/*.crt; do
    [ -f "$CERT" ] || continue
    EXPIRY_EPOCH=$(openssl x509 -enddate -noout -in "$CERT" 2>/dev/null \
      | cut -d= -f2 | xargs -I{} date -d {} +%s 2>/dev/null)
    NOW_EPOCH=$(date +%s)
    DAYS_LEFT=$(( (EXPIRY_EPOCH - NOW_EPOCH) / 86400 ))
    if [ "$DAYS_LEFT" -lt 0 ] 2>/dev/null; then
      fail "Сертификат истёк: $(basename $CERT)"
      CERT_EXPIRED=1
    fi
  done

  if [ "$CERT_EXPIRED" = "1" ]; then
    info "Обновляем сертификаты..."
    microk8s refresh-certs --cert ca.crt 2>/dev/null
    microk8s stop && sleep 5 && microk8s start
    sleep 20
    ok "Сертификаты обновлены, microk8s перезапущен"
  else
    ok "Сертификаты в порядке"
  fi

  # Шаг 7: Итоговая проверка
  echo ""
  head "==> [7] Итоговая проверка"
  microk8s kubectl get nodes 2>/dev/null && ok "Кластер доступен" || fail "Кластер недоступен"
  microk8s kubectl get pods -n kube-system 2>/dev/null | head -10

  echo ""
  head "============================================"
  head "  ВОССТАНОВЛЕНИЕ ЗАВЕРШЕНО"
  head "  Если нода всё ещё недоступна — запусти диагностику:"
  head "  bash $0 check"
  head "============================================"
  echo ""
}

# ============================================================
# Роутинг
# ============================================================
case "$ACTION" in
  check)   do_check   ;;
  recover) do_recover ;;
  *)
    echo "Использование: $0 check | recover"
    exit 1
    ;;
esac
