# 1. Временно переключить k8s-api на локальный IP
sed -i 's/172\.16\.175\.20\s*k8s-api/172.16.175.19 k8s-api/' /etc/hosts

# 2. Рестартовать kube-vip pod
crictl stopp $(crictl pods --name kube-vip | grep -v POD | awk '{print $1}')

# 3. Подождать ~15 сек, проверить что VIP появился
sleep 15 && ip addr show eno1 | grep 172.16.175.20

# 4. Как только VIP появился — вернуть нормальный /etc/hosts
sed -i 's/172\.16\.175\.19\s*k8s-api/172.16.175.20 k8s-api/' /etc/hosts

# 5. Проверить кластер
kubectl --kubeconfig /etc/kubernetes/admin.conf get nodes
