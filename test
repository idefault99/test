# 1. Текущий статус всех сервисов
sudo snap services microk8s

# 2. Что в cluster.yaml сейчас (сколько нод?)
cat /var/snap/microk8s/current/var/kubernetes/backend/cluster.yaml

# 3. Лог kubelite после join — ищем новую причину
sudo journalctl -u snap.microk8s.daemon-kubelite -n 50 --no-pager | grep -iE "error|fatal|failed|refused|timeout" | tail -20

# 4. CNI — есть ли конфиг?
ls /var/snap/microk8s/current/args/cni-network/
ls /var/snap/microk8s/current/opt/cni/bin/ | head -10


# Какой CNI был до бэкапа?
cat /var/snap/microk8s/current/args/cni-network/cni.yaml 2>/dev/null | head -10

# Включён ли аддон?
microk8s status 2>/dev/null | grep -E "calico|flannel|cilium"
