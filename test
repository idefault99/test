# =============================================================================
# pg_locks — блокировки
# =============================================================================
pg_locks_custom:
  query: |
    SELECT
      d.datname,
      l.mode,
      count(*) AS count
    FROM pg_locks l
    LEFT JOIN pg_database d ON l.database = d.oid
    WHERE d.datname IS NOT NULL
    GROUP BY d.datname, l.mode
  metrics:
    - datname:
        usage: LABEL
        description: "Database name"
    - mode:
        usage: LABEL
        description: "Lock mode"
    - count:
        usage: GAUGE
        description: "Lock count"

# =============================================================================
# pg_stat_replication — лаг репликации Patroni (только на primary)
# =============================================================================
pg_replication_custom:
  query: |
    SELECT
      client_addr::text AS client_addr,
      application_name,
      state,
      sync_state,
      CASE WHEN sent_lsn IS NOT NULL AND write_lsn IS NOT NULL
           THEN (sent_lsn - write_lsn)::bigint ELSE 0
      END AS write_lag_bytes,
      CASE WHEN sent_lsn IS NOT NULL AND flush_lsn IS NOT NULL
           THEN (sent_lsn - flush_lsn)::bigint ELSE 0
      END AS flush_lag_bytes,
      CASE WHEN sent_lsn IS NOT NULL AND replay_lsn IS NOT NULL
           THEN (sent_lsn - replay_lsn)::bigint ELSE 0
      END AS replay_lag_bytes
    FROM pg_stat_replication
  metrics:
    - client_addr:
        usage: LABEL
        description: "Replica address"
    - application_name:
        usage: LABEL
        description: "Patroni node name"
    - state:
        usage: LABEL
        description: "Replication state"
    - sync_state:
        usage: LABEL
        description: "Sync state"
    - write_lag_bytes:
        usage: GAUGE
        description: "Write lag bytes"
    - flush_lag_bytes:
        usage: GAUGE
        description: "Flush lag bytes"
    - replay_lag_bytes:
        usage: GAUGE
        description: "Replay lag bytes"

# =============================================================================
# Размер баз данных
# =============================================================================
pg_database_size_custom:
  query: |
    SELECT
      datname,
      pg_database_size(datname) AS size_bytes
    FROM pg_database
    WHERE datname NOT IN ('template0', 'template1')
      AND datname IS NOT NULL
  metrics:
    - datname:
        usage: LABEL
        description: "Database name"
    - size_bytes:
        usage: GAUGE
        description: "Database size bytes"

# =============================================================================
# Использование лимита подключений (max_connections=1500)
# =============================================================================
pg_connections_limit_custom:
  query: |
    SELECT
      d.datname,
      d.datconnlimit                          AS connection_limit,
      count(a.pid)                            AS active_connections,
      current_setting('max_connections')::int AS max_connections_global,
      CASE WHEN d.datconnlimit <= 0 THEN 0
           ELSE round(count(a.pid) * 100.0 / d.datconnlimit, 2)
      END AS connection_usage_pct
    FROM pg_database d
    LEFT JOIN pg_stat_activity a ON a.datname = d.datname
    WHERE d.datname NOT IN ('template0', 'template1')
      AND d.datname IS NOT NULL
    GROUP BY d.datname, d.datconnlimit
  metrics:
    - datname:
        usage: LABEL
        description: "Database name"
    - connection_limit:
        usage: GAUGE
        description: "Per-DB connection limit"
    - active_connections:
        usage: GAUGE
        description: "Active connections"
    - max_connections_global:
        usage: GAUGE
        description: "Global max_connections"
    - connection_usage_pct:
        usage: GAUGE
        description: "Connection limit usage %"

# =============================================================================
# pg_stat_statements_aggregated — агрегированная статистика по БД
# =============================================================================
pg_stat_statements_aggregated:
  query: |
    SELECT
      d.datname,
      COALESCE(SUM(s.calls), 0)::bigint AS calls_total,
      COALESCE(TRUNC(SUM(s.total_exec_time)), 0)::bigint AS total_exec_time_ms,
      COALESCE(TRUNC(AVG(s.min_exec_time)), 0)::bigint AS avg_min_exec_time_ms,
      COALESCE(TRUNC(AVG(s.max_exec_time)), 0)::bigint AS avg_max_exec_time_ms,
      COALESCE(TRUNC(AVG(s.mean_exec_time)), 0)::bigint AS avg_mean_exec_time_ms,
      COALESCE(TRUNC(SUM(s.total_exec_time) / NULLIF(SUM(s.calls), 0)), 0)::bigint AS weighted_mean_exec_time_ms,
      COALESCE(SUM(s.rows), 0)::bigint AS rows_total,
      COALESCE(SUM(s.shared_blks_hit), 0)::bigint AS shared_blks_hit_total,
      COALESCE(SUM(s.shared_blks_read), 0)::bigint AS shared_blks_read_total,
      CASE
        WHEN (SUM(s.shared_blks_hit) + SUM(s.shared_blks_read)) = 0 THEN 0
        ELSE ROUND(SUM(s.shared_blks_hit) * 100.0 / (SUM(s.shared_blks_hit) + SUM(s.shared_blks_read)), 2)
      END AS cache_hit_ratio_pct,
      COUNT(DISTINCT s.queryid) AS unique_queries_count
    FROM pg_database d
    LEFT JOIN pg_stat_statements s ON d.oid = s.dbid
    WHERE d.datname NOT IN ('template0', 'template1')
      AND d.datname IS NOT NULL
    GROUP BY d.datname
    ORDER BY total_exec_time_ms DESC
  metrics:
    - datname:
        usage: LABEL
        description: "Database name"
    - calls_total:
        usage: COUNTER
        description: "Total query calls across all queries"
    - total_exec_time_ms:
        usage: COUNTER
        description: "Total execution time in milliseconds"
    - avg_min_exec_time_ms:
        usage: GAUGE
        description: "Average minimum execution time (ms)"
    - avg_max_exec_time_ms:
        usage: GAUGE
        description: "Average maximum execution time (ms)"
    - avg_mean_exec_time_ms:
        usage: GAUGE
        description: "Average mean execution time (ms)"
    - weighted_mean_exec_time_ms:
        usage: GAUGE
        description: "Weighted mean execution time (ms) = total_time / total_calls"
    - rows_total:
        usage: COUNTER
        description: "Total rows returned/affected"
    - shared_blks_hit_total:
        usage: COUNTER
        description: "Total shared buffer cache hits"
    - shared_blks_read_total:
        usage: COUNTER
        description: "Total shared buffer disk reads"
    - cache_hit_ratio_pct:
        usage: GAUGE
        description: "Cache hit ratio percentage"
    - unique_queries_count:
        usage: GAUGE
        description: "Number of unique queries"