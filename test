#!/bin/bash
# =============================================================
# stand-backup.sh — Бэкап и восстановление стенда
# Совместим с MicroK8s
#
# Использование:
#   ./stand-backup.sh                         # меню
#   ./stand-backup.sh backup                  # бэкап всех test-stand* неймспейсов
#   ./stand-backup.sh backup test-stand-app   # бэкап одного неймспейса
#   ./stand-backup.sh restore ./backup-dir    # восстановление всего стенда
#   ./stand-backup.sh restore ./backup-dir test-stand-app  # восстановление одного ns
# =============================================================
set -euo pipefail

# --- Конфиг ---
NS_PREFIX="test-stand"
BACKUP_BASE="/opt/stand-backups"

# --- Определяем команды для microk8s ---
if command -v microk8s.helm3 &>/dev/null; then
  HELM="microk8s.helm3"
  KUBECTL="microk8s.kubectl"
elif command -v microk8s &>/dev/null; then
  helm() { microk8s helm "$@"; }
  kubectl() { microk8s kubectl "$@"; }
  export -f helm kubectl
  HELM="helm"
  KUBECTL="kubectl"
elif command -v helm &>/dev/null; then
  HELM="helm"
  KUBECTL="kubectl"
else
  echo "ERROR: helm не найден"
  exit 1
fi

# --- Цвета ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

# --- Порядок восстановления ресурсов ---
RESTORE_ORDER=(
  "namespaces"
  "storageclasses"
  "persistentvolumes"
  "persistentvolumeclaims"
  "secrets"
  "configmaps"
  "serviceaccounts"
  "roles"
  "rolebindings"
  "clusterroles"
  "clusterrolebindings"
  "services"
  "deployments"
  "statefulsets"
  "daemonsets"
  "horizontalpodautoscalers"
  "poddisruptionbudgets"
  "ingresses"
  "networkpolicies"
)

# --- Типы ресурсов для бэкапа ---
RESOURCE_TYPES=(
  "namespaces"
  "storageclasses"
  "persistentvolumes"
  "persistentvolumeclaims"
  "secrets"
  "configmaps"
  "serviceaccounts"
  "roles"
  "rolebindings"
  "clusterroles"
  "clusterrolebindings"
  "services"
  "deployments"
  "statefulsets"
  "daemonsets"
  "replicasets"
  "horizontalpodautoscalers"
  "poddisruptionbudgets"
  "ingresses"
  "networkpolicies"
  "resourcequotas"
  "limitranges"
)

# =============================================================
# --- ФУНКЦИИ ---
# =============================================================

# --- Получить все неймспейсы по префиксу ---
get_namespaces() {
  local prefix="${1:-$NS_PREFIX}"
  $KUBECTL get namespaces -o jsonpath='{.items[*].metadata.name}' | \
    tr ' ' '\n' | grep "^${prefix}" || true
}

# --- Очистка метаданных через jq ---
clean_metadata() {
  jq '
    del(
      .metadata.resourceVersion,
      .metadata.uid,
      .metadata.generation,
      .metadata.creationTimestamp,
      .metadata.managedFields,
      .metadata.annotations."kubectl.kubernetes.io/last-applied-configuration",
      .metadata.annotations."deployment.kubernetes.io/revision",
      .status
    ) |
    if .metadata.ownerReferences then
      del(.metadata.ownerReferences)
    else . end
  '
}

# --- Бэкап одного неймспейса ---
backup_namespace() {
  local NS=$1
  local BACKUP_DIR=$2

  echo -e "  ${CYAN}Бэкапим namespace: $NS${NC}"
  local NS_DIR="$BACKUP_DIR/namespaces/$NS"
  mkdir -p "$NS_DIR"

  local backed_up=0
  local skipped=0

  # --- Бэкап каждого типа ресурса ---
  for RESOURCE in "${RESOURCE_TYPES[@]}"; do
    # Кластерные ресурсы — не привязаны к namespace
    if [[ "$RESOURCE" == "namespaces" || \
          "$RESOURCE" == "storageclasses" || \
          "$RESOURCE" == "persistentvolumes" || \
          "$RESOURCE" == "clusterroles" || \
          "$RESOURCE" == "clusterrolebindings" ]]; then
      continue  # сохраняем отдельно
    fi

    # Получаем ресурсы в неймспейсе
    ITEMS=$($KUBECTL get "$RESOURCE" -n "$NS" -o json 2>/dev/null || true)
    COUNT=$(echo "$ITEMS" | jq '.items | length' 2>/dev/null || echo 0)

    if [[ "$COUNT" -eq 0 ]]; then
      skipped=$((skipped + 1))
      continue
    fi

    mkdir -p "$NS_DIR/$RESOURCE"

    # Сохраняем каждый ресурс в отдельный файл
    echo "$ITEMS" | jq -c '.items[]' 2>/dev/null | while IFS= read -r ITEM; do
      NAME=$(echo "$ITEM" | jq -r '.metadata.name')
      echo "$ITEM" | clean_metadata > "$NS_DIR/$RESOURCE/${NAME}.json"
      backed_up=$((backed_up + 1))
    done

    echo -e "    ${RESOURCE}: ${COUNT} объектов"
  done

  # --- Helm releases в неймспейсе ---
  local HELM_DIR="$BACKUP_DIR/helm/$NS"
  mkdir -p "$HELM_DIR"

  RELEASES=$($HELM list -n "$NS" -q 2>/dev/null || true)
  if [[ -n "$RELEASES" ]]; then
    echo -e "    ${CYAN}Helm releases:${NC}"
    while IFS= read -r RELEASE; do
      [[ -z "$RELEASE" ]] && continue
      mkdir -p "$HELM_DIR/$RELEASE"

      # Values
      $HELM get values "$RELEASE" -n "$NS" \
        > "$HELM_DIR/$RELEASE/values.yaml" 2>/dev/null || true

      # History
      $HELM history "$RELEASE" -n "$NS" \
        > "$HELM_DIR/$RELEASE/history.txt" 2>/dev/null || true

      # Info (chart name, version)
      $HELM list -n "$NS" -o json | \
        jq '.[] | select(.name=="'"$RELEASE"'")' \
        > "$HELM_DIR/$RELEASE/info.json" 2>/dev/null || true

      echo -e "      $RELEASE — OK"
    done <<< "$RELEASES"
  fi
}

# --- Бэкап кластерных ресурсов ---
backup_cluster_resources() {
  local BACKUP_DIR=$1
  local NAMESPACES=$2

  echo -e "  ${CYAN}Бэкапим кластерные ресурсы...${NC}"
  local CLUSTER_DIR="$BACKUP_DIR/cluster"
  mkdir -p "$CLUSTER_DIR"

  # Namespace объекты
  mkdir -p "$CLUSTER_DIR/namespaces"
  for NS in $NAMESPACES; do
    $KUBECTL get namespace "$NS" -o json 2>/dev/null | \
      clean_metadata > "$CLUSTER_DIR/namespaces/${NS}.json" || true
    echo -e "    namespace/$NS"
  done

  # StorageClasses
  mkdir -p "$CLUSTER_DIR/storageclasses"
  $KUBECTL get storageclasses -o json 2>/dev/null | \
    jq -c '.items[]' | while IFS= read -r ITEM; do
      NAME=$(echo "$ITEM" | jq -r '.metadata.name')
      echo "$ITEM" | clean_metadata > "$CLUSTER_DIR/storageclasses/${NAME}.json"
    done

  # PersistentVolumes связанные с нашими неймспейсами
  mkdir -p "$CLUSTER_DIR/persistentvolumes"
  $KUBECTL get pv -o json 2>/dev/null | \
    jq -c '.items[]' | while IFS= read -r ITEM; do
      CLAIM_NS=$(echo "$ITEM" | jq -r '.spec.claimRef.namespace // ""')
      for NS in $NAMESPACES; do
        if [[ "$CLAIM_NS" == "$NS" ]]; then
          NAME=$(echo "$ITEM" | jq -r '.metadata.name')
          echo "$ITEM" | clean_metadata > "$CLUSTER_DIR/persistentvolumes/${NAME}.json"
          echo -e "    pv/$NAME (ns: $CLAIM_NS)"
          break
        fi
      done
    done

  # ClusterRoles и ClusterRoleBindings связанные с нашими SA
  mkdir -p "$CLUSTER_DIR/clusterroles"
  mkdir -p "$CLUSTER_DIR/clusterrolebindings"

  $KUBECTL get clusterrolebindings -o json 2>/dev/null | \
    jq -c '.items[]' | while IFS= read -r ITEM; do
      for NS in $NAMESPACES; do
        if echo "$ITEM" | jq -e ".subjects[]? | select(.namespace == \"$NS\")" &>/dev/null; then
          NAME=$(echo "$ITEM" | jq -r '.metadata.name')
          echo "$ITEM" | clean_metadata > "$CLUSTER_DIR/clusterrolebindings/${NAME}.json"
          break
        fi
      done
    done
}

# --- Сохранить метаданные бэкапа ---
save_backup_meta() {
  local BACKUP_DIR=$1
  local NAMESPACES=$2

  cat > "$BACKUP_DIR/backup-meta.json" << EOF
{
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "date": "$(date '+%Y-%m-%d %H:%M:%S')",
  "ns_prefix": "$NS_PREFIX",
  "namespaces": $(echo "$NAMESPACES" | tr ' ' '\n' | jq -R . | jq -s .),
  "k8s_version": "$($KUBECTL version --short 2>/dev/null | head -2 | tr '\n' '|' || true)",
  "helm_version": "$($HELM version --short 2>/dev/null || true)"
}
EOF
  echo -e "  Метаданные сохранены: $BACKUP_DIR/backup-meta.json"
}

# =============================================================
# --- БЭКАП ---
# =============================================================
do_backup() {
  local FILTER_NS="${1:-}"
  local TIMESTAMP=$(date +%Y%m%d-%H%M%S)
  local BACKUP_DIR="$BACKUP_BASE/backup-${TIMESTAMP}"
  mkdir -p "$BACKUP_DIR"

  echo ""
  echo -e "${BLUE}=========================================="
  echo "  БЭКАП СТЕНДА"
  echo "  Директория: $BACKUP_DIR"
  echo -e "==========================================${NC}"

  # Получаем неймспейсы
  if [[ -n "$FILTER_NS" ]]; then
    if ! $KUBECTL get namespace "$FILTER_NS" &>/dev/null; then
      echo -e "${RED}ERROR: namespace '$FILTER_NS' не найден${NC}"
      exit 1
    fi
    NAMESPACES="$FILTER_NS"
    echo -e "Режим: один namespace '$FILTER_NS'"
  else
    NAMESPACES=$(get_namespaces)
    echo -e "Режим: все namespace с префиксом '${NS_PREFIX}*'"
  fi

  if [[ -z "$NAMESPACES" ]]; then
    echo -e "${RED}ERROR: неймспейсов не найдено${NC}"
    exit 1
  fi

  echo ""
  echo "Найдены неймспейсы:"
  echo "$NAMESPACES" | tr ' ' '\n' | while read -r NS; do
    echo -e "  - $NS"
  done
  echo ""

  # --- Кластерные ресурсы ---
  backup_cluster_resources "$BACKUP_DIR" "$NAMESPACES"

  # --- Бэкап каждого неймспейса ---
  echo ""
  echo -e "${CYAN}Бэкапим неймспейсы...${NC}"
  for NS in $NAMESPACES; do
    backup_namespace "$NS" "$BACKUP_DIR"
  done

  # --- Метаданные ---
  save_backup_meta "$BACKUP_DIR" "$NAMESPACES"

  # --- Архивируем ---
  echo ""
  echo -e "${CYAN}Создаём архив...${NC}"
  tar -czf "${BACKUP_DIR}.tar.gz" -C "$BACKUP_BASE" "backup-${TIMESTAMP}"
  rm -rf "$BACKUP_DIR"
  echo -e "${GREEN}Архив: ${BACKUP_DIR}.tar.gz${NC}"

  echo ""
  echo -e "${GREEN}=== БЭКАП ЗАВЕРШЁН ===${NC}"
  echo "Путь: ${BACKUP_DIR}.tar.gz"
  du -sh "${BACKUP_DIR}.tar.gz"
}

# =============================================================
# --- ВОССТАНОВЛЕНИЕ ---
# =============================================================

# --- Применить ресурс с очисткой ---
apply_resource() {
  local FILE=$1
  local NS=${2:-}

  if [[ ! -f "$FILE" ]]; then
    return 0
  fi

  # Дополнительная очистка перед apply
  local CLEANED
  CLEANED=$(cat "$FILE" | jq '
    del(
      .metadata.resourceVersion,
      .metadata.uid,
      .metadata.generation,
      .metadata.creationTimestamp,
      .metadata.managedFields,
      .metadata.ownerReferences,
      .status,
      .metadata.annotations."kubectl.kubernetes.io/last-applied-configuration"
    )
  ')

  if [[ -n "$NS" ]]; then
    echo "$CLEANED" | $KUBECTL apply -n "$NS" -f - 2>/dev/null || \
    echo "$CLEANED" | $KUBECTL create -n "$NS" -f - 2>/dev/null || true
  else
    echo "$CLEANED" | $KUBECTL apply -f - 2>/dev/null || \
    echo "$CLEANED" | $KUBECTL create -f - 2>/dev/null || true
  fi
}

do_restore() {
  local BACKUP_PATH=$1
  local FILTER_NS="${2:-}"

  # --- Распаковываем если архив ---
  local WORK_DIR
  if [[ "$BACKUP_PATH" == *.tar.gz ]]; then
    WORK_DIR="/tmp/stand-restore-$(date +%s)"
    mkdir -p "$WORK_DIR"
    echo -e "${CYAN}Распаковываем архив...${NC}"
    tar -xzf "$BACKUP_PATH" -C "$WORK_DIR" --strip-components=1
  else
    WORK_DIR="$BACKUP_PATH"
  fi

  if [[ ! -d "$WORK_DIR" ]]; then
    echo -e "${RED}ERROR: директория бэкапа не найдена: $WORK_DIR${NC}"
    exit 1
  fi

  echo ""
  echo -e "${BLUE}=========================================="
  echo "  ВОССТАНОВЛЕНИЕ СТЕНДА"
  echo "  Бэкап: $BACKUP_PATH"
  echo -e "==========================================${NC}"

  # Показываем метаданные бэкапа
  if [[ -f "$WORK_DIR/backup-meta.json" ]]; then
    echo ""
    echo "Информация о бэкапе:"
    jq -r '"  Дата:        " + .date, "  K8s версия:  " + .k8s_version, "  Неймспейсы: " + (.namespaces | join(", "))' \
      "$WORK_DIR/backup-meta.json" 2>/dev/null || true
  fi

  # Определяем неймспейсы для восстановления
  local NAMESPACES_TO_RESTORE=()
  if [[ -n "$FILTER_NS" ]]; then
    NAMESPACES_TO_RESTORE=("$FILTER_NS")
    echo -e "\nРежим: только namespace '$FILTER_NS'"
  else
    if [[ -d "$WORK_DIR/cluster/namespaces" ]]; then
      while IFS= read -r F; do
        NS=$(basename "$F" .json)
        NAMESPACES_TO_RESTORE+=("$NS")
      done < <(find "$WORK_DIR/cluster/namespaces" -name "*.json" | sort)
    fi
    echo -e "\nРежим: все неймспейсы из бэкапа"
  fi

  echo ""
  echo "Будут восстановлены:"
  for NS in "${NAMESPACES_TO_RESTORE[@]}"; do
    echo -e "  - $NS"
  done
  echo ""
  read -rp "Продолжить? [y/N]: " CONFIRM
  if [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]]; then
    echo "Отменено."
    exit 0
  fi

  local RESTORED=()
  local ERRORS=()

  # ==========================================================
  # Шаг 1: StorageClasses
  # ==========================================================
  echo ""
  echo -e "${CYAN}[1/7] StorageClasses...${NC}"
  if [[ -d "$WORK_DIR/cluster/storageclasses" ]]; then
    for F in "$WORK_DIR/cluster/storageclasses"/*.json; do
      [[ -f "$F" ]] || continue
      NAME=$(basename "$F" .json)
      if $KUBECTL get storageclass "$NAME" &>/dev/null; then
        echo -e "  ${YELLOW}Уже существует: $NAME${NC}"
      else
        apply_resource "$F" && echo -e "  ${GREEN}storageclass/$NAME${NC}" || \
          ERRORS+=("storageclass/$NAME")
      fi
    done
  fi

  # ==========================================================
  # Шаг 2: Namespaces
  # ==========================================================
  echo ""
  echo -e "${CYAN}[2/7] Namespaces...${NC}"
  for NS in "${NAMESPACES_TO_RESTORE[@]}"; do
    local NS_FILE="$WORK_DIR/cluster/namespaces/${NS}.json"
    if $KUBECTL get namespace "$NS" &>/dev/null; then
      echo -e "  ${YELLOW}Уже существует: $NS${NC}"
    else
      if [[ -f "$NS_FILE" ]]; then
        apply_resource "$NS_FILE" && echo -e "  ${GREEN}namespace/$NS${NC}" || \
          ERRORS+=("namespace/$NS")
      else
        $KUBECTL create namespace "$NS" && echo -e "  ${GREEN}namespace/$NS (создан)${NC}" || \
          ERRORS+=("namespace/$NS")
      fi
    fi
  done

  # ==========================================================
  # Шаг 3: PersistentVolumes
  # ==========================================================
  echo ""
  echo -e "${CYAN}[3/7] PersistentVolumes...${NC}"
  if [[ -d "$WORK_DIR/cluster/persistentvolumes" ]]; then
    for F in "$WORK_DIR/cluster/persistentvolumes"/*.json; do
      [[ -f "$F" ]] || continue
      NAME=$(basename "$F" .json)
      # Проверяем принадлежит ли PV нашим неймспейсам
      CLAIM_NS=$(jq -r '.spec.claimRef.namespace // ""' "$F")
      local MATCH=false
      for NS in "${NAMESPACES_TO_RESTORE[@]}"; do
        if [[ "$CLAIM_NS" == "$NS" ]]; then
          MATCH=true
          break
        fi
      done
      if [[ "$MATCH" == "true" ]]; then
        if $KUBECTL get pv "$NAME" &>/dev/null; then
          echo -e "  ${YELLOW}Уже существует: pv/$NAME${NC}"
        else
          apply_resource "$F" && echo -e "  ${GREEN}pv/$NAME${NC}" || \
            ERRORS+=("pv/$NAME")
        fi
      fi
    done
  fi

  # ==========================================================
  # Шаг 4: Ресурсы неймспейсов (в правильном порядке)
  # ==========================================================
  echo ""
  echo -e "${CYAN}[4/7] Ресурсы неймспейсов...${NC}"

  for NS in "${NAMESPACES_TO_RESTORE[@]}"; do
    local NS_DIR="$WORK_DIR/namespaces/$NS"
    [[ -d "$NS_DIR" ]] || continue

    echo -e "  ${YELLOW}namespace: $NS${NC}"

    for RESOURCE in "${RESTORE_ORDER[@]}"; do
      # Пропускаем кластерные — уже обработали
      [[ "$RESOURCE" == "namespaces" ]] && continue
      [[ "$RESOURCE" == "storageclasses" ]] && continue
      [[ "$RESOURCE" == "persistentvolumes" ]] && continue
      [[ "$RESOURCE" == "clusterroles" ]] && continue
      [[ "$RESOURCE" == "clusterrolebindings" ]] && continue

      local RES_DIR="$NS_DIR/$RESOURCE"
      [[ -d "$RES_DIR" ]] || continue

      local COUNT=0
      for F in "$RES_DIR"/*.json; do
        [[ -f "$F" ]] || continue
        NAME=$(basename "$F" .json)

        # Пропускаем системные serviceaccounts
        if [[ "$RESOURCE" == "serviceaccounts" && "$NAME" == "default" ]]; then
          continue
        fi

        # Пропускаем системные secrets
        if [[ "$RESOURCE" == "secrets" ]]; then
          TYPE=$(jq -r '.type // ""' "$F")
          if [[ "$TYPE" == "kubernetes.io/service-account-token" ]]; then
            continue
          fi
        fi

        apply_resource "$F" "$NS" && COUNT=$((COUNT + 1)) || \
          ERRORS+=("$NS/$RESOURCE/$NAME")
      done

      [[ $COUNT -gt 0 ]] && echo -e "    ${RESOURCE}: ${COUNT} объектов"
    done
  done

  # ==========================================================
  # Шаг 5: RBAC кластерный
  # ==========================================================
  echo ""
  echo -e "${CYAN}[5/7] ClusterRoleBindings...${NC}"
  if [[ -d "$WORK_DIR/cluster/clusterrolebindings" ]]; then
    for F in "$WORK_DIR/cluster/clusterrolebindings"/*.json; do
      [[ -f "$F" ]] || continue
      NAME=$(basename "$F" .json)
      apply_resource "$F" && echo -e "  ${GREEN}clusterrolebinding/$NAME${NC}" || \
        ERRORS+=("clusterrolebinding/$NAME")
    done
  fi

  # ==========================================================
  # Шаг 6: Helm releases
  # ==========================================================
  echo ""
  echo -e "${CYAN}[6/7] Helm releases...${NC}"

  for NS in "${NAMESPACES_TO_RESTORE[@]}"; do
    local HELM_NS_DIR="$WORK_DIR/helm/$NS"
    [[ -d "$HELM_NS_DIR" ]] || continue

    echo -e "  ${YELLOW}namespace: $NS${NC}"

    for RELEASE_DIR in "$HELM_NS_DIR"/*/; do
      [[ -d "$RELEASE_DIR" ]] || continue
      RELEASE=$(basename "$RELEASE_DIR")

      local INFO_FILE="$RELEASE_DIR/info.json"
      local VALUES_FILE="$RELEASE_DIR/values.yaml"

      if [[ ! -f "$INFO_FILE" ]]; then
        echo -e "    ${RED}$RELEASE: info.json не найден${NC}"
        ERRORS+=("helm/$NS/$RELEASE")
        continue
      fi

      CHART_FULL=$(jq -r '.chart' "$INFO_FILE")
      CHART_NAME=$(echo "$CHART_FULL" | sed 's/-[0-9][0-9.]*$//')
      CHART_VERSION=$(echo "$CHART_FULL" | grep -oP '[0-9]+\.[0-9]+\.[0-9.]+[^"]*$' || true)

      # Проверяем существует ли релиз
      RELEASE_EXISTS=$($HELM list -n "$NS" -q 2>/dev/null | grep -x "$RELEASE" || true)

      VALUES_FLAG=""
      [[ -f "$VALUES_FILE" ]] && VALUES_FLAG="-f $VALUES_FILE"

      if [[ -n "$RELEASE_EXISTS" ]]; then
        echo -e "    ${YELLOW}$RELEASE: уже существует — upgrade${NC}"
        if $HELM upgrade "$RELEASE" "$CHART_NAME" \
          -n "$NS" \
          --reuse-values \
          $VALUES_FLAG \
          ${CHART_VERSION:+--version "$CHART_VERSION"} \
          > /tmp/helm-restore.log 2>&1; then
          echo -e "    ${GREEN}$RELEASE: OK${NC}"
          RESTORED+=("$NS|$RELEASE|upgrade")
        else
          echo -e "    ${RED}$RELEASE: ОШИБКА$(tail -1 /tmp/helm-restore.log)${NC}"
          ERRORS+=("helm/$NS/$RELEASE")
        fi
      else
        echo -e "    $RELEASE: install"
        if $HELM install "$RELEASE" "$CHART_NAME" \
          -n "$NS" \
          --create-namespace \
          $VALUES_FLAG \
          ${CHART_VERSION:+--version "$CHART_VERSION"} \
          > /tmp/helm-restore.log 2>&1; then
          echo -e "    ${GREEN}$RELEASE: OK${NC}"
          RESTORED+=("$NS|$RELEASE|install")
        else
          echo -e "    ${RED}$RELEASE: ОШИБКА $(tail -1 /tmp/helm-restore.log)${NC}"
          ERRORS+=("helm/$NS/$RELEASE")
        fi
      fi
    done
  done

  # ==========================================================
  # Шаг 7: Проверка подов
  # ==========================================================
  echo ""
  echo -e "${CYAN}[7/7] Проверка подов...${NC}"
  for NS in "${NAMESPACES_TO_RESTORE[@]}"; do
    echo -e "  ${YELLOW}$NS:${NC}"
    $KUBECTL get pods -n "$NS" 2>/dev/null || true
  done

  # --- Чистим tmp ---
  if [[ "$BACKUP_PATH" == *.tar.gz ]]; then
    rm -rf "$WORK_DIR"
  fi

  # ==========================================================
  # Таблица результатов
  # ==========================================================
  echo ""
  echo "=========================================="
  echo "  ВОССТАНОВЛЕНО (Helm)"
  echo "=========================================="
  printf "%-30s %-20s %-10s\n" "NAMESPACE" "RELEASE" "ACTION"
  printf "%-30s %-20s %-10s\n" "------------------------------" "--------------------" "----------"
  if [[ ${#RESTORED[@]} -eq 0 ]]; then
    echo "  Нет helm-релизов"
  else
    for ROW in "${RESTORED[@]}"; do
      IFS='|' read -r NS REL ACT <<< "$ROW"
      printf "%-30s %-20s ${GREEN}%-10s${NC}\n" "$NS" "$REL" "$ACT"
    done
  fi

  echo ""
  echo "=========================================="
  echo "  ОШИБКИ"
  echo "=========================================="
  if [[ ${#ERRORS[@]} -eq 0 ]]; then
    echo -e "  ${GREEN}Ошибок нет${NC}"
  else
    for ERR in "${ERRORS[@]}"; do
      echo -e "  ${RED}$ERR${NC}"
    done
  fi

  echo ""
  echo -e "${GREEN}=== ВОССТАНОВЛЕНИЕ ЗАВЕРШЕНО ===${NC}"
}

# =============================================================
# --- СПИСОК БЭКАПОВ ---
# =============================================================
list_backups() {
  echo ""
  echo "Доступные бэкапы в $BACKUP_BASE:"
  echo ""
  if ls "$BACKUP_BASE"/backup-*.tar.gz &>/dev/null; then
    ls -lh "$BACKUP_BASE"/backup-*.tar.gz | \
      awk '{print $5, $9}' | \
      while read -r SIZE PATH; do
        NAME=$(basename "$PATH")
        DATE=$(echo "$NAME" | grep -oP '\d{8}-\d{6}' | \
          sed 's/\(....\)\(..\)\(..\)-\(..\)\(..\)\(..\)/\1-\2-\3 \4:\5:\6/')
        echo -e "  ${CYAN}$NAME${NC}  $DATE  ($SIZE)"
      done
  else
    echo "  Бэкапов не найдено"
  fi
  echo ""
}

# =============================================================
# --- МЕНЮ ---
# =============================================================
show_menu() {
  echo ""
  echo -e "${BLUE}=========================================="
  echo "  STAND BACKUP/RESTORE"
  echo "  Префикс: ${NS_PREFIX}*"
  echo -e "==========================================${NC}"
  echo ""
  echo "  1) Создать бэкап всех неймспейсов (${NS_PREFIX}*)"
  echo "  2) Создать бэкап одного неймспейса"
  echo "  3) Восстановить весь стенд из бэкапа"
  echo "  4) Восстановить один неймспейс из бэкапа"
  echo "  5) Список бэкапов"
  echo "  6) Выйти"
  echo ""
  read -rp "Выбор [1-6]: " CHOICE

  case "$CHOICE" in
    1)
      do_backup
      ;;
    2)
      echo ""
      echo "Доступные неймспейсы:"
      get_namespaces | tr ' ' '\n' | while read -r NS; do
        echo "  - $NS"
      done
      echo ""
      read -rp "Введи namespace: " NS_INPUT
      do_backup "$NS_INPUT"
      ;;
    3)
      list_backups
      read -rp "Путь к архиву бэкапа: " BACKUP_PATH
      do_restore "$BACKUP_PATH"
      ;;
    4)
      list_backups
      read -rp "Путь к архиву бэкапа: " BACKUP_PATH
      echo ""
      read -rp "Namespace для восстановления: " NS_INPUT
      do_restore "$BACKUP_PATH" "$NS_INPUT"
      ;;
    5)
      list_backups
      show_menu
      ;;
    6)
      echo "Выход."
      exit 0
      ;;
    *)
      echo "Неверный выбор"
      show_menu
      ;;
  esac
}

# =============================================================
# --- ТОЧКА ВХОДА ---
# =============================================================
mkdir -p "$BACKUP_BASE"

case "${1:-menu}" in
  backup)
    do_backup "${2:-}"
    ;;
  restore)
    if [[ -z "${2:-}" ]]; then
      echo "ERROR: укажи путь к бэкапу"
      echo "Использование: $0 restore /path/to/backup.tar.gz [namespace]"
      exit 1
    fi
    do_restore "$2" "${3:-}"
    ;;
  list)
    list_backups
    ;;
  menu|*)
    show_menu
    ;;
esac
