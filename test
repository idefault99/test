# Получить реальный CA который отдаёт Vault
openssl s_client -connect vault.test.ru:443 2>/dev/null \
  | openssl x509 -out /tmp/vault-real.crt

# Пересоздать ConfigMap с реальным сертом
microk8s kubectl delete configmap vault-ca -n external-secrets
microk8s kubectl create configmap vault-ca \
  --from-file=ca.crt=/tmp/vault-real.crt \
  -n external-secrets

microk8s kubectl rollout restart deployment external-secrets -n external-secrets
