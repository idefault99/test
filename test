{{- if eq .Values.enableService.redis.enable true }}
{{- $modules := .Files.Get "files/redis_module.yaml" | fromYaml -}}
{{- range $module := $modules.main }}
{{- if or (index $.Values.enableModules $module) (eq $module "")}}
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ $.Values.labels.redis }}-deployment
  annotations:
    "helm.sh/resource-policy": keep
  labels:
    app: {{ $.Values.labels.redis }}
    app.kubernetes.io/managed-by: Helm
  namespace: {{ $.Release.Namespace }}{{ if eq $module "" }}{{ else }}-{{ $module }}{{ end }}
spec:
  serviceName: {{ $.Values.labels.redis }}-headless
  {{- if eq $.Values.enableService.redis.type "cluster" }}
  replicas: 3
  {{- else if eq $.Values.enableService.redis.type "single" }}
  replicas: 1
  {{- else }}
  {{ fail "Type of redis must be 'single' or 'cluster'" }}
  {{- end }}
  selector:
    matchLabels:
      app: {{ $.Values.labels.redis }}
  podManagementPolicy: OrderedReady
  updateStrategy:
    type: RollingUpdate
  persistentVolumeClaimRetentionPolicy:
    whenDeleted: Retain
    whenScaled: Retain
  template:
    metadata:
      labels:
        app: {{ $.Values.labels.redis }}
    spec:
      {{- if eq $.Values.enableService.redis.type "cluster" }}
      affinity:
        podAntiAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            - labelSelector:
                matchExpressions:
                  - key: app
                    operator: In
                    values:
                      - {{ $.Values.labels.redis }}
              topologyKey: kubernetes.io/hostname
      {{- end }}
      initContainers:
        # Исправляем права на /data для nonroot образа.
        # Работает с любым storage: nfs-csi, longhorn, emptyDir —
        # потому что запускается уже после того как том примонтирован.
        # busybox запускается от root, поэтому chown всегда проходит.
        - name: fix-permissions
          image: busybox:1.36
          command: ['sh', '-c']
          args:
            - |
              mkdir -p /data
              # Получаем UID/GID основного контейнера из образа redis
              # Стандартный redis-образ использует UID 999 (redis user)
              chown -R 999:999 /data
              chmod -R 755 /data
              echo "==> /data permissions fixed: $(ls -la /data)"
          volumeMounts:
            - name: {{ $.Values.labels.redis }}-data
              mountPath: /data
          securityContext:
            runAsUser: 0   # root — только для chown, основной контейнер nonroot

        - name: init-data-dir
          image: {{ $.Values.images.redis }}
          command: ['sh', '-c']
          args:
            - |
              CLUSTER_MODE="{{ $.Values.enableService.redis.type }}"
              NODES_CONF="/data/nodes.conf"
              
              echo "==> Redis data init | Режим: $CLUSTER_MODE"
              echo "==> Содержимое /data/:"
              ls -la /data/ 2>/dev/null || echo "  (пусто)"

              if [ "$CLUSTER_MODE" = "cluster" ]; then
                if [ ! -f "$NODES_CONF" ]; then
                  echo "==> nodes.conf отсутствует — очищаем /data/ для cluster mode"
                  find /data -mindepth 1 -delete 2>/dev/null || true
                  echo "==> Очищено"
                else
                  echo "==> nodes.conf найден — данные от cluster mode, пропускаем очистку"
                fi
              else
                if [ -f "$NODES_CONF" ]; then
                  echo "==> nodes.conf найден — очищаем /data/ для single mode"
                  find /data -mindepth 1 -delete 2>/dev/null || true
                  echo "==> Очищено"
                else
                  echo "==> Данные совместимы с single mode — пропускаем очистку"
                fi
              fi

              echo "==> /data/ после инициализации: "
              ls -la /data/ 2>/dev/null || echo "  (пусто)"
          volumeMounts:
            - name: {{ $.Values.labels.redis }}-data
              mountPath: /data
      containers:
        - name: {{ $.Values.labels.redis }}
          image: {{ $.Values.images.redis }}
          imagePullPolicy: IfNotPresent
          {{- if eq $.Values.enableService.redis.type "cluster" }}
          command:
            - sh
            - -c
            - |
              cat > /tmp/redis.conf << EOF
              port {{ $.Values.ports.internal.redis.client }}
              cluster-enabled yes
              cluster-config-file /data/nodes.conf
              cluster-node-timeout 5000
              appendonly yes
              dir /data
              cluster-announce-hostname $(MY_POD_NAME).{{ $.Values.labels.redis }}-headless.{{ $.Release.Namespace }}{{ if eq $module "" }}{{ else }}-{{ $module }}{{ end }}.svc.{{ $.Values.localK8sDomain }}
              EOF
              exec redis-server /tmp/redis.conf
          env:
            - name: MY_POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
          {{- else }}
          command:
            - redis-server
            - --appendonly
            - "yes"
            - --dir
            - /data
          {{- end }}
          ports:
            - name: client
              containerPort: {{ $.Values.ports.internal.redis.client }}
          {{- if eq $.Values.enableService.redis.type "cluster" }}
            - name: bus
              containerPort: {{ $.Values.ports.internal.redis.bus }}
          {{- end }}
          volumeMounts:
            - name: {{ $.Values.labels.redis }}-data
              mountPath: /data
          resources:
            limits:
              cpu: {{ ((((($.Values.configPods).redis).resources).limits).cpu) | default "200m" }}
              memory: {{ ((((($.Values.configPods).redis).resources).limits).memory) | default "500Mi" }}
            requests:
              cpu: {{ ((((($.Values.configPods).redis).resources).requests).cpu) | default "100m" }}
              memory: {{ ((((($.Values.configPods).redis).resources).requests).memory) | default "250Mi" }}
          readinessProbe:
            exec:
              command:
                - redis-cli
                - ping
            initialDelaySeconds: 5
            periodSeconds: 5
            failureThreshold: 5
          livenessProbe:
            exec:
              command:
                - redis-cli
                - ping
            initialDelaySeconds: 10
            periodSeconds: 10
            failureThreshold: 3
      imagePullSecrets:
        - name: {{ $.Values.imagePullSecret }}

      # Том определяется здесь только если PVC выключен.
      # Если PVC включен — том создаётся через volumeClaimTemplates ниже
      # и StatefulSet сам его монтирует по имени.
      {{- if not ($.Values.enableService.redis.pvcEnabled) }}
      volumes:
        - name: {{ $.Values.labels.redis }}-data
          emptyDir: {}
      {{- end }}

  # PVC создаётся только если явно включён в values:
  #   enableService.redis.pvcEnabled: true
  # При выключенном pvcEnabled используется emptyDir (см. выше).
  # Это позволяет менять storage (nfs-csi / longhorn) только через values
  # без изменения шаблона.
  {{- if $.Values.enableService.redis.pvcEnabled }}
  volumeClaimTemplates:
    - metadata:
        name: {{ $.Values.labels.redis }}-data
      spec:
        accessModes:
          - ReadWriteOnce
        storageClassName: {{ $.Values.enableService.redis.storageClassName | default "nfs-csi" }}
        resources:
          requests:
            storage: {{ $.Values.enableService.redis.storageSize | default "1Gi" }}
  {{- end }}
{{- end }}
{{- end }}
{{- end }}
---
{{- if eq .Values.enableService.redis.enable true }}
{{- $modules := .Files.Get "files/redis_module.yaml" | fromYaml -}}
{{- range $module := $modules.main }}
{{- if or (index $.Values.enableModules $module) (eq $module "")}}
{{- $ns := printf "%s%s" $.Release.Namespace (ternary "" (printf "-%s" $module) (eq $module "")) }}
---
apiVersion: batch/v1
kind: Job
metadata:
  name: {{ $.Values.labels.redis }}-pre-upgrade-{{ $.Release.Revision }}
  namespace: {{ $ns }}
  annotations:
    "helm.sh/hook": pre-upgrade
    "helm.sh/hook-weight": "-5"
    "helm.sh/hook-delete-policy": before-hook-creation,hook-succeeded
spec:
  backoffLimit: 1
  activeDeadlineSeconds: 120
  ttlSecondsAfterFinished: 60
  template:
    spec:
      serviceAccountName: {{ $.Values.labels.redis }}-waiter-sa
      restartPolicy: Never
      imagePullSecrets:
        - name: {{ $.Values.imagePullSecret }}
      containers:
        - name: pre-upgrade
          image: {{ $.Values.images.kubectl }}
          command: ['sh', '-c']
          args:
            - |
              NS="{{ $ns }}"
              STS="{{ $.Values.labels.redis }}-deployment"
              if ! kubectl get statefulset $STS -n $NS > /dev/null 2>&1; then
                echo "StatefulSet не найден"
                exit 0
              fi

              VCT=$(kubectl get statefulset $STS -n $NS \
                -o jsonpath='{.spec.volumeClaimTemplates}' 2>/dev/null)

              if [ -n "$VCT" ] && [ "$VCT" != "null" ] && [ "$VCT" != "[]" ]; then
                echo "volumeClaimTemplates уже есть - StatefulSet совместим"
                exit 0
              fi

              echo "Старый StatefulSet без volumeClaimTemplates - удаляем с cascade=orphan"
              kubectl delete statefulset $STS -n $NS --cascade=orphan
{{- end }}
{{- end }}
{{- end }}
---
{{- if and (eq .Values.enableService.redis.enable true) (eq .Values.enableService.redis.type "cluster") }}
{{- $modules := .Files.Get "files/redis_module.yaml" | fromYaml -}}
{{- range $module := $modules.main }}
{{- if or (index $.Values.enableModules $module) (eq $module "")}}
{{- $ns := printf "%s%s" $.Release.Namespace (ternary "" (printf "-%s" $module) (eq $module "")) }}
---
apiVersion: batch/v1
kind: Job
metadata:
  name: {{ $.Values.labels.redis }}-job-{{ $.Release.Revision }}
  labels:
    app: {{ $.Values.labels.redis }}
  namespace: {{ $ns }}
  annotations:
    "helm.sh/hook": post-install,post-upgrade
    "helm.sh/hook-weight": "5"
    "helm.sh/hook-delete-policy": before-hook-creation
spec:
  backoffLimit: 3
  activeDeadlineSeconds: 600
  ttlSecondsAfterFinished: 300
  template:
    spec:
      serviceAccountName: {{ $.Values.labels.redis }}-waiter-sa
      restartPolicy: Never
      imagePullSecrets:
        - name: {{ $.Values.imagePullSecret }}
      initContainers:
        - name: wait-for-redis-nodes
          image: registry.test.model.svo.aero/dpm/iac/infra:kubectl
          command: ['sh', '-c']
          args:
            - |
              NS="{{ $ns }}"
              PREFIX="{{ $.Values.labels.redis }}-deployment"

              for INDEX in 0 1 2; do
                POD="${PREFIX}-${INDEX}"

                ATTEMPTS=0
                until kubectl get pod $POD -n $NS > /dev/null 2>&1; do
                  ATTEMPTS=$((ATTEMPTS + 1))
                  if [ $ATTEMPTS -ge 60 ]; then
                    echo "error: ${POD} не появился"
                    exit 1
                  fi
                  sleep 5
                done

                echo "  ${POD} найден, ждём Ready..."
                kubectl wait --for=condition=Ready \
                  -n $NS pod/$POD --timeout=300s

                echo "  ${POD}: Ready"
              done

              echo "OK"
      containers:
        - name: {{ $.Values.labels.redis }}
          image: {{ $.Values.images.redis }}
          imagePullPolicy: "IfNotPresent"
          command: ["sh", "-c"]
          args:
            - |
              POD0="{{ $.Values.labels.redis }}-deployment-0.{{ $.Values.labels.redis }}-headless.{{ $ns }}.svc.{{ $.Values.localK8sDomain }}"
              POD1="{{ $.Values.labels.redis }}-deployment-1.{{ $.Values.labels.redis }}-headless.{{ $ns }}.svc.{{ $.Values.localK8sDomain }}"
              POD2="{{ $.Values.labels.redis }}-deployment-2.{{ $.Values.labels.redis }}-headless.{{ $ns }}.svc.{{ $.Values.localK8sDomain }}"
              PORT="{{ $.Values.ports.internal.redis.client }}"

              echo "Проверяем состояние кластера..."
              CLUSTER_INFO=$(redis-cli -h $POD0 -p $PORT cluster info 2>/dev/null)
              CLUSTER_STATE=$(echo "$CLUSTER_INFO" | grep "^cluster_state" | cut -d: -f2 | tr -d '[:space:]')
              CLUSTER_SLOTS_OK=$(echo "$CLUSTER_INFO" | grep "^cluster_slots_ok" | cut -d: -f2 | tr -d '[:space:]')
              CLUSTER_NODES=$(echo "$CLUSTER_INFO" | grep "^cluster_known_nodes" | cut -d: -f2 | tr -d '[:space:]')

              echo "  state=${CLUSTER_STATE} slots_ok=${CLUSTER_SLOTS_OK} known_nodes=${CLUSTER_NODES}"

              if [ "$CLUSTER_STATE" = "ok" ] && \
                 [ "${CLUSTER_SLOTS_OK:-0}" = "16384" ] && \
                 [ "${CLUSTER_NODES:-0}" -ge "3" ]; then
                exit 0
              fi

              for POD in $POD0 $POD1 $POD2; do
                redis-cli -h $POD -p $PORT flushall 2>/dev/null || true
                redis-cli -h $POD -p $PORT cluster reset hard 2>/dev/null || true
              done
              sleep 3

              echo "Создаём Redis Cluster"
              redis-cli --cluster create \
                $POD0:$PORT \
                $POD1:$PORT \
                $POD2:$PORT \
                --cluster-replicas 0 \
                --cluster-yes

              if [ $? -ne 0 ]; then
                echo "error: не удалось создать кластер"
                exit 1
              fi

              sleep 3
              redis-cli -h $POD0 -p $PORT cluster info
              echo ""
              redis-cli -h $POD0 -p $PORT cluster nodes
{{- end }}
{{- end }}
{{- end }}
