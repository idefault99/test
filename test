#!/bin/bash
# install-vault.sh — Установка HashiCorp Vault на Ubuntu
set -euo pipefail

VAULT_VERSION="1.17.2"
VAULT_DOMAIN="vault.internal"   # или IP VM, например 192.168.1.10
VAULT_DATA_DIR="/opt/vault/data"
VAULT_CONFIG_DIR="/etc/vault.d"
VAULT_TLS_DIR="/opt/vault/tls"
VAULT_USER="vault"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
log()  { echo -e "${GREEN}[INFO]${NC} $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
err()  { echo -e "${RED}[ERR]${NC} $*"; exit 1; }

# ── 1. Зависимости ──────────────────────────────────────────────
log "Устанавливаем зависимости..."
apt-get update -q
apt-get install -y curl gnupg openssl jq unzip

# ── 2. HashiCorp репозиторий ────────────────────────────────────
log "Добавляем HashiCorp repo..."
curl -fsSL https://apt.releases.hashicorp.com/gpg | gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg
echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" \
  > /etc/apt/sources.list.d/hashicorp.list
apt-get update -q
apt-get install -y vault

log "Vault $(vault version) установлен"

# ── 3. Пользователь и директории ───────────────────────────────
log "Создаём пользователя и директории..."
id -u ${VAULT_USER} &>/dev/null || useradd --system --home /etc/vault.d --shell /bin/false ${VAULT_USER}
mkdir -p ${VAULT_DATA_DIR} ${VAULT_TLS_DIR}
chown -R ${VAULT_USER}:${VAULT_USER} /opt/vault

# ── 4. Self-signed TLS ─────────────────────────────────────────
log "Генерируем self-signed TLS (CA + cert)..."

# CA
openssl genrsa -out ${VAULT_TLS_DIR}/ca.key 4096
openssl req -x509 -new -nodes \
  -key ${VAULT_TLS_DIR}/ca.key \
  -sha256 -days 3650 \
  -subj "/CN=vault-ca/O=internal" \
  -out ${VAULT_TLS_DIR}/ca.crt

# Cert
VAULT_IP=$(hostname -I | awk '{print $1}')
openssl genrsa -out ${VAULT_TLS_DIR}/vault.key 2048
openssl req -new \
  -key ${VAULT_TLS_DIR}/vault.key \
  -subj "/CN=${VAULT_DOMAIN}/O=internal" \
  -out ${VAULT_TLS_DIR}/vault.csr

cat > ${VAULT_TLS_DIR}/vault.ext <<EOF
[SAN]
subjectAltName=DNS:${VAULT_DOMAIN},DNS:localhost,IP:${VAULT_IP},IP:127.0.0.1
EOF

openssl x509 -req \
  -in ${VAULT_TLS_DIR}/vault.csr \
  -CA ${VAULT_TLS_DIR}/ca.crt \
  -CAkey ${VAULT_TLS_DIR}/ca.key \
  -CAcreateserial \
  -out ${VAULT_TLS_DIR}/vault.crt \
  -days 3650 -sha256 \
  -extfile ${VAULT_TLS_DIR}/vault.ext \
  -extensions SAN

chown -R ${VAULT_USER}:${VAULT_USER} ${VAULT_TLS_DIR}
chmod 600 ${VAULT_TLS_DIR}/*.key
chmod 644 ${VAULT_TLS_DIR}/*.crt

log "TLS готов. CA cert: ${VAULT_TLS_DIR}/ca.crt"
log "Vault IP: ${VAULT_IP}"

# ── 5. Конфиг Vault ────────────────────────────────────────────
log "Создаём конфиг Vault..."
cat > ${VAULT_CONFIG_DIR}/vault.hcl <<EOF
ui            = true
disable_mlock = true

storage "raft" {
  path    = "${VAULT_DATA_DIR}"
  node_id = "vault-node-1"
}

listener "tcp" {
  address       = "0.0.0.0:8200"
  tls_cert_file = "${VAULT_TLS_DIR}/vault.crt"
  tls_key_file  = "${VAULT_TLS_DIR}/vault.key"
}

api_addr     = "https://${VAULT_IP}:8200"
cluster_addr = "https://${VAULT_IP}:8201"
EOF

chown ${VAULT_USER}:${VAULT_USER} ${VAULT_CONFIG_DIR}/vault.hcl
chmod 640 ${VAULT_CONFIG_DIR}/vault.hcl

# ── 6. systemd ─────────────────────────────────────────────────
log "Настраиваем systemd..."
cat > /etc/systemd/system/vault.service <<EOF
[Unit]
Description=HashiCorp Vault
Documentation=https://developer.hashicorp.com/vault/docs
Requires=network-online.target
After=network-online.target

[Service]
User=${VAULT_USER}
Group=${VAULT_USER}
ExecStart=/usr/bin/vault server -config=${VAULT_CONFIG_DIR}/vault.hcl
ExecReload=/bin/kill -HUP \$MAINPID
KillMode=process
KillSignal=SIGINT
Restart=on-failure
RestartSec=5
LimitNOFILE=65536
LimitMEMLOCK=infinity
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable vault
systemctl start vault
sleep 3

log "Vault запущен: $(systemctl is-active vault)"

# ── 7. Инициализация ───────────────────────────────────────────
export VAULT_ADDR="https://127.0.0.1:8200"
export VAULT_CACERT="${VAULT_TLS_DIR}/ca.crt"

log "Инициализируем Vault (5 ключей, порог 3)..."
INIT_OUTPUT=$(vault operator init -key-shares=5 -key-threshold=3 -format=json)

echo "${INIT_OUTPUT}" > /root/vault-init.json
chmod 600 /root/vault-init.json

log "Unseal keys и root token сохранены в /root/vault-init.json — СОХРАНИ В НАДЁЖНОМ МЕСТЕ!"

# Auto-unseal для первого запуска
log "Распечатываем Vault (3 ключа из 5)..."
for i in 0 1 2; do
  KEY=$(echo "${INIT_OUTPUT}" | jq -r ".unseal_keys_b64[${i}]")
  vault operator unseal "${KEY}"
done

ROOT_TOKEN=$(echo "${INIT_OUTPUT}" | jq -r '.root_token')
log "Vault распечатан и готов"

echo ""
echo -e "${GREEN}════════════════════════════════════════${NC}"
echo -e "${GREEN}  Vault установлен и инициализирован!${NC}"
echo -e "${GREEN}════════════════════════════════════════${NC}"
echo -e "  URL:        https://${VAULT_IP}:8200"
echo -e "  CA cert:    ${VAULT_TLS_DIR}/ca.crt"
echo -e "  Init dump:  /root/vault-init.json"
echo -e "  Root token: ${ROOT_TOKEN}"
echo -e "${YELLOW}  ⚠ Сохрани /root/vault-init.json в надёжном месте!${NC}"
echo ""
echo "export VAULT_ADDR=https://${VAULT_IP}:8200"
echo "export VAULT_CACERT=${VAULT_TLS_DIR}/ca.crt"
echo "export VAULT_TOKEN=${ROOT_TOKEN}"

