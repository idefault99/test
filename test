## Шаблонизация и отладка

```bash
# Рендер шаблонов локально без деплоя (аналог dry-run, но без обращения к API)
helm template <release-name> <chart>
helm template my-nginx bitnami/nginx

# Рендер с указанием namespace
helm template my-nginx bitnami/nginx -n production

# Рендер с кастомными values
helm template my-nginx bitnami/nginx -f values.yaml

# Рендер с --set
helm template my-nginx bitnami/nginx --set replicaCount=2

# Рендер только конкретного шаблона
helm template my-nginx ./my-chart/ -s templates/deployment.yaml

# Рендер с включением CRD
helm template my-nginx bitnami/nginx --include-crds

# Валидация чарта (структура, синтаксис, dependencies)
helm lint <chart>
helm lint ./my-chart/

# Линтинг со своими values
helm lint ./my-chart/ -f values.yaml

# Линтинг с флагом строгости (warning → error)
helm lint ./my-chart/ --strict

# Тест задеплоенного релиза (запускает test-хуки из чарта)
helm test <release-name>
helm test my-nginx

# Тест с выводом логов
helm test my-nginx --logs

# Тест в конкретном namespace
helm test my-nginx -n production
```

