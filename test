# Все переменные проекта
curl -s --header "PRIVATE-TOKEN: <your_token>" \
  "https://gitlab.example.com/api/v4/projects/<project_id>/variables" | jq '.'

# Только NAMESPACE переменные
curl -s --header "PRIVATE-TOKEN: <your_token>" \
  "https://gitlab.example.com/api/v4/projects/<project_id>/variables" | \
  jq '.[] | select(.key == "NAMESPACE")'

# Только VALUES переменные
curl -s --header "PRIVATE-TOKEN: <your_token>" \
  "https://gitlab.example.com/api/v4/projects/<project_id>/variables" | \
  jq '.[] | select(.key == "VALUES")'
