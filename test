## 1. Код библиотеки

### `minio_client/client.py`

```python
import os
import io
from urllib.parse import urlsplit, urlunsplit
from typing import Optional, BinaryIO

import boto3
from botocore.config import Config
from botocore.exceptions import ClientError


class MinioClient:
    """
    Клиент для работы с MinIO S3.
    Автоматически обрабатывает subpath за nginx ingress с rewrite.
    """

    def __init__(self, host: str, access_key: str, secret_key: str, prefix: str = ""):
        """
        host       — хост без префикса, например https://dev.example.com
        access_key — MinIO Access Key
        secret_key — MinIO Secret Key
        prefix     — субпуть если MinIO за nginx rewrite, например /api/s3minio
        """
        self._prefix = prefix.rstrip("/")

        self._s3 = boto3.client(
            "s3",
            endpoint_url=host,
            aws_access_key_id=access_key,
            aws_secret_access_key=secret_key,
            region_name="us-east-1",
            config=Config(
                signature_version="s3v4",
                s3={"addressing_style": "path"},
            ),
        )

        if self._prefix:
            self._s3.meta.events.register("before-send.s3.*", self._add_prefix)

    def _add_prefix(self, request, **kwargs):
        """Добавляет prefix в URL после подписания, до отправки."""
        parsed = urlsplit(request.url)
        request.url = urlunsplit((
            parsed.scheme,
            parsed.netloc,
            self._prefix + parsed.path,
            parsed.query,
            parsed.fragment,
        ))

    # ------------------------------------------------------------------
    # Бакеты
    # ------------------------------------------------------------------

    def list_buckets(self) -> list[str]:
        """Вернуть список имён всех бакетов."""
        response = self._s3.list_buckets()
        return [b["Name"] for b in response.get("Buckets", [])]

    def bucket_exists(self, bucket: str) -> bool:
        """Проверить существует ли бакет."""
        try:
            self._s3.head_bucket(Bucket=bucket)
            return True
        except ClientError as e:
            if e.response["Error"]["Code"] in ("404", "NoSuchBucket"):
                return False
            raise

    def create_bucket(self, bucket: str) -> None:
        """Создать бакет. Если уже существует — ничего не делает."""
        if not self.bucket_exists(bucket):
            self._s3.create_bucket(Bucket=bucket)

    def delete_bucket(self, bucket: str, force: bool = False) -> None:
        """
        Удалить бакет.
        force=True — сначала удаляет все объекты внутри.
        """
        if force:
            self.delete_all_objects(bucket)
        self._s3.delete_bucket(Bucket=bucket)

    # ------------------------------------------------------------------
    # Объекты
    # ------------------------------------------------------------------

    def list_objects(self, bucket: str, prefix: str = "") -> list[dict]:
        """
        Вернуть список объектов в бакете.
        Каждый элемент: {"key": str, "size": int, "last_modified": datetime}
        """
        paginator = self._s3.get_paginator("list_objects_v2")
        result = []
        for page in paginator.paginate(Bucket=bucket, Prefix=prefix):
            for obj in page.get("Contents", []):
                result.append({
                    "key": obj["Key"],
                    "size": obj["Size"],
                    "last_modified": obj["LastModified"],
                })
        return result

    def upload_file(self, bucket: str, local_path: str, object_key: str = None) -> str:
        """
        Загрузить файл с диска в бакет.
        Если object_key не указан — берётся имя файла.
        Возвращает object_key.
        """
        if not os.path.exists(local_path):
            raise FileNotFoundError(f"Файл не найден: {local_path}")
        if object_key is None:
            object_key = os.path.basename(local_path)
        self._s3.upload_file(local_path, bucket, object_key)
        return object_key

    def upload_bytes(self, bucket: str, object_key: str, data: bytes,
                     content_type: str = "application/octet-stream") -> None:
        """Загрузить bytes-объект без сохранения на диск."""
        self._s3.upload_fileobj(io.BytesIO(data), bucket, object_key,
                                ExtraArgs={"ContentType": content_type})

    def download_file(self, bucket: str, object_key: str, local_path: str) -> None:
        """Скачать объект из бакета на диск."""
        self._s3.download_file(bucket, object_key, local_path)

    def download_bytes(self, bucket: str, object_key: str) -> bytes:
        """Скачать объект из бакета в память, вернуть bytes."""
        buf = io.BytesIO()
        self._s3.download_fileobj(bucket, object_key, buf)
        return buf.getvalue()

    def delete_object(self, bucket: str, object_key: str) -> None:
        """Удалить объект."""
        self._s3.delete_object(Bucket=bucket, Key=object_key)

    def delete_all_objects(self, bucket: str) -> None:
        """Удалить все объекты в бакете."""
        objects = self.list_objects(bucket)
        if not objects:
            return
        self._s3.delete_objects(
            Bucket=bucket,
            Delete={"Objects": [{"Key": obj["key"]} for obj in objects]},
        )

    def object_exists(self, bucket: str, object_key: str) -> bool:
        """Проверить существует ли объект."""
        try:
            self._s3.head_object(Bucket=bucket, Key=object_key)
            return True
        except ClientError as e:
            if e.response["Error"]["Code"] in ("404", "NoSuchKey"):
                return False
            raise

    def copy_object(self, src_bucket: str, src_key: str,
                    dst_bucket: str, dst_key: str) -> None:
        """Скопировать объект между бакетами или внутри одного бакета."""
        self._s3.copy_object(
            CopySource={"Bucket": src_bucket, "Key": src_key},
            Bucket=dst_bucket,
            Key=dst_key,
        )

    # ------------------------------------------------------------------
    # Утилиты
    # ------------------------------------------------------------------

    def presigned_url(self, bucket: str, object_key: str,
                      expires_in: int = 3600) -> str:
        """
        Получить временную ссылку на скачивание объекта.
        expires_in — время жизни ссылки в секундах (по умолчанию 1 час).
        """
        return self._s3.generate_presigned_url(
            "get_object",
            Params={"Bucket": bucket, "Key": object_key},
            ExpiresIn=expires_in,
        )

    def create_bucket_and_upload(self, bucket: str, local_path: str,
                                  object_key: str = None) -> str:
        """
        Создать бакет если не существует и загрузить файл.
        Возвращает object_key.
        """
        self.create_bucket(bucket)
        return self.upload_file(bucket, local_path, object_key)
```

