## Фаза 4 — GPU Operator и time-slicing

**[coparking-5]**

```bash
helm repo add nvidia https://helm.ngc.nvidia.com/nvidia
helm repo update

kubectl create namespace gpu-operator

# ConfigMap: 4 слайса на Tesla T4
cat <<'EOF' | kubectl apply -f -
apiVersion: v1
kind: ConfigMap
metadata:
  name: time-slicing-config
  namespace: gpu-operator
data:
  tesla-t4: |-
    version: v1
    flags:
      migStrategy: none
    sharing:
      timeSlicing:
        resources:
        - name: nvidia.com/gpu
          replicas: 4
EOF

# ✦ ИСПРАВЛЕНО: toolkit.enabled=false — НЕ устанавливаем через operator,
# nvidia-ctk уже настроен вручную (1.19.0).
# driver.enabled=false — драйвер 570-open-DKMS установлен вручную.
# cdi.enabled=true требует что CDI конфиг существует на нодах.
# Проверяем перед установкой:
for node in coparking-5 coparking-6 coparking-7 coparking-8; do
  echo "=== $node ==="; ssh $node "ls /var/run/cdi/ 2>/dev/null || echo 'CDI dir missing'"
done

# Если /var/run/cdi/ пустой — генерируем CDI конфиг на каждой GPU-ноде:
# nvidia-ctk cdi generate --output=/etc/cdi/nvidia.yaml
# (выполнить на каждой GPU-ноде если CDI dir missing)

helm install gpu-operator nvidia/gpu-operator \
  --namespace gpu-operator \
  --version v26.3.1 \
  --set driver.enabled=false \
  --set toolkit.enabled=false \
  --set devicePlugin.config.name=time-slicing-config \
  --set devicePlugin.config.default=tesla-t4 \
  --set cdi.enabled=true \
  --set cdi.default=true

kubectl -n gpu-operator rollout status ds/nvidia-device-plugin-daemonset --timeout=300s

# Активируем time-slicing на GPU нодах
kubectl label node -l gpu=true \
  nvidia.com/device-plugin.config=tesla-t4 --overwrite
```

