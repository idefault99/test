sudo tee -a /etc/postgres_exporter/queries.yaml > /dev/null <<'YAML'

# =============================================================================
# pg_stat_statements_aggregated — агрегированная статистика по БД
# =============================================================================
pg_stat_statements_aggregated:
  query: |
    SELECT 
      d.datname,
      COALESCE(SUM(s.calls), 0)::bigint AS calls_total,
      COALESCE(TRUNC(SUM(s.total_exec_time)), 0)::bigint AS total_exec_time_ms,
      COALESCE(TRUNC(AVG(s.min_exec_time)), 0)::bigint AS avg_min_exec_time_ms,
      COALESCE(TRUNC(AVG(s.max_exec_time)), 0)::bigint AS avg_max_exec_time_ms,
      COALESCE(TRUNC(AVG(s.mean_exec_time)), 0)::bigint AS avg_mean_exec_time_ms,
      COALESCE(TRUNC(SUM(s.total_exec_time) / NULLIF(SUM(s.calls), 0)), 0)::bigint AS weighted_mean_exec_time_ms,
      COALESCE(SUM(s.rows), 0)::bigint AS rows_total,
      COALESCE(SUM(s.shared_blks_hit), 0)::bigint AS shared_blks_hit_total,
      COALESCE(SUM(s.shared_blks_read), 0)::bigint AS shared_blks_read_total,
      CASE 
        WHEN (SUM(s.shared_blks_hit) + SUM(s.shared_blks_read)) = 0 THEN 0
        ELSE ROUND(SUM(s.shared_blks_hit) * 100.0 / (SUM(s.shared_blks_hit) + SUM(s.shared_blks_read)), 2)
      END AS cache_hit_ratio_pct,
      COUNT(DISTINCT s.queryid) AS unique_queries_count
    FROM pg_database d
    LEFT JOIN pg_stat_statements s ON d.oid = s.dbid
    WHERE d.datname NOT IN ('template0', 'template1')
      AND d.datname IS NOT NULL
    GROUP BY d.datname
    ORDER BY total_exec_time_ms DESC
  metrics:
    - datname:
        usage: LABEL
        description: "Database name"
    - calls_total:
        usage: COUNTER
        description: "Total query calls across all queries"
    - total_exec_time_ms:
        usage: COUNTER
        description: "Total execution time in milliseconds"
    - avg_min_exec_time_ms:
        usage: GAUGE
        description: "Average minimum execution time (ms)"
    - avg_max_exec_time_ms:
        usage: GAUGE
        description: "Average maximum execution time (ms)"
    - avg_mean_exec_time_ms:
        usage: GAUGE
        description: "Average mean execution time (ms)"
    - weighted_mean_exec_time_ms:
        usage: GAUGE
        description: "Weighted mean execution time (ms) = total_time / total_calls"
    - rows_total:
        usage: COUNTER
        description: "Total rows returned/affected"
    - shared_blks_hit_total:
        usage: COUNTER
        description: "Total shared buffer cache hits"
    - shared_blks_read_total:
        usage: COUNTER
        description: "Total shared buffer disk reads"
    - cache_hit_ratio_pct:
        usage: GAUGE
        description: "Cache hit ratio percentage"
    - unique_queries_count:
        usage: GAUGE
        description: "Number of unique queries"
YAML


