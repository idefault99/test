{{/*
  MongoDB Helm Chart — Improved
  Изменения:
  - Replica Set (rs0) через initContainer: поддержка changeStream/collection.watch()
  - Credentials вынесены в Secret (не ConfigMap)
  - Убран дублирующий PVC (StatefulSet volumeClaimTemplates достаточно)
  - Убран лишний PV при NFS-режиме
  - Добавлены liveness/readiness пробы
  - Добавлен параметризованный imagePullPolicy
  - MongoDB слушает на всех интерфейсах (--bind_ip_all)
  - Добавлен command args через values
*/}}

{{- if eq .Values.enableService.mongodb true }}
---
# ── Secret (credentials) ────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: {{ .Values.labels.mongodb }}-secret
  labels:
    app: {{ .Values.labels.mongodb }}
  namespace: {{ .Release.Namespace }}
type: Opaque
stringData:
  MONGO_INITDB_ROOT_USERNAME: {{ .Values.mongodb.user | quote }}
  MONGO_INITDB_ROOT_PASSWORD: {{ .Values.mongodb.password | quote }}
  # Скрипт инициализации replica set, запускаемый initContainer'ом
  init-rs.js: |
    rs.initiate({
      _id: "rs0",
      members: [{ _id: 0, host: "127.0.0.1:{{ .Values.ports.internal.mongodb }}" }]
    });

---
# ── ConfigMap (не-секретные настройки) ──────────────────────────────────────
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ .Values.labels.mongodb }}-config
  labels:
    app: {{ .Values.labels.mongodb }}
  namespace: {{ .Release.Namespace }}
data:
  MONGO_INITDB_DATABASE: {{ .Values.mongodb.initDatabase | default "admin" | quote }}

---
# ── StatefulSet ──────────────────────────────────────────────────────────────
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ .Values.labels.mongodb }}-deployment
  labels:
    app: {{ .Values.labels.mongodb }}
  namespace: {{ .Release.Namespace }}
spec:
  serviceName: {{ .Values.labels.mongodb }}-service
  replicas: 1
  selector:
    matchLabels:
      app: {{ .Values.labels.mongodb }}
  template:
    metadata:
      labels:
        app: {{ .Values.labels.mongodb }}
    spec:
      {{- if .Values.securityContext.mongodb.enable }}
      securityContext:
        runAsUser: {{ .Values.securityContext.mongodb.runAsUser }}
        runAsGroup: {{ .Values.securityContext.mongodb.runAsGroup }}
        fsGroup: {{ .Values.securityContext.mongodb.fsGroup }}
      {{- end }}

      # ── initContainer: инициализация Replica Set ──────────────────────────
      # Ждёт старта mongod, затем вызывает rs.initiate().
      # Идемпотентно: повторный вызов на уже инициализированном RS безвреден.
      initContainers:
        - name: init-replica-set
          image: {{ .Values.images.mongo }}
          imagePullPolicy: {{ .Values.mongodb.imagePullPolicy | default "IfNotPresent" | quote }}
          command:
            - /bin/sh
            - -c
            - |
              echo "Waiting for mongod to start..."
              until mongosh --quiet --host 127.0.0.1:{{ .Values.ports.internal.mongodb }} \
                    -u "$MONGO_INITDB_ROOT_USERNAME" \
                    -p "$MONGO_INITDB_ROOT_PASSWORD" \
                    --authenticationDatabase admin \
                    --eval "db.adminCommand('ping').ok" 2>/dev/null | grep -q 1; do
                sleep 2
              done
              echo "Initiating replica set rs0..."
              mongosh --host 127.0.0.1:{{ .Values.ports.internal.mongodb }} \
                -u "$MONGO_INITDB_ROOT_USERNAME" \
                -p "$MONGO_INITDB_ROOT_PASSWORD" \
                --authenticationDatabase admin \
                --eval "
                  try {
                    rs.status();
                    print('RS already initiated, skipping.');
                  } catch(e) {
                    rs.initiate({
                      _id: 'rs0',
                      members: [{ _id: 0, host: '127.0.0.1:{{ .Values.ports.internal.mongodb }}' }]
                    });
                    print('RS initiated successfully.');
                  }
                "
          env:
            - name: MONGO_INITDB_ROOT_USERNAME
              valueFrom:
                secretKeyRef:
                  name: {{ .Values.labels.mongodb }}-secret
                  key: MONGO_INITDB_ROOT_USERNAME
            - name: MONGO_INITDB_ROOT_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ .Values.labels.mongodb }}-secret
                  key: MONGO_INITDB_ROOT_PASSWORD

      containers:
        - name: {{ .Values.labels.mongodb }}
          image: {{ .Values.images.mongo }}
          imagePullPolicy: {{ .Values.mongodb.imagePullPolicy | default "IfNotPresent" | quote }}
          # --replSet rs0    : включает Replica Set (нужен для changeStream)
          # --bind_ip_all    : слушать на всех интерфейсах (не только localhost)
          # --keyFile        : для RS без TLS достаточно внутреннего keyFile;
          #                    если внешняя auth не нужна — можно убрать
          args:
            - "--replSet"
            - "rs0"
            - "--bind_ip_all"
          ports:
            - containerPort: {{ .Values.ports.internal.mongodb }}
          env:
            - name: MONGO_INITDB_ROOT_USERNAME
              valueFrom:
                secretKeyRef:
                  name: {{ .Values.labels.mongodb }}-secret
                  key: MONGO_INITDB_ROOT_USERNAME
            - name: MONGO_INITDB_ROOT_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ .Values.labels.mongodb }}-secret
                  key: MONGO_INITDB_ROOT_PASSWORD
          envFrom:
            - configMapRef:
                name: {{ .Values.labels.mongodb }}-config

          resources:
            limits:
              cpu: {{ (((((.Values.configPods).mongodb).resources).limits).cpu) | default "2000m" }}
              memory: {{ (((((.Values.configPods).mongodb).resources).limits).memory) | default "500Mi" }}
            requests:
              cpu: {{ (((((.Values.configPods).mongodb).resources).requests).cpu) | default "100m" }}
              memory: {{ (((((.Values.configPods).mongodb).resources).requests).memory) | default "300Mi" }}

          # ── Liveness: перезапустить pod если mongod завис ─────────────────
          livenessProbe:
            exec:
              command:
                - mongosh
                - "--quiet"
                - "--host"
                - "127.0.0.1:{{ .Values.ports.internal.mongodb }}"
                - "--eval"
                - "db.adminCommand('ping').ok"
            initialDelaySeconds: 30
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 3

          # ── Readiness: не слать трафик пока RS не инициализирован ─────────
          readinessProbe:
            exec:
              command:
                - mongosh
                - "--quiet"
                - "--host"
                - "127.0.0.1:{{ .Values.ports.internal.mongodb }}"
                - "--eval"
                - |
                  var s = rs.status().ok;
                  if (s !== 1) { quit(1); }
            initialDelaySeconds: 15
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 6

          volumeMounts:
            - mountPath: /data/db
              name: {{ .Values.labels.mongodb }}-{{ .Release.Namespace }}-pv-volume

      {{- if .Values.bindNode }}
      nodeSelector:
        kubernetes.io/hostname: {{ .Values.bindNode }}
      {{- end }}

      imagePullSecrets:
        - name: {{ .Values.imagePullSecret }}

  # volumeClaimTemplates создаёт PVC автоматически — отдельный PVC не нужен
  volumeClaimTemplates:
    - metadata:
        name: {{ .Values.labels.mongodb }}-{{ .Release.Namespace }}-pv-volume
        labels:
          app: {{ .Values.labels.mongodb }}
      spec:
        accessModes:
          - ReadWriteOnce
        storageClassName: {{ .Values.mongodb.persistence.storageClass | default "nfs-csi" | quote }}
        resources:
          requests:
            storage: {{ .Values.mongodb.persistence.size | default "5Gi" | quote }}

---
# ── Service ──────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Service
metadata:
  name: {{ .Values.labels.mongodb }}-service
  namespace: {{ .Release.Namespace }}
  labels:
    app: {{ .Values.labels.mongodb }}
spec:
  {{- if .Values.ports.external.mongodb }}
  type: NodePort
  {{- else }}
  type: ClusterIP
  {{- end }}
  selector:
    app: {{ .Values.labels.mongodb }}
  ports:
    - name: mongo
      port: {{ .Values.ports.internal.mongodb }}
      targetPort: {{ .Values.ports.internal.mongodb }}
      {{- if .Values.ports.external.mongodb }}
      nodePort: {{ .Values.ports.external.mongodb }}
      {{- end }}

{{- if eq .Values.NFS.service.mongodb false }}
---
# ── PersistentVolume (только при hostPath / без NFS) ─────────────────────────
# При NFS (nfs-csi) StorageClass сам провизионирует PV — этот блок не нужен.
kind: PersistentVolume
apiVersion: v1
metadata:
  name: {{ .Values.labels.mongodb }}-{{ .Release.Namespace }}-pv-volume
  labels:
    app: {{ .Values.labels.mongodb }}
spec:
  storageClassName: ""
  capacity:
    storage: {{ .Values.mongodb.persistence.size | default "5Gi" | quote }}
  accessModes:
    - ReadWriteOnce
  hostPath:
    path: "{{ .Values.storageLocalPath }}/{{ .Release.Namespace }}/{{ .Values.labels.mongodb }}"
    type: DirectoryOrCreate
  {{- if .Values.bindNode }}
  nodeAffinity:
    required:
      nodeSelectorTerms:
        - matchExpressions:
            - key: kubernetes.io/hostname
              operator: In
              values:
                - {{ .Values.bindNode }}
  {{- end }}
{{- end }}

{{- end }}{{/* enableService.mongodb */}}
