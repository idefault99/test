import requests
from botocore.auth import SigV4Auth
from botocore.awsrequest import AWSRequest
from botocore.credentials import Credentials

def create_bucket_raw(bucket: str):
    """Создать бакет через прямой PUT запрос без тела"""
    url = f"{MINIO_HOST}/{bucket}"
    
    # Подписываем запрос
    credentials = Credentials(ACCESS_KEY, SECRET_KEY)
    request = AWSRequest(method="PUT", url=url, data=b"")
    SigV4Auth(credentials, "s3", "us-east-1").add_auth(request)
    
    # Добавляем префикс в URL уже после подписания
    final_url = f"{MINIO_HOST}{MINIO_PREFIX}/{bucket}"
    
    response = requests.put(
        final_url,
        headers=dict(request.headers),
        data=b"",
        verify=True,
    )
    
    if response.status_code in (200, 204):
        print(f"Бакет создан: {bucket}")
    elif response.status_code == 409:
        print(f"Бакет уже существует: {bucket}")
    else:
        print(f"Ошибка {response.status_code}: {response.text}")
