## Шаг 9. Алёрты `/etc/prometheus/rules/postgresql.yml`

```bash
sudo tee /etc/prometheus/rules/postgresql.yml > /dev/null <<'EOF'
groups:
  - name: postgresql-patroni
    rules:

      # Глобальная утилизация max_connections=1500
      - alert: PostgreSQLHighConnections
        expr: |
          sum by (patroni_cluster) (
            pg_stat_database_custom_numbackends{datname!=""}
          ) / 1500 * 100 > 80
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Высокая нагрузка на соединения ({{ $labels.patroni_cluster }})"
          description: "Использовано {{ $value }}% от max_connections=1500"

      # Критическая утилизация соединений
      - alert: PostgreSQLCriticalConnections
        expr: |
          sum by (patroni_cluster) (
            pg_stat_database_custom_numbackends{datname!=""}
          ) / 1500 * 100 > 95
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Критически много соединений ({{ $labels.patroni_cluster }})"
          description: "Использовано {{ $value }}% от max_connections=1500"

      # idle in transaction (есть timeout 10min в конфиге)
      - alert: PostgreSQLIdleInTransaction
        expr: pg_idle_in_transaction_count > 10
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "Много idle in transaction ({{ $labels.datname }})"
          description: "{{ $value }} соединений в состоянии idle in transaction"

      # Лаг репликации Patroni > 50MB
      - alert: PostgreSQLReplicationLagHigh
        expr: pg_replication_custom_replay_lag_bytes > 52428800
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Лаг репликации Patroni: {{ $labels.application_name }}"
          description: "Replay lag = {{ $value }} байт (> 50MB)"

      # Deadlocks
      - alert: PostgreSQLDeadlocks
        expr: rate(pg_stat_database_custom_deadlocks[5m]) > 0
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "Deadlock в БД {{ $labels.datname }} ({{ $labels.patroni_cluster }})"
          description: "Обнаружены deadlock-и"

      # Низкий cache hit ratio (при shared_buffers=12GB должен быть > 95%)
      - alert: PostgreSQLLowCacheHit
        expr: |
          pg_stat_database_custom_cache_hit_ratio{datname!=""} < 90
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Низкий cache hit: {{ $labels.datname }}"
          description: "Cache hit = {{ $value }}% (норма > 90%, shared_buffers=12GB)"

      # Долгие запросы > 5 минут
      - alert: PostgreSQLLongRunningQuery
        expr: pg_long_running_queries_max_duration_seconds > 300
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: "Долгий запрос в {{ $labels.datname }}"
          description: "{{ $value }} секунд, пользователь {{ $labels.usename }}"

      # Много мёртвых строк
      - alert: PostgreSQLDeadTuples
        expr: pg_stat_user_tables_custom_n_dead_tup > 500000
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Много мёртвых строк: {{ $labels.relname }}"
          description: "{{ $value }} dead tuples в {{ $labels.schemaname }}.{{ $labels.relname }}"

      # Частые checkpoint по требованию (значит WAL растёт быстрее чем ожидалось)
      - alert: PostgreSQLFrequentCheckpoints
        expr: rate(pg_stat_bgwriter_custom_checkpoints_req[15m]) > 0.5
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Частые checkpoint по требованию ({{ $labels.patroni_cluster }})"
          description: "{{ $value }} checkpoint/сек — возможно нужно увеличить max_wal_size"

      # Temp файлы — признак нехватки work_mem
      - alert: PostgreSQLTempFiles
        expr: rate(pg_stat_database_custom_temp_files[5m]) > 1
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Много temp файлов: {{ $labels.datname }}"
          description: "{{ $value }} temp файлов/сек — возможно нужно увеличить work_mem"
EOF
```

Добавить в `prometheus.yml` если ещё не добавлено:

```yaml
rule_files:
  - "/etc/prometheus/rules/*.yml"
```

