# Проверить текущий UID SA
microk8s kubectl get sa external-secrets -n external-secrets \
  -o jsonpath='{.metadata.uid}'


export VAULT_ADDR="https://127.0.0.1:8200"
export VAULT_CACERT="/opt/vault/tls/ca.crt"
export VAULT_TOKEN="$(jq -r .root_token /root/vault-init.json)"

vault write auth/kubernetes/role/dev-devops \
  bound_service_account_names="external-secrets" \
  bound_service_account_namespaces="external-secrets" \
  alias_name_source="serviceaccount_name" \
  policies="dev-devops" \
  ttl=1h \
  max_ttl=24h


microk8s kubectl rollout restart deployment external-secrets -n external-secrets
microk8s kubectl get clustersecretstore vault-cluster-store-dev-devops
