cp -a /etc/kubernetes/manifests/kube-vip.yaml /root/kube-vip.yaml.bak.$(date +%Y%m%d-%H%M%S)

sed -i 's#path: /etc/kubernetes/admin.conf#path: /etc/kubernetes/super-admin.conf#g' \
  /etc/kubernetes/manifests/kube-vip.yaml

sed -i 's#mountPath: /etc/kubernetes/admin.conf#mountPath: /etc/kubernetes/admin.conf#g' \
  /etc/kubernetes/manifests/kube-vip.yaml

sleep 30

echo "== kube-vip kubeconfig path =="
grep -n "path: /etc/kubernetes" /etc/kubernetes/manifests/kube-vip.yaml

echo "== VIP address =="
ip addr show eno1 | grep 172.16.175.20 || true

echo "== VIP ping =="
ping -c3 172.16.175.20 || true

echo "== API via VIP =="
curl -k --max-time 5 https://172.16.175.20:6443/healthz || true

echo "== kube-vip logs tail =="
crictl logs --tail=80 "$(crictl ps -a --name kube-vip -q | head -n1)" 2>&1 \
  | sed -E \
    -e 's/[a-z0-9]{6}\.[a-z0-9]{16}/<TOKEN>/g' \
    -e 's/sha256:[a-f0-9]{64}/sha256:<HASH>/g' \
    -e 's/(client-certificate-data: ).*/\1<REDACTED>/g' \
    -e 's/(client-key-data: ).*/\1<REDACTED>/g' \
    -e 's/(certificate-authority-data: ).*/\1<REDACTED>/g'
