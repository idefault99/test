############### Backend Endpoints ###############
{{- $anyBackend := false -}}
{{- range .Values.microservices.list -}}
{{- if and (ne (.enabled | toString) "false") .path -}}
{{- $anyBackend = true -}}
{{- end -}}
{{- end -}}
{{- if $anyBackend }}
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ .Values.ingressDomain }}-ingress-not-free
  namespace: {{ .Release.Namespace }}
  annotations:
    nginx.ingress.kubernetes.io/proxy-body-size: {{ .Values.ingressSettings.maxBodySize }}
    nginx.ingress.kubernetes.io/proxy-buffer-size: "128k"
    nginx.ingress.kubernetes.io/proxy-buffers: "4 256k"
    nginx.ingress.kubernetes.io/proxy-busy-buffers-size: "256k"
    nginx.ingress.kubernetes.io/cors-allow-origin: '*'
    nginx.ingress.kubernetes.io/rewrite-target: /$1
    nginx.ingress.kubernetes.io/use-regex: 'true'
spec:
  ingressClassName: {{ .Values.ingressClassName }}
  {{- if eq .Values.TLS.enable true }}
  tls:
    - hosts:
        - {{ .Values.ingressDomain }}
      secretName: {{ tpl .Values.TLS.secret . }}
  {{- end }}
  rules:
  - host: {{ .Values.ingressDomain }}
    http:
      paths:
      {{- range .Values.microservices.list }}
      {{- if and (ne (.enabled | toString) "false") .path }}
      - path: {{ .path }}
        pathType: ImplementationSpecific
        backend:
          service:
            name: {{ $.Release.Namespace }}-{{ .name }}-cs
            port:
              number: {{ $.Values.ports.internal.back }}
      {{- end }}
      {{- end }}
{{- end }}
---
labels:
  elasticsearch: elasticsearch
  kafka: kafka
  mongodb: mongodb
  postgresSql: postgressql
  redis: redis
  s3minio: s3minio
  notification: notification
  auth: auth
  keycloak: keycloak
  front: front
  mapserver:
    share: mapserver
  parkingauth:
    share: parkingauth
  bookingserver:
    share: bookingserver
  eventserver:
    share: eventserver
  crashprocessor:
    share: crashprocessor

ports:
  internal:
    keycloak:
      back: 8000
      health: 9000
    s3minioAPI: 9000
    s3minioConsole: 9001
    postgresSql: 5432
    front: 80
    nginx: 8080
    frontTargetPort: 8080
    mongodb: 27017
    back: 8000
    elasticsearch:
      http: 9200
      transport: 9300
    galaxy: 8000
    grpc: 50051
    kafka:
      internal: 9092
      k8sInternal: 9094
    redis:
      client: 6379
      bus: 16379
# Если нужно внешнее подключение через NodePort то, необходимо указать порт
  external:
    postgresSql:
    mongodb:
    kafka:
    galaxy:

# Change to True if you need service in k8s
enableService:
  s3minio: false
  postgresSql: false
  mongodb: false
  kafka: false
  nginx:
    enable: false
    resolver: kube-dns.kube-system
    resolver_valid: 30s
    s3:
      enable: false
      S3_CONNECTOR: s3minio-api-service.{{ .Release.Namespace }}.svc.{{ .Values.localK8sDomain }}:9000
      protocol: http
      verifySsl: true
      S3_BUCKET: front
      S3_ACCESS_KEY:
      S3_SECRET_KEY:
      S3_SECURE:
      FOLDER_NAME:
      SOURCE_PATH:
  elastic:
    # Для запуска elastic кластера с несколькими нодами нужно указать type: multi-node
    enable: false
    type: single-node
    replicas: 1
  redis:
    # Для запуска redis кластера с 3мя нодами нужно указать type: cluster.
    type: single
    enable: false
    pvcEnabled: false
    storageClassName: nfs-csi
    storageSize: 1Gi

mongodb:
  imagePullPolicy: IfNotPresent
  persistence:
    size: 5Gi
    storageClass: nfs-csi
  initDatabase:
  user: root
  password: secretpass
  headless: mongodb-headless.coparking-demo.svc.cluster.local

s3minio:
  root_user: "minioadmin"
  root_password: "minioadmin"
  # EXAMPLE buckets: "front,schedule"
  buckets: "front"
  minio_settings:
    scanner_delay: "\"1\""
  persistence:
    size: 25Gi
    # пусто -> берётся глобальный .Values.storageClassName
    storageClass: ""

kafka:
  replicas: 3
  persistence:
    size: 5Gi
    storageClass: ""
  clusterId: "example"
  autoCreateTopics: false
  numPartitions: "3"
  defaultReplicationFactor: "3"
  offsetsTopicReplicationFactor: "3"
  transactionStateLogReplicationFactor: "3"
  transactionStateLogMinIsr: "2"
  minInsyncReplicas: "2"
  messageMaxBytes: "10485760"
  replicaFetchMaxBytes: "10485760"
  maxRequestSize: "10485760"
  socketRequestMaxBytes: "104857600"
  heapOpts: "-Xmx1024m -Xms1024m"
  # Любые дополнительные KAFKA_CFG_* (ключ: значение) попадут в configmap как есть.
  extraConfig: {}

kafkaUi:
  enabled: false
  clusterName: coparking
  dynamicConfig: false
  auditTopicEnabled: true
  auditConsoleEnabled: true
  auth:
    enabled: false
    type: LOGIN_FORM
    username: admin
    password: "example"
    existingSecret: ""
  extraEnv: []
  ingress:
    enabled: false
    path: /kafka-ui
    host: ""

enableModules:
  mapserver: false
  parkingauth: false
  crashprocessor: false
  bookingserver: false
  eventserver: false

# ─────────────────────────────────────────────────────────────────────────────
# Единый источник правды по микросервисам.
# Из этого списка генерируются: namespace, ExternalName "-cs", target-service,
# И backend-пути Ingress — для записей, у которых задан `path`.
# Правило: имя сервиса = `name`; URL внешнего пути = `path` (может отличаться
# по написанию от name — поэтому и держим рядом, чтобы не рассинхронить).
# Отключить сервис целиком: enabled: false.
# ─────────────────────────────────────────────────────────────────────────────
microservices:
  enabled: true
  defaultPort: 8000
  createNamespace: true
  createTargetService: true
  list:
    # ── воркеры без внешнего HTTP-роута (без path) ──
    - name: streams
    - name: videorecorder
    - name: miniohandler
    - name: segmentator
    - name: platereader
    - name: accidents-detector
    - name: snow-detector
    - name: crashdetection
    - name: car-counter
    - name: obstruction-monitoring
    - name: ledcontroller
    - name: eventsrecorder
    # ── API-сервисы: path => появляется backend-путь в Ingress ──
    - { name: bookingserver,        path: '/api/bookingserver/v1(?:/|$)(.*)' }
    - { name: mapserver,            path: '/api/mapserver/v1(?:/|$)(.*)' }
    - { name: openparkingapi,       path: '/api/openparkingapi/v1(?:/|$)(.*)' }
    - { name: caps-manager,         path: '/api/capsmanager/v1(?:/|$)(.*)' }
    - { name: alert-processor,      path: '/api/alertprocessor/v1(?:/|$)(.*)' }
    - { name: administration,       path: '/api/administration/v1(?:/|$)(.*)' }
    - { name: cameracolorcontroller, path: '/api/cameracolorcontroller/v1(?:/|$)(.*)' }
    - { name: parkingreports,       path: '/api/parkingreports/v1(?:/|$)(.*)' }
    - { name: crashprocessor,       path: '/api/crash-processor/v1(?:/|$)(.*)' }
    - { name: eventserver,          path: '/api/eventserver/v1(?:/|$)(.*)' }
    - { name: parkingauth,          path: '/api/parking-auth/v1(?:/|$)(.*)' }

ingressClassName: nginx
realmName: test-realm
realmClient: test-client
localK8sDomain: cluster.local
ingressDomain:
kafkaExternalIP:
ingressSettings:
  maxBodySize: "500m"
baseNs: main

ingress:
  enabled: true
  # backendPaths больше нет — пути живут в microservices.list (поле path)

imagePullSecret: regcred-2

TLS:
  enable: false
  secret: "{{ .Values.ingressDomain }}-tls-secret"
