  zookeeper-svc:
    image: confluentinc/cp-zookeeper:6.2.0
    hostname: zookeeper-svc
    container_name: zookeeper-svc
    restart: always
    volumes:
      - /server/kafka/conf/zookeeper:/etc/kafka
      - /server/kafka/zoo_data/data:/var/lib/zookeeper/data
      - /server/kafka/zoo_data/log:/var/lib/zookeeper/log
    ports:
      - "2181:2181"
    environment:
      ZOOKEEPER_CLIENT_PORT: 2181
      ZOOKEEPER_TICK_TIME: 2000
    networks:
      - server_network
  kafka1:
    image: confluentinc/cp-kafka:6.2.0
    depends_on:
      - zookeeper-svc
    hostname: kafka1
    container_name: kafka1
    restart: always
    volumes:
      - /server/kafka/data:/var/lib/kafka/data
      - /server/kafka/conf/kafka:/etc/kafka
    ports:
      - "9092:9092"
      - "9094:9094"
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: zookeeper-svc:2181
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: INSIDE:PLAINTEXT,OUTSIDE:PLAINTEXT
      KAFKA_ADVERTISED_LISTENERS: INSIDE://kafka1:9092,OUTSIDE://168.19.184.14:9094
      KAFKA_LISTENERS: INSIDE://0.0.0.0:9092,OUTSIDE://0.0.0.0:9094
      KAFKA_INTER_BROKER_LISTENER_NAME: INSIDE
