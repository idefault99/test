# Всё из конфига
./deploy.sh

# Принудительно — заполни в скрипте:
FORCE_NAMESPACE="test-isua-load-audit"
FORCE_REGISTRY_PATH="registry.example.com/audit/audit"
FORCE_TAG="abc123"


#!/bin/bash
# =============================================================
# deploy.sh — запускается на мастер ноде
# Скачивает чарты/values из GitLab и деплоит helm релизы
# =============================================================
set -euo pipefail

# --- Конфиг ---
GITLAB_URL="https://gitlab.example.com"
GITLAB_TOKEN="glpat-xxxx"
WORK_DIR="/opt/helm-deploy"
DEPLOY_PAUSE=30
ROLLOUT_TIMEOUT=60

# "project_id:ref:release_name:registry_path"
PROJECTS=(
  "123:develop:audit:registry.example.com/audit/audit"
  "456:main:schedule:registry.example.com/schedule/schedule"
  "789:develop:payments:registry.example.com/payments/payments"
)

# =============================================================
# --- Переопределение образов (опционально) ---
# =============================================================

# Переопределить registry path для конкретного project_id
# "project_id:registry_path"
OVERRIDE_REGISTRY=(
  # "123:registry.example.com/my-custom/audit"
)

# Глобальный тег для всех проектов (пусто = брать из релиза)
OVERRIDE_TAG=""

# Переопределить образы полностью для всех проектов
OVERRIDE_IMAGE_MAIN=""
OVERRIDE_IMAGE_MIGRATIONS=""

# =============================================================
# --- Принудительный деплой ---
# Заполни нужные поля, остальные оставь пустыми
# =============================================================

# Деплоить ТОЛЬКО в этот неймспейс (пусто = все)
FORCE_NAMESPACE=""

# Принудительный registry path (пусто = из PROJECTS)
FORCE_REGISTRY_PATH=""

# Принудительный тег (пусто = из релиза)
FORCE_TAG=""

# =============================================================

# --- Аргументы CLI (перезаписывают конфиг выше) ---
# $1 — фильтр по неймспейсу
# $2 — тег
# $3 — image main
# $4 — image migrations
FILTER_NAMESPACE="${1:-}"
[[ -n "${2:-}" ]] && OVERRIDE_TAG="$2"
[[ -n "${3:-}" ]] && OVERRIDE_IMAGE_MAIN="$3"
[[ -n "${4:-}" ]] && OVERRIDE_IMAGE_MIGRATIONS="$4"

# --- Определяем команды для microk8s ---
if command -v microk8s.helm3 &>/dev/null; then
  HELM="microk8s.helm3"
  KUBECTL="microk8s.kubectl"
elif command -v microk8s &>/dev/null; then
  helm() { microk8s helm "$@"; }
  kubectl() { microk8s kubectl "$@"; }
  export -f helm kubectl
  HELM="helm"
  KUBECTL="kubectl"
elif command -v helm &>/dev/null; then
  HELM="helm"
  KUBECTL="kubectl"
else
  echo "ERROR: helm не найден"
  exit 1
fi

echo "Используем: $HELM / $KUBECTL"

# --- Цвета ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

# --- Инфо о конфигурации ---
echo ""
echo "=== Конфигурация деплоя ==="
echo "Фильтр namespace:          ${FILTER_NAMESPACE:-все}"
echo "Override tag:              ${OVERRIDE_TAG:-из релиза}"
echo "Override image main:       ${OVERRIDE_IMAGE_MAIN:-нет}"
echo "Override image migrations: ${OVERRIDE_IMAGE_MIGRATIONS:-нет}"
echo "--- Принудительный деплой ---"
echo "Force namespace:           ${FORCE_NAMESPACE:-нет}"
echo "Force registry path:       ${FORCE_REGISTRY_PATH:-нет}"
echo "Force tag:                 ${FORCE_TAG:-нет}"
echo "==========================="
echo ""

# --- Результаты ---
DEPLOYED=()
SKIPPED=()
ERRORS=()
DEPLOY_COUNT=0

RUN_DIR="$WORK_DIR/run-$(date +%Y%m%d-%H%M%S)"
mkdir -p "$RUN_DIR"

echo "Рабочая директория: $RUN_DIR"

# --- Функция: получить переменные проекта ---
get_variables() {
  local project_id=$1
  curl -sf \
    --header "PRIVATE-TOKEN: $GITLAB_TOKEN" \
    "$GITLAB_URL/api/v4/projects/$project_id/variables?per_page=100"
}

# --- Функция: скачать Helm чарт ---
download_chart() {
  local project_id=$1
  local ref=$2
  local dest=$3

  curl -sf \
    --header "PRIVATE-TOKEN: $GITLAB_TOKEN" \
    "$GITLAB_URL/api/v4/projects/$project_id/repository/archive.tar.gz?path=Helm&ref=$ref" \
    -o "$dest/chart.tar.gz"

  mkdir -p "$dest/chart"
  tar -xzf "$dest/chart.tar.gz" -C "$dest/chart" --strip-components=2
  rm -f "$dest/chart.tar.gz"
}

# --- Функция: получить тег из helm values ---
get_current_tag() {
  local release=$1
  local namespace=$2

  local image
  image=$($HELM get values "$release" -n "$namespace" 2>/dev/null | \
    grep -E 'main:' | head -1 | awk '{print $2}' || true)

  if [[ -n "$image" ]]; then
    echo "$image" | grep -oP ':[^:]+$' | sed 's/^://' | sed 's/\.[^.]*$//'
  else
    echo ""
  fi
}

# --- Функция: ждать rollout ---
wait_rollout() {
  local namespace=$1
  echo -e "  ${CYAN}Ожидаем rollout: $namespace (timeout: ${ROLLOUT_TIMEOUT}s)${NC}"

  local all_ok=true

  for KIND in deployment statefulset daemonset; do
    RESOURCES=$($KUBECTL get "${KIND}s" -n "$namespace" \
      -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)

    if [[ -z "$RESOURCES" ]]; then
      echo "    ${KIND}s: не найдены"
      continue
    fi

    for RES in $RESOURCES; do
      echo -e "    ${KIND}: $RES"
      if ! $KUBECTL rollout status "${KIND}/${RES}" \
        -n "$namespace" \
        --timeout="${ROLLOUT_TIMEOUT}s" 2>/dev/null; then
        echo -e "  ${RED}Rollout не завершился: ${KIND}/${RES}${NC}"
        all_ok=false
      fi
    done
  done

  if $all_ok; then
    echo -e "  ${GREEN}Rollout OK${NC}"
    return 0
  else
    return 1
  fi
}

# --- Функция: показать память ---
show_memory() {
  echo -e "  ${CYAN}Память:${NC}"
  $KUBECTL top nodes 2>/dev/null || true
}

# --- Основной цикл по проектам ---
for PROJECT_ENTRY in "${PROJECTS[@]}"; do
  IFS=':' read -r PROJECT_ID REF RELEASE_NAME REGISTRY_PATH <<< "$PROJECT_ENTRY"

  echo ""
  echo -e "${BLUE}=========================================="
  echo "  Проект: $PROJECT_ID | ref: $REF | release: $RELEASE_NAME"
  echo "  Registry: $REGISTRY_PATH"
  echo -e "==========================================${NC}"

  PROJECT_DIR="$RUN_DIR/project-$PROJECT_ID"
  mkdir -p "$PROJECT_DIR"

  # --- Переопределение registry для этого проекта ---
  for OVERRIDE_ENTRY in "${OVERRIDE_REGISTRY[@]:-}"; do
    [[ -z "$OVERRIDE_ENTRY" ]] && continue
    IFS=':' read -r OVR_ID OVR_REG <<< "$OVERRIDE_ENTRY"
    if [[ "$OVR_ID" == "$PROJECT_ID" ]]; then
      echo -e "  ${YELLOW}Registry переопределён: $OVR_REG${NC}"
      REGISTRY_PATH="$OVR_REG"
    fi
  done

  # --- Получаем переменные ---
  echo ">>> Получаем переменные из GitLab API..."
  VARIABLES=$(get_variables "$PROJECT_ID") || {
    echo -e "${RED}ERROR: Не удалось получить переменные проекта $PROJECT_ID${NC}"
    ERRORS+=("project-$PROJECT_ID|—|—|Не удалось получить переменные из API")
    continue
  }

  # --- Получаем все уникальные scope ---
  SCOPES=$(echo "$VARIABLES" | jq -r '.[].environment_scope' | sort -u | grep -v '^\*$' || true)

  if [[ -z "$SCOPES" ]]; then
    echo -e "${YELLOW}Нет environment scope в проекте $PROJECT_ID${NC}"
    ERRORS+=("project-$PROJECT_ID|—|—|Нет environment scope")
    continue
  fi

  # --- Скачиваем чарт один раз на проект ---
  echo ">>> Скачиваем Helm чарт (ref: $REF)..."
  if ! download_chart "$PROJECT_ID" "$REF" "$PROJECT_DIR"; then
    echo -e "${RED}ERROR: Не удалось скачать чарт проекта $PROJECT_ID${NC}"
    ERRORS+=("project-$PROJECT_ID|—|—|Не удалось скачать Helm чарт")
    continue
  fi
  echo "    Чарт скачан: $PROJECT_DIR/chart/"

  # --- Цикл по scope ---
  while IFS= read -r SCOPE; do
    echo ""
    echo -e "  ${YELLOW}>>> scope: $SCOPE${NC}"

    SCOPE_DIR="$PROJECT_DIR/scopes/$SCOPE"
    mkdir -p "$SCOPE_DIR"

    # NAMESPACE
    NAMESPACE=$(echo "$VARIABLES" | jq -r \
      '.[] | select(.key == "NAMESPACE" and .environment_scope == "'"$SCOPE"'") | .value')

    if [[ -z "$NAMESPACE" ]]; then
      echo -e "  ${RED}NAMESPACE не найден для scope: $SCOPE${NC}"
      ERRORS+=("project-$PROJECT_ID|$SCOPE|—|NAMESPACE не найден")
      continue
    fi

    # --- Принудительный деплой — фильтр по FORCE_NAMESPACE ---
    if [[ -n "$FORCE_NAMESPACE" ]]; then
      if [[ "$NAMESPACE" != "$FORCE_NAMESPACE" ]]; then
        echo -e "  ${YELLOW}Пропускаем: $NAMESPACE (не совпадает с FORCE_NAMESPACE)${NC}"
        SKIPPED+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|Не совпадает с FORCE_NAMESPACE")
        continue
      fi
      echo -e "  ${MAGENTA}ПРИНУДИТЕЛЬНЫЙ деплой → $FORCE_NAMESPACE${NC}"
    # --- Обычный фильтр ---
    elif [[ -n "$FILTER_NAMESPACE" && "$NAMESPACE" != "$FILTER_NAMESPACE" ]]; then
      echo -e "  ${YELLOW}Пропускаем namespace: $NAMESPACE${NC}"
      SKIPPED+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|Не входит в фильтр")
      continue
    fi

    # VALUES
    VALUES_CONTENT=$(echo "$VARIABLES" | jq -r \
      '.[] | select(.key == "VALUES" and .environment_scope == "'"$SCOPE"'") | .value')

    if [[ -n "$VALUES_CONTENT" ]]; then
      echo "$VALUES_CONTENT" > "$SCOPE_DIR/values.yaml"
      VALUES_FLAG="-f $SCOPE_DIR/values.yaml"
    else
      echo -e "  ${YELLOW}VALUES не найден — деплоим без values файла${NC}"
      VALUES_FLAG=""
    fi

    echo "    Namespace: $NAMESPACE"
    echo "    Release:   $RELEASE_NAME"

    # --- Проверяем существует ли релиз ---
    RELEASE_EXISTS=$($HELM list -n "$NAMESPACE" -q 2>/dev/null | grep -x "$RELEASE_NAME" || true)

    if [[ -z "$RELEASE_EXISTS" ]]; then
      echo -e "  ${YELLOW}Релиз не найден — устанавливаем новый (helm install)${NC}"
      HELM_CMD="install"
      CURRENT_TAG="${FORCE_TAG:-${OVERRIDE_TAG:-}}"
    else
      echo -e "  ${GREEN}Релиз найден — обновляем (helm upgrade)${NC}"
      HELM_CMD="upgrade"

      # Приоритет тега: FORCE_TAG > OVERRIDE_TAG > из релиза
      if [[ -n "$FORCE_TAG" ]]; then
        CURRENT_TAG="$FORCE_TAG"
        echo -e "    Тег принудительный: ${MAGENTA}${CURRENT_TAG}${NC}"
      elif [[ -n "$OVERRIDE_TAG" ]]; then
        CURRENT_TAG="$OVERRIDE_TAG"
        echo -e "    Тег переопределён: ${YELLOW}${CURRENT_TAG}${NC}"
      else
        CURRENT_TAG=$(get_current_tag "$RELEASE_NAME" "$NAMESPACE")
        if [[ -z "$CURRENT_TAG" ]]; then
          echo -e "  ${YELLOW}Тег не найден в релизе — images не переопределяем${NC}"
          CURRENT_TAG=""
        else
          echo -e "    Тег из релиза: ${CURRENT_TAG}"
        fi
      fi
    fi

    # --- Определяем эффективный registry ---
    EFFECTIVE_REGISTRY="${FORCE_REGISTRY_PATH:-$REGISTRY_PATH}"
    if [[ -n "$FORCE_REGISTRY_PATH" ]]; then
      echo -e "    Registry принудительный: ${MAGENTA}${EFFECTIVE_REGISTRY}${NC}"
    fi

    # --- Формируем image flags ---
    if [[ -n "$OVERRIDE_IMAGE_MAIN" ]]; then
      # Полное переопределение образов
      IMAGE_MAIN="$OVERRIDE_IMAGE_MAIN"
      IMAGE_MIGRATIONS="${OVERRIDE_IMAGE_MIGRATIONS:-$OVERRIDE_IMAGE_MAIN}"
      echo -e "    Image main:       ${IMAGE_MAIN} ${YELLOW}(переопределён)${NC}"
      echo -e "    Image migrations: ${IMAGE_MIGRATIONS} ${YELLOW}(переопределён)${NC}"
      IMAGE_FLAGS="--set images.main=${IMAGE_MAIN} --set images.migrations=${IMAGE_MIGRATIONS}"
      DISPLAY_TAG="custom"
    elif [[ -n "$CURRENT_TAG" ]]; then
      IMAGE_MAIN="${EFFECTIVE_REGISTRY}:${CURRENT_TAG}.bin"
      IMAGE_MIGRATIONS="${EFFECTIVE_REGISTRY}:${CURRENT_TAG}.migrations"
      echo -e "    Image main:       ${IMAGE_MAIN}"
      echo -e "    Image migrations: ${IMAGE_MIGRATIONS}"
      IMAGE_FLAGS="--set images.main=${IMAGE_MAIN} --set images.migrations=${IMAGE_MIGRATIONS}"
      DISPLAY_TAG="$CURRENT_TAG"
    else
      echo -e "  ${YELLOW}Images не переопределяем${NC}"
      IMAGE_FLAGS=""
      DISPLAY_TAG="no-tag"
    fi

    # --- Память до деплоя ---
    show_memory

    # --- Деплой ---
    DEPLOY_LOG="$SCOPE_DIR/deploy.log"

    if [[ "$HELM_CMD" == "install" ]]; then
      HELM_OK=$($HELM install "$RELEASE_NAME" "$PROJECT_DIR/chart" \
        -n "$NAMESPACE" \
        --create-namespace \
        $VALUES_FLAG \
        $IMAGE_FLAGS \
        > "$DEPLOY_LOG" 2>&1 && echo "ok" || echo "fail")
    else
      HELM_OK=$($HELM upgrade "$RELEASE_NAME" "$PROJECT_DIR/chart" \
        -n "$NAMESPACE" \
        --reuse-values \
        $VALUES_FLAG \
        $IMAGE_FLAGS \
        > "$DEPLOY_LOG" 2>&1 && echo "ok" || echo "fail")
    fi

    if [[ "$HELM_OK" == "ok" ]]; then
      echo -e "  ${GREEN}Helm $HELM_CMD OK${NC}"

      if wait_rollout "$NAMESPACE"; then
        DEPLOYED+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|$RELEASE_NAME|$HELM_CMD|$DISPLAY_TAG|OK")
      else
        DEPLOYED+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|$RELEASE_NAME|$HELM_CMD|$DISPLAY_TAG|ROLLOUT_TIMEOUT")
        ERRORS+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|Rollout не завершился за ${ROLLOUT_TIMEOUT}s")
      fi

    else
      ERROR_MSG=$(tail -3 "$DEPLOY_LOG" | tr '\n' ' ')
      echo -e "  ${RED}ОШИБКА: $ERROR_MSG${NC}"
      ERRORS+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|$ERROR_MSG")
    fi

    DEPLOY_COUNT=$((DEPLOY_COUNT + 1))
    echo -e "  ${CYAN}Пауза ${DEPLOY_PAUSE}s...${NC}"
    sleep "$DEPLOY_PAUSE"

  done <<< "$SCOPES"

done

# =============================================================
# Таблица 1: Задеплоено
# =============================================================
echo ""
echo "=========================================="
echo "  ЗАДЕПЛОЕНО"
echo "=========================================="
printf "%-15s %-20s %-25s %-15s %-10s %-20s %-15s\n" \
  "PROJECT" "SCOPE" "NAMESPACE" "RELEASE" "ACTION" "ТЕГ" "СТАТУС"
printf "%-15s %-20s %-25s %-15s %-10s %-20s %-15s\n" \
  "---------------" "--------------------" "-------------------------" \
  "---------------" "----------" "--------------------" "---------------"

if [[ ${#DEPLOYED[@]} -eq 0 ]]; then
  echo "  Нет успешных деплоев"
else
  for ROW in "${DEPLOYED[@]}"; do
    IFS='|' read -r PROJ SCOPE NS REL ACTION TAG STATUS <<< "$ROW"
    if [[ "$STATUS" == "OK" ]]; then
      printf "%-15s %-20s %-25s %-15s %-10s %-20s ${GREEN}%-15s${NC}\n" \
        "$PROJ" "$SCOPE" "$NS" "$REL" "$ACTION" "$TAG" "$STATUS"
    else
      printf "%-15s %-20s %-25s %-15s %-10s %-20s ${YELLOW}%-15s${NC}\n" \
        "$PROJ" "$SCOPE" "$NS" "$REL" "$ACTION" "$TAG" "$STATUS"
    fi
  done
fi

# =============================================================
# Таблица 2: Пропущено
# =============================================================
echo ""
echo "=========================================="
echo "  ПРОПУЩЕНО"
echo "=========================================="
printf "%-15s %-20s %-25s %-30s\n" \
  "PROJECT" "SCOPE" "NAMESPACE" "ПРИЧИНА"
printf "%-15s %-20s %-25s %-30s\n" \
  "---------------" "--------------------" "-------------------------" \
  "------------------------------"

if [[ ${#SKIPPED[@]} -eq 0 ]]; then
  echo "  Пропущенных нет"
else
  for ROW in "${SKIPPED[@]}"; do
    IFS='|' read -r PROJ SCOPE NS REASON <<< "$ROW"
    printf "%-15s %-20s %-25s ${YELLOW}%-30s${NC}\n" \
      "$PROJ" "$SCOPE" "$NS" "$REASON"
  done
fi

# =============================================================
# Таблица 3: Ошибки
# =============================================================
echo ""
echo "=========================================="
echo "  ОШИБКИ"
echo "=========================================="
printf "%-15s %-20s %-25s %-40s\n" \
  "PROJECT" "SCOPE" "NAMESPACE" "ПРИЧИНА"
printf "%-15s %-20s %-25s %-40s\n" \
  "---------------" "--------------------" "-------------------------" \
  "----------------------------------------"

if [[ ${#ERRORS[@]} -eq 0 ]]; then
  echo "  Ошибок нет"
else
  for ROW in "${ERRORS[@]}"; do
    IFS='|' read -r PROJ SCOPE NS REASON <<< "$ROW"
    printf "%-15s %-20s %-25s ${RED}%-40s${NC}\n" \
      "$PROJ" "$SCOPE" "$NS" "$REASON"
  done
fi

echo ""
echo "Всего деплоев: $DEPLOY_COUNT"
echo "Логи: $RUN_DIR/"
