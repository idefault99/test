#!/bin/bash
# replace-registry.sh — заменить registry-хост во всех деплойментах всех неймспейсов

set -euo pipefail

usage() {
  echo "Usage: $0 <old-registry-host> <new-registry-host>"
  echo "  Example: $0 test.def harbor.test"
  echo ""
  echo "  Before: test.def/repo/project/test:tag.1"
  echo "  After:  harbor.test/repo/project/test:tag.1"
  exit 1
}

[[ $# -ne 2 ]] && usage

OLD_REGISTRY="${1%/}"
NEW_REGISTRY="${2%/}"

KUBECTL="${KUBECTL:-kubectl}"

echo "==> Old registry: ${OLD_REGISTRY}"
echo "==> New registry: ${NEW_REGISTRY}"
echo ""

found=0
patched=0

NAMESPACES=$($KUBECTL get namespaces -o jsonpath='{.items[*].metadata.name}')

for ns in $NAMESPACES; do
  DEPLOYMENTS=$($KUBECTL get deployments -n "$ns" \
    -o jsonpath='{.items[*].metadata.name}' 2>/dev/null) || continue
  [[ -z "$DEPLOYMENTS" ]] && continue

  for deploy in $DEPLOYMENTS; do
    CONTAINERS=$($KUBECTL get deployment "$deploy" -n "$ns" \
      -o jsonpath='{range .spec.template.spec.containers[*]}{.name}={.image}{"\n"}{end}{range .spec.template.spec.initContainers[*]}{.name}={.image}{"\n"}{end}' \
      2>/dev/null) || continue

    while IFS='=' read -r cname cimage; do
      [[ -z "$cname" || -z "$cimage" ]] && continue

      # Хост — всё до первого '/'
      cur_registry="${cimage%%/*}"
      # Остаток — путь + тег
      cur_rest="${cimage#*/}"

      if [[ "$cur_registry" == "$OLD_REGISTRY" ]]; then
        new_full="${NEW_REGISTRY}/${cur_rest}"
        ((found++)) || true

        echo "[${ns}/${deploy}] ${cname}"
        echo "  old: ${cimage}"
        echo "  new: ${new_full}"

        IS_INIT=$($KUBECTL get deployment "$deploy" -n "$ns" \
          -o jsonpath="{.spec.template.spec.initContainers[?(@.name==\"${cname}\")].name}" \
          2>/dev/null)
        CTYPE=$([[ -n "$IS_INIT" ]] && echo "initContainers" || echo "containers")

        PATCH="{\"spec\":{\"template\":{\"spec\":{\"${CTYPE}\":[{\"name\":\"${cname}\",\"image\":\"${new_full}\"}]}}}}"

        if $KUBECTL patch deployment "$deploy" -n "$ns" \
            --type=strategic -p "$PATCH" > /dev/null 2>&1; then
          echo "  ✓ patched"
          ((patched++)) || true
        else
          echo "  ✗ FAILED"
        fi
        echo ""
      fi
    done <<< "$CONTAINERS"
  done
done

echo "==> Done. Found: ${found}, Patched: ${patched}"
