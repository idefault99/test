#!/usr/bin/env bash
# ==============================================================================
# gitlab_migrate.sh — полная миграция GitLab проекта (без registry и variables)
#
# Использование:
#   ./gitlab_migrate.sh \
#     --host https://gitlab.example.com \
#     --token glpat-xxxxxxxxxxxx \
#     --source my-group/my-project \
#     --target-namespace "Projects/Development/sys" \
#     --target-name newrepo
#
# Опционально:
#   --export-file /path/to/existing.tar.gz   (пропустить экспорт, использовать файл)
#   --keep-export                             (не удалять скачанный архив после импорта)
# ==============================================================================

set -euo pipefail

# ──────────────────────────────────────────────
# Цвета
# ──────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

log()     { echo -e "${CYAN}[$(date '+%H:%M:%S')]${RESET} $*"; }
ok()      { echo -e "${GREEN}[✓]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[!]${RESET} $*"; }
error()   { echo -e "${RED}[✗]${RESET} $*" >&2; exit 1; }
section() { echo -e "\n${BOLD}${CYAN}══ $* ══${RESET}"; }

# ──────────────────────────────────────────────
# Парсинг аргументов
# ──────────────────────────────────────────────
GITLAB_HOST=""
TOKEN=""
SOURCE=""          # path или numeric ID исходного проекта
TARGET_NS=""       # namespace целевого проекта (группа / подгруппа)
TARGET_NAME=""     # slug нового проекта
EXPORT_FILE=""     # если указан — пропускаем экспорт
KEEP_EXPORT=false

usage() {
  grep '^#' "$0" | grep -v '#!/' | sed 's/^# \{0,3\}//'
  exit 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)            GITLAB_HOST="${2%/}"; shift 2 ;;
    --token)           TOKEN="$2"; shift 2 ;;
    --source)          SOURCE="$2"; shift 2 ;;
    --target-namespace) TARGET_NS="$2"; shift 2 ;;
    --target-name)     TARGET_NAME="$2"; shift 2 ;;
    --export-file)     EXPORT_FILE="$2"; shift 2 ;;
    --keep-export)     KEEP_EXPORT=true; shift ;;
    --help|-h)         usage ;;
    *) error "Неизвестный аргумент: $1" ;;
  esac
done

# ──────────────────────────────────────────────
# Проверка обязательных параметров
# ──────────────────────────────────────────────
[[ -z "$GITLAB_HOST" ]]  && error "--host обязателен"
[[ -z "$TOKEN" ]]        && error "--token обязателен"
[[ -z "$SOURCE" ]]       && error "--source обязателен"
[[ -z "$TARGET_NS" ]]    && error "--target-namespace обязателен"
[[ -z "$TARGET_NAME" ]]  && error "--target-name обязателен"

# ──────────────────────────────────────────────
# Зависимости
# ──────────────────────────────────────────────
for cmd in curl jq; do
  command -v "$cmd" &>/dev/null || error "Требуется '$cmd', установите его."
done

# ──────────────────────────────────────────────
# Вспомогательные функции
# ──────────────────────────────────────────────
api_get() {
  # api_get <path> [extra curl args...]
  local path="$1"; shift
  curl -fsSL --header "PRIVATE-TOKEN: $TOKEN" "$@" "${GITLAB_HOST}/api/v4${path}"
}

api_post() {
  # api_post <path> [extra curl args...]
  local path="$1"; shift
  curl -fsSL --request POST --header "PRIVATE-TOKEN: $TOKEN" "$@" "${GITLAB_HOST}/api/v4${path}"
}

# URL-кодирование пути проекта
urlencode() {
  python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1], safe=''))" "$1"
}

# Получить числовой ID проекта по пути или ID
resolve_project_id() {
  local ref="$1"
  if [[ "$ref" =~ ^[0-9]+$ ]]; then
    echo "$ref"
  else
    local encoded
    encoded=$(urlencode "$ref")
    api_get "/projects/${encoded}" | jq -r '.id'
  fi
}

# Получить ID namespace по пути
resolve_namespace_id() {
  local ns="$1"
  local encoded
  encoded=$(urlencode "$ns")
  # Попробовать как группу
  local result
  result=$(api_get "/groups/${encoded}" 2>/dev/null | jq -r '.id // empty') || true
  if [[ -z "$result" ]]; then
    # Попробовать как user namespace
    result=$(api_get "/namespaces?search=${encoded}" 2>/dev/null | jq -r '.[0].id // empty') || true
  fi
  echo "$result"
}

# Polling с таймаутом
poll() {
  local label="$1"
  local check_cmd="$2"      # команда, которая выводит текущий статус
  local ok_val="$3"         # значение = успех
  local fail_val="$4"       # значение = ошибка
  local timeout="${5:-3600}" # секунды (дефолт 1 час)
  local interval="${6:-10}"

  local elapsed=0
  local status

  while true; do
    status=$(eval "$check_cmd" 2>/dev/null || echo "error")
    log "${label}: ${status}"

    [[ "$status" == "$ok_val" ]]   && return 0
    [[ "$status" == "$fail_val" ]] && return 1
    [[ "$status" == "error" ]]     && return 1

    if [[ $elapsed -ge $timeout ]]; then
      warn "Таймаут ожидания (${timeout}s)"
      return 1
    fi

    sleep "$interval"
    elapsed=$((elapsed + interval))
  done
}

# ══════════════════════════════════════════════
# ШАГ 0: Проверка подключения и прав
# ══════════════════════════════════════════════
section "Проверка"

user_info=$(api_get "/user") || error "Не удалось подключиться к GitLab или неверный токен"
username=$(echo "$user_info" | jq -r '.username')
ok "Авторизован как: ${username}"

# Разрешить source → ID
log "Определяем ID исходного проекта: $SOURCE"
SOURCE_ID=$(resolve_project_id "$SOURCE") || true
[[ -z "$SOURCE_ID" || "$SOURCE_ID" == "null" ]] && error "Проект '${SOURCE}' не найден"
ok "Исходный проект ID: ${SOURCE_ID}"

# Получить имя исходного проекта для информации
src_info=$(api_get "/projects/${SOURCE_ID}")
src_path=$(echo "$src_info" | jq -r '.path_with_namespace')
ok "Путь источника: ${src_path}"

# Разрешить namespace
log "Определяем namespace: $TARGET_NS"
NS_ID=$(resolve_namespace_id "$TARGET_NS") || true
[[ -z "$NS_ID" || "$NS_ID" == "null" ]] && error "Namespace '${TARGET_NS}' не найден или нет доступа"
ok "Namespace ID: ${NS_ID}"

# ══════════════════════════════════════════════
# ШАГ 1: Экспорт
# ══════════════════════════════════════════════

if [[ -n "$EXPORT_FILE" ]]; then
  [[ -f "$EXPORT_FILE" ]] || error "Файл экспорта не найден: $EXPORT_FILE"
  ok "Используем готовый файл экспорта: $EXPORT_FILE"
else
  section "Экспорт проекта"
  EXPORT_FILE="gitlab_export_${SOURCE_ID}_$(date +%Y%m%d_%H%M%S).tar.gz"

  log "Запускаем экспорт..."
  export_resp=$(api_post "/projects/${SOURCE_ID}/export")
  export_msg=$(echo "$export_resp" | jq -r '.message // .error // "ok"')
  ok "Экспорт запущен: ${export_msg}"

  log "Ожидаем завершения экспорта (может занять несколько минут)..."
  poll \
    "Статус экспорта" \
    "api_get /projects/${SOURCE_ID}/export | jq -r '.export_status'" \
    "finished" \
    "error" \
    3600 15 \
    || error "Экспорт завершился с ошибкой"

  ok "Экспорт завершён"

  log "Скачиваем архив → ${EXPORT_FILE} ..."
  curl -fL --header "PRIVATE-TOKEN: $TOKEN" \
    -o "$EXPORT_FILE" \
    "${GITLAB_HOST}/api/v4/projects/${SOURCE_ID}/export/download"

  FILESIZE=$(du -sh "$EXPORT_FILE" | cut -f1)
  ok "Архив скачан: ${EXPORT_FILE} (${FILESIZE})"
fi

# ══════════════════════════════════════════════
# ШАГ 2: Импорт
# ══════════════════════════════════════════════
section "Импорт проекта"

log "Отправляем импорт: namespace='${TARGET_NS}', name='${TARGET_NAME}'"

import_resp=$(api_post "/projects/import" \
  --form "path=${TARGET_NAME}" \
  --form "namespace=${TARGET_NS}" \
  --form "overwrite=false" \
  --form "file=@${EXPORT_FILE}")

import_id=$(echo "$import_resp" | jq -r '.id // empty')
import_err=$(echo "$import_resp" | jq -r '.message // .error // empty')

if [[ -z "$import_id" || "$import_id" == "null" ]]; then
  echo "$import_resp" | jq . >&2
  error "Импорт не стартовал: ${import_err}"
fi

ok "Проект создан с ID: ${import_id}"
log "Ожидаем завершения импорта..."

poll \
  "Статус импорта" \
  "api_get /projects/${import_id}/import | jq -r '.import_status'" \
  "finished" \
  "failed" \
  7200 15 \
  || {
    # Показать детали ошибки
    details=$(api_get "/projects/${import_id}/import" 2>/dev/null | jq -r '.import_error // "нет деталей"')
    error "Импорт завершился с ошибкой: ${details}"
  }

ok "Импорт завершён успешно"

# ══════════════════════════════════════════════
# ШАГ 3: Активация pipeline schedules
# ══════════════════════════════════════════════
section "Pipeline Schedules"

log "Проверяем расписания (они импортируются как inactive)..."
schedules=$(api_get "/projects/${import_id}/pipeline_schedules" 2>/dev/null || echo "[]")
count=$(echo "$schedules" | jq 'length')

if [[ "$count" -gt 0 ]]; then
  warn "Найдено ${count} pipeline schedule(s) — они inactive после импорта."
  echo "$schedules" | jq -r '.[] | "  - [\(.id)] \(.description) | cron: \(.cron) | active: \(.active)"'
  warn "Активируйте нужные вручную: Settings → CI/CD → Pipeline schedules"
  warn "Или через API: POST /api/v4/projects/${import_id}/pipeline_schedules/<id>"
else
  ok "Pipeline schedules не найдены"
fi

# ══════════════════════════════════════════════
# ШАГ 4: Итог
# ══════════════════════════════════════════════
section "Результат"

new_proj=$(api_get "/projects/${import_id}" 2>/dev/null)
new_url=$(echo "$new_proj" | jq -r '.web_url // "—"')
new_path=$(echo "$new_proj" | jq -r '.path_with_namespace // "—"')

echo ""
echo -e "${GREEN}${BOLD}Миграция завершена!${RESET}"
echo -e "  Источник : ${src_path}"
echo -e "  Новый    : ${new_path}"
echo -e "  URL      : ${new_url}"
echo ""
echo -e "${YELLOW}Что нужно сделать вручную:${RESET}"
echo "  1. CI/CD Variables     — перенести вручную (Settings → CI/CD → Variables)"
echo "  2. Container Registry  — skopeo copy (см. инструкцию выше)"
echo "  3. Webhooks            — пересоздать (Settings → Webhooks)"
echo "  4. Deploy keys/tokens  — подключить (Settings → Repository → Deploy keys)"
echo "  5. Pipeline schedules  — активировать нужные (Settings → CI/CD → Schedules)"
echo "  6. Masked variables    — значения [MASKED] нужно выставить вручную"
echo ""

# Удалить архив если не просили сохранить
if [[ "$KEEP_EXPORT" == false && -z "${EXPORT_FILE_ORIG:-}" ]]; then
  rm -f "$EXPORT_FILE"
  ok "Архив удалён: ${EXPORT_FILE}"
else
  ok "Архив сохранён: ${EXPORT_FILE}"
fi


chmod +x gitlab_migrate.sh

./gitlab_migrate.sh \
  --host https://gitlab.example.com \
  --token glpat-xxxxxxxxxxxx \
  --source "old-group/old-project" \
  --target-namespace "Проекты/Разработка/sys" \
  --target-name "newrepo"
