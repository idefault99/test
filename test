{{- $vault := .Values.vault -}}
{{- $stand := .Values.stand.name -}}

apiVersion: external-secrets.io/v1beta1
kind: ClusterSecretStore
metadata:
  name: {{ $vault.clusterSecretStore.name }}
  labels:
    {{- include "stand-secrets.labels" . | nindent 4 }}
spec:
  provider:
    vault:
      server: {{ $vault.address }}
      path: {{ $vault.kvMount }}
      version: v2
      auth:
        kubernetes:
          mountPath: {{ $vault.authPath }}
          role: {{ $stand }}
          serviceAccountRef:
            name: {{ $vault.serviceAccount.name }}
            namespace: {{ $vault.serviceAccount.namespace }}
      caProvider:
        type: ConfigMap
        name: {{ $vault.caConfigMap }}
        key: ca.crt
        namespace: {{ $vault.serviceAccount.namespace }}

---
{{- $stand := .Values.stand.name -}}
{{- $vault := .Values.vault -}}

{{/* ExternalSecrets для infra */}}
{{- range .Values.stand.infra.services }}
---
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{ .secretName }}
  namespace: {{ $stand }}
  labels:
    {{- include "stand-secrets.labels" $ | nindent 4 }}
    vault-section: infra
    vault-service: {{ .name }}
spec:
  refreshInterval: {{ $vault.refreshInterval }}
  secretStoreRef:
    name: {{ $vault.clusterSecretStore.name }}
    kind: ClusterSecretStore
  target:
    name: {{ .secretName }}
    creationPolicy: Owner
    deletionPolicy: Retain
  dataFrom:
    - extract:
        key: {{ $stand }}/infra/{{ .name }}
{{- end }}

{{/* ExternalSecrets для каждого app namespace */}}
{{- range .Values.stand.apps }}
{{- $app := . }}
{{- $suffix := .suffix }}
{{- $appNs := printf "%s-%s" $stand $suffix }}
{{- range .services }}
---
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{ .secretName }}
  namespace: {{ $appNs }}
  labels:
    {{- include "stand-secrets.labels" $ | nindent 4 }}
    vault-section: {{ $suffix }}
    vault-service: {{ .name }}
spec:
  refreshInterval: {{ $vault.refreshInterval }}
  secretStoreRef:
    name: {{ $vault.clusterSecretStore.name }}
    kind: ClusterSecretStore
  target:
    name: {{ .secretName }}
      creationPolicy: Owner
      deletionPolicy: Retain
  dataFrom:
    - extract:
        key: {{ $stand }}/{{ $suffix }}/{{ .name }}
{{- end }}
{{- end }}

---
microk8s kubectl apply -f - <<EOF
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: external-secrets-controller
rules:
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  - apiGroups: [""]
    resources: ["serviceaccounts"]
    verbs: ["get", "list", "watch"]
  - apiGroups: [""]
    resources: ["serviceaccounts/token"]
    verbs: ["create"]
  - apiGroups: [""]
    resources: ["namespaces"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["external-secrets.io"]
    resources: ["*"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: external-secrets-controller
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: external-secrets-controller
subjects:
  - kind: ServiceAccount
    name: external-secrets
    namespace: external-secrets
EOF

---
# 1. ClusterSecretStore стал Valid?
microk8s kubectl get clustersecretstore -A

# 2. ExternalSecret синхронизировались?
microk8s kubectl get externalsecret -A

# 3. Если нет — смотреть Events
microk8s kubectl describe clustersecretstore vault-cluster-store-test-stand
microk8s kubectl describe externalsecret approvals-vault-secret -n dev-devops-approvals
