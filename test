"""Содержит функцию получения соединения redis."""

from aodb_log_tools import get_logger
from redis.asyncio import Redis
from redis.typing import KeyT, ResponseT

from config.settings import get_settings

logger = get_logger(__name__)


class LoggedRedis(Redis):
    """Redis c логированием."""

    def flushdb(self, **kwargs) -> ResponseT: # noqa: ANN003
        """Логирует стек вызова перед очисткой кэша."""
        logger.warning('Вызван redis.flushdb', kwargs=kwargs)
        return super().flushdb(**kwargs)

    def delete(self, *args: KeyT) -> ResponseT:
        """Логирует стек вызова перед удачением кэша."""
        logger.warning('Вызван redis.delete', args=args)
        return super().delete(*args)


def get_redis_pool() -> Redis:
    """Получить redis соединение."""
    settings = get_settings()
    return LoggedRedis.from_url(
        settings.redis_dsn,
        encoding='utf-8',
        decode_responses=True,
        max_connections=settings.REDIS_POOL_MAX_SIZE,
    )
