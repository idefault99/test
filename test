#!/usr/bin/env bash
# ================================================================
#  microk8s-not-starting.sh
#  Диагностика когда microk8s не стартует
#  Все команды в одном файле, только встроенные средства
# ================================================================

RED='\033[0;31m'; YEL='\033[0;33m'; GRN='\033[0;32m'
CYN='\033[0;36m'; WHT='\033[1;37m'; DIM='\033[2m'
BOLD='\033[1m';   RST='\033[0m'

header()  { echo -e "\n${CYN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n  $1\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RST}"; }
section() { echo -e "\n${WHT}${BOLD}▶ $1${RST}\n${DIM}──────────────────────────────────────────────────────${RST}"; }
ok()      { echo -e "  ${GRN}✔${RST}  $1"; }
warn()    { echo -e "  ${YEL}⚠${RST}  $1"; }
bad()     { echo -e "  ${RED}✘${RST}  $1"; }
kv()      { printf "  ${WHT}%-36s${RST} %s\n" "$1" "$2"; }

LOG="/tmp/mk8s-nostart-$(date +%Y%m%d-%H%M%S).log"
exec > >(tee -a "$LOG") 2>&1

echo -e "${BOLD}${CYN}"
echo "  MicroK8s не стартует — диагностика"
echo "  $(date '+%Y-%m-%d %H:%M:%S')  |  host: $(hostname)"
echo -e "${RST}"

# ════════════════════════════════════════════════════════════════
header "1. РЕСУРСЫ — диск и RAM"

section "Диск (первая причина отказа)"
df -h | grep -v "tmpfs\|udev" | while read -r fs sz us av pc mnt; do
  [[ "$pc" =~ ^[0-9]+%$ ]] || continue
  pct=${pc//%/}
  if (( pct > 90 )); then
    bad "ДИСК ЗАПОЛНЕН: ${mnt} = ${pct}%  — microk8s не стартует при 100%"
    echo -e "  ${RED}Очистить: journalctl --vacuum-size=200M${RST}"
  elif (( pct > 80 )); then
    warn "Диск ${mnt} = ${pct}%"
  else
    ok "${mnt} = ${pct}%"
  fi
done

section "RAM"
mem_avail=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
mem_total=$(grep MemTotal     /proc/meminfo | awk '{print $2}')
mem_pct=$(( mem_avail * 100 / mem_total ))
kv "Available:" "$(( mem_avail / 1024 )) MB (${mem_pct}%)"
(( mem_pct < 10 )) && bad "Мало RAM — microk8s может не запуститься" \
                   || ok "RAM достаточно"

# ════════════════════════════════════════════════════════════════
header "2. SNAP — состояние пакета"

section "Версия и статус snap"
snap info microk8s | grep -E "installed|channel|tracking|refresh"

section "Все сервисы microk8s"
snap services microk8s

# ════════════════════════════════════════════════════════════════
header "3. SYSTEMD — статус каждого демона"

DAEMONS=(
  "snap.microk8s.daemon-kubelite"
  "snap.microk8s.daemon-k8s-dqlite"
  "snap.microk8s.daemon-containerd"
  "snap.microk8s.daemon-cluster-agent"
  "snap.microk8s.daemon-apiserver-kicker"
)

for svc in "${DAEMONS[@]}"; do
  section "${svc##snap.microk8s.}"
  state=$(systemctl is-active "$svc" 2>/dev/null || echo "unknown")
  if [[ "$state" == "active" ]]; then
    ok "Запущен"
  elif [[ "$state" == "failed" ]]; then
    bad "FAILED"
  else
    warn "Статус: $state"
  fi
  # Последние строки статуса
  systemctl status "$svc" --no-pager -l 2>/dev/null | tail -20 | sed 's/^/  /'
done

# ════════════════════════════════════════════════════════════════
header "4. ЛОГИ ДЕМОНОВ (последние 60 строк каждого)"

section "kubelite"
journalctl -u snap.microk8s.daemon-kubelite \
  -n 60 --no-pager -o short-iso 2>/dev/null | \
  grep -v "^-- " | sed 's/^/  /'

section "k8s-dqlite"
journalctl -u snap.microk8s.daemon-k8s-dqlite \
  -n 60 --no-pager -o short-iso 2>/dev/null | \
  grep -v "^-- " | sed 's/^/  /'

section "containerd"
journalctl -u snap.microk8s.daemon-containerd \
  -n 60 --no-pager -o short-iso 2>/dev/null | \
  grep -v "^-- " | sed 's/^/  /'

section "cluster-agent"
journalctl -u snap.microk8s.daemon-cluster-agent \
  -n 30 --no-pager -o short-iso 2>/dev/null | \
  grep -v "^-- " | sed 's/^/  /'

section "apiserver-kicker"
journalctl -u snap.microk8s.daemon-apiserver-kicker \
  -n 30 --no-pager -o short-iso 2>/dev/null | \
  grep -v "^-- " | sed 's/^/  /'

section "Snap logs (общий)"
snap logs microk8s -n 50 2>/dev/null | sed 's/^/  /'

# ════════════════════════════════════════════════════════════════
header "5. КЛЮЧЕВЫЕ ОШИБКИ — фильтр по всем логам"

section "Все ERROR/FATAL/PANIC за последние 30 минут"
journalctl -u snap.microk8s.daemon-kubelite \
           -u snap.microk8s.daemon-k8s-dqlite \
           -u snap.microk8s.daemon-containerd \
  --since "30 minutes ago" --no-pager 2>/dev/null | \
  grep -iE "error|fatal|panic|failed|timeout|permission denied|no space|cannot|address already in use|certificate|tls|connection refused" | \
  grep -v "^-- " | \
  sed 's/^/  /' | head -50

# ════════════════════════════════════════════════════════════════
header "6. СЕТЬ — порты и конфликты"

section "Порты которые должен слушать microk8s"
for port in 6443 2380 2379 19001 10250 10255 10257 10259; do
  # Проверяем через /proc/net/tcp6 и tcp
  hex_port=$(printf '%04X' $port)
  if grep -q ":${hex_port} " /proc/net/tcp6 2>/dev/null || \
     grep -q ":${hex_port} " /proc/net/tcp  2>/dev/null; then
    ok "Порт $port — слушает"
  else
    warn "Порт $port — не слушает"
  fi
done

section "Что занимает порт 6443 (apiserver)"
ss -tlnp 2>/dev/null | grep ":6443" | sed 's/^/  /' || echo "  Никто не слушает 6443"

section "Что занимает порт 19001 (dqlite)"
ss -tlnp 2>/dev/null | grep ":19001" | sed 's/^/  /' || echo "  Никто не слушает 19001"

# ════════════════════════════════════════════════════════════════
header "7. ФАЙЛЫ И ПРАВА"

section "Ключевые файлы конфигурации"
FILES=(
  "/var/snap/microk8s/current/args/kube-apiserver"
  "/var/snap/microk8s/current/args/kubelet"
  "/var/snap/microk8s/current/args/kube-controller-manager"
  "/var/snap/microk8s/current/var/kubernetes/backend/cluster.crt"
  "/var/snap/microk8s/current/var/kubernetes/backend/cluster.key"
  "/var/snap/microk8s/current/certs/ca.crt"
  "/var/snap/microk8s/current/credentials/kubelet.config"
)
for f in "${FILES[@]}"; do
  if [[ -f "$f" ]]; then
    perm=$(stat -c "%a %U:%G" "$f" 2>/dev/null)
    ok "${f##*/}  [$perm]"
  else
    bad "НЕТ ФАЙЛА: $f"
  fi
done

section "Размер dqlite базы"
dqlite_dir="/var/snap/microk8s/current/var/kubernetes/backend"
if [[ -d "$dqlite_dir" ]]; then
  du -sh "$dqlite_dir" 2>/dev/null | sed 's/^/  /'
  ls -lh "$dqlite_dir" 2>/dev/null | sed 's/^/  /'
else
  bad "dqlite директория не найдена: $dqlite_dir"
fi

section "Snap директория — свободное место"
df -h /var/snap/microk8s/ 2>/dev/null | sed 's/^/  /'

# ════════════════════════════════════════════════════════════════
header "8. СЕРТИФИКАТЫ"

section "Проверка срока действия сертификатов"
CERT_DIR="/var/snap/microk8s/current/certs"
if [[ -d "$CERT_DIR" ]]; then
  for cert in "$CERT_DIR"/*.crt; do
    [[ -f "$cert" ]] || continue
    expiry=$(openssl x509 -in "$cert" -noout -enddate 2>/dev/null | cut -d= -f2)
    exp_epoch=$(date -d "$expiry" +%s 2>/dev/null || echo 0)
    now_epoch=$(date +%s)
    days_left=$(( (exp_epoch - now_epoch) / 86400 ))
    if (( days_left < 0 )); then
      bad "ИСТЁК: $(basename $cert) — ${expiry}"
    elif (( days_left < 30 )); then
      warn "Скоро истекает: $(basename $cert) — через ${days_left} дней"
    else
      ok "$(basename $cert) — действителен ещё ${days_left} дней"
    fi
  done
else
  warn "Директория сертификатов не найдена: $CERT_DIR"
fi

# ════════════════════════════════════════════════════════════════
header "9. ВСТРОЕННАЯ ДИАГНОСТИКА MICROK8S"

section "microk8s inspect"
microk8s inspect 2>&1 | tail -40 | sed 's/^/  /' || warn "microk8s inspect недоступен"

# ════════════════════════════════════════════════════════════════
header "10. ПОПЫТКА ЗАПУСКА"

section "Попытка старта"
echo -e "  ${DIM}Выполняем: snap start microk8s...${RST}"
snap start microk8s 2>&1 | sed 's/^/  /'
sleep 5

echo -e "  ${DIM}Статус после старта:${RST}"
snap services microk8s 2>/dev/null | sed 's/^/  /'

echo -e "\n  ${DIM}Ждём ready (30 сек таймаут)...${RST}"
microk8s status --wait-ready --timeout 30 2>&1 | sed 's/^/  /' || true

# ════════════════════════════════════════════════════════════════
header "ИТОГ"

echo ""
echo -e "  ${WHT}Лог сохранён: ${CYN}${LOG}${RST}"
echo ""
echo -e "  ${WHT}Следующие шаги если не помогло:${RST}"
echo -e "  ${DIM}1.${RST} Скинуть лог: ${CYN}cat $LOG${RST}"
echo -e "  ${DIM}2.${RST} Полный inspect: ${CYN}sudo microk8s inspect${RST}"
echo -e "  ${DIM}3.${RST} Если сертификаты истекли: ${CYN}sudo microk8s refresh-certs --cert ca.crt${RST}"
echo -e "  ${DIM}4.${RST} Если диск полный: ${CYN}journalctl --vacuum-size=200M && microk8s ctr images prune --all${RST}"
echo -e "  ${DIM}5.${RST} Крайний случай: ${CYN}sudo snap remove microk8s && sudo snap install microk8s --classic${RST}"
echo ""
