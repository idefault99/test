### Шаг 2. Массовая миграция всех namespace

Миграцию лучше делать батчами по 5-10 namespace, не всё сразу.

```bash
# Получить полный список namespace с redis
kubectl get pods -A | grep "redis-deployment-0" | awk '{print $1}' | sort -u > /tmp/redis_namespaces.txt
cat /tmp/redis_namespaces.txt
wc -l /tmp/redis_namespaces.txt  # ~160 namespace

# Скрипт миграции одного namespace
migrate_namespace() {
  NS=$1
  echo ""
  echo "============================================"
  echo "==> Мигрируем: $NS"
  echo "============================================"

  # Сохранить количество ключей до
  KEYS_BEFORE=$(kubectl exec -n $NS redis-deployment-0 -- redis-cli dbsize 2>/dev/null || echo "N/A")
  echo "  Ключей до миграции: $KEYS_BEFORE"

  # Удалить старый StatefulSet (без удаления подов)
  kubectl delete statefulset redis-deployment -n $NS --cascade=orphan
  if [ $? -ne 0 ]; then
    echo "  ОШИБКА: не удалось удалить StatefulSet в $NS"
    return 1
  fi

  # helm upgrade
  helm upgrade infra ./path/to/chart -n $NS -f values.yaml
  if [ $? -ne 0 ]; then
    echo "  ОШИБКА: helm upgrade упал в $NS"
    return 1
  fi

  # Ждём готовности всех подов
  echo "  Ждём готовности подов (до 3 минут)..."
  kubectl wait --for=condition=Ready pod -l app=redis -n $NS --timeout=180s
  if [ $? -ne 0 ]; then
    echo "  ОШИБКА: поды не поднялись в $NS за 3 минуты"
    kubectl get pods -n $NS | grep redis
    return 1
  fi

  # Проверяем кластер
  CLUSTER_STATE=$(kubectl exec -n $NS redis-deployment-0 -- redis-cli cluster info 2>/dev/null | grep cluster_state | cut -d: -f2 | tr -d '[:space:]')
  KEYS_AFTER=$(kubectl exec -n $NS redis-deployment-0 -- redis-cli -c dbsize 2>/dev/null || echo "N/A")

  echo "  Cluster state: $CLUSTER_STATE"
  echo "  Ключей после: $KEYS_AFTER"

  if [ "$CLUSTER_STATE" = "ok" ]; then
    echo "  ✓ $NS — УСПЕШНО"
    return 0
  else
    echo "  ✗ $NS — КЛАСТЕР НЕ OK (state=$CLUSTER_STATE)"
    return 1
  fi
}

# Запуск по одному namespace из файла
while read NS; do
  migrate_namespace "$NS"
  if [ $? -ne 0 ]; then
    echo ""
    echo "!!! Ошибка в $NS. Остановка. Разберись с проблемой вручную."
    echo "!!! Продолжить с следующего namespace можно командой:"
    echo "!!! migrate_namespace <next_namespace>"
    break
  fi
  # Пауза между namespace чтобы не перегружать nfs-csi
  sleep 5
done < /tmp/redis_namespaces.txt
```

