#!/usr/bin/env python3
"""
Скрипт для извлечения image path и tag из values.yaml в GitLab-репозитории через API.

Использование:
    python3 scan_values.py --url https://gitlab.example.com --project-id 123 --token YOUR_TOKEN --branch main
"""

import argparse
import re
import sys
from urllib.parse import quote as url_quote
from urllib.request import Request, urlopen
from urllib.error import HTTPError
import json


def gitlab_api(base_url: str, token: str, endpoint: str) -> any:
    """Выполняет GET-запрос к GitLab API."""
    url = f"{base_url}/api/v4{endpoint}"
    req = Request(url, headers={"PRIVATE-TOKEN": token})
    try:
        with urlopen(req) as resp:
            return json.loads(resp.read().decode())
    except HTTPError as e:
        if e.code == 404:
            return None
        raise


def get_tree(base_url: str, token: str, project_id: str, path: str, branch: str) -> list:
    """Получает список файлов/директорий в указанном пути через repository/tree."""
    encoded_path = url_quote(path, safe="")
    endpoint = (
        f"/projects/{project_id}/repository/tree"
        f"?path={encoded_path}&ref={branch}&per_page=100"
    )
    result = gitlab_api(base_url, token, endpoint)
    return result if result else []


def get_file_raw(base_url: str, token: str, project_id: str, file_path: str, branch: str) -> str | None:
    """Получает содержимое файла через repository/files/.../raw."""
    encoded = url_quote(file_path, safe="")
    url = f"{base_url}/api/v4/projects/{project_id}/repository/files/{encoded}/raw?ref={branch}"
    req = Request(url, headers={"PRIVATE-TOKEN": token})
    try:
        with urlopen(req) as resp:
            return resp.read().decode()
    except HTTPError:
        return None


def extract_image(content: str) -> tuple[str, str] | None:
    """Извлекает путь к репозиторию и tag из строки image: registry/path:tag."""
    match = re.search(r'image:\s*[^/\s]+(/\S+):(\S+)', content)
    if match:
        return match.group(1), match.group(2)
    return None


def process_values(base_url: str, token: str, project_id: str, branch: str,
                   display_path: str, file_path: str, results: list):
    """Читает values.yaml и извлекает image, добавляет результат в список."""
    content = get_file_raw(base_url, token, project_id, file_path, branch)
    if content is None:
        results.append((display_path, "values.yaml не найден", ""))
        return
    parsed = extract_image(content)
    if parsed is None:
        results.append((display_path, "image не найден в values.yaml", ""))
    else:
        results.append((display_path, parsed[0], parsed[1]))


def main():
    parser = argparse.ArgumentParser(description="Сканирование values.yaml в GitLab-репозитории")
    parser.add_argument("--url", required=True, help="URL GitLab (например https://gitlab.example.com)")
    parser.add_argument("--project-id", required=True, help="ID проекта в GitLab")
    parser.add_argument("--token", required=True, help="GitLab Private Token")
    parser.add_argument("--branch", required=True, help="Ветка репозитория")
    args = parser.parse_args()

    base_url = args.url.rstrip("/")
    token = args.token
    project_id = args.project_id
    branch = args.branch

    results = []

    # Получаем корень репозитория
    root_items = get_tree(base_url, token, project_id, "", branch)
    root_dirs = [item["name"] for item in root_items if item["type"] == "tree"]

    for module in sorted(root_dirs):
        if module.startswith("."):
            continue

        if module == "main":
            # Обрабатываем только main/fronts/*
            fronts_items = get_tree(base_url, token, project_id, "main/fronts", branch)
            apps = [item["name"] for item in fronts_items if item["type"] == "tree"]
            for app in sorted(apps):
                display_path = f"main/fronts/{app}"
                file_path = f"main/fronts/{app}/values.yaml"
                process_values(base_url, token, project_id, branch, display_path, file_path, results)
            continue

        # Обычный module — смотрим содержимое
        module_items = get_tree(base_url, token, project_id, module, branch)
        module_files = [item["name"] for item in module_items if item["type"] == "blob"]
        module_dirs = [item["name"] for item in module_items if item["type"] == "tree"]

        if "values.yaml" in module_files:
            # values.yaml лежит прямо в module — module сам является app
            display_path = module
            file_path = f"{module}/values.yaml"
            process_values(base_url, token, project_id, branch, display_path, file_path, results)

        for app in sorted(module_dirs):
            display_path = f"{module}/{app}"
            file_path = f"{module}/{app}/values.yaml"
            process_values(base_url, token, project_id, branch, display_path, file_path, results)

    # Вывод
    if not results:
        print("Ничего не найдено.")
        sys.exit(0)

    # Считаем ширину колонок для ровного вывода
    col1 = max(len(r[0]) for r in results)
    col2 = max(len(r[1]) for r in results)

    for path, image, tag in results:
        if tag:
            print(f"{path:<{col1}}  —  {image:<{col2}}  —  {tag}")
        else:
            print(f"{path:<{col1}}  —  {image}")


if __name__ == "__main__":
    main()
