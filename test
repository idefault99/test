## 1. Код библиотеки

### `minio_client/client.py`

```python
import boto3
from botocore.config import Config
from urllib.parse import urlsplit, urlunsplit


class MinioClient:
    """
    Фабрика настроенного boto3 S3 клиента для MinIO.
    Инкапсулирует логику подключения и обход nginx subpath rewrite.
    """

    def __init__(self, host: str, access_key: str, secret_key: str, prefix: str = ""):
        """
        host       — хост без префикса, например https://dev.example.com
        access_key — MinIO Access Key
        secret_key — MinIO Secret Key
        prefix     — субпуть если MinIO за nginx rewrite, например /api/s3minio
        """
        self._prefix = prefix.rstrip("/")

        self._s3 = boto3.client(
            "s3",
            endpoint_url=host,
            aws_access_key_id=access_key,
            aws_secret_access_key=secret_key,
            region_name="us-east-1",
            config=Config(
                signature_version="s3v4",
                s3={"addressing_style": "path"},
            ),
        )

        if self._prefix:
            self._s3.meta.events.register("before-send.s3.*", self._add_prefix)

    def _add_prefix(self, request, **kwargs):
        """Добавляет prefix в URL после подписания, до отправки. Не трогать."""
        parsed = urlsplit(request.url)
        request.url = urlunsplit((
            parsed.scheme,
            parsed.netloc,
            self._prefix + parsed.path,
            parsed.query,
            parsed.fragment,
        ))

    def get_s3(self):
        """Вернуть настроенный boto3 S3 клиент."""
        return self._s3
```

