#!/bin/bash
# ============================================================
# Redis Backup & Restore
#
# Использование:
#   bash redis_backup_restore.sh backup  <namespace>           — сделать бэкап
#   bash redis_backup_restore.sh restore <namespace>           — восстановить последний бэкап
#   bash redis_backup_restore.sh restore <namespace> <файл>   — восстановить конкретный бэкап
#   bash redis_backup_restore.sh list    <namespace>           — список бэкапов
#   bash redis_backup_restore.sh check   <namespace>           — проверить dbsize и предложить восстановление
#
# Бэкапы хранятся в: /opt/redis-backups/<namespace>/
# ============================================================

ACTION="${1}"
NS="${2}"
BACKUP_FILE="${3}"

REDIS_POD="redis-deployment-0"
REDIS_DATA_DIR="/data"
BACKUP_DIR="/opt/redis-backups/${NS}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

ok()   { echo -e "${GREEN}  ✓ $1${NC}"; }
fail() { echo -e "${RED}  ✗ $1${NC}"; }
info() { echo -e "${YELLOW}  → $1${NC}"; }
head() { echo -e "${CYAN}$1${NC}"; }
die()  { echo -e "${RED}ОШИБКА: $1${NC}"; exit 1; }

# ============================================================
# Проверка аргументов
# ============================================================
if [ -z "$ACTION" ] || [ -z "$NS" ]; then
  echo "Использование:"
  echo "  $0 backup  <namespace>"
  echo "  $0 restore <namespace> [путь/к/файлу.rdb]"
  echo "  $0 list    <namespace>"
  echo "  $0 check   <namespace>"
  exit 1
fi

# ============================================================
# Проверка что под запущен
# ============================================================
check_pod() {
  STATUS=$(kubectl get pod $REDIS_POD -n $NS --no-headers 2>/dev/null | awk '{print $3}')
  if [ "$STATUS" != "Running" ]; then
    die "Под $REDIS_POD в namespace $NS не Running (статус: ${STATUS:-не найден})"
  fi
}

# ============================================================
# BACKUP
# ============================================================
do_backup() {
  head ""
  head "============================================"
  head "  БЭКАП Redis → $NS"
  head "============================================"

  check_pod

  # Создаём директорию для бэкапов
  mkdir -p "$BACKUP_DIR"

  # Имя файла с временной меткой
  TIMESTAMP=$(date +%Y%m%d_%H%M%S)
  DEST="$BACKUP_DIR/dump_${TIMESTAMP}.rdb"
  LATEST="$BACKUP_DIR/dump_latest.rdb"

  # Текущий размер БД
  DBSIZE=$(kubectl exec -n $NS $REDIS_POD -- redis-cli dbsize 2>/dev/null)
  MEMORY=$(kubectl exec -n $NS $REDIS_POD -- redis-cli info memory 2>/dev/null \
    | grep "used_memory_human" | head -1 | cut -d: -f2 | tr -d '[:space:]')
  info "Ключей в БД: $DBSIZE | Память: $MEMORY"

  if [ "${DBSIZE}" = "0" ]; then
    echo ""
    echo -e "${YELLOW}  ⚠ БД пустая (dbsize=0). Бэкап будет сохранён, но данных нет.${NC}"
    read -p "  Продолжить? (y/N): " CONFIRM
    [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ] && echo "Отменено." && exit 0
  fi

  # Принудительный BGSAVE чтобы flush данных на диск
  info "Запускаем BGSAVE..."
  kubectl exec -n $NS $REDIS_POD -- redis-cli bgsave > /dev/null 2>&1

  # Ждём завершения BGSAVE
  for i in $(seq 1 30); do
    SAVE_STATUS=$(kubectl exec -n $NS $REDIS_POD -- redis-cli lastsave 2>/dev/null)
    BGSAVE_STATUS=$(kubectl exec -n $NS $REDIS_POD -- redis-cli info persistence 2>/dev/null \
      | grep "rdb_bgsave_in_progress" | cut -d: -f2 | tr -d '[:space:]')
    if [ "$BGSAVE_STATUS" = "0" ]; then
      break
    fi
    sleep 1
  done
  ok "BGSAVE завершён"

  # Копируем dump.rdb с пода на ноду через stdin/stdout (обходим проблему tar+permissions)
  info "Копируем dump.rdb из пода на ноду..."
  kubectl exec -n $NS $REDIS_POD -- cat "$REDIS_DATA_DIR/dump.rdb" > "$DEST" 2>/dev/null

  if [ ! -s "$DEST" ]; then
    # Если dump.rdb пустой или отсутствует (Redis без persistency не создаёт его)
    info "dump.rdb не найден или пуст — сохраняем через DUMP всех ключей..."

    if [ "${DBSIZE}" = "0" ]; then
      # Создаём пустой файл-маркер
      echo "EMPTY_DB_$(date +%s)" > "$DEST"
      ok "Пустой бэкап сохранён как маркер"
    else
      die "Не удалось скопировать dump.rdb. Проверь что Redis запущен с --appendonly yes или --save"
    fi
  else
    ok "Файл скопирован: $DEST ($(du -h "$DEST" | cut -f1))"
  fi

  # Обновляем симлинк на последний бэкап
  ln -sf "$DEST" "$LATEST"
  ok "Симлинк обновлён: $LATEST → $DEST"

  # Удаляем бэкапы старше 7 дней (оставляем последние 10)
  find "$BACKUP_DIR" -name "dump_*.rdb" | sort -r | tail -n +11 | xargs rm -f 2>/dev/null
  info "Старые бэкапы очищены (хранятся последние 10)"

  echo ""
  head "============================================"
  ok "БЭКАП ЗАВЕРШЁН"
  echo -e "  Файл   : ${CYAN}$DEST${NC}"
  echo -e "  Размер : $(du -h "$DEST" | cut -f1)"
  echo -e "  Ключей : $DBSIZE"
  echo -e "  Время  : $(date)"
  head "============================================"
  echo ""
}

# ============================================================
# RESTORE
# ============================================================
do_restore() {
  head ""
  head "============================================"
  head "  ВОССТАНОВЛЕНИЕ Redis ← $NS"
  head "============================================"

  # Определяем файл для восстановления
  if [ -n "$BACKUP_FILE" ]; then
    SOURCE="$BACKUP_FILE"
  else
    SOURCE="$BACKUP_DIR/dump_latest.rdb"
    info "Файл не указан — используем последний бэкап"
  fi

  if [ ! -f "$SOURCE" ]; then
    die "Файл не найден: $SOURCE\nСписок доступных бэкапов: $0 list $NS"
  fi

  FILE_SIZE=$(du -h "$SOURCE" | cut -f1)
  info "Файл для восстановления: $SOURCE ($FILE_SIZE)"
  info "Namespace: $NS | Pod: $REDIS_POD"

  echo ""
  echo -e "${YELLOW}  ⚠ Внимание: текущие данные Redis будут ЗАМЕНЕНЫ данными из бэкапа!${NC}"
  read -p "  Продолжить? (y/N): " CONFIRM
  [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ] && echo "Отменено." && exit 0

  check_pod

  # Текущее состояние до восстановления
  DBSIZE_BEFORE=$(kubectl exec -n $NS $REDIS_POD -- redis-cli dbsize 2>/dev/null)
  info "Ключей до восстановления: $DBSIZE_BEFORE"

  # Шаг 1: Отключаем автосохранение чтобы Redis не перезаписал наш файл
  info "Отключаем автосохранение..."
  kubectl exec -n $NS $REDIS_POD -- redis-cli config set save "" > /dev/null 2>&1
  kubectl exec -n $NS $REDIS_POD -- redis-cli config set appendonly no > /dev/null 2>&1
  ok "Автосохранение отключено"

  # Шаг 2: Бэкапим текущий dump.rdb на случай отката
  info "Сохраняем текущий dump.rdb как .bak (для отката)..."
  kubectl exec -n $NS $REDIS_POD -- sh -c \
    "[ -f $REDIS_DATA_DIR/dump.rdb ] && cp $REDIS_DATA_DIR/dump.rdb $REDIS_DATA_DIR/dump.rdb.bak 2>/dev/null || true"
  ok "Текущий дамп сохранён как dump.rdb.bak"

  # Шаг 3: Копируем новый dump.rdb в под через stdin
  info "Копируем бэкап в под..."
  kubectl exec -n $NS $REDIS_POD -- sh -c 'cat > /data/dump.rdb' < "$SOURCE"
  if [ $? -ne 0 ]; then
    die "Не удалось скопировать файл в под"
  fi
  ok "Файл скопирован в $REDIS_DATA_DIR/dump.rdb"

  # Шаг 4: Перезапускаем под — Redis при старте читает dump.rdb с диска
  info "Перезапускаем под для загрузки данных из дампа..."
  kubectl delete pod $REDIS_POD -n $NS > /dev/null 2>&1
  if [ $? -ne 0 ]; then
    die "Не удалось удалить под"
  fi

  info "Ждём восстановления пода (до 120 сек)..."
  kubectl wait --for=condition=Ready pod/$REDIS_POD -n $NS --timeout=120s > /dev/null 2>&1
  if [ $? -ne 0 ]; then
    die "Под не поднялся за 120 секунд. Проверь: kubectl describe pod $REDIS_POD -n $NS"
  fi
  ok "Под снова Running"

  # Небольшая пауза чтобы Redis успел загрузить данные
  sleep 2

  # Шаг 5: Проверяем результат
  DBSIZE_AFTER=$(kubectl exec -n $NS $REDIS_POD -- redis-cli dbsize 2>/dev/null)
  MEMORY_AFTER=$(kubectl exec -n $NS $REDIS_POD -- redis-cli info memory 2>/dev/null \
    | grep "used_memory_human" | head -1 | cut -d: -f2 | tr -d '[:space:]')

  # Шаг 6: Включаем автосохранение обратно
  info "Включаем автосохранение..."
  kubectl exec -n $NS $REDIS_POD -- redis-cli config set save "3600 1 300 100 60 10000" > /dev/null 2>&1
  ok "Автосохранение включено"

  echo ""
  head "============================================"
  if [ "${DBSIZE_AFTER:-0}" -gt 0 ] 2>/dev/null; then
    ok "ВОССТАНОВЛЕНИЕ ЗАВЕРШЕНО УСПЕШНО"
  else
    echo -e "${YELLOW}  ⚠ ВОССТАНОВЛЕНИЕ ЗАВЕРШЕНО (dbsize=0 — бэкап был пустым или данные не загрузились)${NC}"
  fi
  echo -e "  Ключей до   : ${YELLOW}$DBSIZE_BEFORE${NC}"
  echo -e "  Ключей после: ${GREEN}$DBSIZE_AFTER${NC}"
  echo -e "  Память после: $MEMORY_AFTER"
  echo -e "  Бэкап из    : $SOURCE"
  echo ""
  echo -e "  Откат (если что-то не так):"
  echo -e "  ${CYAN}kubectl exec -n $NS $REDIS_POD -- sh -c 'cp $REDIS_DATA_DIR/dump.rdb.bak $REDIS_DATA_DIR/dump.rdb'${NC}"
  echo -e "  ${CYAN}kubectl delete pod $REDIS_POD -n $NS${NC}"
  head "============================================"
  echo ""
}

# ============================================================
# LIST — список доступных бэкапов
# ============================================================
do_list() {
  head ""
  head "============================================"
  head "  БЭКАПЫ Redis: $NS"
  head "============================================"

  if [ ! -d "$BACKUP_DIR" ] || [ -z "$(ls $BACKUP_DIR/dump_*.rdb 2>/dev/null)" ]; then
    info "Бэкапов не найдено в $BACKUP_DIR"
    echo ""
    return
  fi

  LATEST_TARGET=$(readlink -f "$BACKUP_DIR/dump_latest.rdb" 2>/dev/null)

  printf "  %-45s %-10s %s\n" "ФАЙЛ" "РАЗМЕР" "ДАТА"
  echo "  -------------------------------------------------------------------"

  ls -t "$BACKUP_DIR"/dump_*.rdb 2>/dev/null | while read F; do
    SIZE=$(du -h "$F" | cut -f1)
    DATE=$(date -r "$F" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || stat -c %y "$F" | cut -d. -f1)
    MARKER=""
    [ "$(readlink -f "$F")" = "$LATEST_TARGET" ] && MARKER=" ← latest"
    printf "  %-45s %-10s %s%s\n" "$(basename $F)" "$SIZE" "$DATE" "$MARKER"
  done

  echo ""
  echo -e "  Директория: ${CYAN}$BACKUP_DIR${NC}"
  echo ""
}

# ============================================================
# CHECK — проверить dbsize и предложить восстановление
# ============================================================
do_check() {
  head ""
  head "============================================"
  head "  ПРОВЕРКА Redis: $NS"
  head "============================================"

  check_pod

  DBSIZE=$(kubectl exec -n $NS $REDIS_POD -- redis-cli dbsize 2>/dev/null)
  MEMORY=$(kubectl exec -n $NS $REDIS_POD -- redis-cli info memory 2>/dev/null \
    | grep "used_memory_human" | head -1 | cut -d: -f2 | tr -d '[:space:]')
  PING=$(kubectl exec -n $NS $REDIS_POD -- redis-cli ping 2>/dev/null)

  info "PING: $PING"
  info "Ключей: $DBSIZE"
  info "Память: $MEMORY"

  # Список доступных бэкапов
  LATEST="$BACKUP_DIR/dump_latest.rdb"
  if [ -f "$LATEST" ]; then
    BACKUP_DATE=$(date -r "$LATEST" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || stat -c %y "$LATEST" | cut -d. -f1)
    BACKUP_SIZE=$(du -h "$LATEST" | cut -f1)
    info "Последний бэкап: $BACKUP_DATE ($BACKUP_SIZE)"
  else
    info "Бэкапов не найдено в $BACKUP_DIR"
  fi

  echo ""

  if [ "${DBSIZE:-0}" = "0" ] 2>/dev/null; then
    echo -e "${RED}  ✗ БД ПУСТАЯ (dbsize=0)!${NC}"
    echo ""

    if [ -f "$LATEST" ]; then
      echo -e "${YELLOW}  Доступен бэкап от $BACKUP_DATE ($BACKUP_SIZE)${NC}"
      echo ""
      read -p "  Восстановить из последнего бэкапа прямо сейчас? (y/N): " CONFIRM
      if [ "$CONFIRM" = "y" ] || [ "$CONFIRM" = "Y" ]; then
        do_restore
      else
        echo ""
        info "Для восстановления вручную:"
        echo -e "  ${CYAN}$0 restore $NS${NC}"
        echo -e "  ${CYAN}$0 restore $NS <путь/к/файлу.rdb>${NC}"
      fi
    else
      fail "Бэкапов нет. Сначала создай бэкап когда БД не пустая:"
      echo -e "  ${CYAN}$0 backup $NS${NC}"
    fi
  else
    ok "БД в норме ($DBSIZE ключей)"
    echo ""
    echo -e "  Создать бэкап прямо сейчас:"
    echo -e "  ${CYAN}$0 backup $NS${NC}"
  fi
  echo ""
}

# ============================================================
# Роутинг
# ============================================================
case "$ACTION" in
  backup)  do_backup  ;;
  restore) do_restore ;;
  list)    do_list    ;;
  check)   do_check   ;;
  *)
    echo "Неизвестное действие: $ACTION"
    echo "Доступные: backup | restore | list | check"
    exit 1
    ;;
esac


---
# Сделать бэкап (кладёт в /opt/redis-backups/<namespace>/)
bash redis_backup_restore.sh backup dev-devops

# Проверить dbsize и если 0 — сразу предложит восстановить
bash redis_backup_restore.sh check dev-devops

# Восстановить из последнего бэкапа
bash redis_backup_restore.sh restore dev-devops

# Восстановить из конкретного файла
bash redis_backup_restore.sh restore dev-devops /opt/redis-backups/dev-devops/dump_20260320_120000.rdb

# Список всех бэкапов
bash redis_backup_restore.sh list dev-devops

---
bash redis_backup_restore.sh check dev-devops
# → Покажет что БД пустая
# → Найдёт последний бэкап
# → Спросит "восстановить прямо сейчас? (y/N)"
# → Одно нажатие Y — и всё готово

