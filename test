# 1. Перенести архив и распаковать на хосте с Ansible
scp k8s-ansible.tar.gz user@bastion:~/
ssh user@bastion 'tar xzf k8s-ansible.tar.gz'

# 2. Заполнить group_vars/all.yml — пароли, local_registry, ansible_user в inventory.ini

# 3. Аудит всех нод (убедиться что схема такая же)
ansible-playbook playbooks/00-audit.yml -K

# 4. ← НОВЫЙ ОБЯЗАТЕЛЬНЫЙ ШАГ
ansible-playbook playbooks/01-fixup.yml -K
# Делает: SystemdCgroup=true, kubeadm reset, убирает tunl0, nf_conntrack, kubectl

# 5. Основной кластер
ansible-playbook playbooks/03-k8s-cluster.yml -K

# 6. GPU Operator
ansible-playbook playbooks/04-gpu-operator.yml -K

# 7-8. Storage и сервисы
ansible-playbook playbooks/05-longhorn.yml -K
ansible-playbook playbooks/06-services.yml -K
