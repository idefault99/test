#!/bin/bash
# node-bandwidth-matrix.sh — замер пропускной способности между всеми парами нод

set -euo pipefail

NAMESPACE="${1:-default}"
IMAGE="networkstatic/iperf3"
DURATION="${2:-10}"
PARALLEL="${3:-4}"
LABEL="iperf3-test"

cleanup() {
  echo ""
  echo "=== Cleanup ==="
  kubectl delete pods -n "$NAMESPACE" -l "app=$LABEL" --ignore-not-found --wait=false
  echo "Поды удалены."
}
trap cleanup EXIT

# Получаем список нод (только Ready, без master если не нужен)
NODES=($(kubectl get nodes \
  --field-selector='status.conditions[?(@.type=="Ready")].status=True' \
  -o jsonpath='{.items[*].metadata.name}'))

NODE_COUNT=${#NODES[@]}
echo "=== Ноды в кластере ($NODE_COUNT): ${NODES[*]}"
echo "=== Namespace: $NAMESPACE | duration: ${DURATION}s | parallel: $PARALLEL"
echo ""

# Запускаем сервер на каждой ноде заранее
echo "--- Запускаем iperf3-серверы на всех нодах..."
for node in "${NODES[@]}"; do
  pod_name="iperf3-server-${node//\./-}"
  kubectl run "$pod_name" \
    -n "$NAMESPACE" \
    --image="$IMAGE" \
    --labels="app=$LABEL" \
    --overrides="{\"spec\":{\"nodeSelector\":{\"kubernetes.io/hostname\":\"$node\"},\"tolerations\":[{\"operator\":\"Exists\"}]}}" \
    --restart=Never \
    -- iperf3 -s 1>/dev/null
done

# Ждём пока все серверы поднимутся
echo "--- Ожидаем Ready всех серверов..."
for node in "${NODES[@]}"; do
  pod_name="iperf3-server-${node//\./-}"
  kubectl wait pod "$pod_name" \
    -n "$NAMESPACE" \
    --for=condition=Ready \
    --timeout=60s 1>/dev/null
  echo "    ✓ $pod_name"
done

# Собираем IP серверов
declare -A NODE_IPS
for node in "${NODES[@]}"; do
  pod_name="iperf3-server-${node//\./-}"
  ip=$(kubectl get pod "$pod_name" -n "$NAMESPACE" \
    -o jsonpath='{.status.podIP}')
  NODE_IPS[$node]="$ip"
  echo "    $node → ${NODE_IPS[$node]}"
done

echo ""
echo "=== Матрица пропускной способности (Gbits/sec) ==="
echo ""

# Заголовок таблицы
printf "%-30s" "FROM \\ TO"
for dst in "${NODES[@]}"; do
  printf "%-22s" "$dst"
done
echo ""
printf "%-30s" ""
for dst in "${NODES[@]}"; do
  printf "%-22s" "--------------------"
done
echo ""

# Прогоняем тесты по всем парам
declare -A RESULTS

for src in "${NODES[@]}"; do
  printf "%-30s" "$src"

  for dst in "${NODES[@]}"; do
    if [[ "$src" == "$dst" ]]; then
      printf "%-22s" "—"
      continue
    fi

    server_ip="${NODE_IPS[$dst]}"
    client_pod="iperf3-client-${src//\./-}-to-${dst//\./-}"

    # Запускаем клиент и парсим результат
    result=$(kubectl run "$client_pod" \
      -n "$NAMESPACE" \
      --image="$IMAGE" \
      --labels="app=$LABEL" \
      --overrides="{\"spec\":{\"nodeSelector\":{\"kubernetes.io/hostname\":\"$src\"},\"tolerations\":[{\"operator\":\"Exists\"}]}}" \
      --restart=Never \
      --rm \
      -it \
      --quiet \
      -- iperf3 -c "$server_ip" -t "$DURATION" -P "$PARALLEL" 2>/dev/null \
      | grep -E '\[SUM\].*sender' \
      | awk '{print $(NF-1), $NF}' || echo "ERR")

    RESULTS["${src}-${dst}"]="$result"
    printf "%-22s" "$result"
  done
  echo ""
done

echo ""
echo "=== Детальные результаты ==="
for src in "${NODES[@]}"; do
  for dst in "${NODES[@]}"; do
    [[ "$src" == "$dst" ]] && continue
    echo "  $src → $dst : ${RESULTS[${src}-${dst}]:-N/A}"
  done
done
