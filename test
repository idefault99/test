# 8. ПРОВЕРИТЬ ДИСКИ ПОД LONGHORN НА ВСЕХ НОДАХ
# =====================================================================

for n in coparking-5 coparking-6 coparking-7 coparking-8 coparking-9 coparking-10; do
  echo "===== $n ====="
  ssh root@$n "lsblk -dno NAME,SIZE,MODEL"
  ssh root@$n "df -hT /var/lib/longhorn || true"
  ssh root@$n "grep longhorn /etc/fstab || true"
  ssh root@$n "ls -ldZ /var/lib/longhorn || true"
  ssh root@$n "systemctl is-active iscsid || true"
  ssh root@$n "cat /etc/iscsi/initiatorname.iscsi || true"
done


# Если /var/lib/longhorn ещё НЕ подготовлен на какой-то ноде,
# выполнить на этой ноде.
#
# ВНИМАНИЕ:
#   mkfs.xfs удалит данные на /dev/sdb.
#   Перед выполнением убедиться, что /dev/sdb — data disk, не OS disk.

# Выполнить на каждой ноде, где ещё нет /var/lib/longhorn:

lsblk -dno NAME,SIZE,MODEL

mkfs.xfs -f -L longhorn /dev/sdb

UUID=$(blkid -s UUID -o value /dev/sdb)
echo "UUID=$UUID"

mkdir -p /var/lib/longhorn

grep -q "/var/lib/longhorn" /etc/fstab || \
  echo "UUID=$UUID /var/lib/longhorn xfs defaults,noatime,nodiratime 0 0" >> /etc/fstab

systemctl daemon-reload

mount -a

df -hT /var/lib/longhorn

dnf install -y policycoreutils-python-utils iscsi-initiator-utils

semanage fcontext -a -t container_file_t '/var/lib/longhorn(/.*)?' 2>/dev/null || true

restorecon -RvF /var/lib/longhorn

echo "InitiatorName=$(iscsi-iname)" > /etc/iscsi/initiatorname.iscsi

systemctl enable --now iscsid

systemctl is-active iscsid

ls -ldZ /var/lib/longhorn


