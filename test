# kubeadm reset чистит всё что init создал
sudo kubeadm reset --force

# Удалить kube-vip манифест вручную (он останется после reset)
sudo rm -f /etc/kubernetes/manifests/kube-vip.yaml

# Убедиться что всё чисто
ip addr show eno1          # 172.16.175.20 не должно быть
sudo crictl ps -a          # контейнеров k8s не должно быть
