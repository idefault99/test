microk8s kubectl get secret minio-vault-secret -n stand-test \
  -o jsonpath='{.data}' | jq 'to_entries[] | {(.key): (.value | @base64d)}'

# Проверить конкретный ExternalSecret
microk8s kubectl describe externalsecret minio-vault-secret -n stand-test
