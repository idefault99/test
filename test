kubectl get pod -n longhorn-system longhorn-manager-w9mzg -o jsonpath='{.spec.nodeName}'
---
# Экспортировать pause:3.1
ctr -n k8s.io images export /tmp/pause-3.1.tar registry.k8s.io/pause:3.1

# Скопировать на остальные ноды
for node in coparking-6 coparking-7 coparking-8 coparking-9 coparking-10; do
  scp /tmp/pause-3.1.tar ikbelykh@${node}:/tmp/
  ssh ikbelykh@${node} "sudo ctr -n k8s.io images import /tmp/pause-3.1.tar"
done
---
# Проверить текущее значение на любой ноде
grep sandbox_image /etc/containerd/config.toml
---
ansible all_nodes -i inventory.ini -b -m replace -a \
  "path=/etc/containerd/config.toml regexp='sandbox_image.*pause:3\\.1\"' replace='sandbox_image = \"registry.k8s.io/pause:3.10\"'"
ansible all_nodes -i inventory.ini -b -m systemd -a "name=containerd state=restarted"
---
kubectl delete pods -n longhorn-system -l app=longhorn-iscsi-selinux-workaround
---
# Посмотреть имена контейнеров в поде
kubectl get pod -n longhorn-system longhorn-manager-229mh \
  -o jsonpath='{.spec.containers[*].name}'

# Логи второго (не запущенного) контейнера
kubectl logs -n longhorn-system longhorn-manager-229mh -c <второй_контейнер>
