# Добавляем helm аннотации к существующему StatefulSet вручную
kubectl annotate statefulset redis-deployment -n test-gis-svo \
  meta.helm.sh/release-name=infra \
  meta.helm.sh/release-namespace=test-gis-svo \
  --overwrite

kubectl label statefulset redis-deployment -n test-gis-svo \
  app.kubernetes.io/managed-by=Helm \
  --overwrite

# Теперь helm install
helm install infra ./path/to/chart -n test-gis-svo -f values.yaml
