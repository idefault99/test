# Узнаём адрес NFS сервера
kubectl get sc nfs-csi -o jsonpath='{.parameters.server}'
echo ""

# Узнаём какой под csi-nfs-node на microk8s-5
kubectl get pods -n kube-system -o wide | grep csi-nfs-node | grep microk8s-5

# Логи именно этого пода
kubectl logs -n kube-system <csi-nfs-node-pod-на-microk8s-5> -c nfs | tail -30

# Проверяем доступность NFS с самой ноды
ssh microk8s-5 "showmount -e <nfs-server-ip>"
ssh microk8s-5 "mount -t nfs <nfs-server-ip>:/ /mnt && echo OK && umount /mnt"
