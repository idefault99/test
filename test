# Посмотреть кто реально подписал сертификат Vault
openssl s_client -connect vault.test.ru:443 -showcerts 2>/dev/null | \
  openssl x509 -noout -issuer -subject

# Посмотреть что внутри vault-ca-full.pem на Vault VM
ssh root@vault-vm "openssl x509 -noout -issuer -subject -in /tmp/vault-ca-full.pem"




# Вытащить полную цепочку прямо с Vault
openssl s_client -connect vault.test.ru:443 -showcerts 2>/dev/null | \
  sed -n '/-----BEGIN CERTIFICATE-----/,/-----END CERTIFICATE-----/p' \
  > /tmp/vault-chain.pem

# Проверить сколько сертов получили
grep -c "BEGIN CERTIFICATE" /tmp/vault-chain.pem

# Пересоздать Secret с реальной цепочкой
microk8s kubectl delete secret vault-ca-secret -n external-secrets
microk8s kubectl create secret generic vault-ca-secret \
  --from-file=ca.crt=/tmp/vault-chain.pem \
  -n external-secrets

microk8s kubectl rollout restart deployment external-secrets -n external-secrets
