variables:
  TAG: ${CI_COMMIT_SHORT_SHA}
  TARGET: production

stages:
  - build
  - deploy

# ─── BUILD ────────────────────────────────────────────────────────────────────

.buildkit_bin:
  stage: build
  script:
    - |
      docker buildx build ./ -f ${CI_PROJECT_DIR}/Docker/Dockerfile \
        --tag ${CI_REGISTRY_IMAGE}:${TAG}.bin \
        --tag ${CI_REGISTRY_IMAGE}:latest \
        --cache-to  type=registry,ref=${CI_REGISTRY_IMAGE}/cache,mode=max \
        --cache-from type=registry,ref=${CI_REGISTRY_IMAGE}/cache \
        --target ${TARGET} \
        --build-arg RSA_PRIVATE_KEY=${RSA_PRIVATE_KEY} \
        --build-arg NEXUS_PYPI_URL=${NEXUS_PYPI_URL} \
        --build-arg NEXUS_USERNAME=${NEXUS_USERNAME} \
        --build-arg NEXUS_PASSWORD=${NEXUS_PASSWORD} \
        --build-arg GITLAB_USERNAME=gitlab-ci-token \
        --build-arg GITLAB_TOKEN=${CI_JOB_TOKEN} \
        --build-arg http_proxy=${http_proxy} \
        --build-arg https_proxy=${https_proxy} \
        --build-arg no_proxy=${no_proxy} \
        --push=true

build_bin:
  extends: .buildkit_bin

# ─── DEPLOY ───────────────────────────────────────────────────────────────────

deploy:
  stage: deploy
  image: alpine:3.19
  before_script:
    - apk add --no-cache ansible sshpass openssh-client
    # Отключаем проверку host key (или монтируйте known_hosts)
    - mkdir -p ~/.ssh
    - echo "StrictHostKeyChecking no" >> ~/.ssh/config
  script:
    - |
      ansible-playbook ansible/deploy.yml \
        -i ansible/inventory.ini \
        -e "deploy_image=${CI_REGISTRY_IMAGE}" \
        -e "deploy_tag=${TAG}.bin" \
        -e "registry_user=${CI_REGISTRY_USER}" \
        -e "registry_password=${CI_REGISTRY_PASSWORD}" \
        -e "registry_host=${CI_REGISTRY}" \
        -e "target_host=${DEPLOY_HOST}" \
        -e "ansible_user=${DEPLOY_USER}" \
        -e "ansible_password=${DEPLOY_PASSWORD}" \
        -e "ansible_become_password=${DEPLOY_PASSWORD}"
  environment:
    name: production
  # Запускать только из main/master или вручную
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'
      when: on_success
    - when: manual
---
---
- name: Deploy docker-compose with new image tag
  hosts: deploy_targets
  become: true

  vars:
    # Путь к docker-compose на целевом хосте
    compose_dir: /opt/app
    compose_file: "{{ compose_dir }}/docker-compose.yml"
    # Имя сервиса в compose-файле, тег которого нужно обновить
    compose_service: app

  tasks:

    # ── 1. Логин в GitLab Registry ──────────────────────────────────────────
    - name: Login to container registry
      community.docker.docker_login:
        registry_url: "{{ registry_host }}"
        username: "{{ registry_user }}"
        password: "{{ registry_password }}"
      no_log: true

    # ── 2. Обновить тег в docker-compose.yml ────────────────────────────────
    - name: Render docker-compose with new tag
      ansible.builtin.replace:
        path: "{{ compose_file }}"
        # Заменяем строку вида:  image: registry.example.com/group/project:*
        regexp: '^(\s*image:\s*{{ deploy_image | regex_escape }}):.*$'
        replace: '\1:{{ deploy_tag }}'
      notify: restart compose

    # ── 3. Pull нового образа ───────────────────────────────────────────────
    - name: Pull new image
      community.docker.docker_image:
        name: "{{ deploy_image }}:{{ deploy_tag }}"
        source: pull
        force_source: true

    # ── 4. Запустить/перезапустить compose ─────────────────────────────────
    - name: Apply docker-compose (up -d)
      community.docker.docker_compose_v2:
        project_src: "{{ compose_dir }}"
        pull: never           # уже pulled выше
        recreate: always      # пересоздать контейнеры с новым образом
        remove_orphans: true
      register: compose_result

    # ── 5. Показать статус ──────────────────────────────────────────────────
    - name: Show compose result
      ansible.builtin.debug:
        var: compose_result

    # ── 6. Healthcheck — ждём, пока сервис поднимется ───────────────────────
    - name: Wait for service to become healthy
      community.docker.docker_container_info:
        name: "{{ compose_service }}"
      register: container_info
      until: >
        container_info.container is defined and
        (
          container_info.container.State.Health is not defined or
          container_info.container.State.Health.Status == 'healthy'
        ) and
        container_info.container.State.Running == true
      retries: 20
      delay: 5

    # ── 7. Удалить старые образы (опционально) ──────────────────────────────
    - name: Remove dangling images
      community.docker.docker_prune:
        images: true
        images_filters:
          dangling: true

    # ── 8. Logout ───────────────────────────────────────────────────────────
    - name: Logout from registry
      community.docker.docker_login:
        registry_url: "{{ registry_host }}"
        state: absent

  handlers:
    - name: restart compose
      community.docker.docker_compose_v2:
        project_src: "{{ compose_dir }}"
        recreate: always
---
