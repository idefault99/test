{{- range .Values.videorecorder.nodes }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: videorecorder-{{ .name | lower | replace " " "-" }}
  labels:
    app.kubernetes.io/name: videorecorder
    app.kubernetes.io/instance: {{ $.Release.Name }}
    projectLabel: videorecorder
    coparking/node: {{ .name | quote }}
spec:
  replicas: {{ .replicas }}
  selector:
    matchLabels:
      app.kubernetes.io/name: videorecorder
      projectLabel: videorecorder
      coparking/node: {{ .name | quote }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: videorecorder
        projectLabel: videorecorder
        coparking/node: {{ .name | quote }}
    spec:
      nodeSelector:
        kubernetes.io/hostname: {{ .name | quote }}
      containers:
        - name: videorecorder
          image: "{{ $.Values.image.repository }}:{{ $.Values.image.tag }}"
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: {{ $.Values.parkingPort | default 8000 }}
              protocol: TCP
          envFrom:
            - configMapRef:
                name: {{ $.Release.Name }}-config
          resources:
            limits:
              cpu: {{ ((($.Values.resources).limits).cpu) | default "500m" | quote }}
              memory: {{ ((($.Values.resources).limits).memory) | default "512Mi" | quote }}
              nvidia.com/gpu: {{ ((($.Values.resources).limits).gpu) | default 1 | quote }}
            requests:
              cpu: {{ ((($.Values.resources).requests).cpu) | default "100m" | quote }}
              memory: {{ ((($.Values.resources).requests).memory) | default "512Mi" | quote }}
          livenessProbe:
            httpGet:
              path: /health
              port: http
            initialDelaySeconds: 30
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: /health
              port: http
            initialDelaySeconds: 5
            periodSeconds: 5
      {{- with $.Values.imagePullSecrets }}
      imagePullSecrets:
        {{- toYaml . | nindent 8 }}
      {{- end }}
{{- end }}
---
