# Деплоить: helm upgrade --install stand-secrets ./charts/stand-secrets \
#             --namespace test-stand \
#             --values values.yaml \
#             --set-file vault.caCert=./vault-ca.crt

vault:
  address: "https://vault.test.ru"
  kvMount: "stands"
  authPath: "kubernetes"
  caConfigMap: "vault-ca"
  serviceAccount:
    name: "external-secrets"
    namespace: "external-secrets"
  caCert: ""                         # передаётся через --set-file
  refreshInterval: "5m"
  clusterSecretStore:
    name: vault-cluster-store-test-stand   # для каждого стенда своё

stand:
  name: "test-stand"
  infra:
    services:
      - name: s3minio
        secretName: s3minio-vault-secret
  apps:
    - suffix: "approvals"
      services:
        - name: approvals
          secretName: approvals-vault-secret
