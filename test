---
vault:
  address: "https://192.168.1.10:8200"   # IP твоей VM с Vault
  caConfigMap: "vault-ca"                 # ConfigMap с ca.crt (создаётся ниже)
  authPath: "kubernetes"
  kvPath: "secret"

stand:
  name: "stand-test"   # Меняешь на имя стенда

  # Список namespace-ов стенда
  # suffix: infra → namespace = stand-test (сам стенд)
  # suffix: appone → namespace = stand-test-appone
  namespaces:
    - suffix: "infra"
      # Ключи из Vault path secret/stand-test/infra → в Secret
      secretName: "vault-infra-secrets"
      data:
        - secretKey: "db-password"       # имя ключа в K8s Secret
          remoteKey: "db-password"       # имя ключа в Vault
        - secretKey: "minio-access-key"
          remoteKey: "minio-access-key"

    - suffix: "appone"
      secretName: "vault-app-secrets"
      data:
        - secretKey: "db-password"
          remoteKey: "db-password"
        - secretKey: "app-api-key"
          remoteKey: "app-api-key"

    - suffix: "apptwo"
      secretName: "vault-app-secrets"
      data:
        - secretKey: "db-password"
          remoteKey: "db-password"


---
{{- $stand := .Values.stand.name }}
{{- range .Values.stand.namespaces }}
{{- $ns := ternary $stand (printf "%s-%s" $stand .suffix) (eq .suffix "infra") }}
{{- $role := printf "%s-%s" $stand .suffix }}
---
apiVersion: external-secrets.io/v1beta1
kind: SecretStore
metadata:
  name: vault-backend
  namespace: {{ $ns }}
spec:
  provider:
    vault:
      server: {{ $.Values.vault.address }}
      path: {{ $.Values.vault.kvPath }}
      version: v2
      auth:
        kubernetes:
          mountPath: {{ $.Values.vault.authPath }}
          role: {{ $role }}
          serviceAccountRef:
            name: external-secrets
            namespace: external-secrets
      caProvider:
        type: ConfigMap
        name: {{ $.Values.vault.caConfigMap }}
        key: ca.crt
        namespace: external-secrets
{{- end }}

---
{{- $stand := .Values.stand.name }}
{{- range .Values.stand.namespaces }}
{{- $ns := ternary $stand (printf "%s-%s" $stand .suffix) (eq .suffix "infra") }}
{{- $vaultPath := printf "%s/%s" $stand .suffix }}
---
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {{ .secretName }}
  namespace: {{ $ns }}
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: vault-backend
    kind: SecretStore
  target:
    name: {{ .secretName }}
    creationPolicy: Owner
  data:
  {{- range .data }}
    - secretKey: {{ .secretKey }}
      remoteRef:
        key: {{ $vaultPath }}
        property: {{ .remoteKey }}
  {{- end }}
{{- end }}



---
{{- $stand := .Values.stand.name }}
{{- range .Values.stand.namespaces }}
{{- $ns := ternary $stand (printf "%s-%s" $stand .suffix) (eq .suffix "infra") }}
