#!/bin/bash
# replace-image.sh — заменить registry/repo часть образа, сохранив тег

set -euo pipefail

usage() {
  echo "Usage: $0 <old-registry/repo> <new-registry/repo>"
  echo "  Example: $0 test.def/repo/test harbor.test/repo/test"
  echo ""
  echo "  Before: test.def/repo/test:tag.1"
  echo "  After:  harbor.test/repo/test:tag.1"
  exit 1
}

[[ $# -ne 2 ]] && usage

OLD_IMAGE="${1%/}"
NEW_IMAGE="${2%/}"

KUBECTL="${KUBECTL:-kubectl}"

# Извлечь тег/digest из полного image url
# Правило: тег — это то, что после последнего ':', НО только если
# слева от ':' нет '/' после этого ':' (иначе это порт registry)
parse_image() {
  local full="$1"
  local url tag suffix

  if [[ "$full" == *"@"* ]]; then
    # digest: image@sha256:abc123
    url="${full%%@*}"
    suffix="@${full#*@}"
  else
    # Проверяем есть ли тег: ищем последнее ':'
    # Тег есть если после последнего ':' нет '/'
    local last_colon_part="${full##*:}"
    local before_last_colon="${full%:*}"

    if [[ "$full" == *":"* && "$last_colon_part" != *"/"* ]]; then
      # После последнего ':' нет '/' — это тег
      url="$before_last_colon"
      suffix=":${last_colon_part}"
    else
      # Нет тега (или двоеточие только в порту registry)
      url="$full"
      suffix=""
    fi
  fi

  echo "${url}|${suffix}"
}

echo "==> Old image URL: ${OLD_IMAGE}"
echo "==> New image URL: ${NEW_IMAGE}"
echo ""

found=0
patched=0

NAMESPACES=$($KUBECTL get namespaces -o jsonpath='{.items[*].metadata.name}')

for ns in $NAMESPACES; do
  DEPLOYMENTS=$($KUBECTL get deployments -n "$ns" \
    -o jsonpath='{.items[*].metadata.name}' 2>/dev/null) || continue
  [[ -z "$DEPLOYMENTS" ]] && continue

  for deploy in $DEPLOYMENTS; do
    CONTAINERS=$($KUBECTL get deployment "$deploy" -n "$ns" \
      -o jsonpath='{range .spec.template.spec.containers[*]}{.name}={.image}{"\n"}{end}{range .spec.template.spec.initContainers[*]}{.name}={.image}{"\n"}{end}' \
      2>/dev/null) || continue

    while IFS='=' read -r cname cimage; do
      [[ -z "$cname" || -z "$cimage" ]] && continue

      parsed=$(parse_image "$cimage")
      cur_url="${parsed%%|*}"
      cur_suffix="${parsed##*|}"

      if [[ "$cur_url" == "$OLD_IMAGE" ]]; then
        new_full="${NEW_IMAGE}${cur_suffix}"
        ((found++)) || true

        echo "[${ns}/${deploy}] ${cname}"
        echo "  old: ${cimage}"
        echo "  new: ${new_full}"

        IS_INIT=$($KUBECTL get deployment "$deploy" -n "$ns" \
          -o jsonpath="{.spec.template.spec.initContainers[?(@.name==\"${cname}\")].name}" \
          2>/dev/null)
        CTYPE=$([[ -n "$IS_INIT" ]] && echo "initContainers" || echo "containers")

        PATCH="{\"spec\":{\"template\":{\"spec\":{\"${CTYPE}\":[{\"name\":\"${cname}\",\"image\":\"${new_full}\"}]}}}}"

        if $KUBECTL patch deployment "$deploy" -n "$ns" \
            --type=strategic -p "$PATCH" > /dev/null 2>&1; then
          echo "  ✓ patched"
          ((patched++)) || true
        else
          echo "  ✗ FAILED"
        fi
        echo ""
      fi
    done <<< "$CONTAINERS"
  done
done

echo "==> Done. Found: ${found}, Patched: ${patched}"
