def add_prefix_before_send(request, **kwargs):
    parsed = urlsplit(request.url)
    new_path = MINIO_PREFIX + parsed.path
    request.url = urlunsplit((
        parsed.scheme,
        parsed.netloc,
        new_path,
        parsed.query,
        parsed.fragment,
    ))
    print(f"[before-send] {request.method} {request.url}")  # добавь эту строку
