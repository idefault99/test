  script:
    - echo $CI_JOB_TOKEN | docker login -u $CI_REGISTRY_USER $CI_REGISTRY --password-stdin
    - echo ${REGISTRY_PASSWORD} | docker login -u ${REGISTRY_LOGIN} $EXTERNAL_REGISTRY --password-stdin
    - docker pull ${CI_REGISTRY_IMAGE}:${TAG}.bin
