    - docker push ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH_TO_REP_IMAGE}:${TAG}.migrations
    - docker image rm ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH}:${TAG}.bin || exit 0
    - docker image rm ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH}:${TAG}.migrations || exit 0
    - docker image rm ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH_TO_REP_IMAGE}:${TAG}.bin || exit 0
    - docker image rm ${EXTERNAL_REGISTRY}/${EXTERNAL_REGISTRY_PATH_TO_REP_IMAGE}:${TAG}.migrations || exit 0
    - docker image rm ${CI_REGISTRY_IMAGE}:${TAG}.bin || exit 0
    - docker image rm ${CI_REGISTRY_IMAGE}:${TAG}.migrations || exit 0

---
services:
  backend:
    image: registry.test.model.svo.aero/dpm/airport_digital_ecosystem/aodb/mail-service:${TAG}
    working_dir: /code/app
    command: bash -c "uvicorn main:app --host 0.0.0.0 --port ${APP_PORT}"
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
      migrations:
        condition: service_completed_successfully
    env_file:
      - .env
    healthcheck:
      test: wget --no-verbose -O /dev/null --tries=1 http://localhost:8000${APP_API_PREFIX}/healthcheck || exit 1
      interval: 10s
      timeout: 5s
      retries: 5

  migrations:
    image: registry.test.model.svo.aero/dpm/airport_digital_ecosystem/aodb/mail-service:${TAG}.migrations
    working_dir: /code
    command: bash -c "alembic upgrade head"
    volumes:
      - ./.env:/code/.env
      - ./alembic.ini:/code/alembic.ini
      - ./migrations/:/code/migrations/
    depends_on:
      db:
        condition: service_healthy
    env_file:
      - .env

  test:
    image: registry.test.model.svo.aero/dpm/airport_digital_ecosystem/aodb/mail-service:${TAG}
    working_dir: /code/app
    command: bash -c "pytest --junitxml=report.xml -v --cov --cov-report term --cov-report xml:coverage.xml"
    volumes:
      - ./.env:/code/.env
      - ./report.xml:/code/app/report.xml
      - ./coverage.xml:/code/app/coverage.xml
    depends_on:
      backend:
        condition: service_healthy
    env_file:
      - .env
    links:
      - backend

  ruff:
    image: registry.test.model.svo.aero/dpm/airport_digital_ecosystem/aodb/mail-service:${TAG}
    working_dir: /code
    command: bash -c "ruff check . --output-format gitlab > code_quality.json"
    volumes:
      - ./code_quality.json:/code/code_quality.json
      - ./ruff.toml:/code/ruff.toml

  db:
    image: registry.test.model.svo.aero/dpm/iac/infra:postgres-16-alpine
    environment:
      - POSTGRES_USER=${DB_USER}
      - POSTGRES_PASSWORD=${DB_PASSWORD}
      - POSTGRES_DB=${DB_NAME}
    healthcheck:
      test: [ "CMD", "pg_isready", "-q", "-d", "${DB_NAME}", "-U", "${DB_USER}" ]
      interval: 2s
      timeout: 2s
      retries: 20

  redis:
    image: registry.test.model.svo.aero/dpm/iac/infra:redis-7.0.11
    healthcheck:
      test: [ "CMD", "redis-cli", "--raw", "incr", "ping" ]
      interval: 5s
      timeout: 5s
      retries: 20
