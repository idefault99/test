#!/bin/bash
# =============================================================
# Helm Release — Export & Redeploy
# Совместим с MicroK8s (microk8s.helm3 / helm)
# =============================================================
set -euo pipefail

# --- Определяем команды для microk8s ---
if command -v microk8s.helm3 &>/dev/null; then
  HELM="microk8s.helm3"
  KUBECTL="microk8s.kubectl"
elif command -v helm &>/dev/null; then
  HELM="helm"
  KUBECTL="kubectl"
else
  echo "ERROR: helm не найден"
  exit 1
fi

echo "Используем: $HELM / $KUBECTL"

# --- Параметры ---
NAMESPACE="${1:-}"
RELEASE="${2:-}"
BACKUP_DIR="./helm-backup-$(date +%Y%m%d-%H%M%S)"
mkdir -p "$BACKUP_DIR"

# --- Найти namespace если не передан ---
if [[ -z "$NAMESPACE" ]]; then
  echo ""
  echo "Доступные неймспейсы с helm релизами:"
  $HELM list -A --short 2>/dev/null || $HELM list -A
  echo ""
  read -rp "Введи namespace: " NAMESPACE
fi

# --- Найти релиз если не передан ---
if [[ -z "$RELEASE" ]]; then
  RELEASES=$($HELM list -n "$NAMESPACE" -q)
  COUNT=$(echo "$RELEASES" | grep -c . || true)

  if [[ "$COUNT" -eq 0 ]]; then
    echo "ERROR: релизов в namespace '$NAMESPACE' не найдено"
    exit 1
  elif [[ "$COUNT" -eq 1 ]]; then
    RELEASE="$RELEASES"
    echo "Найден единственный релиз: $RELEASE"
  else
    echo "Релизы в namespace '$NAMESPACE':"
    echo "$RELEASES"
    read -rp "Введи имя релиза: " RELEASE
  fi
fi

echo ""
echo "=== Экспорт релиза: $RELEASE / namespace: $NAMESPACE ==="

# --- Собираем всю информацию ---
echo ">>> Metadata"
$HELM get metadata "$RELEASE" -n "$NAMESPACE" | tee "$BACKUP_DIR/metadata.txt"

CHART_NAME=$(grep "^CHART:" "$BACKUP_DIR/metadata.txt" | awk '{print $2}' | sed 's/-[0-9].*//')
CHART_VERSION=$(grep "^CHART:" "$BACKUP_DIR/metadata.txt" | awk '{print $2}' | grep -oP '[0-9]+\.[0-9]+\.[0-9]+.*')

echo ""
echo ">>> Values"
$HELM get values "$RELEASE" -n "$NAMESPACE" | tee "$BACKUP_DIR/values.yaml"

echo ""
echo ">>> Manifest"
$HELM get manifest "$RELEASE" -n "$NAMESPACE" > "$BACKUP_DIR/manifest.yaml"
echo "Сохранён: $BACKUP_DIR/manifest.yaml"

echo ""
echo ">>> История"
$HELM history "$RELEASE" -n "$NAMESPACE" | tee "$BACKUP_DIR/history.txt"

CURRENT_REVISION=$(grep -m1 "deployed" "$BACKUP_DIR/history.txt" | awk '{print $1}')

echo ""
echo "=== Итого ==="
echo "Chart:    $CHART_NAME"
echo "Version:  $CHART_VERSION"
echo "Revision: $CURRENT_REVISION"
echo "Backup:   $BACKUP_DIR/"

# --- Репозиторий ---
echo ""
echo ">>> Доступные helm репозитории:"
$HELM repo list 2>/dev/null || echo "Репозитории не добавлены"

echo ""
echo "=========================================="
echo "Что делаем?"
echo "  1) helm upgrade --reuse-values (быстро, те же values)"
echo "  2) helm upgrade -f values.yaml  (из сохранённого файла)"
echo "  3) helm rollback               (откат на предыдущую ревизию)"
echo "  4) kubectl apply -f manifest   (без helm, аварийный вариант)"
echo "  5) Выйти"
echo "=========================================="
read -rp "Выбор [1-5]: " ACTION

case "$ACTION" in
  1)
    echo ">>> Upgrade --reuse-values"
    $HELM upgrade "$RELEASE" "$CHART_NAME" \
      -n "$NAMESPACE" \
      --reuse-values \
      --version "$CHART_VERSION"
    ;;
  2)
    echo ">>> Upgrade -f values.yaml"
    read -rp "Укажи путь к чарту или repo/chart [${CHART_NAME}]: " CHART_INPUT
    CHART_INPUT="${CHART_INPUT:-$CHART_NAME}"
    $HELM upgrade "$RELEASE" "$CHART_INPUT" \
      -n "$NAMESPACE" \
      -f "$BACKUP_DIR/values.yaml" \
      --version "$CHART_VERSION"
    ;;
  3)
    PREV_REVISION=$(( CURRENT_REVISION - 1 ))
    echo ">>> Rollback на ревизию $PREV_REVISION"
    read -rp "Ревизия для отката [$PREV_REVISION]: " REV_INPUT
    REV_INPUT="${REV_INPUT:-$PREV_REVISION}"
    $HELM rollback "$RELEASE" "$REV_INPUT" -n "$NAMESPACE"
    ;;
  4)
    echo ">>> kubectl apply -f manifest.yaml"
    $KUBECTL apply -f "$BACKUP_DIR/manifest.yaml" -n "$NAMESPACE"
    ;;
  5)
    echo "Выход. Бэкап сохранён в $BACKUP_DIR/"
    exit 0
    ;;
  *)
    echo "Неверный выбор"
    exit 1
    ;;
esac

echo ""
echo "=== Проверка после деплоя ==="
$HELM status "$RELEASE" -n "$NAMESPACE"
$KUBECTL get pods -n "$NAMESPACE"


---
chmod +x helm-redeploy.sh

# Интерактивно (спросит namespace и релиз)
./helm-redeploy.sh

# Или сразу с параметрами
./helm-redeploy.sh my-namespace my-release
