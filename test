# 1. Что сейчас в /data у redis
kubectl exec -n test-gis-svo redis-deployment-0 -- ls -la /data/

# 2. Владелец файлов
kubectl exec -n test-gis-svo redis-deployment-0 -- stat /data/

# 3. Может ли Redis писать в /data
kubectl exec -n test-gis-svo redis-deployment-0 -- sh -c \
  'touch /data/test_write && echo "OK" && rm /data/test_write || echo "CANNOT WRITE"'

# 4. Что говорит Redis про persistence
kubectl exec -n test-gis-svo redis-deployment-0 -- redis-cli info persistence \
  | grep -E "aof_enabled|rdb_last_bgsave|aof_last_write"
