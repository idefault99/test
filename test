# 1. Скачать CA cert из ConfigMap и проверить curl с ним
microk8s kubectl get configmap vault-ca -n external-secrets \
  -o jsonpath='{.data.ca\.crt}' > /tmp/vault-ca.crt

curl -v --cacert /tmp/vault-ca.crt https://vault.test.ru/v1/sys/health

# 2. Проверить что cert не пустой
cat /tmp/vault-ca.crt

# 3. Проверить что CA совпадает с тем что отдаёт Vault
echo | openssl s_client -connect vault.test.ru:443 2>/dev/null \
  | openssl x509 -noout -issuer -subject
