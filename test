#!/bin/bash
# scale-to-zero.sh — Scale всех workload'ов в ноль и отключить CronJob'ы в неймспейсе

set -euo pipefail

NAMESPACE="${1:?Укажи неймспейс: $0 <namespace>}"
DRY_RUN="${2:-false}"  # передай "true" для dry-run

KUBECTL_ARGS=""
[[ "$DRY_RUN" == "true" ]] && KUBECTL_ARGS="--dry-run=client"

echo "=== Namespace: $NAMESPACE | dry-run: $DRY_RUN ==="

# --- Deployments ---
echo ""
echo "[1/4] Scaling Deployments to 0..."
kubectl get deployments -n "$NAMESPACE" -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n' | while read -r name; do
  [[ -z "$name" ]] && continue
  echo "  → deployment/$name"
  kubectl scale deployment "$name" -n "$NAMESPACE" --replicas=0 $KUBECTL_ARGS
done

# --- StatefulSets ---
echo ""
echo "[2/4] Scaling StatefulSets to 0..."
kubectl get statefulsets -n "$NAMESPACE" -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n' | while read -r name; do
  [[ -z "$name" ]] && continue
  echo "  → statefulset/$name"
  kubectl scale statefulset "$name" -n "$NAMESPACE" --replicas=0 $KUBECTL_ARGS
done

# --- DaemonSets (через nodeSelector impossible → patch) ---
echo ""
echo "[3/4] Suspending DaemonSets (nodeSelector: non-existing-node)..."
kubectl get daemonsets -n "$NAMESPACE" -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n' | while read -r name; do
  [[ -z "$name" ]] && continue
  echo "  → daemonset/$name"
  kubectl patch daemonset "$name" -n "$NAMESPACE" $KUBECTL_ARGS \
    -p '{"spec":{"template":{"spec":{"nodeSelector":{"non-existing-node":"true"}}}}}'
done

# --- CronJobs (suspend: true) ---
echo ""
echo "[4/4] Suspending CronJobs..."
kubectl get cronjobs -n "$NAMESPACE" -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n' | while read -r name; do
  [[ -z "$name" ]] && continue
  echo "  → cronjob/$name"
  kubectl patch cronjob "$name" -n "$NAMESPACE" $KUBECTL_ARGS \
    -p '{"spec":{"suspend":true}}'
done

echo ""
echo "=== Done ==="
echo ""
echo "Статус:"
kubectl get deploy,sts,ds,cronjob -n "$NAMESPACE" \
  -o custom-columns=\
'KIND:.kind,NAME:.metadata.name,REPLICAS:.spec.replicas,SUSPENDED:.spec.suspend'
