---
############### S3Minio Endpoints ###############
{{ if eq .Values.enableService.s3minio true }}
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ .Values.ingressDomain }}-ingress-s3minio
  namespace: {{ .Release.Namespace }}
  annotations:
    nginx.ingress.kubernetes.io/proxy-body-size: {{ .Values.ingressSettings.maxBodySize }}
    nginx.ingress.kubernetes.io/proxy-buffer-size: "128k"
    nginx.ingress.kubernetes.io/proxy-buffers: "4 256k"
    nginx.ingress.kubernetes.io/proxy-busy-buffers-size: "256k"
    nginx.ingress.kubernetes.io/rewrite-target: /$2
    nginx.ingress.kubernetes.io/use-regex: 'true'
    nginx.ingress.kubernetes.io/proxy-request-buffering: "off"
spec:
  ingressClassName: {{ .Values.ingressClassName }}
  {{ if eq .Values.TLS.enable true }}
  tls:
    - hosts:
        - {{ .Values.ingressDomain }}
      secretName: {{ tpl .Values.TLS.secret . }}
  {{ end }}
  rules:
  - host: {{ .Values.ingressDomain }}
    http:
      paths:
      - path: /api/s3minio(/|$)(.*)
        pathType: Prefix
        backend:
          service:
            name: {{ .Values.labels.s3minio }}-api-service
            port:
              number: {{ .Values.ports.internal.s3minioAPI }}
      - path: /s3minio(/|$)(.*)
        pathType: ImplementationSpecific
        backend:
          service:
            name: {{ .Values.labels.s3minio }}-console-service
            port:
              number: {{ .Values.ports.internal.s3minioConsole }}
{{ end }}

