## Файл: `minio_client/upload.py`

> Добавить рядом с `client.py`. Скрипт читает переменные окружения,
> берёт файлы из SOURCE_PATH и загружает их в MinIO.

```python
import os
import sys
import glob

from minio_client import MinioClient


def main():
    # Переменные окружения — задаются в джобе GitLab CI
    S3_HOST       = os.environ.get("S3_HOST", "")
    S3_PREFIX     = os.environ.get("S3_PREFIX", "")
    S3_ACCESS_KEY = os.environ.get("S3_ACCESS_KEY", "")
    S3_SECRET_KEY = os.environ.get("S3_SECRET_KEY", "")
    S3_BUCKET     = os.environ.get("S3_BUCKET", "")
    FOLDER_NAME   = os.environ.get("FOLDER_NAME", "backup").strip("/")
    SOURCE_PATH   = os.environ.get("SOURCE_PATH", "./dump")

    # Валидация обязательных переменных
    errors = []
    if not S3_HOST:       errors.append("S3_HOST")
    if not S3_ACCESS_KEY: errors.append("S3_ACCESS_KEY")
    if not S3_SECRET_KEY: errors.append("S3_SECRET_KEY")
    if not S3_BUCKET:     errors.append("S3_BUCKET")

    if errors:
        print(f"[ERROR] Не заданы переменные окружения: {', '.join(errors)}")
        sys.exit(1)

    if not os.path.isdir(SOURCE_PATH):
        print(f"[ERROR] Директория не найдена: {SOURCE_PATH}")
        sys.exit(1)

    # Собираем список файлов из SOURCE_PATH
    files = glob.glob(os.path.join(SOURCE_PATH, "**", "*"), recursive=True)
    files = [f for f in files if os.path.isfile(f)]

    if not files:
        print(f"[ERROR] В директории {SOURCE_PATH} нет файлов")
        sys.exit(1)

    print(f"Найдено файлов: {len(files)}")
    print(f"Подключаюсь к {S3_HOST} → бакет: {S3_BUCKET}/{FOLDER_NAME}")

    # Инициализация клиента из нашей библиотеки
    client = MinioClient(
        host=S3_HOST,
        access_key=S3_ACCESS_KEY,
        secret_key=S3_SECRET_KEY,
        prefix=S3_PREFIX,
    )
    s3 = client.get_s3()

    # Загрузка файлов
    success = 0
    failed = 0

    for local_path in files:
        filename = os.path.basename(local_path)
        object_key = f"{FOLDER_NAME}/{filename}"

        try:
            size = os.path.getsize(local_path)
            print(f"  Загружаю: {filename} ({size} bytes) → {S3_BUCKET}/{object_key}")
            s3.upload_file(local_path, S3_BUCKET, object_key)
            print(f"  ✅ Готово: {object_key}")
            success += 1
        except Exception as e:
            print(f"  ❌ Ошибка: {filename} — {e}")
            failed += 1

    print(f"\nЗагружено: {success} | Ошибок: {failed}")

    if failed > 0:
        sys.exit(1)


if __name__ == "__main__":
    main()
```

