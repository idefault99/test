## Шаг 8. Дополнительные метрики pg_stat_* (включить по необходимости)

Ниже — готовые блоки для добавления в `queries.yaml`. Включай по мере необходимости.

### pg_stat_ssl — SSL соединения

```yaml
pg_stat_ssl:
  query: |
    SELECT
      pg_database.datname,
      count(*) FILTER (WHERE ssl = true) AS ssl_connections,
      count(*) FILTER (WHERE ssl = false) AS plain_connections
    FROM pg_stat_activity
    JOIN pg_stat_ssl ON pg_stat_ssl.pid = pg_stat_activity.pid
    JOIN pg_database ON pg_database.datname = pg_stat_activity.datname
    WHERE pg_stat_activity.datname IS NOT NULL
    GROUP BY pg_database.datname
  metrics:
    - datname:
        usage: LABEL
        description: "Имя БД"
    - ssl_connections:
        usage: GAUGE
        description: "SSL соединений"
    - plain_connections:
        usage: GAUGE
        description: "Обычных соединений"
```

### pg_stat_wal — статистика WAL (PostgreSQL 14+)

```yaml
pg_stat_wal:
  query: |
    SELECT
      wal_records,
      wal_fpi,
      wal_bytes,
      wal_buffers_full,
      wal_write,
      wal_sync,
      wal_write_time,
      wal_sync_time
    FROM pg_stat_wal
  metrics:
    - wal_records:
        usage: COUNTER
        description: "Всего WAL записей"
    - wal_bytes:
        usage: COUNTER
        description: "Байт записано в WAL"
    - wal_buffers_full:
        usage: COUNTER
        description: "Раз WAL буферы были полны"
    - wal_write_time:
        usage: COUNTER
        description: "Время записи WAL (мс)"
    - wal_sync_time:
        usage: COUNTER
        description: "Время sync WAL (мс)"
```

