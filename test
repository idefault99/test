# =============================================================================
# .deploy — Helm-релиз в изолированный кластер через jump host.
#
# Топология трафика:
#   • kube API   : runner --(ssh -L)--> jump --> KUBE_API_HOST:6443
#   • pull образов: node containerd (HTTPS_PROXY=jump:3128)
#                   --> jump:3128 --(ssh -R)--> runner tinyproxy --> registry
#
# !!! INFRA (вне CI, но обязательно) !!!
#   На jump host в /etc/ssh/sshd_config должно быть:
#       GatewayPorts clientspecified
#   затем `systemctl reload sshd`.
#   Иначе sshd молча биндит reverse-порт на 127.0.0.1, ноды бьются в
#   недоступный jump:3128 и получают `proxyconnect: connection refused`,
#   а ExitOnForwardFailure=yes это НЕ ловит (форвард формально "принят").
#   Пайплайн ниже это детектит и падает с понятным сообщением, а не
#   деплоит в никуда.
#
# Требуемые CI/CD-переменные:
#   JUMP_HOST, JUMP_USER, JUMP_SSH_KEY (путь к файлу ИЛИ содержимое ключа),
#   KUBE_API_HOST, KUBECONFIG, NAMESPACE, RELEASE_NAME, VALUES, CI_REGISTRY
# =============================================================================

.deploy:
  stage: deploy
  tags: [docker]
  image:
    name: ${CI_REGISTRY}/dpm/iac/infra:helm
    pull_policy: [always, if-not-present]
    entrypoint: [""]
  variables:
    PROXY_PORT: "3128"
    KUBE_API_PORT: "6443"
    SSH_CTL: "/tmp/deploy-ssh.ctl"
    TP_CONF: "/etc/tinyproxy/tinyproxy.conf"

  before_script:
    # --- helpers (живут в этом же shell до конца script) --------------------
    - |
      set -euo pipefail
      log() { printf '\n\033[1;34m[deploy]\033[0m %s\n' "$*"; }
      die() { printf '\n\033[1;31m[deploy][FATAL]\033[0m %s\n' "$*" >&2; exit 1; }
      # Ждём реального открытия TCP-порта вместо `sleep N`.
      wait_tcp() {
        local host=$1 port=$2 name=$3 tries=${4:-30} i
        for i in $(seq 1 "$tries"); do
          if (exec 3<>"/dev/tcp/${host}/${port}") 2>/dev/null; then
            exec 3>&- 3<&-; log "${name}: ${host}:${port} доступен"; return 0
          fi
          sleep 1
        done
        return 1
      }

    # --- зависимости --------------------------------------------------------
    - |
      log "Проверка/установка зависимостей"
      if ! command -v tinyproxy >/dev/null 2>&1; then
        rm -f /etc/apt/sources.list.d/helm-stable-debian.list \
              /etc/apt/sources.list.d/helm.list 2>/dev/null || true
        apt-get update -qq
        apt-get install -y --no-install-recommends \
          tinyproxy openssh-client iproute2 curl procps
      fi

    # --- SSH-ключ -----------------------------------------------------------
    - |
      log "Подготовка SSH-ключа"
      mkdir -p ~/.ssh && chmod 700 ~/.ssh
      if [ -f "$JUMP_SSH_KEY" ]; then
        cat "$JUMP_SSH_KEY" > ~/.ssh/id_proxy
      else
        printf '%s\n' "$JUMP_SSH_KEY" > ~/.ssh/id_proxy
      fi
      chmod 600 ~/.ssh/id_proxy
      ssh-keygen -y -f ~/.ssh/id_proxy >/dev/null || die "SSH key invalid"
      ssh-keyscan -H "$JUMP_HOST" >> ~/.ssh/known_hosts 2>/dev/null || true

    # --- tinyproxy ----------------------------------------------------------
    - |
      log "Запуск tinyproxy на 127.0.0.1:${PROXY_PORT}"
      mkdir -p /etc/tinyproxy /var/log/tinyproxy /var/run/tinyproxy
      cat > "$TP_CONF" <<EOF
      User nobody
      Group nogroup
      Port ${PROXY_PORT}
      Listen 127.0.0.1
      Timeout 600
      DefaultErrorFile "/usr/share/tinyproxy/default.html"
      LogFile "/var/log/tinyproxy/tinyproxy.log"
      LogLevel Info
      MaxClients 100
      Allow 127.0.0.1
      ViaProxyName "tinyproxy"
      EOF
      tinyproxy -c "$TP_CONF"
      wait_tcp 127.0.0.1 "${PROXY_PORT}" tinyproxy 15 || {
        cat /var/log/tinyproxy/tinyproxy.log 2>/dev/null || true
        die "tinyproxy не слушает 127.0.0.1:${PROXY_PORT}"
      }

    # --- SSH-туннель (control master -> чистый teardown без pkill-грепа) -----
    - |
      log "Поднятие SSH-туннеля (reverse proxy + local kube API)"
      ssh -M -S "$SSH_CTL" -fN \
        -o ServerAliveInterval=30 -o ServerAliveCountMax=3 \
        -o ExitOnForwardFailure=yes \
        -o StrictHostKeyChecking=accept-new \
        -o ControlPersist=yes \
        -i ~/.ssh/id_proxy \
        -R 0.0.0.0:${PROXY_PORT}:127.0.0.1:${PROXY_PORT} \
        -L 127.0.0.1:${KUBE_API_PORT}:${KUBE_API_HOST}:${KUBE_API_PORT} \
        "${JUMP_USER}@${JUMP_HOST}"
      ssh -S "$SSH_CTL" -O check "${JUMP_USER}@${JUMP_HOST}" \
        || die "SSH control master не запустился"

    # --- проверка 1: local-forward до kube API ------------------------------
    - |
      log "Проверка local-forward до kube API"
      wait_tcp 127.0.0.1 "${KUBE_API_PORT}" kube-api 20 \
        || die "kube API недоступен через 127.0.0.1:${KUBE_API_PORT}"

    # --- проверка 2: reverse-forward реально забинжен на 0.0.0.0 ------------
    #     (ключевая проверка — ловит GatewayPorts no)
    - |
      log "Проверка reverse-forward на jump host (интерфейс bind)"
      binds=$(ssh -S "$SSH_CTL" "${JUMP_USER}@${JUMP_HOST}" \
        "ss -Htln 'sport = :${PROXY_PORT}' | awk '{print \$4}'" 2>/dev/null || true)
      [ -n "$binds" ] \
        || die "reverse-forward не забинжен на ${JUMP_HOST}:${PROXY_PORT} (туннель есть, listener нет)"
      if ! printf '%s\n' "$binds" | grep -Eq "(^|[^0-9.])(0\.0\.0\.0|\*|\[::\]):${PROXY_PORT}\$"; then
        die "reverse-forward слушает только loopback на jump host (${binds//$'\n'/ }). Нужен 'GatewayPorts clientspecified' в sshd_config на ${JUMP_HOST} + reload sshd."
      fi
      log "bind OK: ${binds//$'\n'/ }"

    # --- проверка 3: e2e proxy-цепочка jump -> runner -> registry -----------
    #     воспроизводит ровно то, что делает containerd на ноде (минус хоп нода->jump)
    - |
      log "E2E проверка proxy-цепочки jump -> runner tinyproxy -> registry"
      REG_HOST="${CI_REGISTRY%%/*}"
      if ssh -S "$SSH_CTL" "${JUMP_USER}@${JUMP_HOST}" "command -v curl >/dev/null 2>&1"; then
        code=$(ssh -S "$SSH_CTL" "${JUMP_USER}@${JUMP_HOST}" \
          "curl -sS -o /dev/null -w '%{http_code}' --max-time 15 \
           -x http://127.0.0.1:${PROXY_PORT} https://${REG_HOST}/v2/ 2>/dev/null" || echo 000)
        [ "$code" != "000" ] \
          || die "proxy-цепочка не работает: jump не достучался до ${REG_HOST} через туннель (tinyproxy/сеть runner), curl code=000"
        log "proxy-цепочка OK (registry /v2/ -> HTTP ${code})"
      else
        log "curl на jump host отсутствует — e2e-проверка пропущена (не критично)"
      fi

  script:
    - |
      set -euo pipefail
      export TAG="${CI_COMMIT_REF_SLUG}"
      # helm/kubectl ходят на 127.0.0.1:6443 напрямую — прокси им не нужен
      unset HTTP_PROXY HTTPS_PROXY http_proxy https_proxy ALL_PROXY all_proxy NO_PROXY no_proxy
      helm --kubeconfig "$KUBECONFIG" upgrade -i \
        --history-max 2 \
        -n "$NAMESPACE" "$RELEASE_NAME" ./Helm \
        -f "$VALUES" \
        --set "image.tag=${TAG}.bin" \
        --wait --timeout 5m

  after_script:
    # отдельный shell: CI-переменные доступны, функции из before_script — нет
    - ssh -S "/tmp/deploy-ssh.ctl" -O exit "${JUMP_USER}@${JUMP_HOST}" 2>/dev/null || true
    - pkill -x tinyproxy 2>/dev/null || true
    - rm -f ~/.ssh/id_proxy /tmp/deploy-ssh.ctl 2>/dev/null || true

  # Поведение «всегда manual» (как в исходнике). Верхний when игнорируется
  # при наличии rules — оставлен для читаемости, можно убрать.
  when: manual
  rules:
    - if: $CI_COMMIT_TAG
      when: manual
    - if: $CI_OPEN_MERGE_REQUESTS
      when: manual
    - if: $CI_COMMIT_REF_NAME =~ /^(main|master|develop|release\/.*)$/
      when: manual
    - if: $CI_COMMIT_REF_NAME !~ /^(main|master|develop|release\/.*)$/
      when: manual
