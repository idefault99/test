export NO_PROXY="localhost,127.0.0.1,k8s-api,172.16.175.20,172.16.175.19,172.16.175.21,172.16.175.23,172.16.175.25,172.16.175.27,172.16.175.29,172.16.175.0/24,10.96.0.0/12,10.244.0.0/16,.svc,.cluster.local"
export no_proxy="$NO_PROXY"

unset HTTP_PROXY
unset HTTPS_PROXY
unset http_proxy
unset https_proxy

echo "== proxy env =="
env | grep -i proxy || true

echo "== API direct by name =="
curl -k --max-time 5 https://k8s-api:6443/healthz

echo "== kubectl via super-admin =="
KUBECONFIG=/etc/kubernetes/super-admin.conf kubectl get --raw=/healthz
KUBECONFIG=/etc/kubernetes/super-admin.conf kubectl get nodes -o wide
---
kubeadm init phase upload-config all --config /root/kubeadm-config.yaml
kubeadm init phase upload-certs --upload-certs --config /root/kubeadm-config.yaml
kubeadm init phase mark-control-plane --config /root/kubeadm-config.yaml
kubeadm init phase bootstrap-token --config /root/kubeadm-config.yaml
kubeadm init phase kubelet-finalize all
kubeadm init phase addon all --config /root/kubeadm-config.yaml

mkdir -p /root/.kube
cp -f /etc/kubernetes/admin.conf /root/.kube/config
chmod 600 /root/.kube/config

KUBECONFIG=/etc/kubernetes/admin.conf kubectl get nodes -o wide
KUBECONFIG=/etc/kubernetes/admin.conf kubectl get pods -A -o wide
---
grep -q '^NO_PROXY=' /etc/environment && \
  sed -i 's#^NO_PROXY=.*#NO_PROXY=localhost,127.0.0.1,k8s-api,172.16.175.20,172.16.175.19,172.16.175.21,172.16.175.23,172.16.175.25,172.16.175.27,172.16.175.29,172.16.175.0/24,10.96.0.0/12,10.244.0.0/16,.svc,.cluster.local#' /etc/environment || \
  echo 'NO_PROXY=localhost,127.0.0.1,k8s-api,172.16.175.20,172.16.175.19,172.16.175.21,172.16.175.23,172.16.175.25,172.16.175.27,172.16.175.29,172.16.175.0/24,10.96.0.0/12,10.244.0.0/16,.svc,.cluster.local' >> /etc/environment

grep -q '^no_proxy=' /etc/environment && \
  sed -i 's#^no_proxy=.*#no_proxy=localhost,127.0.0.1,k8s-api,172.16.175.20,172.16.175.19,172.16.175.21,172.16.175.23,172.16.175.25,172.16.175.27,172.16.175.29,172.16.175.0/24,10.96.0.0/12,10.244.0.0/16,.svc,.cluster.local#' /etc/environment || \
  echo 'no_proxy=localhost,127.0.0.1,k8s-api,172.16.175.20,172.16.175.19,172.16.175.21,172.16.175.23,172.16.175.25,172.16.175.27,172.16.175.29,172.16.175.0/24,10.96.0.0/12,10.244.0.0/16,.svc,.cluster.local' >> /etc/environment
