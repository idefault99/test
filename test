POD8=$(kubectl -n gpu-operator get pod -l app=nvidia-device-plugin-daemonset \
  --field-selector spec.nodeName=coparking-8 -o jsonpath='{.items[0].metadata.name}')
echo "$POD8"
kubectl -n gpu-operator delete pod "$POD8"
kubectl -n gpu-operator rollout status ds/nvidia-device-plugin-daemonset --timeout=180s
---
kubectl get node coparking-8 -o jsonpath='{.status.capacity.nvidia\.com/gpu}{"\n"}'
---
POD8=$(kubectl -n gpu-operator get pod -l app=nvidia-device-plugin-daemonset \
  --field-selector spec.nodeName=coparking-8 -o jsonpath='{.items[0].metadata.name}')
kubectl -n gpu-operator exec "$POD8" -c nvidia-device-plugin -- \
  sh -c 'cat "$CONFIG_FILE" 2>/dev/null || cat /available-configs/* 2>/dev/null'
---
kubectl -n gpu-operator get cm time-slicing-config -o jsonpath='{.data}{"\n"}'   # посмотреть ключи и replicas
