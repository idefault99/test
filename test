# GENERAL OPTIONS
stages:
  - build
  - lint_and_test
  - deploy
  - publish_helm_releases
  - publish_image
  - publish_helm

workflow:
  auto_cancel:
    on_new_commit: interruptible
  rules:
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"
    - if: $CI_COMMIT_BRANCH && $CI_OPEN_MERGE_REQUESTS && $CI_PIPELINE_SOURCE != "web"
      when: never
    - if: $CI_COMMIT_BRANCH
    - if: $CI_COMMIT_TAG
    - if: $CI_PIPELINE_SOURCE == "web"

default:
  interruptible: true # TODO возможно стоит сделать не все джобы interruptible, а только некоторые
  before_script:
    - export TAG=$(eval $TAG_SCRIPT) # TAG variable definition

variables:
  TAG_SCRIPT: '(if [ "$${CI_COMMIT_TAG}" == "" ]; then echo "$${CI_COMMIT_REF_SLUG}"; else echo "$${CI_COMMIT_TAG}"; fi);'
  KUBECONFIG: $KUBE_CONF_2
  SONAR_HOST_URL: 'https://sonarqube.code-discovery.ru'

# STAGES

############### BUILD ###############
.buildkit_build:
  stage: build
  allow_failure: true
  tags:
    - docker 
  image:
    name: registry.test.model.svo.aero/dpm/iac/infra/docker:28.5.0-rc.1-cli-alpine3.22
  services: 
    - registry.test.model.svo.aero/dpm/iac/infra/docker:28.5.0-rc.1-dind-alpine3.22
  variables:
    TARGET: production
    DOCKER_TLS_CERTDIR: "/certs"
    DOCKER_HOST: "unix:///runner/services/docker/docker.sock"
  before_script:
    - mkdir -p $HOME/.docker/
    - echo "${CI_JOB_TOKEN}" | docker login registry.test.model.svo.aero --username gitlab-ci-token --password-stdin
    - export TAG=$(eval $TAG_SCRIPT)
    - docker context create my-builder
    - docker buildx create my-builder --driver docker-container --use --buildkitd-config ${BUILDKITD_CONFIG}
  after_script:
     - docker context rm my-builder

.buildkit_bin:
  extends: .buildkit_build
  variables:
    TARGET: production
    PACKAGE_GROUPS: main
  script:
    - |
      docker buildx build ./ -f ${CI_PROJECT_DIR}/Docker/Dockerfile \
      --tag ${CI_REGISTRY_IMAGE}:${TAG}.bin \
      --tag $CI_REGISTRY_IMAGE:latest \
      --cache-to type=registry,ref=$CI_REGISTRY_IMAGE/cache,mode=max \
      --cache-from type=registry,ref=$CI_REGISTRY_IMAGE/cache \
      --target ${TARGET}  \
      --build-arg POETRY_PACKAGE_GROUPS=${PACKAGE_GROUPS} \
      --build-arg PROJECT_REVISION=${TAG} \
      --build-arg GITLAB_USERNAME=gitlab-ci-token \
      --build-arg GITLAB_TOKEN=${CI_JOB_TOKEN} \
      --build-arg NEXUS_PYPI_URL=${NEXUS_PYPI_URL} \
      --build-arg NEXUS_USERNAME=${NEXUS_USERNAME} \
      --build-arg NEXUS_PASSWORD=${NEXUS_PASSWORD} \
      --build-arg http_proxy=$http_proxy \
      --build-arg https_proxy=$https_proxy \
      --build-arg no_proxy=$no_proxy \
      --push=true
  rules:
    - if: $CI_COMMIT_TAG
      when: on_success
    - if: $CI_OPEN_MERGE_REQUESTS
      when: on_success
    - when: manual

.buildkit_migrations:
  extends: .buildkit_build
  script:
    - |
      docker buildx build ./ -f ${CI_PROJECT_DIR}/Docker/migrations.Dockerfile \
      --tag ${CI_REGISTRY_IMAGE}:${TAG}.migrations \
      --tag $CI_REGISTRY_IMAGE:latest \
      --cache-to type=registry,ref=$CI_REGISTRY_IMAGE/cache,mode=max \
      --cache-from type=registry,ref=$CI_REGISTRY_IMAGE/cache \
      --build-arg NEXUS_PYPI_URL=${NEXUS_PYPI_URL} \
      --build-arg NEXUS_USERNAME=${NEXUS_USERNAME} \
      --build-arg NEXUS_PASSWORD=${NEXUS_PASSWORD} \
      --build-arg http_proxy=$http_proxy \
      --build-arg https_proxy=$https_proxy \
      --build-arg no_proxy=$no_proxy \
      --push=true

.buildkit_source:
  extends: .buildkit_build
  variables:
    TARGET: source
    PACKAGE_GROUPS: main,dev,test
  script:
    - |
      docker buildx build ./ -f ${CI_PROJECT_DIR}/Docker/Dockerfile \
      --tag ${CI_REGISTRY_IMAGE}:${TAG} \
      --tag $CI_REGISTRY_IMAGE:latest \
      --cache-to type=registry,ref=$CI_REGISTRY_IMAGE/cache,mode=max \
      --cache-from type=registry,ref=$CI_REGISTRY_IMAGE/cache \
      --target ${TARGET}  \
      --build-arg POETRY_PACKAGE_GROUPS=${PACKAGE_GROUPS} \
      --build-arg PROJECT_REVISION=${TAG} \
      --build-arg GITLAB_USERNAME=gitlab-ci-token \
      --build-arg GITLAB_TOKEN=${CI_JOB_TOKEN} \
      --build-arg NEXUS_PYPI_URL=${NEXUS_PYPI_URL} \
      --build-arg NEXUS_USERNAME=${NEXUS_USERNAME} \
      --build-arg NEXUS_PASSWORD=${NEXUS_PASSWORD} \
      --build-arg http_proxy=$http_proxy \
      --build-arg https_proxy=$https_proxy \
      --build-arg no_proxy=$no_proxy \
      --push=true
  rules:
    - if: $CI_OPEN_MERGE_REQUESTS
      when: on_success
    - if: $CI_COMMIT_TAG == null && $CI_COMMIT_REF_NAME !~ /^(main|master|develop|release\/.*)$/
      when: manual

# Appsec tests
sast_bandit:
  stage: lint_and_test
  allow_failure: true
  tags:
    - docker 
  image: registry.test.model.svo.aero/dpm/is/sast/bandit:1.8.6
  script:
    - bandit -r . --severity-level high -f txt -o report.txt && true
    - cat report.txt
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
      when: on_success
    - when: never
  artifacts:
    when: always
    paths: 
      - report.txt

############### LINT & TEST ###############
.docker_compose_test:
  stage: lint_and_test
  tags:
    - shell
  needs:
    - job: build_source
  before_script:
    - echo $CI_JOB_TOKEN | docker login -u $CI_REGISTRY_USER $CI_REGISTRY --password-stdin
    - export TAG=$(eval $TAG_SCRIPT)
    - cat .env.example > .env
    - docker compose -f docker-compose.test.yml pull
  after_script:
    - >
      if [ $CI_JOB_STATUS == 'failed' ]; then
        docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} logs
      fi
    - export TAG=$(eval $TAG_SCRIPT)
    - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} down
    - docker volume prune -f
  rules:
    - if: $CI_OPEN_MERGE_REQUESTS
      when: on_success
    - if: $CI_COMMIT_TAG == null && $CI_COMMIT_REF_NAME !~ /^(main|master|develop|release\/.*)$/
      when: on_success

.linter:
  extends: .docker_compose_test
  allow_failure: true
  script:
    - touch ./code_quality.json
    - export TAG=$(eval $TAG_SCRIPT)
    - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} up --renew-anon-volumes --exit-code-from ruff ruff
  artifacts:
    when: always
    reports:
      codequality: ./code_quality.json

.test:
  extends: .docker_compose_test
  variables:
    TEST_SERVICES: ""
  script:
    - touch ./report.xml
    - touch ./coverage.xml
    - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} up -d --renew-anon-volumes --force-recreate --remove-orphans ${TEST_SERVICES}
    - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} up --remove-orphans --renew-anon-volumes --force-recreate --exit-code-from test test
    - sed -i 's|" filename="|" filename="src/|g' ./coverage.xml || true
  coverage: '/(?i)total.*? (100(?:\.0+)?\%|[1-9]?\d(?:\.\d+)?\%)$/'
  artifacts:
    when: always
    reports:
      junit: ./report.xml
      coverage_report:
        coverage_format: cobertura
        path: ./coverage.xml

# SonarQube
sonarqube-check:
  tags:
    - docker
  stage: lint_and_test
  image:
    name: registry.test.model.svo.aero/dpm/iac/infra/sonarqube:sonar-scanner_self-truststore
    entrypoint: [""]
  variables:
    SONAR_USER_HOME: "${CI_PROJECT_DIR}/.sonar"
    GIT_DEPTH: "0"
  cache:
    key: "${CI_JOB_NAME}"
    paths:
      - .sonar/cache
  script:
    - sonar-scanner
      -Dsonar.host.url=$SONAR_HOST_URL
      -Dsonar.token=$SONAR_TOKEN
      -Dsonar.projectKey="$CI_PROJECT_NAME-$CI_PROJECT_ID"
      -Dsonar.projectName="$CI_PROJECT_TITLE"
      -Dsonar.scanner.skipSystemTruststore=true
      -Dsonar.scanner.truststorePath="/opt/sonar-scanner/.sonar/ssl/gitlab.test.model.svo.aero__truststore.p12"
      -Dsonar.scanner.truststorePassword="$SONAR_SCANNER_TRUSTSTORE_PASSWORD"
  rules:
    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH
      when: always
      allow_failure: true

############### DEPLOY ###############
.deploy:
  stage: deploy
  tags:
    - docker
  image:
    name: registry.test.model.svo.aero/dpm/iac/infra:helm
    pull_policy: [always, if-not-present]
    entrypoint: [""]
  variables:
    REGISTRY: "${CI_REGISTRY_IMAGE}"
    IMAGE_POSTFIX: ".bin" # для фронта будем указывать "", для прочего просто менять эту переменную
  before_script:
    - export TAG=$(eval $TAG_SCRIPT)
    - if [ -z "$VALUES" ]; then echo "Переменная VALUES не задана для ${CI_ENVIRONMENT_NAME}"; exit 1; fi
    - if [ -z "$NAMESPACE" ]; then echo "Переменная NAMESPACE не задана для ${CI_ENVIRONMENT_NAME}"; exit 1; fi
    - git -c http.sslVerify=false clone https://gitlab-ci-token:${CI_JOB_TOKEN}@gitlab.test.model.svo.aero/dpm/iac/dev-infra.git
    - cp -r ./dev-infra/templates/utils ./Helm/templates
  script:
    - |
      helm upgrade -i -n $NAMESPACE ${RELEASE_NAME} ./Helm -f $VALUES \
      --set "image=${REGISTRY}:${TAG}${IMAGE_POSTFIX}"
  when: manual
  rules:
    - if: $CI_COMMIT_TAG
      when: manual
    - if: $CI_OPEN_MERGE_REQUESTS
      when: manual
      # needs: ["linter", "test"]
    - if: $CI_COMMIT_REF_NAME =~ /^(main|master|develop|release\/.*)$/
      when: manual
    - if: $CI_COMMIT_REF_NAME !~ /^(main|master|develop|release\/.*)$/
      when: manual

