# compare_tags.py v2

Сравнение тэгов из `values.yaml` с тэгами в Kubernetes. Вывод двумя таблицами: расхождения и совпадения.

## Установка

```bash
cat << 'EOF' > compare_tags.py
#!/usr/bin/env python3
"""
Сравнение тэгов из values.yaml (вывод scan_values.py) с тэгами в Kubernetes.

Использование:
    python3 compare_tags.py --input output.txt --stand test-dfgr --kubectl-cmd k
    python3 compare_tags.py --input output.txt --stand test-dfgr --quiet
"""

import argparse
import subprocess
import re
import sys
import os
import json as json_mod


# Цвета для терминала
class Colors:
    RED = "\033[91m"
    GREEN = "\033[92m"
    YELLOW = "\033[93m"
    CYAN = "\033[96m"
    BOLD = "\033[1m"
    DIM = "\033[2m"
    RESET = "\033[0m"


NO_COLORS = Colors()
for attr in ["RED", "GREEN", "YELLOW", "CYAN", "BOLD", "DIM", "RESET"]:
    setattr(NO_COLORS, attr, "")


def run_cmd(cmd):
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=120)
    return result.stdout, result.stderr, result.returncode


def get_namespaces(kubectl, stand):
    stdout, stderr, rc = run_cmd(f"{kubectl} get ns -o name")
    if rc != 0:
        return [], f"kubectl get ns failed: {stderr.strip()}"
    namespaces = []
    for line in stdout.strip().splitlines():
        ns = line.strip().removeprefix("namespace/")
        if ns.startswith(f"{stand}-") or ns == stand:
            namespaces.append(ns)
    return namespaces, ""


def get_images_from_ns(kubectl, ns):
    """Получает образы из deployments и jobs через jsonpath.
    Возвращает список (resource_kind, resource_name, image_path, tag)."""
    images = []
    seen = set()

    for kind, short in [("deployments", "deploy"), ("jobs", "job")]:
        # jsonpath: для каждого ресурса выводим name и все images через разделитель
        tpl = (
            '{range .items[*]}'
            '{.metadata.name}{"\\t"}'
            '{range .spec.template.spec.containers[*]}'
            '{.image}{"\\n"}'
            '{end}'
            '{range .spec.template.spec.initContainers[*]}'
            '{.image}{"\\n"}'
            '{end}'
            '{"---\\n"}'
            '{end}'
        )
        stdout, stderr, rc = run_cmd(
            f"{kubectl} -n {ns} get {kind} -o jsonpath='{tpl}' 2>/dev/null"
        )
        if rc != 0 or not stdout.strip():
            continue

        current_name = ""
        for line in stdout.strip().split("\n"):
            line = line.strip()
            if line == "---":
                current_name = ""
                continue
            if "\t" in line:
                parts = line.split("\t", 1)
                current_name = parts[0]
                img_str = parts[1].strip() if len(parts) > 1 else ""
            else:
                img_str = line

            if not img_str or not current_name:
                continue

            match = re.search(r'[^/\s]+(/\S+):(\S+)', img_str)
            if match:
                key = (short, current_name, match.group(1), match.group(2))
                if key not in seen:
                    seen.add(key)
                    images.append(key)

    return images


def parse_input_file(filepath):
    entries = []
    current_display = ""

    with open(filepath, "r", encoding="utf-8") as f:
        for line in f:
            line = line.rstrip("\n")
            if not line.strip():
                continue

            entry = {
                "raw": line,
                "display_path": "",
                "sub_name": "",
                "image_path": "",
                "tag": "",
                "tpl_tag": "",
                "is_error": False,
            }

            segments = line.split("  —  ")

            first = segments[0]
            if first.strip():
                sub_match = re.search(r'\((\S+)\)\s*$', first.strip())
                if sub_match:
                    entry["sub_name"] = sub_match.group(1)
                    path_part = first[:first.rfind("(")].strip()
                    if path_part:
                        current_display = path_part
                else:
                    current_display = first.strip()
            else:
                sub_match = re.search(r'\((\S+)\)', first)
                if sub_match:
                    entry["sub_name"] = sub_match.group(1)

            entry["display_path"] = current_display

            if "не найден" in line:
                entry["is_error"] = True

            if len(segments) >= 2:
                entry["image_path"] = segments[1].strip()

            if len(segments) >= 3:
                third = segments[2].strip()
                tpl_match = re.search(r'\[(.*?)\]', third)
                if tpl_match:
                    entry["tpl_tag"] = f"[{tpl_match.group(1)}]"
                    entry["tag"] = third[:third.rfind("[")].strip()
                else:
                    entry["tag"] = third

            entries.append(entry)

    return entries


def extract_module(display_path):
    parts = display_path.split("/")
    if parts[0] == "main":
        return ""
    return parts[0]


def format_table(rows, c):
    """Форматирует таблицу с выравниванием по колонкам.
    rows: список кортежей (display_path, sub_name, image_path, repo_tag, tpl_tag, k8s_info)"""
    if not rows:
        return []

    col1 = max(len(r[0]) for r in rows)
    col2 = max((len(f"({r[1]})") for r in rows if r[1]), default=0)
    col3 = max(len(r[2]) for r in rows)
    col4 = max(len(r[3]) for r in rows)
    col5 = max((len(r[4]) for r in rows if r[4]), default=0)
    col6 = max((len(r[5]) for r in rows if r[5]), default=0)

    lines = []
    prev_display = None
    for display_path, sub_name, image_path, repo_tag, tpl_tag, k8s_info in rows:
        if display_path == prev_display:
            col1_str = " " * col1
        else:
            col1_str = f"{display_path:<{col1}}"
        prev_display = display_path

        if sub_name:
            col2_str = f"({sub_name})"
            col2_str = f"{col2_str:<{col2}}"
        else:
            col2_str = " " * col2 if col2 else ""

        spacer2 = "  " if col2 else ""

        line = f"{col1_str}{spacer2}{col2_str}  —  {image_path:<{col3}}  —  {repo_tag:<{col4}}"

        if tpl_tag:
            line = f"{line}  {tpl_tag:<{col5}}"
        elif col5:
            line = f"{line}  {' ' * col5}"

        if k8s_info:
            line = f"{line}  —  {k8s_info}"

        lines.append(line)

    return lines


def main():
    parser = argparse.ArgumentParser(description="Сравнение тэгов values.yaml с Kubernetes")
    parser.add_argument("--input", required=True, help="Файл с выводом scan_values.py")
    parser.add_argument("--stand", required=True, help="Название стенда (префикс неймспейса)")
    parser.add_argument("--kubectl-cmd", default="k", help="Команда kubectl (по умолчанию: k)")
    parser.add_argument("--output", default="compare_result.txt", help="Файл для вывода")
    parser.add_argument("--quiet", action="store_true", help="Выводить только расхождения")
    args = parser.parse_args()

    use_color = sys.stdout.isatty()
    c = Colors() if use_color else NO_COLORS
    errors = []

    # Парсим входной файл
    try:
        entries = parse_input_file(args.input)
    except Exception as e:
        print(f"Ошибка чтения входного файла: {e}", file=sys.stderr)
        sys.exit(1)

    if not entries:
        print("Входной файл пуст.")
        sys.exit(0)

    # Неймспейсы
    namespaces, ns_err = get_namespaces(args.kubectl_cmd, args.stand)
    if ns_err:
        errors.append(ns_err)

    # Модули
    modules = set()
    for e in entries:
        m = extract_module(e["display_path"])
        if m:
            modules.add(m)

    module_to_ns = {}
    for m in modules:
        expected_ns = f"{args.stand}-{m}"
        if expected_ns in namespaces:
            module_to_ns[m] = expected_ns

    # Кэш образов из k8s
    ns_images_cache = {}

    def get_ns_images(ns):
        if ns not in ns_images_cache:
            try:
                ns_images_cache[ns] = get_images_from_ns(args.kubectl_cmd, ns)
            except Exception as e:
                errors.append(f"Ошибка получения образов из ns '{ns}': {e}")
                ns_images_cache[ns] = []
        return ns_images_cache[ns]

    # Сравнение
    diff_rows = []   # расхождения
    ok_rows = []     # совпадения
    error_rows = []  # ошибки парсинга (нет values.yaml и т.д.)

    for entry in entries:
        module = extract_module(entry["display_path"])

        if not module or entry["is_error"]:
            error_rows.append((
                entry["display_path"], entry["sub_name"],
                entry["image_path"], entry["tag"],
                entry["tpl_tag"], ""
            ))
            continue

        ns = module_to_ns.get(module)
        if not ns:
            diff_rows.append((
                entry["display_path"], entry["sub_name"],
                entry["image_path"], entry["tag"],
                entry["tpl_tag"], "ns не найден"
            ))
            err_msg = f"Неймспейс для модуля '{module}' не найден среди {args.stand}-*"
            if err_msg not in errors:
                errors.append(err_msg)
            continue

        k8s_images = get_ns_images(ns)
        image_path = entry["image_path"].strip()
        tag = entry["tag"].strip()

        if not image_path or not tag:
            error_rows.append((
                entry["display_path"], entry["sub_name"],
                entry["image_path"], entry["tag"],
                entry["tpl_tag"], ""
            ))
            continue

        # Ищем ВСЕ совпадения по image path (может быть в нескольких deploy/job)
        matches = [
            (kind, name, k8s_tag)
            for kind, name, k8s_path, k8s_tag in k8s_images
            if k8s_path == image_path
        ]

        if not matches:
            diff_rows.append((
                entry["display_path"], entry["sub_name"],
                image_path, tag,
                entry["tpl_tag"], "не найден в k8s"
            ))
            continue

        for kind, name, k8s_tag in matches:
            resource_label = f"{kind}/{name}"
            if k8s_tag == tag:
                ok_rows.append((
                    entry["display_path"], entry["sub_name"],
                    image_path, tag,
                    entry["tpl_tag"], resource_label
                ))
            else:
                diff_rows.append((
                    entry["display_path"], entry["sub_name"],
                    image_path, tag,
                    entry["tpl_tag"], f"k8s: {k8s_tag} ({resource_label})"
                ))

    # Вывод
    output_lines = []

    if diff_rows or error_rows:
        output_lines.append(f"{c.BOLD}{c.RED}=== РАСХОЖДЕНИЯ ==={c.RESET}")
        output_lines.append("")
        all_diff = diff_rows + error_rows
        for line in format_table(all_diff, c):
            output_lines.append(line)
    else:
        output_lines.append(f"{c.BOLD}{c.GREEN}Расхождений нет.{c.RESET}")

    if ok_rows and not args.quiet:
        output_lines.append("")
        output_lines.append(f"{c.BOLD}{c.GREEN}=== СОВПАДЕНИЯ ==={c.RESET}")
        output_lines.append("")
        for line in format_table(ok_rows, c):
            output_lines.append(line)

    # Вывод в stdout
    for line in output_lines:
        print(line)

    # Запись в файл (без цветов)
    try:
        # Убираем ANSI-коды для файла
        ansi_escape = re.compile(r'\033\[[0-9;]*m')
        with open(args.output, "w", encoding="utf-8") as f:
            for line in output_lines:
                f.write(ansi_escape.sub("", line) + "\n")

            if errors:
                f.write("\n" + "=" * 80 + "\n")
                f.write("ОШИБКИ:\n")
                f.write("=" * 80 + "\n")
                for err in errors:
                    f.write(f"  * {err}\n")

        print(f"\n{c.DIM}Результат записан в {args.output}{c.RESET}")
    except Exception as e:
        print(f"Ошибка записи в файл: {e}", file=sys.stderr)
        sys.exit(1)

    if errors:
        print(f"\n{c.YELLOW}ОШИБКИ ({len(errors)}):{c.RESET}")
        for err in errors:
            print(f"  {c.YELLOW}*{c.RESET} {err}")


if __name__ == "__main__":
    main()
EOF
chmod +x compare_tags.py
```

## Использование

```bash
# Полный вывод (расхождения + совпадения)
python3 compare_tags.py --input scan_output.txt --stand test-dfgr --kubectl-cmd k

# Только расхождения
python3 compare_tags.py --input scan_output.txt --stand test-dfgr --quiet
```

|Параметр       |Описание                            |По умолчанию        |
|---------------|------------------------------------|--------------------|
|`--input`      |Файл с выводом `scan_values.py`     |—                   |
|`--stand`      |Название стенда (префикс неймспейса)|—                   |
|`--kubectl-cmd`|Команда kubectl                     |`k`                 |
|`--output`     |Файл для вывода                     |`compare_result.txt`|
|`--quiet`      |Только расхождения                  |`false`             |

## Что изменилось в v2

- **jsonpath вместо describe+grep** — один вызов на ресурс, точный парсинг, включая initContainers
- **Дедупликация** — один и тот же образ в нескольких deployments обрабатывается корректно, каждое совпадение выводится отдельно
- **Имя ресурса** — в выводе видно `deploy/app-name` или `job/migrate-job`
- **Две таблицы** — расхождения сверху, совпадения снизу
- **Цветной вывод** — в терминале красный/зелёный, в файл без цветов
- **`--quiet`** — показать только проблемы