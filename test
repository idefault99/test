# 1. Основные логи kube-apiserver — именно он фиксирует все операции
sudo journalctl -u snap.microk8s.daemon-apiserver --since "3 days ago" | grep -iE "delete|$NS|helm"

# 2. Все microk8s демоны разом
sudo journalctl -u snap.microk8s.* --since "3 days ago" | grep -iE "delete|dev-devops|helm" | tail -50

# 3. Логи непосредственно в snap директории
sudo find /var/snap/microk8s/common -name "*.log" 2>/dev/null
sudo ls -la /var/snap/microk8s/common/var/log/

# 4. Containerd логи — видно запуски контейнеров
sudo journalctl -u snap.microk8s.daemon-containerd --since "3 days ago" | grep -iE "delete|dev-devops" | tail -30

# 5. Kubernetes controller-manager — он обрабатывает удаления ресурсов
sudo journalctl -u snap.microk8s.daemon-controller-manager --since "3 days ago" | tail -50

# 6. Смотрим вообще все snap сервисы microk8s которые есть
sudo systemctl list-units "snap.microk8s.*" --all

# 7. Логи прямо из контейнера apiserver через crictl
sudo microk8s kubectl get pods -n kube-system | grep apiserver
sudo microk8s kubectl logs -n kube-system -l component=kube-apiserver --since=72h 2>/dev/null | grep -iE "delete|dev-devops|helm" | tail -50
