#!/usr/bin/env bash
# ================================================================
#  microk8s-restore-calico.sh
#  Восстановление Calico CNI после velero restore
#  MicroK8s addon, revision 8566, v1.30.14
# ================================================================

RED='\033[0;31m'; YEL='\033[0;33m'; GRN='\033[0;32m'
CYN='\033[0;36m'; WHT='\033[1;37m'; DIM='\033[2m'
BOLD='\033[1m';   RST='\033[0m'

header()  { echo -e "\n${CYN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n  $1\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RST}"; }
section() { echo -e "\n${WHT}${BOLD}▶ $1${RST}\n${DIM}──────────────────────────────────────────────────────${RST}"; }
ok()      { echo -e "  ${GRN}✔${RST}  $1"; }
warn()    { echo -e "  ${YEL}⚠${RST}  $1"; }
bad()     { echo -e "  ${RED}✘${RST}  $1"; }
info()    { echo -e "  ${DIM}·${RST}  $1"; }
die()     { echo -e "\n${RED}${BOLD}FATAL: $1${RST}\n"; exit 1; }

[[ $EUID -ne 0 ]] && die "Запустите с sudo"

LOG="/tmp/calico-restore-$(date +%Y%m%d-%H%M%S).log"
exec > >(tee -a "$LOG") 2>&1

echo -e "${BOLD}${CYN}"
echo "  Calico CNI Restore — MicroK8s addon"
echo "  $(date '+%Y-%m-%d %H:%M:%S')  |  host: $(hostname)"
echo -e "${RST}"

SNAP_DATA="/var/snap/microk8s/current"
SNAP_BIN="/snap/microk8s/current/bin"
MK8S="microk8s"
CNI_DIR="${SNAP_DATA}/args/cni-network"
CNI_BIN_DIR="${SNAP_DATA}/opt/cni/bin"

# ════════════════════════════════════════════════════════════════
header "1. ПРОВЕРКА СОСТОЯНИЯ"

section "MicroK8s статус"
mk8s_running=false
if snap services microk8s | grep -q "daemon-kubelite.*active"; then
  ok "MicroK8s запущен"
  mk8s_running=true
else
  warn "MicroK8s не запущен — попытка старта"
  snap start microk8s
  sleep 10
  if snap services microk8s | grep -q "daemon-kubelite.*active"; then
    ok "MicroK8s запущен"
    mk8s_running=true
  else
    warn "MicroK8s не запустился — продолжаем восстановление CNI вручную"
  fi
fi

section "Текущий статус Calico"
calico_status=$(microk8s status 2>/dev/null | grep -i calico || echo "недоступно")
info "Calico в microk8s status: $calico_status"

# Проверяем CNI конфиг
cni_yaml_exists=false
if [[ -f "${CNI_DIR}/cni.yaml" ]]; then
  ok "cni.yaml существует: ${CNI_DIR}/cni.yaml"
  cni_yaml_exists=true
else
  bad "cni.yaml отсутствует: ${CNI_DIR}/cni.yaml"
fi

# Проверяем CNI бинари
if [[ -f "${CNI_BIN_DIR}/calico" ]]; then
  ok "calico бинарь найден"
else
  bad "calico бинарь отсутствует: ${CNI_BIN_DIR}/calico"
fi

# Проверяем calico pods
section "Calico pods"
microk8s kubectl get pods -n kube-system -l k8s-app=calico-node 2>/dev/null | sed 's/^/  /' \
  || info "kubectl недоступен или pods не найдены"

# ════════════════════════════════════════════════════════════════
header "2. ВОССТАНОВЛЕНИЕ CALICO"

section "Шаг 1 — Отключить и включить addon calico"
info "Это пересоздаст все конфиги и бинари calico..."

# Сначала disable
echo -e "  ${DIM}Выполняем: microk8s disable calico...${RST}"
microk8s disable calico 2>&1 | sed 's/^/  /' || warn "disable вернул ошибку (продолжаем)"
sleep 5

# Потом enable
echo -e "  ${DIM}Выполняем: microk8s enable calico...${RST}"
microk8s enable calico 2>&1 | sed 's/^/  /'
enable_exit=$?

if (( enable_exit == 0 )); then
  ok "calico addon включён"
else
  warn "enable вернул код $enable_exit — проверяем вручную"
fi

# ════════════════════════════════════════════════════════════════
header "3. ПРОВЕРКА ПОСЛЕ ВКЛЮЧЕНИЯ"

section "CNI конфиги"
sleep 5
if [[ -f "${CNI_DIR}/cni.yaml" ]]; then
  ok "cni.yaml создан"
  info "Содержимое:"
  head -20 "${CNI_DIR}/cni.yaml" | sed 's/^/    /'
else
  bad "cni.yaml не создан — переходим к ручному восстановлению"
fi

section "CNI бинари"
if [[ -d "$CNI_BIN_DIR" ]]; then
  ls "$CNI_BIN_DIR" 2>/dev/null | sed 's/^/  /'
  [[ -f "${CNI_BIN_DIR}/calico" ]] && ok "calico бинарь на месте" || bad "calico бинарь отсутствует"
fi

# ════════════════════════════════════════════════════════════════
header "4. ОЖИДАНИЕ CALICO PODS"

section "Ждём поднятия calico-node (до 3 минут)"
echo ""
timeout=180
elapsed=0
interval=10

while (( elapsed < timeout )); do
  ready=$(microk8s kubectl get pods -n kube-system -l k8s-app=calico-node \
    --no-headers 2>/dev/null | grep -c "Running" || true)
  total=$(microk8s kubectl get pods -n kube-system -l k8s-app=calico-node \
    --no-headers 2>/dev/null | wc -l || true)

  printf "  [%3ds] calico-node: %s/%s Running\r" "$elapsed" "$ready" "$total"

  if (( ready > 0 && ready == total && total > 0 )); then
    echo ""
    ok "calico-node pods запущены: ${ready}/${total}"
    break
  fi

  sleep $interval
  elapsed=$(( elapsed + interval ))
done

if (( elapsed >= timeout )); then
  echo ""
  warn "Таймаут ожидания calico pods"
fi

# ════════════════════════════════════════════════════════════════
header "5. ДИАГНОСТИКА ЕСЛИ PODS НЕ ПОДНЯЛИСЬ"

section "Статус calico pods"
microk8s kubectl get pods -n kube-system | grep -iE "calico|cni" | sed 's/^/  /' \
  || warn "kubectl недоступен"

section "События kube-system"
microk8s kubectl get events -n kube-system --sort-by='.lastTimestamp' 2>/dev/null \
  | grep -iE "calico|cni|network|Error|Failed" | tail -15 | sed 's/^/  /' \
  || info "События недоступны"

section "Логи calico-node (если pod существует)"
calico_pod=$(microk8s kubectl get pods -n kube-system -l k8s-app=calico-node \
  --no-headers 2>/dev/null | head -1 | awk '{print $1}')
if [[ -n "$calico_pod" ]]; then
  info "Pod: $calico_pod"
  microk8s kubectl logs -n kube-system "$calico_pod" --tail=30 2>/dev/null | sed 's/^/  /' \
    || warn "Логи недоступны"
else
  warn "calico-node pod не найден"
fi

# ════════════════════════════════════════════════════════════════
header "6. ВОССТАНОВЛЕНИЕ НОД"

section "Статус нод"
microk8s kubectl get nodes -o wide 2>/dev/null | sed 's/^/  /' || warn "kubectl недоступен"

section "Снять taint NotReady если есть"
not_ready_nodes=$(microk8s kubectl get nodes --no-headers 2>/dev/null \
  | grep "NotReady" | awk '{print $1}' || true)

if [[ -n "$not_ready_nodes" ]]; then
  warn "Ноды в NotReady: $not_ready_nodes"
  info "Ждём пока Calico поднимется и ноды сами перейдут в Ready..."
  info "Если ноды не переходят — проверь: microk8s kubectl describe node <node>"
else
  ok "Все ноды Ready"
fi

# ════════════════════════════════════════════════════════════════
header "7. ПРОВЕРКА СЕТИ"

section "Тест pod-to-pod сети"
info "Создаём тестовый pod..."
microk8s kubectl run net-test --image=busybox:1.35 --restart=Never \
  --command -- sleep 30 2>/dev/null || warn "Не удалось создать тестовый pod"

sleep 10
pod_status=$(microk8s kubectl get pod net-test --no-headers 2>/dev/null | awk '{print $3}' || echo "unknown")
kv() { printf "  ${WHT}%-30s${RST} %s\n" "$1" "$2"; }
kv "Тестовый pod статус:" "$pod_status"

if [[ "$pod_status" == "Running" ]]; then
  ok "Сеть работает — pod запустился"
  # Тест DNS
  dns_result=$(microk8s kubectl exec net-test -- nslookup kubernetes 2>/dev/null | grep -c "Address" || true)
  (( dns_result > 0 )) && ok "DNS работает" || warn "DNS не отвечает"
else
  bad "Pod не запустился — сеть может не работать"
  microk8s kubectl describe pod net-test 2>/dev/null | grep -A5 "Events:" | sed 's/^/  /'
fi

# Удаляем тестовый pod
microk8s kubectl delete pod net-test --grace-period=0 2>/dev/null || true

# ════════════════════════════════════════════════════════════════
header "ИТОГ"

echo ""
echo -e "  ${WHT}Статус компонентов:${RST}"
microk8s kubectl get pods -n kube-system 2>/dev/null \
  | grep -iE "calico|coredns|metrics" | sed 's/^/  /' || warn "kubectl недоступен"

echo ""
echo -e "  ${WHT}Если Calico всё ещё не работает:${RST}"
echo -e "  ${DIM}1.${RST} Проверить логи: ${CYN}microk8s kubectl logs -n kube-system -l k8s-app=calico-node${RST}"
echo -e "  ${DIM}2.${RST} Описание ноды:  ${CYN}microk8s kubectl describe node $(hostname)${RST}"
echo -e "  ${DIM}3.${RST} Пересоздать:    ${CYN}microk8s disable calico && microk8s enable calico${RST}"
echo -e "  ${DIM}4.${RST} Перезапуск:     ${CYN}sudo snap restart microk8s && sleep 30${RST}"
echo ""
echo -e "  Лог: ${CYN}${LOG}${RST}"
echo ""
