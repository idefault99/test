project = Project.find(123)

# Посмотреть что в registry
project.container_repositories.each do |repo|
  puts "#{repo.id} #{repo.path} #{repo.name}"
end

---
# Обновить пути в БД
project.container_repositories.each do |repo|
  new_path = repo.path.gsub('old-reponame', 'new-reponame')
  repo.update!(path: new_path)
  puts "Updated: #{repo.path}"
end

---
# Найти где лежит registry
sudo find /var/opt/gitlab -type d -name "old-reponame" 2>/dev/null

# Переименовать
sudo mv /var/opt/gitlab/gitlab-rails/shared/registry/docker/registry/v2/repositories/group/old-reponame \
        /var/opt/gitlab/gitlab-rails/shared/registry/docker/registry/v2/repositories/group/new-reponame

# Перезапустить registry
sudo gitlab-ctl restart registry
