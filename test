#!/usr/bin/env bash
# ==============================================================================
# pull_external_push_internal.sh
#
# Делает pull образа из внешнего registry (с заменой хоста),
# перетегирует обратно в оригинальный ref и пушит в свой registry.
#
# Использование:
#   ./pull_external_push_internal.sh <image_ref>
#
# Пример:
#   ./pull_external_push_internal.sh registry.test/db/system/m/service:0.4.1-0.bin
#
# Что происходит:
#   1. Берём ref: registry.test/db/system/m/service:0.4.1-0.bin
#   2. Заменяем хост: registry.external:443/db/system/m/service:0.4.1-0.bin
#   3. docker pull registry.external:443/db/system/m/service:0.4.1-0.bin
#   4. docker tag  registry.external:443/...  registry.test/db/system/m/service:0.4.1-0.bin
#   5. docker push registry.test/db/system/m/service:0.4.1-0.bin
#
# Требования:
#   - docker (залогинен в оба registry)
# ==============================================================================

set -euo pipefail

# ──────────────────────────────────────────────────────────────────────────────
# Конфигурация
# ──────────────────────────────────────────────────────────────────────────────
SRC_REGISTRY="registry.external:443"   # Откуда тянем
DST_REGISTRY="registry.test"           # Куда пушим (он же в оригинальном ref)

# ──────────────────────────────────────────────────────────────────────────────
# Цвета
# ──────────────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

log_info()  { echo -e "${GREEN}[INFO]${NC}  $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }
die()       { log_error "$*"; exit 1; }

# ──────────────────────────────────────────────────────────────────────────────
# Аргументы
# ──────────────────────────────────────────────────────────────────────────────
usage() {
    echo "Использование: $0 <image_ref>"
    echo "Пример: $0 registry.test/db/system/m/service:0.4.1-0.bin"
    exit 1
}

[[ $# -ne 1 ]] && usage

ORIGINAL_REF="$1"

# Проверяем что ref начинается с DST_REGISTRY
if [[ "$ORIGINAL_REF" != "${DST_REGISTRY}/"* ]]; then
    die "Переданный ref '${ORIGINAL_REF}' не начинается с '${DST_REGISTRY}/'"
fi

# Строим ref для внешнего registry: заменяем только первый компонент (хост)
PATH_PART="${ORIGINAL_REF#${DST_REGISTRY}/}"
EXTERNAL_REF="${SRC_REGISTRY}/${PATH_PART}"

# ──────────────────────────────────────────────────────────────────────────────
# Проверка наличия тега через GitLab Registry API (Docker Registry HTTP API v2)
# ──────────────────────────────────────────────────────────────────────────────
# Из EXTERNAL_REF вытаскиваем: хост, путь к репо, тег
# Формат: host/path/to/repo:tag
REPO_WITH_TAG="${EXTERNAL_REF#${SRC_REGISTRY}/}"   # db/system/m/service:0.4.1-0.bin
REPO_PATH="${REPO_WITH_TAG%:*}"                     # db/system/m/service
WANTED_TAG="${REPO_WITH_TAG##*:}"                   # 0.4.1-0.bin

log_info "Источник:    ${EXTERNAL_REF}"
log_info "Назначение:  ${ORIGINAL_REF}"
echo ""

log_info "=== Проверка тега в ${SRC_REGISTRY} ==="

# GitLab Registry реализует Docker Registry HTTP API v2
# GET /v2/<repo>/tags/list — возвращает {"name":"...","tags":["tag1","tag2",...]}
# Авторизация берётся из ~/.docker/config.json автоматически через --netrc-optional,
# но надёжнее получить токен через www-authenticate challenge.

# Получаем токен: сначала пробуем без auth — registry вернёт 401 с WWW-Authenticate
AUTH_HEADER=""
CHALLENGE=$(curl -si "https://${SRC_REGISTRY}/v2/" 2>/dev/null | grep -i "www-authenticate" || true)

if [[ -n "$CHALLENGE" ]]; then
    # Парсим realm и service из: Bearer realm="https://...",service="...",scope="..."
    REALM=$(echo "$CHALLENGE" | grep -oP '(?<=realm=")[^"]+')
    SERVICE=$(echo "$CHALLENGE" | grep -oP '(?<=service=")[^"]+')
    SCOPE="repository:${REPO_PATH}:pull"

    # Берём credentials из ~/.docker/config.json
    DOCKER_CONFIG="${DOCKER_CONFIG:-$HOME/.docker}/config.json"
    DOCKER_AUTH_B64=$(jq -r --arg host "$SRC_REGISTRY" '.auths[$host].auth // empty' "$DOCKER_CONFIG" 2>/dev/null || true)

    if [[ -n "$DOCKER_AUTH_B64" ]]; then
        TOKEN=$(curl -sf -u "$(echo "$DOCKER_AUTH_B64" | base64 -d)"             "${REALM}?service=${SERVICE}&scope=${SCOPE}" 2>/dev/null             | jq -r '.token // .access_token // empty')
        [[ -n "$TOKEN" ]] && AUTH_HEADER="Authorization: Bearer ${TOKEN}"
    fi
fi

# Запрашиваем список тегов
TAGS_RESPONSE=$(curl -sf     ${AUTH_HEADER:+-H "$AUTH_HEADER"}     "https://${SRC_REGISTRY}/v2/${REPO_PATH}/tags/list" 2>/dev/null || true)

if [[ -z "$TAGS_RESPONSE" ]]; then
    log_error "Не удалось получить список тегов для ${REPO_PATH} из ${SRC_REGISTRY}"
    log_error "Проверьте доступность registry и выполните: docker login ${SRC_REGISTRY}"
    exit 1
fi

# Проверяем наличие нужного тега
TAG_EXISTS=$(echo "$TAGS_RESPONSE" | jq -r --arg tag "$WANTED_TAG"     'if .tags then (.tags | map(select(. == $tag)) | length) else 0 end')

if [[ "$TAG_EXISTS" -eq 0 ]]; then
    log_error "Тег '${WANTED_TAG}' не найден в ${SRC_REGISTRY}/${REPO_PATH}"
    echo ""
    log_info "Доступные теги:"
    echo "$TAGS_RESPONSE" | jq -r '.tags // [] | sort | .[]' | sed 's/^/  /'
    exit 1
fi

log_info "Тег '${WANTED_TAG}' найден."
echo ""

log_info "=== docker pull ==="
docker pull "$EXTERNAL_REF" || die "docker pull завершился с ошибкой: ${EXTERNAL_REF}"

log_info "=== docker tag ==="
docker tag "$EXTERNAL_REF" "$ORIGINAL_REF" || die "docker tag завершился с ошибкой"

log_info "=== docker push ==="
docker push "$ORIGINAL_REF" || die "docker push завершился с ошибкой: ${ORIGINAL_REF}"

# Опционально: убрать локальные образы (раскомментировать если нужно)
# docker rmi "$EXTERNAL_REF" "$ORIGINAL_REF" || true

log_info "=== Готово ==="
log_info "  ${EXTERNAL_REF}"
log_info "  → ${ORIGINAL_REF}"
