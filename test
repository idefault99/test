sed -i 's/- name: "1\/2 · containerd — доступ к {{ local_registry }}"/- name: "1\/2 · containerd — настройка registry"/' playbooks/02-registry.yml
sed -i 's/- name: "2\/2 · Kubernetes — imagePullSecret для {{ local_registry }}"/- name: "2\/2 · Kubernetes — imagePullSecret"/' playbooks/02-registry.yml
---
# Запустить в фоне ожидание
while true; do
  pod=$(kubectl get pod -n longhorn-system -l app=longhorn-ui --field-selector=status.phase=Running -o name 2>/dev/null | head -1)
  if [ -n "$pod" ]; then
    kubectl exec -n longhorn-system $pod -- cat /var/config/nginx/nginx.conf 2>/dev/null && break
  fi
  sleep 1
done
---
# Посмотреть ConfigMap/Secret который генерирует конфиг
kubectl get configmap -n longhorn-system -o name | xargs -I{} kubectl get -n longhorn-system {} -o yaml 2>/dev/null | grep -A30 'nginx.conf\|resolver\|longhorn-backend'
---
# Проверить DNS прямо с control-plane ноды через kube-dns
kubectl exec -n kube-system coredns-668d6bf9bc-2vfmd -- \
  nslookup longhorn-backend.longhorn-system.svc.cluster.local 127.0.0.1
