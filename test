main_menu() {
  while true; do
    banner
    echo -e "  ${W}Выберите раздел:${NC}"
    echo ""
    echo -e "  ${C}╔═══════════════════════════════════════╗${NC}"
    echo -e "  ${C}║${NC}  ${G}1)${NC}  📋  Просмотр                      ${C}║${NC}"
    echo -e "  ${C}║${NC}       Топики, сообщения, consumer lag  ${C}║${NC}"
    echo -e "  ${C}╠═══════════════════════════════════════╣${NC}"
    echo -e "  ${C}║${NC}  ${M}2)${NC}  ⚙️   Управление                     ${C}║${NC}"
    echo -e "  ${C}║${NC}       Создание, удаление, produce      ${C}║${NC}"
    echo -e "  ${C}╠═══════════════════════════════════════╣${NC}"
    echo -e "  ${C}║${NC}  ${Y}3)${NC}  🔧  Настройки подключения           ${C}║${NC}"
    echo -e "  ${C}║${NC}       Брокер, SASL, SSL                 ${C}║${NC}"
    echo -e "  ${C}╠═══════════════════════════════════════╣${NC}"
    echo -e "  ${C}║${NC}  ${Y}4)${NC}  🔌  Проверить соединение            ${C}║${NC}"
    echo -e "  ${C}╠═══════════════════════════════════════╣${NC}"
    echo -e "  ${C}║${NC}  ${R}0)${NC}  🚪  Выход                           ${C}║${NC}"
    echo -e "  ${C}╚═══════════════════════════════════════╝${NC}"
    echo ""
    # Статус инструментов
    local tools_status=""
    [[ -n "$KCAT_CMD" ]] && tools_status+="${G}kcat✓${NC} "
    [[ -n "$KAFKA_BIN" ]] && tools_status+="${G}kafka-bin✓${NC} "
    [[ -z "$tools_status" ]] && tools_status="${R}инструменты не найдены${NC}"
    echo -e "  ${D}Инструменты: ${NC}${tools_status}"
    echo ""
    read -rp "  Выбор: " choice
    case "$choice" in
      1) view_menu ;;
      2) manage_menu ;;
      3) settings_menu ;;
      4) test_connection ;;
      0) echo -e "\n  ${C}До свидания!${NC}\n"; exit 0 ;;
      *) warn "Неверный выбор" ;;
    esac
  done
}

# ─────────────────────────────────────────────────────────────────────────────
# ТОЧКА ВХОДА
# ─────────────────────────────────────────────────────────────────────────────
main() {
  # Аргументы командной строки
  case "${1:-}" in
    --broker|-b)   BROKER="${2:-$BROKER}" ;;
    --help|-h)
      echo "Usage: $0 [--broker host:port]"
      echo "  Конфиг сохраняется в $CONFIG_FILE"
      exit 0
      ;;
  esac

  load_config
  detect_tools
  check_tools || { press_any; }
  main_menu
}

main "$@"
