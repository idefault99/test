labels:
  elasticsearch: elasticsearch
  kafka: kafka
  mongodb: mongodb
  postgresSql: postgressql
  redis: redis
  s3minio: s3minio
  notification: notification
  auth: auth
  keycloak: keycloak
  front: front
  mapserver:
    share: mapserver
  parkingauth:
    share: parkingauth
  bookingserver:
    share: bookingserver
  eventserver:
    share: eventserver
  crashprocessor:
    share: crashprocessor

ports:
  internal:
    keycloak:
      back: 8000
      health: 9000
    s3minioAPI: 9000
    s3minioConsole: 9001
    postgresSql: 5432
    front: 80
    nginx: 8080
    frontTargetPort: 8080
    mongodb: 27017
    back: 8000
    elasticsearch: 
      http: 9200
      transport: 9300
    galaxy: 8000
    grpc: 50051
    kafka:
      internal: 9092
      k8sInternal: 9094
    redis:
      client: 6379
      bus: 16379
# Если нужно внешнее подключение через NodePort то, необходимо указать порт
  external:
    postgresSql:
    mongodb:
    kafka:
    galaxy:

# Change to True if you need service in k8s
enableService:
  s3minio: false
  postgresSql: false
  mongodb: false
  kafka: false
  nginx:
    enable: false
    resolver: kube-dns.kube-system
    resolver_valid: 30s
    s3:
      enable: false
      S3_CONNECTOR: s3minio-api-service.{{ .Release.Namespace }}.svc.{{ .Values.localK8sDomain }}:9000
      protocol: http
      verifySsl: true
      S3_BUCKET: front
      S3_ACCESS_KEY:
      S3_SECRET_KEY:
      S3_SECURE:
      FOLDER_NAME:
      SOURCE_PATH:
  elastic:
    # Для запуска elastic кластера с несколькими нодами нужно указать type: multi-node
    enable: false
    type: single-node
    replicas: 1
  redis:
    # Для запуска redis кластера с 3мя нодами нужно указать type: cluster.
    type: single
    enable: false
    pvcEnabled: false
    storageClassName: nfs-csi
    storageSize: 1Gi

mongodb:
  imagePullPolicy: IfNotPresent
  persistence:
    size: 5Gi
    storageClass: nfs-csi
  initDatabase:
  user: root
  password: secretpass
  headless: mongodb-headless.coparking-demo.svc.cluster.local

s3minio:
  root_user: "minioadmin"
  root_password: "minioadmin"
  # EXAMPLE buckets: "front,schedule"
  buckets: "front"
  minio_settings:
    scanner_delay: "\"1\""
  persistence:
    size: 25Gi
    # пусто -> берётся глобальный .Values.storageClassName
    storageClass: ""

kafka:
  replicas: 3
  persistence:
    size: 5Gi
    storageClass: ""
  clusterId: "example"
  autoCreateTopics: false
  numPartitions: "3"
  defaultReplicationFactor: "3"
  offsetsTopicReplicationFactor: "3"
  transactionStateLogReplicationFactor: "3"
  transactionStateLogMinIsr: "2"
  minInsyncReplicas: "2"
  messageMaxBytes: "10485760"
  replicaFetchMaxBytes: "10485760"
  maxRequestSize: "10485760"
  socketRequestMaxBytes: "104857600"
  heapOpts: "-Xmx1024m -Xms1024m"
  # Любые дополнительные KAFKA_CFG_* (ключ: значение) попадут в configmap как есть.
  extraConfig: {}

kafkaUi:
  enabled: false
  clusterName: coparking
  dynamicConfig: false
  auditTopicEnabled: true
  auditConsoleEnabled: true
  auth:
    enabled: false
    type: LOGIN_FORM
    username: admin
    password: "example"
    existingSecret: ""
  extraEnv: []
  ingress:
    enabled: false
    path: /kafka-ui
    host: ""

enableModules:
  mapserver: false
  parkingauth: false
  crashprocessor: false
  bookingserver: false
  eventserver: false

microservices:
  enabled: true
  defaultPort: 8000
  createNamespace: true
  createTargetService: true
  list:
    - name: streams
    - name: videorecorder
    - name: miniohandler
    - name: segmentator
    - name: platereader
    - name: accidents-detector
    - name: snow-detector
    - name: crashdetection
    - name: car-counter
    - name: obstruction-monitoring
    - name: parkingreports
    - name: ledcontroller
    - name: openparkingapi
    - name: caps-manager
    - name: alert-processor
    - name: administration
    - name: cameracolorcontroller
    - name: parkingauth
    - name: bookingserver
    - name: eventserver
    - name: crashprocessor
    - name: mapserver
    - name: eventsrecorder

ingressClassName: nginx
realmName: test-realm
realmClient: test-client
localK8sDomain: cluster.local
ingressDomain:
kafkaExternalIP:
ingressSettings:
  maxBodySize: "500m"
baseNs: main


ingress:
  enabled: true
  backendPaths:
    - { path: '/api/bookingserver/v1(?:/|$)(.*)',         service: bookingserver }
    - { path: '/api/mapserver/v1(?:/|$)(.*)',             service: mapserver }
    - { path: '/api/openparkingapi/v1(?:/|$)(.*)',        service: openparkingapi }
    - { path: '/api/capsmanager/v1(?:/|$)(.*)',           service: capsmanager }
    - { path: '/api/alertprocessor/v1(?:/|$)(.*)',        service: alertprocessor }
    - { path: '/api/administration/v1(?:/|$)(.*)',        service: administration }
    - { path: '/api/cameracolorcontroller/v1(?:/|$)(.*)', service: cameracolorcontroller }
    - { path: '/api/eventserver/v1(?:/|$)(.*)',           service: eventserver }
    - { path: '/api/parkingreports/v1(?:/|$)(.*)',        service: parkingreports }
    - { path: '/api/crash-processor/v1(?:/|$)(.*)',       service: crash-processor }
    - { path: '/api/parking-auth/v1(?:/|$)(.*)',          service: parkingauth }

imagePullSecret: regcred-2

TLS:
  enable: false
  secret: "{{ .Values.ingressDomain }}-tls-secret"
---
################ Namespaces для микросервисов ################
# Для каждого включённого микросервиса создаётся отдельный неймспейс
# "<release-namespace>-<name>" - например coparking-streams
#
{{- if .Values.microservices.enabled }}
{{- range .Values.microservices.list }}
{{- $createNs := $.Values.microservices.createNamespace }}
{{- if hasKey . "createNamespace" }}{{- $createNs = .createNamespace }}{{- end }}
{{- if and (ne (.enabled | toString) "false") $createNs }}
---
apiVersion: v1
kind: Namespace
metadata:
  name: {{ include "coparking.msNamespace" (dict "root" $ "name" .name) }}
  labels:
    name: {{ include "coparking.msNamespace" (dict "root" $ "name" .name) }}
    {{- include "coparking.commonLabels" (dict "root" $ "app" .name) | nindent 4 }}
  annotations:
    "helm.sh/resource-policy": keep
{{- end }}
{{- end }}
{{- end }}
---
###############################################################################
# Cross-namespace доступ к микросервисам.
#
# Для каждого включённого микросервиса в основном неймспейсе создаётся
# ExternalName-сервис "<base>-<name>-cs", указывающий на сервис микросервиса
# "<base>-<name>-service" в его собственном неймспейсе "<base>-<name>".
#
###############################################################################
{{- if .Values.microservices.enabled }}
{{- $base := .Release.Namespace }}
{{- range .Values.microservices.list }}
{{- if ne (.enabled | toString) "false" }}
{{- $port := .port | default $.Values.microservices.defaultPort }}
{{- $selector := .selector | default .name }}
{{- $msNs := include "coparking.msNamespace" (dict "root" $ "name" .name) }}
{{- $createTarget := $.Values.microservices.createTargetService }}
{{- if hasKey . "createTargetService" }}{{- $createTarget = .createTargetService }}{{- end }}
---
apiVersion: v1
kind: Service
metadata:
  name: {{ $base }}-{{ .name }}-cs
  namespace: {{ $base }}
  labels:
    app: {{ .name }}
    {{- include "coparking.commonLabels" (dict "root" $ "app" .name) | nindent 4 }}
spec:
  type: ExternalName
  externalName: {{ $base }}-{{ .name }}-service.{{ $msNs }}.svc.{{ $.Values.localK8sDomain }}
  ports:
    - port: {{ $port }}
      protocol: TCP
{{- if $createTarget }}
---
apiVersion: v1
kind: Service
metadata:
  name: {{ $base }}-{{ .name }}-service
  namespace: {{ $msNs }}
  labels:
    app: {{ $selector }}
    {{- include "coparking.commonLabels" (dict "root" $ "app" .name) | nindent 4 }}
spec:
  type: ClusterIP
  selector:
    app: {{ $selector }}
  ports:
    - port: {{ $port }}
      protocol: TCP
{{- end }}
{{- end }}
{{- end }}
{{- end }}
