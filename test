#### Шаг Б.5 — Обновляем etcd static pod

**[CP СЕРВЕРЫ]** — на каждом:

```bash
# Заменяем старые IP на новые в etcd манифесте
sed -i \
  -e 's|10\.10\.10\.21|10.20.30.21|g' \
  -e 's|10\.10\.10\.22|10.20.30.22|g' \
  -e 's|10\.10\.10\.23|10.20.30.23|g' \
  /etc/kubernetes/manifests/etcd.yaml

# Обновляем peer URLs в самом etcd (выполнить только на СЕРВЕР1)
# Останавливаем kubelet — etcd упадёт, потом поднимем вручную
systemctl stop kubelet
```

**[СЕРВЕР1]** — принудительный запуск etcd как одиночного узла:

```bash
# Временно добавляем --force-new-cluster
sed -i '/etcd$/a\    - --force-new-cluster' /etc/kubernetes/manifests/etcd.yaml

# Запускаем kubelet — etcd стартует в single-node режиме
systemctl start kubelet
sleep 30

# Обновляем peer URLs
ETCDCTL_API=3 etcdctl member list \
  --endpoints=https://127.0.0.1:2379 \
  --cacert=/etc/kubernetes/pki/etcd/ca.crt \
  --cert=/etc/kubernetes/pki/etcd/server.crt \
  --key=/etc/kubernetes/pki/etcd/server.key

# Для каждого члена обновляем URL (ID берём из вывода выше)
for SERVER_IP in 10.20.30.21 10.20.30.22 10.20.30.23; do
  MEMBER_ID=$(ETCDCTL_API=3 etcdctl member list \
    --endpoints=https://127.0.0.1:2379 \
    --cacert=/etc/kubernetes/pki/etcd/ca.crt \
    --cert=/etc/kubernetes/pki/etcd/server.crt \
    --key=/etc/kubernetes/pki/etcd/server.key \
    | grep $SERVER_IP | cut -d, -f1)
  [ -n "$MEMBER_ID" ] && \
    ETCDCTL_API=3 etcdctl member update $MEMBER_ID \
      --peer-urls=https://${SERVER_IP}:2380 \
      --endpoints=https://127.0.0.1:2379 \
      --cacert=/etc/kubernetes/pki/etcd/ca.crt \
      --cert=/etc/kubernetes/pki/etcd/server.crt \
      --key=/etc/kubernetes/pki/etcd/server.key
done

# Убираем --force-new-cluster
sed -i '/force-new-cluster/d' /etc/kubernetes/manifests/etcd.yaml
```

