## Шаг 1 — Установка Vault на Ubuntu VM

**Где:** Ubuntu VM, от root.

**Что поправить перед запуском:**

|Переменная     |По умолчанию    |Что поставить           |
|---------------|----------------|------------------------|
|`VAULT_DOMAIN` |`vault.test.ru`|Домен Vault в твоём DNS |
|`KEY_SHARES`   |`5`             |Количество Shamir-долей |
|`KEY_THRESHOLD`|`3`             |Минимум долей для unseal|

**Запуск:**

```bash
scp install-vault.sh user@vault-vm:~/
ssh user@vault-vm
sudo bash install-vault.sh
```

**Что делает:** устанавливает Vault 1.19.3 через HashiCorp apt, генерирует self-signed CA + cert с SAN для домена и IP, запускает через systemd (unit из пакета с `CAP_IPC_LOCK`), инициализирует, распечатывает, сохраняет init-данные в `/root/vault-init.json`.

**Результат:** скрипт напечатает `VAULT_ADDR`, `VAULT_TOKEN`, путь к `ca.crt`.

> ! Сохрани `/root/vault-init.json` в надёжном месте. После перезагрузки VM нужно вручную unseal (3 ключа из файла).

```bash
#!/bin/bash
# sudo bash install-vault.sh
set -euo pipefail

# ══════════════════════════════════════════
VAULT_DOMAIN="vault.test.ru"
VAULT_DATA_DIR="/opt/vault/data"
VAULT_TLS_DIR="/opt/vault/tls"
VAULT_CONFIG_DIR="/etc/vault.d"
VAULT_USER="vault"
KEY_SHARES=5
KEY_THRESHOLD=3
# ══════════════════════════════════════════

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
log()     { echo -e "${GREEN}[INFO]${NC}  $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()     { echo -e "${RED}[ERR]${NC}   $*"; exit 1; }
section() { echo -e "\n${CYAN}══════ $* ══════${NC}"; }

[[ $EUID -ne 0 ]] && err "Запускать от root"

section "1. Зависимости"
apt-get update -q
apt-get install -y curl gnupg openssl jq wget lsb-release

section "2. HashiCorp apt репозиторий (Vault 1.19.x)"
# Актуальный GPG ключ HashiCorp
wget -qO- https://apt.releases.hashicorp.com/gpg \
  | gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg

# Определяем кодовое имя: для Ubuntu 24.04 = noble
DISTRO_CODENAME=$(grep -oP '(?<=UBUNTU_CODENAME=).*' /etc/os-release 2>/dev/null || lsb_release -cs)
log "Ubuntu codename: ${DISTRO_CODENAME}"

echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] \
https://apt.releases.hashicorp.com ${DISTRO_CODENAME} main" \
  > /etc/apt/sources.list.d/hashicorp.list

apt-get update -q
apt-get install -y vault

VAULT_INSTALLED_VERSION=$(vault version | grep -oP '[\d.]+')
log "Установлен Vault ${VAULT_INSTALLED_VERSION}"

section "3. Директории"
# Пользователь vault создаётся postinst-скриптом пакета
mkdir -p "${VAULT_DATA_DIR}" "${VAULT_TLS_DIR}"
chown -R "${VAULT_USER}:${VAULT_USER}" /opt/vault
chmod 750 "${VAULT_DATA_DIR}" "${VAULT_TLS_DIR}"

section "4. Self-signed TLS (CA + cert для домена ${VAULT_DOMAIN})"

# CA
openssl genrsa -out "${VAULT_TLS_DIR}/ca.key" 4096 2>/dev/null
openssl req -x509 -new -nodes \
  -key "${VAULT_TLS_DIR}/ca.key" \
  -sha256 -days 3650 \
  -subj "/CN=vault-ca/O=internal" \
  -out "${VAULT_TLS_DIR}/ca.crt"

# Vault cert — SAN включает домен + localhost + IP VM
VAULT_IP=$(hostname -I | awk '{print $1}')
log "IP VM: ${VAULT_IP}, домен: ${VAULT_DOMAIN}"

openssl genrsa -out "${VAULT_TLS_DIR}/vault.key" 2048 2>/dev/null

openssl req -new \
  -key "${VAULT_TLS_DIR}/vault.key" \
  -subj "/CN=${VAULT_DOMAIN}/O=internal" \
  -out "${VAULT_TLS_DIR}/vault.csr"

cat > "${VAULT_TLS_DIR}/vault.ext" <<EOF
[SAN]
subjectAltName=DNS:${VAULT_DOMAIN},DNS:localhost,IP:${VAULT_IP},IP:127.0.0.1
EOF

openssl x509 -req \
  -in "${VAULT_TLS_DIR}/vault.csr" \
  -CA "${VAULT_TLS_DIR}/ca.crt" \
  -CAkey "${VAULT_TLS_DIR}/ca.key" \
  -CAcreateserial \
  -out "${VAULT_TLS_DIR}/vault.crt" \
  -days 3650 -sha256 \
  -extfile "${VAULT_TLS_DIR}/vault.ext" \
  -extensions SAN 2>/dev/null

# Права
chown -R "${VAULT_USER}:${VAULT_USER}" "${VAULT_TLS_DIR}"
chmod 600 "${VAULT_TLS_DIR}"/*.key
chmod 644 "${VAULT_TLS_DIR}"/*.crt "${VAULT_TLS_DIR}"/*.csr 2>/dev/null || true

log "TLS готов: ${VAULT_TLS_DIR}/vault.crt (SAN: ${VAULT_DOMAIN}, ${VAULT_IP})"

section "5. Конфиг Vault (Raft, TLS, disable_mlock=true)"
cat > "${VAULT_CONFIG_DIR}/vault.hcl" <<EOF
# Vault 1.19.x — single-node Raft, TLS, domain: ${VAULT_DOMAIN}

ui            = true
disable_mlock = true   # обязательно для Raft; станет жёстким требованием в 1.20

api_addr     = "https://${VAULT_DOMAIN}:8200"
cluster_addr = "https://${VAULT_DOMAIN}:8201"

listener "tcp" {
  address       = "0.0.0.0:8200"
  tls_cert_file = "${VAULT_TLS_DIR}/vault.crt"
  tls_key_file  = "${VAULT_TLS_DIR}/vault.key"
}

storage "raft" {
  path    = "${VAULT_DATA_DIR}"
  node_id = "vault-node-1"
}
EOF

chown "${VAULT_USER}:${VAULT_USER}" "${VAULT_CONFIG_DIR}/vault.hcl"
chmod 640 "${VAULT_CONFIG_DIR}/vault.hcl"

section "6. Запуск через systemd (unit из пакета)"
# Пакет vault ставит правильный unit с CAP_IPC_LOCK, LimitMEMLOCK=infinity
systemctl daemon-reload
systemctl enable vault
systemctl start vault
sleep 3

if ! systemctl is-active --quiet vault; then
  err "vault.service не запустился. journalctl -u vault -n 50"
fi
log "vault.service активен"

section "7. Инициализация Vault"
export VAULT_ADDR="https://127.0.0.1:8200"
export VAULT_CACERT="${VAULT_TLS_DIR}/ca.crt"

for i in $(seq 1 15); do
  STATUS_CODE=$(curl -sk -o /dev/null -w "%{http_code}" "${VAULT_ADDR}/v1/sys/health" || true)
  if [[ "${STATUS_CODE}" =~ ^(200|429|472|473|501|503)$ ]]; then
    break
  fi
  log "Ожидаем Vault API (попытка ${i}/15, code=${STATUS_CODE})..."
  sleep 2
done

log "Инициализируем (key-shares=${KEY_SHARES}, key-threshold=${KEY_THRESHOLD})..."
INIT_OUTPUT=$(vault operator init \
  -key-shares="${KEY_SHARES}" \
  -key-threshold="${KEY_THRESHOLD}" \
  -format=json)

echo "${INIT_OUTPUT}" > /root/vault-init.json
chmod 600 /root/vault-init.json
log "Init-данные сохранены в /root/vault-init.json"

section "8. Unseal (${KEY_THRESHOLD} ключа из ${KEY_SHARES})"
for i in $(seq 0 $((KEY_THRESHOLD - 1))); do
  KEY=$(echo "${INIT_OUTPUT}" | jq -r ".unseal_keys_b64[${i}]")
  vault operator unseal "${KEY}" > /dev/null
  log "Unseal ключ $((i+1))/${KEY_THRESHOLD} применён"
done

ROOT_TOKEN=$(echo "${INIT_OUTPUT}" | jq -r '.root_token')

SEALED=$(vault status -format=json | jq -r '.sealed')
if [[ "${SEALED}" != "false" ]]; then
  err "Vault всё ещё sealed. Смотри journalctl -u vault"
fi

section "Готово!"
echo ""
echo -e "${GREEN}╔══════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║         Vault установлен и готов!           ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════════╝${NC}"
echo ""
echo -e "  Vault URL:    ${CYAN}https://${VAULT_DOMAIN}:8200${NC}"
echo -e "  Root token:   ${YELLOW}${ROOT_TOKEN}${NC}"
echo -e "  CA cert:      ${VAULT_TLS_DIR}/ca.crt"
echo -e "  Init dump:    /root/vault-init.json"
echo ""
echo -e "${YELLOW}  Скопируй /root/vault-init.json в надёжное место!${NC}"
echo -e "${YELLOW}  После перезагрузки VM — вручную unseal (3 ключа)${NC}"
echo ""
echo -e "${CYAN}Переменные для setup-vault.sh:${NC}"
echo "  export VAULT_ADDR=\"https://${VAULT_DOMAIN}:8200\""
echo "  export VAULT_CACERT=\"${VAULT_TLS_DIR}/ca.crt\""
echo "  export VAULT_TOKEN=\"${ROOT_TOKEN}\""
```

