# Включить
sudo microk8s enable dashboard

# Статус поднятия
sudo microk8s kubectl get pods -n kube-system | grep dashboard

# Живой watch
sudo microk8s kubectl get pods -n kube-system -w | grep dashboard

# Логи самого dashboard
sudo microk8s kubectl logs -n kube-system -l k8s-app=kubernetes-dashboard -f
