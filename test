before_script:
  - mkdir -p ~/.docker
  - echo "$DOCKER_CONFIG_JSON" > ~/.docker/config.json

before_script:
  - apk add --no-cache ansible sshpass openssh-client
  - export TAG=$(eval $TAG_SCRIPT)
  - mkdir -p ~/.ssh
  - echo "StrictHostKeyChecking no" >> ~/.ssh/config
  # config.json для docker login на хосте
  - mkdir -p ~/.docker
  - echo "$DOCKER_CONFIG_JSON" > /tmp/docker-config.json

- name: Copy docker config to host
  ansible.builtin.shell: |
    mkdir -p /root/.docker
    cat > /root/.docker/config.json << 'DOCKERCFG'
    {{ docker_config }}
    DOCKERCFG
  no_log: true

- |
  ansible-playbook ansible/deploy.yml \
    -e "docker_config=$(cat /tmp/docker-config.json)" \
    ...
