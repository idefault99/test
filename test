# Чей это IP
kubectl get pods -A -o wide | grep "10.96.183.166"

# Или это Service IP — тогда смотрим endpoints
kubectl get svc -A | grep "10.96.183.166"
kubectl get endpoints -A | grep "10.96.183.166"


# Что за namespace controller пытался удалить dev-devops-variation
kubectl get ns dev-devops-variation
# Если Terminating — это объясняет все последующие ошибки namespace_controller

# История событий namespace
kubectl get events -n dev-devops-variation --sort-by='.lastTimestamp' 2>/dev/null | tail -20

# Смотрим все действия этого IP за пятницу
sudo journalctl -u snap.microk8s.daemon-kubelite --since "2026-03-20 08:00:00" --until "2026-03-20 18:00:00" \
  | grep "client:10.96.183.166" \
  | grep -v "GET\|get\|list\|watch" \
  | head -50
