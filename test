NS="<namespace>"

# Удаляем поды
kubectl delete pod redis-deployment-0 redis-deployment-1 redis-deployment-2 -n $NS 2>/dev/null

# Удаляем PVC
kubectl delete pvc redis-data-redis-deployment-0 -n $NS
kubectl delete pvc redis-data-redis-deployment-1 -n $NS
kubectl delete pvc redis-data-redis-deployment-2 -n $NS

# Находим и удаляем PV (они в статусе Released после удаления PVC)
kubectl get pv | grep $NS | awk '{print $1}' | xargs kubectl delete pv

# StatefulSet создаст новые PVC и PV автоматически при старте подов
kubectl get pvc -n $NS | grep redis
kubectl get pods -n $NS | grep redis
