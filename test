---
# Фаза 3: Развёртывание Kubernetes кластера
# Предусловие: Фазы 1 и 2 выполнены на всех нодах
#
# Запуск: ansible-playbook playbooks/03-k8s-cluster.yml -K
#
# Плейбук идемпотентен:
#   - kubeadm init  пропускается если /etc/kubernetes/admin.conf существует
#   - kubeadm join  пропускается если /etc/kubernetes/kubelet.conf существует
#   - Calico/Helm  повторный apply безопасен

# ─── Play 0: Проверка containerd (критичный precheck) ────────────────────────
- name: "0/7 · Precheck — containerd SystemdCgroup"
  hosts: all_nodes
  become: true
  gather_facts: false
  tasks:

    - name: Проверить SystemdCgroup в containerd config
      command: grep SystemdCgroup /etc/containerd/config.toml
      register: r_cgroup_check
      changed_when: false

    - name: "СТОП: SystemdCgroup = false — запустите сначала 01-fixup.yml!"
      fail:
        msg: |
          На {{ inventory_hostname }} containerd имеет SystemdCgroup = false.
          Это сломает kubelet. Запустите сначала:
            ansible-playbook playbooks/01-fixup.yml -K
      when: "'SystemdCgroup = false' in r_cgroup_check.stdout"

    - name: Проверить что нет tunl0 / старых Calico интерфейсов
      shell: "ip link show | grep -E 'tunl0|vxlan.calico' || true"
      register: r_old_ifaces
      changed_when: false

    - name: "Предупреждение: обнаружены старые сетевые интерфейсы"
      debug:
        msg: |
          ВНИМАНИЕ: На {{ inventory_hostname }} обнаружены интерфейсы от предыдущего K8s:
          {{ r_old_ifaces.stdout }}
          Рекомендуется сначала запустить 01-fixup.yml
      when: r_old_ifaces.stdout | length > 0

# ─── Play 1: Calico NetworkManager config (все ноды) ─────────────────────────
- name: "1/7 · Calico — NetworkManager config"
  hosts: all_nodes
  become: true
  gather_facts: false
  tasks:

    - name: Drop calico.conf для NetworkManager
      copy:
        content: |
          [keyfile]
          unmanaged-devices=interface-name:cali*;interface-name:tunl*;interface-name:vxlan.calico
        dest: /etc/NetworkManager/conf.d/calico.conf
        mode: "0644"

    - name: Reload NetworkManager
      systemd:
        name: NetworkManager
        state: reloaded

    # На нодах уже есть 172.30.0.0/16 в trusted (из Фазы 1).
    # Убеждаемся что правильный service_subnet в trusted zone.
    - name: "firewalld: service_subnet {{ service_subnet }} → trusted"
      firewalld:
        zone: trusted
        source: "{{ service_subnet }}"
        permanent: true
        state: enabled

    - name: Reload firewalld
      command: firewall-cmd --reload
      changed_when: false

# ─── Play 2: kube-vip static pod (CP ноды, до init/join) ─────────────────────
- name: "2/7 · kube-vip — static pod на CP нодах"
  hosts: control_plane
  become: true
  gather_facts: false
  tasks:

    - name: Проверить наличие kube-vip манифеста
      stat:
        path: /etc/kubernetes/manifests/kube-vip.yaml
      register: kubevip_exists

    - name: Создать директорию /etc/kubernetes/manifests
      file:
        path: /etc/kubernetes/manifests
        state: directory
        mode: "0755"

    - name: Проверить наличие образа kube-vip в containerd
      shell: "ctr -n k8s.io image ls | grep -q 'kube-vip:{{ kubevip_version }}'"
      register: r_kubevip_image
      changed_when: false
      failed_when: false

    - name: Pull образ kube-vip из локального registry
      command: >
        ctr -n k8s.io image pull
        {{ local_registry }}/kube-vip/kube-vip:{{ kubevip_version }}
      when:
        - not kubevip_exists.stat.exists
        - r_kubevip_image.rc != 0

    - name: Сгенерировать kube-vip манифест
      shell: |
        ctr -n k8s.io run --rm --net-host \
          {{ local_registry }}/kube-vip/kube-vip:{{ kubevip_version }} kv \
          /kube-vip manifest pod \
          --interface {{ vip_interface }} \
          --address {{ vip }} \
          --controlplane \
          --arp \
          --leaderElection \
        > /tmp/kube-vip-raw.yaml && \
        sed 's|path: /etc/kubernetes/admin\.conf|path: /etc/kubernetes/super-admin.conf|g' \
          /tmp/kube-vip-raw.yaml > /etc/kubernetes/manifests/kube-vip.yaml
      args:
        creates: /etc/kubernetes/manifests/kube-vip.yaml

# ─── Play 3: kubeadm init (только первая CP нода) ────────────────────────────
- name: "3/7 · kubeadm init — инициализация кластера"
  hosts: first_control_plane
  become: true
  gather_facts: true
  tasks:

    - name: Проверить — кластер уже инициализирован?
      stat:
        path: /etc/kubernetes/admin.conf
      register: k8s_initialized

    - name: Скопировать kubeadm-config.yaml
      template:
        src: "{{ playbook_dir }}/../templates/kubeadm-config.yaml.j2"
        dest: /root/kubeadm-config.yaml
        mode: "0600"

    - name: Pre-pull образов (может не сработать в закрытом контуре — не критично)
      command: >
        kubeadm config images pull
        --config /root/kubeadm-config.yaml
      when: not k8s_initialized.stat.exists
      ignore_errors: true
      register: images_pull_result

    # Bootstrap trick: kube-vip с --leaderElection нужен API сервер для election.
    # Временно меняем k8s-api → node_ip чтобы kubeadm api-check и kube-vip
    # могли подключиться к реальному IP ноды, не к VIP (которого ещё нет).
    - name: "Bootstrap: k8s-api → {{ node_ip }} (временно, для kubeadm init)"
      lineinfile:
        path: /etc/hosts
        regexp: '.*\bk8s-api\b'
        line: "{{ node_ip }} k8s-api"
        backup: yes
      when: not k8s_initialized.stat.exists

    - name: "⚙ kubeadm init (может занять 3-5 минут)"
      command: >
        kubeadm init
        --config /root/kubeadm-config.yaml
        --upload-certs
        --ignore-preflight-errors=ImagePull
      register: kubeadm_init_result
      when: not k8s_initialized.stat.exists
      async: 600
      poll: 15

    - name: "Bootstrap: восстановить k8s-api → VIP {{ vip }}"
      lineinfile:
        path: /etc/hosts
        regexp: '.*\bk8s-api\b'
        line: "{{ vip }} k8s-api"

    - name: Создать /root/.kube
      file:
        path: /root/.kube
        state: directory
        mode: "0700"

    - name: Скопировать admin.conf в ~/.kube/config
      copy:
        src: /etc/kubernetes/admin.conf
        dest: /root/.kube/config
        remote_src: true
        mode: "0600"

    - name: Дождаться admin.conf (страховка)
      wait_for:
        path: /etc/kubernetes/admin.conf
        timeout: 30

    - name: "Откатить kube-vip: super-admin.conf → admin.conf"
      replace:
        path: /etc/kubernetes/manifests/kube-vip.yaml
        regexp: 'path: /etc/kubernetes/super-admin\.conf'
        replace: 'path: /etc/kubernetes/admin.conf'

    - name: Дождаться VIP {{ vip }}:6443
      wait_for:
        host: "{{ vip }}"
        port: 6443
        timeout: 90
        delay: 5

    - name: Создать свежий join-token
      command: kubeadm token create --print-join-command
      register: r_join_cmd

    - name: Upload certs — получить свежий certificate-key
      command: kubeadm init phase upload-certs --upload-certs
      register: r_upload_certs

    - name: Извлечь join token
      set_fact:
        k8s_join_token: >-
          {{ r_join_cmd.stdout | regex_search('--token\s+(\S+)', '\1') | first }}

    - name: Извлечь CA cert hash
      set_fact:
        k8s_ca_hash: >-
          {{ r_join_cmd.stdout | regex_search('sha256:(\S+)', '\1') | first }}

    - name: Извлечь certificate key
      set_fact:
        k8s_cert_key: >-
          {{ r_upload_certs.stdout_lines | select('match', '^[0-9a-f]{64}$') | list | first }}

    - name: Показать join-реквизиты
      debug:
        msg: |
          Token:    {{ k8s_join_token }}
          CA hash:  {{ k8s_ca_hash }}
          Cert key: {{ k8s_cert_key }}

# ─── Play 4: Join дополнительных CP нод ──────────────────────────────────────
- name: "4/7 · kubeadm join — дополнительные CP ноды"
  hosts: additional_control_plane
  become: true
  gather_facts: true
  serial: 1
  vars:
    k8s_join_token: "{{ hostvars[groups['first_control_plane'][0]]['k8s_join_token'] }}"
    k8s_ca_hash:    "{{ hostvars[groups['first_control_plane'][0]]['k8s_ca_hash'] }}"
    k8s_cert_key:   "{{ hostvars[groups['first_control_plane'][0]]['k8s_cert_key'] }}"
  tasks:

    - name: Проверить — нода уже присоединена?
      stat:
        path: /etc/kubernetes/kubelet.conf
      register: node_joined

    - name: Создать конфиг join CP
      template:
        src: "{{ playbook_dir }}/../templates/kubeadm-join-cp.yaml.j2"
        dest: /root/kubeadm-join-cp.yaml
        mode: "0600"
      when: not node_joined.stat.exists

    - name: "⚙ kubeadm join как CP (может занять 3 минуты)"
      command: kubeadm join --config /root/kubeadm-join-cp.yaml
      when: not node_joined.stat.exists
      async: 300
      poll: 10

    - name: Создать /root/.kube
      file:
        path: /root/.kube
        state: directory
        mode: "0700"

    - name: Скопировать admin.conf
      copy:
        src: /etc/kubernetes/admin.conf
        dest: /root/.kube/config
        remote_src: true
        mode: "0600"

# ─── Play 5: Join воркеров ────────────────────────────────────────────────────
- name: "5/7 · kubeadm join — воркеры"
  hosts: workers
  become: true
  gather_facts: false
  vars:
    k8s_join_token: "{{ hostvars[groups['first_control_plane'][0]]['k8s_join_token'] }}"
    k8s_ca_hash:    "{{ hostvars[groups['first_control_plane'][0]]['k8s_ca_hash'] }}"
  tasks:

    - name: Проверить — нода уже присоединена?
      stat:
        path: /etc/kubernetes/kubelet.conf
      register: node_joined

    - name: Создать конфиг join worker
      template:
        src: "{{ playbook_dir }}/../templates/kubeadm-join-worker.yaml.j2"
        dest: /root/kubeadm-join-worker.yaml
        mode: "0600"
      when: not node_joined.stat.exists

    - name: "⚙ kubeadm join как worker"
      command: kubeadm join --config /root/kubeadm-join-worker.yaml
      when: not node_joined.stat.exists
      async: 300
      poll: 10

# ─── Play 6: Calico, taints, labels ──────────────────────────────────────────
- name: "6/7 · Calico CNI + taint removal + labels"
  hosts: first_control_plane
  become: true
  gather_facts: false
  environment:
    KUBECONFIG: /root/.kube/config
  tasks:

    - name: Проверить наличие Calico operator манифеста
      stat:
        path: "{{ playbook_dir }}/../files/manifests/calico-tigera-operator.yaml"
      register: calico_manifest
      delegate_to: localhost
      become: false

    - name: ОШИБКА — calico-tigera-operator.yaml не найден
      fail:
        msg: |
          Файл files/manifests/calico-tigera-operator.yaml не найден.
          Запустите ./prepare.sh на машине с интернетом чтобы скачать его.
      when: not calico_manifest.stat.exists

    - name: Скопировать Calico operator манифест
      copy:
        src: "{{ playbook_dir }}/../files/manifests/calico-tigera-operator.yaml"
        dest: /tmp/calico-tigera-operator.yaml

    - name: Применить Calico Tigera Operator
      command: kubectl apply -f /tmp/calico-tigera-operator.yaml

    - name: Дождаться tigera-operator
      command: >
        kubectl -n tigera-operator rollout status
        deployment/tigera-operator --timeout=120s

    - name: Сгенерировать Calico Installation CR
      template:
        src: "{{ playbook_dir }}/../templates/calico-installation.yaml.j2"
        dest: /tmp/calico-installation.yaml

    - name: Применить Calico Installation
      command: kubectl apply -f /tmp/calico-installation.yaml

    - name: "Дождаться calico-node DaemonSet (до 5 минут)"
      command: >
        kubectl -n calico-system rollout status
        ds/calico-node --timeout=300s

    - name: Снять NoSchedule taint с CP нод
      command: >
        kubectl taint nodes {{ item }}
        node-role.kubernetes.io/control-plane:NoSchedule-
      loop: "{{ groups['control_plane'] }}"
      ignore_errors: true

    - name: Лейблы GPU нод
      command: "kubectl label node {{ item }} gpu=true --overwrite"
      loop: "{{ groups['gpu_nodes'] }}"

    - name: Лейблы storage нод
      command: "kubectl label node {{ item }} storage=true --overwrite"
      loop: "{{ groups['storage_nodes'] }}"

    - name: Лейбл Longhorn (все ноды)
      command: >
        kubectl label node {{ item }}
        node.longhorn.io/create-default-disk=true --overwrite
      loop: "{{ groups['all_nodes'] }}"

# ─── Play 7: Установка Helm ───────────────────────────────────────────────────
- name: "7/7 · Helm установка"
  hosts: first_control_plane
  become: true
  gather_facts: false
  tasks:

    - name: Проверить — Helm уже установлен?
      stat:
        path: /usr/local/bin/helm
      register: helm_installed

    - name: Проверить наличие Helm tarball
      stat:
        path: "{{ playbook_dir }}/../files/binaries/helm-{{ helm_version }}-linux-amd64.tar.gz"
      register: helm_tarball
      delegate_to: localhost
      become: false
      when: not helm_installed.stat.exists

    - name: ОШИБКА — Helm tarball не найден
      fail:
        msg: |
          Файл files/binaries/helm-{{ helm_version }}-linux-amd64.tar.gz не найден.
          Запустите ./prepare.sh чтобы скачать его.
      when: not helm_installed.stat.exists and not helm_tarball.stat.exists

    - name: Скопировать Helm tarball на сервер
      copy:
        src: "{{ playbook_dir }}/../files/binaries/helm-{{ helm_version }}-linux-amd64.tar.gz"
        dest: "/tmp/helm-{{ helm_version }}-linux-amd64.tar.gz"
      when: not helm_installed.stat.exists

    - name: Распаковать Helm
      unarchive:
        src: "/tmp/helm-{{ helm_version }}-linux-amd64.tar.gz"
        dest: /tmp/
        remote_src: true
      when: not helm_installed.stat.exists

    - name: Установить helm binary
      copy:
        src: /tmp/linux-amd64/helm
        dest: /usr/local/bin/helm
        remote_src: true
        mode: "0755"
      when: not helm_installed.stat.exists

    - name: Проверить helm version
      command: helm version
      register: helm_ver
      changed_when: false

    - name: Итог — состояние кластера
      command: kubectl get nodes -o wide
      environment:
        KUBECONFIG: /root/.kube/config
      register: r_nodes
      changed_when: false

    - name: "✓ Фаза 3 завершена — ноды кластера"
      debug:
        msg: "{{ r_nodes.stdout }}"
