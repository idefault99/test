## Файл: джоба в репозитории бэкапа

> Это идёт в `.gitlab-ci.yml` того репозитория где уже живут
> `backup-probegi-dev` и `upload-probegi-dev`.
> Меняем только image и последнюю строку script.

```yaml
upload-probegi-dev:
  extends: .upload
  environment: dev
  image:
    # Образ из репозитория minio-client — поменяй путь на свой
    name: registry.gitlab.com/your-group/minio-client:s3publisher-v2.0.0
    entrypoint: [""]
  variables:
    S3_HOST: ${S3_HOST}            # https://dev.example.com
    S3_PREFIX: ${S3_PREFIX}        # /api/s3minio
    S3_BUCKET: ${S3_BUCKET}        # имя бакета
    S3_ACCESS_KEY: ${S3_ACCESS_KEY}
    S3_SECRET_KEY: ${S3_SECRET_KEY}
    FOLDER_NAME: ${FOLDER_NAME}    # backup/postgres
    SOURCE_PATH: ./dump
  needs:
    - job: backup-probegi-dev
      artifacts: true
  script:
    - chmod 400 "$SSH_PRIVATE_KEY"
    - mkdir -p dump
    - DUMP_NAME="$(tr -d '\r\n' < dump-meta/dump_name.txt)"
    - DUMP_PATH="$(tr -d '\r\n' < dump-meta/dump_path.txt)"
    - DUMP_HOST="$(tr -d '\r\n' < dump-meta/dump_host.txt)"
    - DUMP_USER="$(tr -d '\r\n' < dump-meta/dump_user.txt)"
    - apt-get update && apt-get install -y openssh-client
    - scp -i "$SSH_PRIVATE_KEY" -o StrictHostKeyChecking=no "${DUMP_USER}@${DUMP_HOST}:${DUMP_PATH}" "./dump/${DUMP_NAME}"
    - ls -lh ./dump
    - python -m minio_client.upload  # ← вместо /app/code/main.bin
```

