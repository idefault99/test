#!/usr/bin/env bash
# =============================================================================
# gitlab_deploy_retry.sh
# Находит последний пайплайн, где запускалась указанная джоба,
# делает retry этой джобы и следит за выполнением.
#
# Использование:
#   ./gitlab_deploy_retry.sh -j <job_name> -p <project_id_or_path> [-u <gitlab_url>] [-t <token>]
#
# Переменные окружения (альтернатива флагам):
#   GITLAB_URL   — базовый URL GitLab (по умолчанию https://gitlab.com)
#   GITLAB_TOKEN — personal/project access token
# =============================================================================

set -euo pipefail

# ── Цвета ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Значения по умолчанию ────────────────────────────────────────────────────
GITLAB_URL="${GITLAB_URL:-https://gitlab.com}"
GITLAB_TOKEN="${GITLAB_TOKEN:-}"
PROJECT=""
JOB_NAME=""
POLL_INTERVAL=10   # секунд между проверками статуса
MAX_PAGES=20       # сколько страниц пайплайнов перебирать

# ── Хелперы ──────────────────────────────────────────────────────────────────
log()  { echo -e "${CYAN}[INFO]${RESET}  $*"; }
ok()   { echo -e "${GREEN}[OK]${RESET}    $*"; }
warn() { echo -e "${YELLOW}[WARN]${RESET}  $*"; }
err()  { echo -e "${RED}[ERROR]${RESET} $*" >&2; }
die()  { err "$*"; exit 1; }

usage() {
  cat <<EOF
${BOLD}Использование:${RESET}
  $(basename "$0") -j <job_name> -p <project> [-u <gitlab_url>] [-t <token>]

${BOLD}Параметры:${RESET}
  -j  Имя джобы (обязательно)
  -p  ID или URL-encoded путь проекта, например: 42 или mygroup%2Fmyrepo
  -u  Базовый URL GitLab (по умолчанию: \$GITLAB_URL или https://gitlab.com)
  -t  GitLab Access Token (по умолчанию: \$GITLAB_TOKEN)
  -i  Интервал поллинга в секундах (по умолчанию: 10)
  -h  Эта справка

${BOLD}Пример:${RESET}
  GITLAB_TOKEN=glpat-xxx ./$(basename "$0") -j deploy-staging -p mygroup%2Fmyrepo
EOF
  exit 0
}

# ── Разбор аргументов ────────────────────────────────────────────────────────
while getopts ":j:p:u:t:i:h" opt; do
  case $opt in
    j) JOB_NAME="$OPTARG" ;;
    p) PROJECT="$OPTARG" ;;
    u) GITLAB_URL="$OPTARG" ;;
    t) GITLAB_TOKEN="$OPTARG" ;;
    i) POLL_INTERVAL="$OPTARG" ;;
    h) usage ;;
    :) die "Опция -$OPTARG требует аргумент." ;;
    *) die "Неизвестная опция: -$OPTARG" ;;
  esac
done

[[ -z "$JOB_NAME" ]]     && die "Укажите имя джобы: -j <job_name>"
[[ -z "$PROJECT" ]]      && die "Укажите проект: -p <project>"
[[ -z "$GITLAB_TOKEN" ]] && die "Укажите токен: -t <token> или \$GITLAB_TOKEN"

GITLAB_URL="${GITLAB_URL%/}"   # убираем trailing slash
API="${GITLAB_URL}/api/v4"

# ── Базовая функция запроса ──────────────────────────────────────────────────
gl_get() {
  local url="$1"
  curl -fsSL \
    --header "PRIVATE-TOKEN: ${GITLAB_TOKEN}" \
    "${url}"
}

gl_post() {
  local url="$1"
  curl -fsSL -X POST \
    --header "PRIVATE-TOKEN: ${GITLAB_TOKEN}" \
    "${url}"
}

# ── 1. Поиск последнего пайплайна с нужной джобой ────────────────────────────
log "Ищем последний пайплайн с джобой '${BOLD}${JOB_NAME}${RESET}' в проекте '${BOLD}${PROJECT}${RESET}'..."

FOUND_PIPELINE_ID=""
FOUND_JOB_ID=""
FOUND_JOB_STATUS=""
FOUND_BRANCH=""
FOUND_PIPELINE_URL=""
FOUND_COMMIT_SHORT=""
FOUND_COMMIT_MSG=""

for page in $(seq 1 "$MAX_PAGES"); do
  pipelines_json=$(gl_get "${API}/projects/${PROJECT}/pipelines?per_page=50&page=${page}&order_by=id&sort=desc" 2>/dev/null)

  # Нет больше пайплайнов
  count=$(echo "$pipelines_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d))" 2>/dev/null || echo 0)
  [[ "$count" -eq 0 ]] && break

  # Перебираем пайплайны на странице
  pipeline_ids=$(echo "$pipelines_json" | python3 -c "
import sys, json
for p in json.load(sys.stdin):
    print('|'.join([str(p['id']), p['ref'], p['web_url'], p.get('sha','')]))
")

  while IFS='|' read -r pid pref purl psha; do
    # Получаем джобы пайплайна
    jobs_json=$(gl_get "${API}/projects/${PROJECT}/pipelines/${pid}/jobs?per_page=100" 2>/dev/null)

    match=$(echo "$jobs_json" | python3 -c "
import sys, json
jobs = json.load(sys.stdin)
for j in jobs:
    if (j.get('name') == '${JOB_NAME}'
            and j.get('stage') == 'deploy'
            and j.get('status') == 'success'):
        print(j['id'], j['status'])
        break
" 2>/dev/null || true)

    if [[ -n "$match" ]]; then
      FOUND_JOB_ID=$(echo "$match" | awk '{print $1}')
      FOUND_JOB_STATUS=$(echo "$match" | awk '{print $2}')
      FOUND_PIPELINE_ID="$pid"
      FOUND_BRANCH="$pref"
      FOUND_PIPELINE_URL="$purl"
      FOUND_COMMIT_SHORT="${psha:0:8}"

      # Короткое сообщение коммита
      FOUND_COMMIT_MSG=$(gl_get "${API}/projects/${PROJECT}/repository/commits/${psha}" 2>/dev/null \
        | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('title',''))" 2>/dev/null || echo "")
      break 2
    fi
  done <<< "$pipeline_ids"
done

[[ -z "$FOUND_PIPELINE_ID" ]] && die "Пайплайн не найден: джоба '${JOB_NAME}' со stage=deploy и status=success отсутствует (проверено ${MAX_PAGES} страниц)."

echo ""
echo -e "  ${BOLD}Найден пайплайн:${RESET}"
echo -e "    ID:      ${BOLD}${FOUND_PIPELINE_ID}${RESET}"
echo -e "    Ветка:   ${BOLD}${FOUND_BRANCH}${RESET}"
echo -e "    Коммит:  ${BOLD}${FOUND_COMMIT_SHORT}${RESET}  ${FOUND_COMMIT_MSG}"
echo -e "    URL:     ${CYAN}${FOUND_PIPELINE_URL}${RESET}"
echo -e "    Джоба:   ${BOLD}${JOB_NAME}${RESET}  (job id: ${FOUND_JOB_ID}, статус: ${FOUND_JOB_STATUS})"
echo ""

read -rp "$(echo -e "${YELLOW}Сделать retry этой джобы? [y/N]:${RESET} ")" confirm
[[ "${confirm,,}" != "y" ]] && { warn "Отменено."; exit 0; }

# ── 2. Запуск retry ───────────────────────────────────────────────────────────
log "Запускаем retry джобы ${JOB_NAME} (id: ${FOUND_JOB_ID})..."

retry_json=$(gl_post "${API}/projects/${PROJECT}/jobs/${FOUND_JOB_ID}/retry" 2>/dev/null)

NEW_JOB_ID=$(echo "$retry_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['id'])" 2>/dev/null || true)
NEW_JOB_URL=$(echo "$retry_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('web_url',''))" 2>/dev/null || true)

[[ -z "$NEW_JOB_ID" ]] && die "Не удалось получить ID новой джобы. Ответ API: ${retry_json}"

ok "Retry запущен. Новая джоба: ${CYAN}${NEW_JOB_URL}${RESET}"
echo ""

# ── 3. Поллинг статуса ────────────────────────────────────────────────────────
log "Следим за выполнением (интервал: ${POLL_INTERVAL}s)..."

prev_status=""
start_ts=$(date +%s)

while true; do
  job_json=$(gl_get "${API}/projects/${PROJECT}/jobs/${NEW_JOB_ID}" 2>/dev/null)

  status=$(echo "$job_json"   | python3 -c "import sys,json; print(json.load(sys.stdin).get('status','unknown'))" 2>/dev/null || echo "unknown")
  stage=$(echo "$job_json"    | python3 -c "import sys,json; print(json.load(sys.stdin).get('stage',''))" 2>/dev/null || echo "")
  duration=$(echo "$job_json" | python3 -c "import sys,json; d=json.load(sys.stdin); dur=d.get('duration'); print(f'{dur:.0f}s' if dur else '—')" 2>/dev/null || echo "—")

  elapsed=$(( $(date +%s) - start_ts ))

  if [[ "$status" != "$prev_status" ]]; then
    ts=$(date '+%H:%M:%S')
    case "$status" in
      running)  echo -e "  ${YELLOW}▶ [${ts}]${RESET} Статус: ${BOLD}running${RESET}  (stage: ${stage})" ;;
      pending)  echo -e "  ${CYAN}⏳ [${ts}]${RESET} Статус: pending — ожидаем раннера..." ;;
      created)  echo -e "  ${CYAN}⏳ [${ts}]${RESET} Статус: created" ;;
      success)  break ;;
      failed)   break ;;
      canceled) break ;;
      skipped)  break ;;
      *)        echo -e "  [${ts}] Статус: ${status}" ;;
    esac
    prev_status="$status"
  else
    # Прогресс-точка каждые N секунд без смены статуса
    printf "."
  fi

  sleep "$POLL_INTERVAL"
done

echo ""
echo ""

# ── 4. Итог ───────────────────────────────────────────────────────────────────
total_elapsed=$(( $(date +%s) - start_ts ))

case "$status" in
  success)
    ok "${BOLD}Джоба завершена успешно!${RESET}  (${duration}, всего ждали: ${total_elapsed}s)"
    ;;

  failed|canceled|skipped)
    err "${BOLD}Джоба завершилась со статусом: ${status}${RESET}"
    echo ""

    # Выводим последние строки лога
    log "Получаем лог джобы..."
    trace=$(curl -fsSL \
      --header "PRIVATE-TOKEN: ${GITLAB_TOKEN}" \
      "${API}/projects/${PROJECT}/jobs/${NEW_JOB_ID}/trace" 2>/dev/null || true)

    if [[ -n "$trace" ]]; then
      echo -e "${BOLD}══ Последние 60 строк лога ══${RESET}"
      echo "$trace" \
        | sed 's/\x1b\[[0-9;]*m//g' \
        | tail -n 60
      echo -e "${BOLD}══════════════════════════════${RESET}"
    else
      warn "Не удалось получить лог джобы."
    fi

    # Ищем строки с типичными маркерами ошибок
    echo ""
    log "Ключевые строки с ошибками:"
    if [[ -n "$trace" ]]; then
      echo "$trace" \
        | sed 's/\x1b\[[0-9;]*m//g' \
        | grep -iE "(error|fatal|failed|exit code|exception|traceback|panic|FAILED|ERR!)" \
        | tail -n 20 \
        | while IFS= read -r line; do
            echo -e "  ${RED}►${RESET} ${line}"
          done || warn "Специфичных строк ошибок не найдено."
    fi

    echo ""
    echo -e "  Полный лог: ${CYAN}${NEW_JOB_URL}${RESET}"
    exit 1
    ;;
esac
