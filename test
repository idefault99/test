-- Кол-во CPU (логических ядер)
SELECT current_setting('max_parallel_workers') AS max_parallel_workers;

-- Память: основные настройки
SELECT name, setting, unit
FROM pg_settings
WHERE name IN (
    'shared_buffers',
    'work_mem',
    'maintenance_work_mem',
    'effective_cache_size',
    'max_connections'
)
ORDER BY name;
