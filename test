#!/bin/bash
# scale-to-zero.sh
# Использование: ./scale-to-zero.sh <namespaces-file> [true]

set -euo pipefail

NS_FILE="${1:?Укажи файл с неймспейсами: $0 <namespaces-file> [dry-run]}"
DRY_RUN="${2:-false}"

[[ ! -f "$NS_FILE" ]] && { echo "Файл не найден: $NS_FILE"; exit 1; }

KUBECTL_ARGS=""
[[ "$DRY_RUN" == "true" ]] && KUBECTL_ARGS="--dry-run=client"

echo "=== Файл: $NS_FILE | dry-run: $DRY_RUN ==="

scale_resources() {
  local kind="$1"
  local ns="$2"
  local names

  names=$(kubectl get "$kind" -n "$ns" \
    -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)

  [[ -z "$names" ]] && return

  for name in $names; do
    case "$kind" in
      deployments|statefulsets)
        echo "        → $kind/$name"
        kubectl scale "$kind" "$name" -n "$ns" --replicas=0 $KUBECTL_ARGS
        ;;
      daemonsets)
        echo "        → daemonset/$name"
        kubectl patch daemonset "$name" -n "$ns" $KUBECTL_ARGS \
          -p '{"spec":{"template":{"spec":{"nodeSelector":{"non-existing-node":"true"}}}}}'
        ;;
      cronjobs)
        echo "        → cronjob/$name"
        kubectl patch cronjob "$name" -n "$ns" $KUBECTL_ARGS \
          -p '{"spec":{"suspend":true}}'
        ;;
    esac
  done
}

process_namespace() {
  local ns="$1"
  echo ""
  echo "━━━ Namespace: $ns ━━━"
  echo "  [1/4] Deployments → replicas=0"
  scale_resources deployments "$ns"
  echo "  [2/4] StatefulSets → replicas=0"
  scale_resources statefulsets "$ns"
  echo "  [3/4] DaemonSets → nodeSelector patch"
  scale_resources daemonsets "$ns"
  echo "  [4/4] CronJobs → suspend=true"
  scale_resources cronjobs "$ns"
  echo "  ✓ $ns — готово"
}

# Читаем файл через fd 3 — stdin не трогаем
while IFS= read -r line <&3 || [[ -n "$line" ]]; do
  line="${line// /}"
  [[ -z "$line" ]] && continue
  [[ "$line" == \#* ]] && continue
  process_namespace "$line"
done 3< "$NS_FILE"

echo ""
echo "=== Всё готово ==="
