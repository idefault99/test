## Откат и удаление

```bash
# Откатить релиз до предыдущей ревизии
helm rollback <release-name>
helm rollback my-nginx

# Откатить до конкретной ревизии
helm rollback my-nginx 3

# Откатить и ждать готовности
helm rollback my-nginx --wait

# Откатить с таймаутом
helm rollback my-nginx --timeout 5m0s

# Удалить релиз (все ресурсы Kubernetes удаляются)
helm uninstall <release-name>
helm uninstall my-nginx

# Удалить релиз из конкретного namespace
helm uninstall my-nginx -n production

# Удалить, но сохранить историю (можно потом откатить)
helm uninstall my-nginx --keep-history

# Удалить и ждать завершения удаления всех ресурсов
helm uninstall my-nginx --wait

# Dry-run удаления (без реального выполнения)
helm uninstall my-nginx --dry-run
```

