{{- if eq .Values.enableService.redis.enable true }}
{{- $modules := .Files.Get "files/redis_module.yaml" | fromYaml -}}
{{- range $module := $modules.main }}
{{- if or (index $.Values.enableModules $module) (eq $module "")}}
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ $.Values.labels.redis }}-deployment
  annotations:
    "helm.sh/resource-policy": keep
  labels:
    app: {{ $.Values.labels.redis }}
    app.kubernetes.io/managed-by: Helm
  namespace: {{ $.Release.Namespace }}{{ if eq $module "" }}{{ else }}-{{ $module }}{{ end }}
spec:
  serviceName: {{ $.Values.labels.redis }}-headless

  {{- if eq $.Values.enableService.redis.type "cluster" }}
  replicas: 3
  {{- else if eq $.Values.enableService.redis.type "single" }}
  replicas: 1
  {{- else }}
  {{ fail "Type of redis must be 'single' or 'cluster'" }}
  {{- end }}

  selector:
    matchLabels:
      app: {{ $.Values.labels.redis }}

  podManagementPolicy: OrderedReady

  updateStrategy:
    type: RollingUpdate

  {{- if eq $.Values.enableService.redis.type "cluster" }}
  persistentVolumeClaimRetentionPolicy:
    whenDeleted: Retain
    whenScaled: Retain
  {{- end }}

  template:
    metadata:
      labels:
        app: {{ $.Values.labels.redis }}

    spec:
      securityContext:
        fsGroup: {{ $.Values.enableService.redis.fsGroup | default 1001 }}
        fsGroupChangePolicy: "OnRootMismatch"

      {{- if eq $.Values.enableService.redis.type "cluster" }}
      affinity:
        podAntiAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            - labelSelector:
                matchExpressions:
                  - key: app
                    operator: In
                    values:
                      - {{ $.Values.labels.redis }}
              topologyKey: kubernetes.io/hostname
      {{- end }}

      initContainers:
        - name: init-data-dir
          image: {{ $.Values.images.redis }}
          imagePullPolicy: IfNotPresent
          securityContext:
            runAsUser: 0
            runAsGroup: 0
          command:
            - sh
            - -c
          args:
            - |
              set -e

              CLUSTER_MODE="{{ $.Values.enableService.redis.type }}"
              REDIS_UID="{{ $.Values.enableService.redis.runAsUser | default 1001 }}"
              REDIS_GID="{{ $.Values.enableService.redis.runAsGroup | default 1001 }}"
              NODES_CONF="/data/nodes.conf"

              echo "==> Redis data init | mode: ${CLUSTER_MODE}"
              echo "==> Redis uid/gid: ${REDIS_UID}:${REDIS_GID}"

              echo "==> Current /data content:"
              ls -la /data 2>/dev/null || true

              echo "==> Fixing /data permissions"
              chown -R "${REDIS_UID}:${REDIS_GID}" /data 2>/dev/null || true
              chmod -R g+rwX /data 2>/dev/null || true

              if [ "${CLUSTER_MODE}" = "cluster" ]; then
                if [ ! -f "${NODES_CONF}" ]; then
                  echo "==> nodes.conf not found — cleaning /data for cluster mode"
                  find /data -mindepth 1 -delete 2>/dev/null || true
                  echo "==> /data cleaned"
                else
                  echo "==> nodes.conf found — existing cluster data, skip cleanup"
                fi
              else
                if [ -f "${NODES_CONF}" ]; then
                  echo "==> nodes.conf found — cleaning /data for single mode"
                  find /data -mindepth 1 -delete 2>/dev/null || true
                  echo "==> /data cleaned"
                else
                  echo "==> single mode data is compatible, skip cleanup"
                fi
              fi

              echo "==> Fixing /data permissions after cleanup"
              chown -R "${REDIS_UID}:${REDIS_GID}" /data 2>/dev/null || true
              chmod -R g+rwX /data 2>/dev/null || true

              echo "==> Final /data content:"
              ls -la /data 2>/dev/null || true
          volumeMounts:
            - name: {{ $.Values.labels.redis }}-data
              mountPath: /data

      containers:
        - name: {{ $.Values.labels.redis }}
          image: {{ $.Values.images.redis }}
          imagePullPolicy: IfNotPresent
          securityContext:
            runAsUser: {{ $.Values.enableService.redis.runAsUser | default 1001 }}
            runAsGroup: {{ $.Values.enableService.redis.runAsGroup | default 1001 }}
            allowPrivilegeEscalation: false

          {{- if eq $.Values.enableService.redis.type "cluster" }}
          command:
            - sh
            - -c
            - |
              cat > /tmp/redis.conf << EOF
              port {{ $.Values.ports.internal.redis.client }}
              cluster-enabled yes
              cluster-config-file /data/nodes.conf
              cluster-node-timeout 5000
              appendonly yes
              dir /data
              cluster-announce-hostname $(MY_POD_NAME).{{ $.Values.labels.redis }}-headless.{{ $.Release.Namespace }}{{ if eq $module "" }}{{ else }}-{{ $module }}{{ end }}.svc.{{ $.Values.localK8sDomain }}
              EOF

              exec redis-server /tmp/redis.conf
          env:
            - name: MY_POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
          {{- else }}
          command:
            - redis-server
            - --appendonly
            - "yes"
            - --dir
            - /data
          {{- end }}

          ports:
            - name: client
              containerPort: {{ $.Values.ports.internal.redis.client }}
          {{- if eq $.Values.enableService.redis.type "cluster" }}
            - name: bus
              containerPort: {{ $.Values.ports.internal.redis.bus }}
          {{- end }}

          volumeMounts:
            - name: {{ $.Values.labels.redis }}-data
              mountPath: /data

          resources:
            limits:
              cpu: {{ ((((($.Values.configPods).redis).resources).limits).cpu) | default "200m" }}
              memory: {{ ((((($.Values.configPods).redis).resources).limits).memory) | default "500Mi" }}
            requests:
              cpu: {{ ((((($.Values.configPods).redis).resources).requests).cpu) | default "100m" }}
              memory: {{ ((((($.Values.configPods).redis).resources).requests).memory) | default "250Mi" }}

          readinessProbe:
            exec:
              command:
                - redis-cli
                - ping
            initialDelaySeconds: 5
            periodSeconds: 5
            failureThreshold: 5

          livenessProbe:
            exec:
              command:
                - redis-cli
                - ping
            initialDelaySeconds: 10
            periodSeconds: 10
            failureThreshold: 3

      imagePullSecrets:
        - name: {{ $.Values.imagePullSecret }}

      {{- if eq $.Values.enableService.redis.type "single" }}
      volumes:
        - name: {{ $.Values.labels.redis }}-data
          emptyDir: {}
      {{- end }}

  {{- if eq $.Values.enableService.redis.type "cluster" }}
  volumeClaimTemplates:
    - metadata:
        name: {{ $.Values.labels.redis }}-data
      spec:
        accessModes:
          - ReadWriteOnce
        storageClassName: {{ $.Values.enableService.redis.storageClassName | default "nfs-csi" }}
        resources:
          requests:
            storage: {{ $.Values.enableService.redis.storageSize | default "1Gi" }}
  {{- end }}
{{- end }}
{{- end }}
{{- end }}