#!/bin/bash
# setup-vault.sh — KV, политики, Kubernetes auth
# Запускать после install-vault.sh
# Использование: VAULT_TOKEN=<root_token> bash setup-vault.sh
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
log()     { echo -e "${GREEN}[INFO]${NC} $*"; }
section() { echo -e "\n${CYAN}══ $* ══${NC}"; }

: "${VAULT_TOKEN:?Нужен VAULT_TOKEN}"
: "${VAULT_ADDR:?Нужен VAULT_ADDR}"

export VAULT_CACERT="/opt/vault/tls/ca.crt"

# Стенды и их namespace-ы
# Формат: <стенд>:<namespace_suffix>
# infra = сам stand-test, остальные = stand-test-<suffix>
STANDS=(
  "stand-test:infra appone apptwo"
  # "stand-prod:infra appone"   # добавляй новые стенды сюда
)

# ── 1. KV v2 ──────────────────────────────────────────────────
section "Включаем KV v2"
vault secrets enable -path=secret kv-v2 2>/dev/null || log "KV уже включён"

# ── 2. Политики и секреты для каждого стенда ──────────────────
section "Создаём структуру секретов и политики"

for stand_entry in "${STANDS[@]}"; do
  STAND=$(echo "${stand_entry}" | cut -d: -f1)
  NAMESPACES=$(echo "${stand_entry}" | cut -d: -f2)

  log "Стенд: ${STAND}"

  for ns_suffix in ${NAMESPACES}; do
    # Определяем реальное имя k8s namespace
    if [[ "${ns_suffix}" == "infra" ]]; then
      K8S_NS="${STAND}"
    else
      K8S_NS="${STAND}-${ns_suffix}"
    fi

    VAULT_PATH="secret/${STAND}/${ns_suffix}"
    POLICY_NAME="${STAND}-${ns_suffix}"

    log "  Path: ${VAULT_PATH}  →  K8S namespace: ${K8S_NS}"

    # Создаём placeholder секрет (потом замените реальными данными)
    vault kv put "${VAULT_PATH}" \
      example-key="change-me" \
      db-password="change-me" \
      > /dev/null

    # Создаём политику: только чтение своего пути
    vault policy write "${POLICY_NAME}" - <<EOF
path "secret/data/${STAND}/${ns_suffix}" {
  capabilities = ["read"]
}
path "secret/metadata/${STAND}/${ns_suffix}" {
  capabilities = ["read", "list"]
}
EOF
    log "  Политика ${POLICY_NAME} создана"
  done
done

# ── 3. Kubernetes Auth ─────────────────────────────────────────
section "Настраиваем Kubernetes Auth"
vault auth enable kubernetes 2>/dev/null || log "Kubernetes auth уже включён"

# Параметры кластера — получаем из microk8s
echo ""
echo -e "${YELLOW}Нужны данные MicroK8s кластера. Выполни на узле кластера:${NC}"
echo ""
echo "  microk8s kubectl config view --raw -o jsonpath='{.clusters[0].cluster.server}'"
echo "  microk8s kubectl get cm kube-root-ca.crt -n kube-system -o jsonpath='{.data.ca\.crt}'"
echo ""
read -rp "K8s API server URL (например https://192.168.1.20:16443): " K8S_HOST
read -rp "Вставь CA cert кластера (однострочный base64 или путь к файлу): " K8S_CA_INPUT

if [[ -f "${K8S_CA_INPUT}" ]]; then
  K8S_CA=$(cat "${K8S_CA_INPUT}")
else
  # Если дали base64 — декодируем
  K8S_CA=$(echo "${K8S_CA_INPUT}" | base64 -d 2>/dev/null || echo "${K8S_CA_INPUT}")
fi

# Настраиваем Kubernetes auth backend
vault write auth/kubernetes/config \
  kubernetes_host="${K8S_HOST}" \
  kubernetes_ca_cert="${K8S_CA}" \
  disable_iss_validation=true

log "Kubernetes auth настроен на ${K8S_HOST}"

# ── 4. Vault роли для каждого namespace ───────────────────────
section "Создаём Vault роли для Kubernetes namespace-ов"

ESO_SA_NAME="external-secrets"     # ServiceAccount ESO в каждом namespace
ESO_SA_NAMESPACE="external-secrets" # namespace где стоит ESO оператор

for stand_entry in "${STANDS[@]}"; do
  STAND=$(echo "${stand_entry}" | cut -d: -f1)
  NAMESPACES=$(echo "${stand_entry}" | cut -d: -f2)

  for ns_suffix in ${NAMESPACES}; do
    if [[ "${ns_suffix}" == "infra" ]]; then
      K8S_NS="${STAND}"
    else
      K8S_NS="${STAND}-${ns_suffix}"
    fi

    POLICY_NAME="${STAND}-${ns_suffix}"
    ROLE_NAME="${STAND}-${ns_suffix}"

    vault write auth/kubernetes/role/${ROLE_NAME} \
      bound_service_account_names="${ESO_SA_NAME}" \
      bound_service_account_namespaces="${ESO_SA_NAMESPACE}" \
      policies="${POLICY_NAME}" \
      ttl=1h

    log "Роль ${ROLE_NAME} → SA ${ESO_SA_NAME}/${ESO_SA_NAMESPACE} → политика ${POLICY_NAME}"
  done
done

# ── 5. Итог ───────────────────────────────────────────────────
echo ""
echo -e "${GREEN}════════════════════════════════════════${NC}"
echo -e "${GREEN}  Vault настроен!${NC}"
echo -e "${GREEN}════════════════════════════════════════${NC}"
echo ""
echo -e "${CYAN}Пути секретов:${NC}"
for stand_entry in "${STANDS[@]}"; do
  STAND=$(echo "${stand_entry}" | cut -d: -f1)
  NAMESPACES=$(echo "${stand_entry}" | cut -d: -f2)
  for ns_suffix in ${NAMESPACES}; do
    echo "  vault kv put secret/${STAND}/${ns_suffix} key=value ..."
  done
done
echo ""
echo -e "${CYAN}CA cert для MicroK8s:${NC}"
echo "  /opt/vault/tls/ca.crt"
echo ""
echo -e "${YELLOW}Следующий шаг: установка ESO в MicroK8s${NC}"



