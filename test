def extract_folder_name(yaml_content):
    """Извлекает FOLDER_NAME со второго уровня вложенности.
    Если не найден — пытается найти pathLabel на верхнем уровне.
    Пример:
        configmap:
          FOLDER_NAME: test/ui/
    или:
        pathLabel: front/app/
    Возвращает значение с обрезанным trailing слэшем."""
    # Сначала FOLDER_NAME на втором уровне
    match = re.search(
        r'^[ \t]+FOLDER_NAME:\s*["\']?([^"\'\n]+?)["\']?\s*$',
        yaml_content,
        re.MULTILINE
    )
    if match:
        return match.group(1).strip().rstrip("/")

    # Fallback: pathLabel на верхнем уровне (без отступа)
    match = re.search(
        r'^pathLabel:\s*["\']?([^"\'\n]+?)["\']?\s*$',
        yaml_content,
        re.MULTILINE
    )
    if match:
        return match.group(1).strip().rstrip("/")

    return None

