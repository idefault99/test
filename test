## 3. Тесты

### `tests/test_client.py`

```python
import pytest
from unittest.mock import patch, MagicMock
from minio_client import MinioClient


@pytest.fixture
def client():
    with patch("boto3.client"):
        return MinioClient(
            host="https://example.com",
            access_key="key",
            secret_key="secret",
            prefix="/api/s3minio",
        )


def test_list_buckets(client):
    client._s3.list_buckets.return_value = {
        "Buckets": [{"Name": "test"}, {"Name": "prod"}]
    }
    assert client.list_buckets() == ["test", "prod"]


def test_bucket_exists_true(client):
    client._s3.head_bucket.return_value = {}
    assert client.bucket_exists("test") is True


def test_bucket_exists_false(client):
    from botocore.exceptions import ClientError
    client._s3.head_bucket.side_effect = ClientError(
        {"Error": {"Code": "404", "Message": "Not Found"}}, "HeadBucket"
    )
    assert client.bucket_exists("test") is False


def test_upload_file_not_found(client):
    with pytest.raises(FileNotFoundError):
        client.upload_file("bucket", "/nonexistent/file.txt")
```

Запуск тестов:

