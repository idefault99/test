.test:
  extends: .docker_compose_test
  script:
    - rm -rf ./artifacts
    - mkdir -p ./artifacts
    - chmod 777 ./artifacts
    - export TAG=$(eval $TAG_SCRIPT)
    - TEST_EXIT_CODE=0
    - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} up --remove-orphans --renew-anon-volumes --force-recreate --exit-code-from test test || TEST_EXIT_CODE=$?
    - echo "TEST_EXIT_CODE=$TEST_EXIT_CODE"
    - sed -n '1,120p' ./artifacts/report.xml || true
    - sed -i 's|" filename="|" filename="src/|g' ./artifacts/coverage.xml || true
    - exit $TEST_EXIT_CODE
  coverage: '/(?i)total.*? (100(?:\.0+)?\%|[1-9]?\d(?:\.\d+)?\%)$/'
  artifacts:
    when: always
    paths:
      - ./artifacts/report.xml
      - ./artifacts/coverage.xml
    reports:
      junit: ./artifacts/report.xml
      coverage_report:
        coverage_format: cobertura
        path: ./artifacts/coverage.xml
  after_script:
    - >
      if [ "$CI_JOB_STATUS" = "failed" ]; then
        docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} logs
      fi
    - export TAG=$(eval $TAG_SCRIPT)
    - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} down
    - docker volume prune -f