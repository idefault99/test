header "ИТОГОВЫЙ ОТЧЁТ"

echo ""
echo -e "${RED}${BOLD}ПРОБЛЕМЫ (${#ISSUES[@]}):${RST}"
if (( ${#ISSUES[@]} == 0 )); then
  echo -e "  ${GRN}Критических проблем не обнаружено${RST}"
else
  for i in "${!ISSUES[@]}"; do
    echo -e "  ${RED}$((i+1)).${RST} ${ISSUES[$i]}"
  done
fi

echo ""
echo -e "${YEL}${BOLD}ПРЕДУПРЕЖДЕНИЯ (${#WARNINGS[@]}):${RST}"
if (( ${#WARNINGS[@]} == 0 )); then
  echo -e "  ${GRN}Предупреждений нет${RST}"
else
  for i in "${!WARNINGS[@]}"; do
    echo -e "  ${YEL}$((i+1)).${RST} ${WARNINGS[$i]}"
  done
fi

echo ""
echo -e "${CYN}${BOLD}РЕКОМЕНДАЦИИ (${#RECOMMENDATIONS[@]}):${RST}"
if (( ${#RECOMMENDATIONS[@]} == 0 )); then
  echo -e "  ${GRN}Система в норме, рекомендаций нет${RST}"
else
  # Убрать дубли
  declare -A seen
  idx=1
  for rec_item in "${RECOMMENDATIONS[@]}"; do
    if [[ -z "${seen[$rec_item]+x}" ]]; then
      echo -e "  ${CYN}${idx}.${RST} ${rec_item}"
      seen[$rec_item]=1
      (( idx++ ))
    fi
  done
fi

echo ""
echo -e "${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RST}"
echo -e "  Полный лог: ${WHT}$LOG${RST}"
echo -e "${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RST}"
