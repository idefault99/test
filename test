#!/bin/bash
set -e

echo "==> Установка pip и venv..."
sudo apt update
sudo apt install -y python3 python3-pip python3-venv

echo "==> Создание venv и установка Ansible..."
python3 -m venv ~/.ansible-venv
source ~/.ansible-venv/bin/activate
pip install --upgrade pip ansible

echo "==> Добавление в PATH (~/.bashrc)..."
grep -qxF 'source ~/.ansible-venv/bin/activate' ~/.bashrc \
  || echo 'source ~/.ansible-venv/bin/activate' >> ~/.bashrc

ansible --version
echo "✅ Готово! Перезапусти терминал или выполни: source ~/.bashrc"
