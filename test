# Временно переключить ESO в debug режим
microk8s kubectl set env deployment/external-secrets \
  -n external-secrets \
  LOG_LEVEL=debug

# Подождать 10 сек и смотреть логи
microk8s kubectl logs -n external-secrets \
  -l app.kubernetes.io/name=external-secrets --tail=100 | grep -i "vault\|error\|tls\|cert\|auth"

# Зайти в pod ESO и проверить
ESO_POD=$(microk8s kubectl get pod -n external-secrets \
  -l app.kubernetes.io/name=external-secrets \
  -o jsonpath='{.items[0].metadata.name}')

microk8s kubectl exec -n external-secrets ${ESO_POD} -- \
  wget -qO- --no-check-certificate https://vault.test.ru/v1/sys/health
