# ─── BASE ─────────────────────────────────────────────────────────────────────
FROM python:3.10-slim AS base

WORKDIR /app

ARG GITLAB_USERNAME
ARG GITLAB_TOKEN
ARG NEXUS_PYPI_URL
ARG NEXUS_USERNAME
ARG NEXUS_PASSWORD
ARG POETRY_PACKAGE_GROUPS=main
ARG PROJECT_REVISION=dev

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN pip install --trusted-host pypi.org \
    --trusted-host files.pythonhosted.org \
    poetry

COPY pyproject.toml poetry.lock* ./

# ─── SOURCE (с dev/test зависимостями, для тестов в CI) ──────────────────────
FROM base AS source

RUN poetry config virtualenvs.create false && \
    poetry install --with ${POETRY_PACKAGE_GROUPS} --no-root

COPY . .

# ─── PRODUCTION / PRODUCT (только main, для прода) ───────────────────────────
FROM base AS production

RUN poetry config virtualenvs.create false && \
    poetry install --only main --no-root

COPY . .

# product — алиас для kaniko-джобы (--target product)
FROM production AS product

CMD ["python", "src/main.py"]
