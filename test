import boto3
from botocore.config import Config
from urllib.parse import urlsplit, urlunsplit

# ==============================================================================
# НАСТРОЙКИ
# ==============================================================================

MINIO_HOST     = "https://dev.host.ru"   # БЕЗ префикса!
MINIO_PREFIX   = "/api/s3minio"          # Префикс который nginx срезает
ACCESS_KEY     = "your-access-key"
SECRET_KEY     = "your-secret-key"
BUCKET_NAME    = "your-bucket"

# ==============================================================================
# КЛИЕНТ
# ==============================================================================

s3 = boto3.client(
    "s3",
    endpoint_url=MINIO_HOST,             # Подпись считается для корневого пути
    aws_access_key_id=ACCESS_KEY,
    aws_secret_access_key=SECRET_KEY,
    region_name="us-east-1",
    config=Config(
        signature_version="s3v4",
        s3={"addressing_style": "path"},
    ),
)

def add_prefix_before_send(request, **kwargs):
    """После подписания, перед отправкой — добавляем префикс в URL."""
    parsed = urlsplit(request.url)
    request.url = urlunsplit((
        parsed.scheme,
        parsed.netloc,
        MINIO_PREFIX + parsed.path,
        parsed.query,
        parsed.fragment,
    ))

# Регистрируем для всех S3 операций
s3.meta.events.register("before-send.s3.*", add_prefix_before_send)

# ==============================================================================
# ПРОВЕРКА
# ==============================================================================

if __name__ == "__main__":
    response = s3.list_buckets()
    print("Подключение успешно!")
    for bucket in response.get("Buckets", []):
        print(f"  - {bucket['Name']}")
