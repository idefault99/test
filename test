### Шаг 3. Финальная проверка

```bash
# Проверить что у всех redis есть PVC
kubectl get pvc -A | grep redis-data | grep -v Bound
# Ожидаем: пустой вывод (все Bound)

# Проверить что нет redis без PVC
kubectl get pvc -A | grep redis-data | wc -l
# Должно быть кол-во namespace * 3

# Проверить состояние кластеров во всех namespace
for NS in $(kubectl get pods -A | grep "redis-deployment-0" | awk '{print $1}' | sort -u); do
  STATE=$(kubectl exec -n $NS redis-deployment-0 -- redis-cli cluster info 2>/dev/null | grep cluster_state | cut -d: -f2 | tr -d '[:space:]')
  if [ "$STATE" != "ok" ]; then
    echo "ПРОБЛЕМА: $NS — state=$STATE"
  fi
done
echo "Проверка завершена."
```

