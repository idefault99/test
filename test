# Запускаешь в одном терминале
kubectl exec -n dev-devops <app-pod> -- sh -c '
i=0
while true; do
  i=$((i+1))
  RESULT=$(redis-cli -h redis-service -p 6379 set "test:key:$i" "value-$i" 2>&1)
  GET=$(redis-cli -h redis-service -p 6379 get "test:key:$i" 2>&1)
  echo "$(date +%H:%M:%S) | SET test:key:$i → $RESULT | GET → $GET"
  sleep 1
done
'

---
# Копируем скрипт в под и запускаем
kubectl exec -n dev-devops <app-pod> -- python3 - << 'EOF'
import asyncio
import time
from redis.asyncio import Redis

async def main():
    client = Redis.from_url(
        "redis://redis-service:6379",
        encoding="utf-8",
        decode_responses=True,
    )

    i = 0
    while True:
        i += 1
        ts = time.strftime("%H:%M:%S")
        try:
            await client.set(f"test:key:{i}", f"value-{i}")
            val = await client.get(f"test:key:{i}")
            print(f"{ts} | OK  | SET test:key:{i} → GET {val}")
        except Exception as e:
            print(f"{ts} | ERR | {type(e).__name__}: {e}")
        await asyncio.sleep(1)

asyncio.run(main())
EOF

