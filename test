#!/bin/bash
# Размер БД Redis во всех namespace
# Сортирует по убыванию — сначала самые большие

echo "Собираем данные..."
echo ""

# Временный файл для сортировки
TMP=$(mktemp)

kubectl get pods -A --no-headers 2>/dev/null \
  | grep "redis-deployment-0" \
  | awk '{print $1}' \
  | while read NS; do
      DBSIZE=$(kubectl exec -n $NS redis-deployment-0 -- redis-cli dbsize 2>/dev/null | tr -d '[:space:]')
      MEMORY=$(kubectl exec -n $NS redis-deployment-0 -- redis-cli info memory 2>/dev/null \
        | grep "used_memory_human" | head -1 | cut -d: -f2 | tr -d '[:space:]')
      echo "$DBSIZE $MEMORY $NS"
    done | tee $TMP

echo ""
echo "============================================"
echo "  ТОП — по количеству ключей"
echo "============================================"
printf "%-10s %-10s %s\n" "КЛЮЧЕЙ" "ПАМЯТЬ" "NAMESPACE"
echo "-------------------------------------------"
sort -rn $TMP | while read KEYS MEM NS; do
  if [ "${KEYS:-0}" -gt 0 ] 2>/dev/null; then
    printf "%-10s %-10s %s\n" "$KEYS" "$MEM" "$NS"
  fi
done

echo ""
echo "============================================"
printf "%-10s %s\n" "КЛЮЧЕЙ" "NAMESPACE"
echo "--- Пустые (dbsize=0) ---"
sort -rn $TMP | while read KEYS MEM NS; do
  if [ "${KEYS:-0}" -eq 0 ] 2>/dev/null; then
    printf "%-10s %s\n" "$KEYS" "$NS"
  fi
done

echo ""
TOTAL_NS=$(wc -l < $TMP)
NON_EMPTY=$(awk '$1>0' $TMP | wc -l)
echo "Всего namespace: $TOTAL_NS | С данными: $NON_EMPTY | Пустых: $((TOTAL_NS-NON_EMPTY))"

rm -f $TMP


---

bash redis_dbsize.sh 2>&1 | tee /tmp/redis_dbsize.log
