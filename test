run_custom_sql() {
  header "Выполнить SQL в БД: $CURRENT_DB"
  echo "Введи SQL-запрос одной строкой."
  echo "Пример:"
  echo "  select now();"
  echo "  select * from public.my_table limit 10;"
  echo

  read -r -p "SQL> " user_sql

  if [[ -z "${user_sql// }" ]]; then
    echo "Пустой запрос."
    return
  fi

  echo
  echo "Будет выполнено в БД: $CURRENT_DB"
  echo "Запрос:"
  echo "$user_sql"
  echo

  run_sql "$CURRENT_DB" "$user_sql"
}

---
main_menu() {
  while true; do
    header "Postgres menu | host=$PGHOST port=$PGPORT user=$PGUSER current_db=$CURRENT_DB sample_rows=$SAMPLE_ROWS"
    echo "1) Проверить подключение"
    echo "2) Показать список БД"
    echo "3) Выбрать БД"
    echo "4) Показать текущую БД"
    echo "5) Показать схемы"
    echo "6) Показать таблицы"
    echo "7) Показать размеры таблиц"
    echo "8) Показать колонки таблицы"
    echo "9) Показать первые N строк таблицы"
    echo "10) Показать размер текущей БД"
    echo "11) Показать активные подключения"
    echo "12) Показать долгие запросы"
    echo "13) Показать vacuum/analyze статистику"
    echo "14) Изменить лимит строк sample"
    echo "15) Выполнить SQL-запрос"
    echo "0) Выход"
    echo

    read -r -p "Выбери пункт меню: " choice

    case "$choice" in
      1) check_connection; pause ;;
      2) list_databases; pause ;;
      3) select_database; pause ;;
      4) show_current_db; pause ;;
      5) list_schemas; pause ;;
      6) list_tables; pause ;;
      7) table_sizes; pause ;;
      8) table_columns; pause ;;
      9) table_sample; pause ;;
      10) database_size; pause ;;
      11) connections; pause ;;
      12) long_queries; pause ;;
      13) vacuum_stats; pause ;;
      14) change_sample_rows; pause ;;
      15) run_custom_sql; pause ;;
      0) echo "Выход."; exit 0 ;;
      *) echo "Неизвестный пункт меню."; pause ;;
    esac
  done
}

