services:
  redis:
    image: redis:6.2
    ports:
      - "6379:6379"
    healthcheck:
      test: [ "CMD", "redis-cli", "--raw", "incr", "ping" ]
      interval: 30s
      timeout: 10s
    networks:
      - server_network
  minio:
    image: minio/minio:latest
    container_name: minio-server-parking
    command: server --console-address ":9001" /data
    ports:
      - 9000:9000
      - 9001:9001
    env_file:
      - /server/minio-server/.env
    volumes:
      - /media/minios3/minio-storage:/data
    deploy:
      restart_policy:
        condition: always
        window: 30s
    networks:
      - server_network
  kafka2:
    image: confluentinc/cp-kafka:6.2.0
    hostname: kafka2
    container_name: kafka2
    restart: always
    volumes:
      - /server/kafka/data:/var/lib/kafka/data
    ports:
      - "9094:9094"
      - "9096:9096"
    environment:
      KAFKA_BROKER_ID: 2
      KAFKA_ZOOKEEPER_CONNECT: 168.19.184.14:2181
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: INSIDE:PLAINTEXT,OUTSIDE:PLAINTEXT
      KAFKA_ADVERTISED_LISTENERS: INSIDE://168.19.184.12:9094,OUTSIDE://168.19.184.12:9096
      KAFKA_LISTENERS: INSIDE://0.0.0.0:9094,OUTSIDE://0.0.0.0:9096
      KAFKA_INTER_BROKER_LISTENER_NAME: INSIDE
      KAFKA_MESSAGE_MAX_BYTES: 1000000000          # 5MB limit for large messages
      KAFKA_REPLICA_FETCH_MAX_BYTES: 1000000000    # Sync replica limit for large messages
      KAFKA_NUM_PARTITIONS: 2                  # Increased partitions for high throughput
      KAFKA_TRANSACTION_STATE_LOG_MIN_ISR: 1 #test option
      KAFKA_AUTO_CREATE_TOPICS_ENABLE: false
      KAFKA_DEFAULT_REPLICATION_FACTOR: 2       # Replication for durability
      KAFKA_MIN_INSYNC_REPLICAS: 1
      KAFKA_HEAP_OPTS: "-Xmx6G -Xms6G"          # Increase heap size for large data volume
      KAFKA_REPLICA_SOCKET_TIMEOUT_MS: 30000    # High replication timeout for large messages
      KAFKA_MAX_REQUEST_SIZE: 1000000000          # 10MB max request size for producers
      KAFKA_SOCKET_REQUEST_MAX_BYTES: 1000000000  # Allow larger requests
    networks:
      - server_network
networks:
  server_network:
    external: true
    name: server_network
