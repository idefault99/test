# Сначала распаковываем OCI Layout в директорию
mkdir -p /tmp/k8s-oci
tar -xzf /tmp/k8s/k8s-1.32.13.tar.gz -C /tmp/k8s-oci

# Смотрим какие образы там лежат
cat /tmp/k8s-oci/index.json | python3 -m json.tool

# Импортируем каждый образ в containerd
# skopeo копирует из OCI dir → containerd через ctr
skopeo copy --dest-tls-verify=false \
  oci:/tmp/k8s-oci:registry.k8s.io/kube-apiserver:v1.32.13 \
  containers-storage:registry.k8s.io/kube-apiserver:v1.32.13

ctr -n k8s.io images import /tmp/k8s/calico.cni:v3.29.5.tar.zip
ctr -n k8s.io images import /tmp/k8s/calico.kube-controllers:v3.29.5.tar.zip
ctr -n k8s.io images import /tmp/k8s/calico.node:v3.29.5.tar.zip
