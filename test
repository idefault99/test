# Что происходит с контейнерами прямо сейчас
sudo crictl ps -a | grep -E 'apiserver|etcd|kube-vip'

# Логи apiserver (подставьте CONTAINER_ID из предыдущей команды)
sudo crictl logs $(sudo crictl ps -a | grep apiserver | awk '{print $1}' | head -1) 2>&1 | tail -50

# Логи etcd
sudo crictl logs $(sudo crictl ps -a | grep etcd | grep -v pause | awk '{print $1}' | head -1) 2>&1 | tail -30

# Логи kubelet
sudo journalctl -xeu kubelet -n 80 --no-pager
