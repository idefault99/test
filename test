## 3. Тесты

### `tests/test_client.py`

```python
import pytest
from unittest.mock import patch, MagicMock
from minio_client import MinioClient


@pytest.fixture
def client():
    with patch("boto3.client"):
        return MinioClient(
            host="https://example.com",
            access_key="key",
            secret_key="secret",
            prefix="/api/s3minio",
        )


def test_get_s3_returns_client(client):
    """get_s3() должен возвращать boto3 клиент"""
    s3 = client.get_s3()
    assert s3 is not None


def test_prefix_event_registered(client):
    """При указании prefix должен быть зарегистрирован before-send handler"""
    handlers = client._s3.meta.events._emitter._lookup_cache
    assert client._prefix == "/api/s3minio"


def test_no_prefix_no_handler():
    """Без prefix handler не должен регистрироваться"""
    with patch("boto3.client"):
        client = MinioClient(
            host="https://example.com",
            access_key="key",
            secret_key="secret",
        )
        assert client._prefix == ""


def test_add_prefix_modifies_url(client):
    """_add_prefix должен корректно добавлять префикс в URL"""
    from unittest.mock import MagicMock
    request = MagicMock()
    request.url = "https://example.com/mybucket/file.txt"
    client._add_prefix(request)
    assert request.url == "https://example.com/api/s3minio/mybucket/file.txt"
```

