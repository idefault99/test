initContainers:
  - name: init-keyfile
    image: {{ .Values.images.mongo }}
    securityContext:
      runAsUser: 999  # создаём файл сразу от mongod-пользователя
      runAsGroup: 999
    command:
      - /bin/sh
      - -c
      - |
        openssl rand -base64 756 > /data/db/keyfile
        chmod 600 /data/db/keyfile
        ls -la /data/db/keyfile
    volumeMounts:
      - name: data
        mountPath: /data/db
