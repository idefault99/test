.test:
  extends: .docker_compose_test
  script:
    - rm -f ./report.xml ./coverage.xml
    - touch ./report.xml ./coverage.xml
    - chmod 666 ./report.xml ./coverage.xml
    - export TAG=$(eval $TAG_SCRIPT)
    - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} up --remove-orphans --renew-anon-volumes --force-recreate --exit-code-from test test
    - ls -lah ./report.xml ./coverage.xml
    - wc -c ./report.xml ./coverage.xml || true
    - sed -n '1,80p' ./report.xml || true
    - sed -i 's|" filename="|" filename="src/|g' ./coverage.xml || true
  coverage: '/(?i)total.*? (100(?:\.0+)?\%|[1-9]?\d(?:\.\d+)?\%)$/'
  artifacts:
    when: always
    paths:
      - ./report.xml
      - ./coverage.xml
    reports:
      junit: ./report.xml
      coverage_report:
        coverage_format: cobertura
        path: ./coverage.xml
  after_script:
    - >
      if [ "$CI_JOB_STATUS" = "failed" ]; then
        docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} logs
      fi
    - export TAG=$(eval $TAG_SCRIPT)
    - docker compose -f docker-compose.test.yml --project-name ${CI_JOB_ID} down
    - docker volume prune -f

test:
  extends: .test