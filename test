# config.sh
GITLAB_URL="https://gitlab.example.com"
GITLAB_TOKEN="glpat-xxxx"
MASTER_HOST="user@master-node-ip"
MASTER_WORK_DIR="/opt/helm-deploy"
DEPLOY_PAUSE=30
ROLLOUT_TIMEOUT=60

# "project_id:ref:release_name"
PROJECTS=(
  "123:develop:audit"
  "456:main:schedule"
  "789:develop:payments"
)
---
#!/bin/bash
# =============================================================
# fetch.sh — запускается локально
# Скачивает чарты и values из GitLab, пушит на мастер по SCP
# =============================================================
set -euo pipefail

source "$(dirname "$0")/config.sh"

WORK_DIR="./helm-fetch-$(date +%Y%m%d-%H%M%S)"
mkdir -p "$WORK_DIR"

echo "=== Fetch started: $WORK_DIR ==="

# --- Функция: получить переменные проекта ---
get_variables() {
  local project_id=$1
  curl -sf \
    --header "PRIVATE-TOKEN: $GITLAB_TOKEN" \
    "$GITLAB_URL/api/v4/projects/$project_id/variables?per_page=100"
}

# --- Функция: скачать Helm чарт ---
download_chart() {
  local project_id=$1
  local ref=$2
  local dest=$3

  curl -sf \
    --header "PRIVATE-TOKEN: $GITLAB_TOKEN" \
    "$GITLAB_URL/api/v4/projects/$project_id/repository/archive.tar.gz?path=Helm&ref=$ref" \
    -o "$dest/chart.tar.gz"

  mkdir -p "$dest/chart"
  tar -xzf "$dest/chart.tar.gz" -C "$dest/chart" --strip-components=2
  rm -f "$dest/chart.tar.gz"
}

# --- Цикл по проектам ---
for PROJECT_ENTRY in "${PROJECTS[@]}"; do
  IFS=':' read -r PROJECT_ID REF RELEASE_NAME <<< "$PROJECT_ENTRY"

  echo ""
  echo "--- Проект: $PROJECT_ID | ref: $REF | release: $RELEASE_NAME ---"

  PROJECT_DIR="$WORK_DIR/project-$PROJECT_ID"
  mkdir -p "$PROJECT_DIR"

  # Сохраняем мета для deploy.sh
  echo "$RELEASE_NAME" > "$PROJECT_DIR/release_name"
  echo "$REF"          > "$PROJECT_DIR/ref"

  # --- Скачиваем переменные ---
  echo "  Получаем переменные..."
  VARIABLES=$(get_variables "$PROJECT_ID") || {
    echo "  ERROR: Не удалось получить переменные проекта $PROJECT_ID"
    continue
  }

  # --- Получаем все scope ---
  SCOPES=$(echo "$VARIABLES" | jq -r '.[].environment_scope' | sort -u | grep -v '^\*$' || true)

  if [[ -z "$SCOPES" ]]; then
    echo "  WARN: Нет environment scope"
    continue
  fi

  # --- Для каждого scope сохраняем NAMESPACE и VALUES ---
  while IFS= read -r SCOPE; do
    SCOPE_DIR="$PROJECT_DIR/scopes/$SCOPE"
    mkdir -p "$SCOPE_DIR"

    NAMESPACE=$(echo "$VARIABLES" | jq -r \
      '.[] | select(.key == "NAMESPACE" and .environment_scope == "'"$SCOPE"'") | .value')

    VALUES_CONTENT=$(echo "$VARIABLES" | jq -r \
      '.[] | select(.key == "VALUES" and .environment_scope == "'"$SCOPE"'") | .value')

    if [[ -z "$NAMESPACE" ]]; then
      echo "  WARN: NAMESPACE не найден для scope $SCOPE"
      continue
    fi

    echo "$NAMESPACE" > "$SCOPE_DIR/namespace"

    if [[ -n "$VALUES_CONTENT" ]]; then
      echo "$VALUES_CONTENT" > "$SCOPE_DIR/values.yaml"
    fi

    echo "  scope: $SCOPE → namespace: $NAMESPACE"

  done <<< "$SCOPES"

  # --- Скачиваем чарт ---
  echo "  Скачиваем Helm чарт (ref: $REF)..."
  if ! download_chart "$PROJECT_ID" "$REF" "$PROJECT_DIR"; then
    echo "  ERROR: Не удалось скачать чарт"
    continue
  fi
  echo "  Чарт скачан"

done

# --- Пушим на мастер по SCP ---
echo ""
echo "=== Отправляем на мастер: $MASTER_HOST:$MASTER_WORK_DIR ==="
ssh "$MASTER_HOST" "mkdir -p $MASTER_WORK_DIR"
scp -r "$WORK_DIR/." "$MASTER_HOST:$MASTER_WORK_DIR/payload"
scp "$(dirname "$0")/config.sh" "$MASTER_HOST:$MASTER_WORK_DIR/config.sh"
scp "$(dirname "$0")/deploy.sh" "$MASTER_HOST:$MASTER_WORK_DIR/deploy.sh"
ssh "$MASTER_HOST" "chmod +x $MASTER_WORK_DIR/deploy.sh"

echo ""
echo "=== Готово. Запускаем deploy.sh на мастере ==="
ssh "$MASTER_HOST" "bash $MASTER_WORK_DIR/deploy.sh $MASTER_WORK_DIR/payload"

---
#!/bin/bash
# =============================================================
# deploy.sh — запускается на мастер ноде
# Деплоит helm релизы из переданных чартов
# =============================================================
set -euo pipefail

source "$(dirname "$0")/config.sh"

PAYLOAD_DIR="${1:-./payload}"

if [[ ! -d "$PAYLOAD_DIR" ]]; then
  echo "ERROR: payload директория не найдена: $PAYLOAD_DIR"
  exit 1
fi

# --- Определяем команды для microk8s ---
if command -v microk8s.helm3 &>/dev/null; then
  HELM="microk8s.helm3"
  KUBECTL="microk8s.kubectl"
elif command -v microk8s &>/dev/null; then
  helm() { microk8s helm "$@"; }
  kubectl() { microk8s kubectl "$@"; }
  export -f helm kubectl
  HELM="helm"
  KUBECTL="kubectl"
elif command -v helm &>/dev/null; then
  HELM="helm"
  KUBECTL="kubectl"
else
  echo "ERROR: helm не найден"
  exit 1
fi

# --- Цвета ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# --- Результаты ---
DEPLOYED=()
SKIPPED=()
ERRORS=()
DEPLOY_COUNT=0

# --- Функция: ждать rollout ---
wait_rollout() {
  local namespace=$1
  echo -e "  ${CYAN}Ожидаем rollout: $namespace (timeout: ${ROLLOUT_TIMEOUT}s)${NC}"

  local all_ok=true

  for KIND in deployment statefulset daemonset; do
    RESOURCES=$($KUBECTL get "${KIND}s" -n "$namespace" \
      -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)

    if [[ -z "$RESOURCES" ]]; then
      echo "    ${KIND}s: не найдены"
      continue
    fi

    for RES in $RESOURCES; do
      echo -e "    ${KIND}: $RES"
      if ! $KUBECTL rollout status "${KIND}/${RES}" \
        -n "$namespace" \
        --timeout="${ROLLOUT_TIMEOUT}s" 2>/dev/null; then
        echo -e "  ${RED}Rollout не завершился: ${KIND}/${RES}${NC}"
        all_ok=false
      fi
    done
  done

  if $all_ok; then
    echo -e "  ${GREEN}Rollout OK${NC}"
    return 0
  else
    return 1
  fi
}

# --- Функция: показать память ---
show_memory() {
  echo -e "  ${CYAN}Память:${NC}"
  $KUBECTL top nodes 2>/dev/null || true
}

# --- Цикл по проектам в payload ---
for PROJECT_DIR in "$PAYLOAD_DIR"/project-*; do
  [[ -d "$PROJECT_DIR" ]] || continue

  PROJECT_ID=$(basename "$PROJECT_DIR" | sed 's/project-//')
  RELEASE_NAME=$(cat "$PROJECT_DIR/release_name" 2>/dev/null || echo "")
  CHART_DIR="$PROJECT_DIR/chart"

  if [[ -z "$RELEASE_NAME" ]]; then
    echo "ERROR: release_name не найден в $PROJECT_DIR"
    ERRORS+=("project-$PROJECT_ID|—|—|release_name не найден")
    continue
  fi

  if [[ ! -d "$CHART_DIR" ]]; then
    echo "ERROR: чарт не найден: $CHART_DIR"
    ERRORS+=("project-$PROJECT_ID|—|—|Чарт не найден")
    continue
  fi

  echo ""
  echo -e "${BLUE}=========================================="
  echo "  Проект: $PROJECT_ID | release: $RELEASE_NAME"
  echo -e "==========================================${NC}"

  # --- Цикл по scope ---
  for SCOPE_DIR in "$PROJECT_DIR/scopes"/*/; do
    [[ -d "$SCOPE_DIR" ]] || continue

    SCOPE=$(basename "$SCOPE_DIR")
    NAMESPACE=$(cat "$SCOPE_DIR/namespace" 2>/dev/null || echo "")

    if [[ -z "$NAMESPACE" ]]; then
      echo -e "  ${RED}NAMESPACE не найден для scope $SCOPE${NC}"
      ERRORS+=("project-$PROJECT_ID|$SCOPE|—|NAMESPACE не найден")
      continue
    fi

    echo ""
    echo -e "  ${YELLOW}>>> scope: $SCOPE | namespace: $NAMESPACE${NC}"

    # Values флаг
    if [[ -f "$SCOPE_DIR/values.yaml" ]]; then
      VALUES_FLAG="-f $SCOPE_DIR/values.yaml"
    else
      VALUES_FLAG=""
      echo -e "  ${YELLOW}values.yaml не найден — деплоим без него${NC}"
    fi

    # --- Проверяем существует ли релиз ---
    RELEASE_EXISTS=$($HELM list -n "$NAMESPACE" -q 2>/dev/null | grep -x "$RELEASE_NAME" || true)

    if [[ -z "$RELEASE_EXISTS" ]]; then
      echo -e "  ${YELLOW}Релиз не найден — устанавливаем новый${NC}"
      HELM_CMD="install"
    else
      echo -e "  ${GREEN}Релиз найден — обновляем${NC}"
      HELM_CMD="upgrade"
    fi

    # --- Память до деплоя ---
    show_memory

    # --- helm install или upgrade ---
    DEPLOY_LOG="$SCOPE_DIR/deploy.log"

    if [[ "$HELM_CMD" == "install" ]]; then
      HELM_RESULT=$($HELM install "$RELEASE_NAME" "$CHART_DIR" \
        -n "$NAMESPACE" \
        --create-namespace \
        $VALUES_FLAG \
        > "$DEPLOY_LOG" 2>&1 && echo "ok" || echo "fail")
    else
      HELM_RESULT=$($HELM upgrade "$RELEASE_NAME" "$CHART_DIR" \
        -n "$NAMESPACE" \
        --reuse-values \
        --create-namespace \
        $VALUES_FLAG \
        > "$DEPLOY_LOG" 2>&1 && echo "ok" || echo "fail")
    fi

    if [[ "$HELM_RESULT" == "ok" ]]; then
      echo -e "  ${GREEN}Helm $HELM_CMD OK${NC}"

      # Ждём rollout
      if wait_rollout "$NAMESPACE"; then
        DEPLOYED+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|$RELEASE_NAME|$HELM_CMD|OK")
      else
        DEPLOYED+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|$RELEASE_NAME|$HELM_CMD|ROLLOUT_TIMEOUT")
        ERRORS+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|Rollout не завершился за ${ROLLOUT_TIMEOUT}s")
      fi

    else
      ERROR_MSG=$(tail -3 "$DEPLOY_LOG" | tr '\n' ' ')
      echo -e "  ${RED}ОШИБКА: $ERROR_MSG${NC}"
      ERRORS+=("project-$PROJECT_ID|$SCOPE|$NAMESPACE|$ERROR_MSG")
    fi

    DEPLOY_COUNT=$((DEPLOY_COUNT + 1))
    echo -e "  ${CYAN}Пауза ${DEPLOY_PAUSE}s...${NC}"
    sleep "$DEPLOY_PAUSE"

  done
done

# =============================================================
# Таблица 1: Задеплоено
# =============================================================
echo ""
echo "=========================================="
echo "  ЗАДЕПЛОЕНО"
echo "=========================================="
printf "%-15s %-20s %-30s %-20s %-10s %-15s\n" \
  "PROJECT" "SCOPE" "NAMESPACE" "RELEASE" "ACTION" "СТАТУС"
printf "%-15s %-20s %-30s %-20s %-10s %-15s\n" \
  "---------------" "--------------------" "------------------------------" \
  "--------------------" "----------" "---------------"

if [[ ${#DEPLOYED[@]} -eq 0 ]]; then
  echo "  Нет успешных деплоев"
else
  for ROW in "${DEPLOYED[@]}"; do
    IFS='|' read -r PROJ SCOPE NS REL ACTION STATUS <<< "$ROW"
    if [[ "$STATUS" == "OK" ]]; then
      printf "%-15s %-20s %-30s %-20s %-10s ${GREEN}%-15s${NC}\n" \
        "$PROJ" "$SCOPE" "$NS" "$REL" "$ACTION" "$STATUS"
    else
      printf "%-15s %-20s %-30s %-20s %-10s ${YELLOW}%-15s${NC}\n" \
        "$PROJ" "$SCOPE" "$NS" "$REL" "$ACTION" "$STATUS"
    fi
  done
fi

# =============================================================
# Таблица 2: Пропущено
# =============================================================
echo ""
echo "=========================================="
echo "  ПРОПУЩЕНО"
echo "=========================================="
printf "%-15s %-20s %-30s %-20s\n" "PROJECT" "SCOPE" "NAMESPACE" "ПРИЧИНА"
printf "%-15s %-20s %-30s %-20s\n" \
  "---------------" "--------------------" "------------------------------" "--------------------"

if [[ ${#SKIPPED[@]} -eq 0 ]]; then
  echo "  Пропущенных нет"
else
  for ROW in "${SKIPPED[@]}"; do
    IFS='|' read -r PROJ SCOPE NS REASON <<< "$ROW"
    printf "%-15s %-20s %-30s ${YELLOW}%-20s${NC}\n" "$PROJ" "$SCOPE" "$NS" "$REASON"
  done
fi

# =============================================================
# Таблица 3: Ошибки
# =============================================================
echo ""
echo "=========================================="
echo "  ОШИБКИ"
echo "=========================================="
printf "%-15s %-20s %-30s %-40s\n" "PROJECT" "SCOPE" "NAMESPACE" "ПРИЧИНА"
printf "%-15s %-20s %-30s %-40s\n" \
  "---------------" "--------------------" "------------------------------" \
  "----------------------------------------"

if [[ ${#ERRORS[@]} -eq 0 ]]; then
  echo "  Ошибок нет"
else
  for ROW in "${ERRORS[@]}"; do
    IFS='|' read -r PROJ SCOPE NS REASON <<< "$ROW"
    printf "%-15s %-20s %-30s ${RED}%-40s${NC}\n" "$PROJ" "$SCOPE" "$NS" "$REASON"
  done
fi

echo ""
echo "Всего деплоев: $DEPLOY_COUNT"
