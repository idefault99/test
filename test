# Правильный сервис для поиска
sudo journalctl -u snap.microk8s.daemon-kubelite --since "4 days ago" | grep -iE "delete|dev-devops|helm" | tail -50

# Без фильтра — просто посмотреть что было в выходные
sudo journalctl -u snap.microk8s.daemon-kubelite --since "saturday" --until "monday" | tail -200

# Смотрим что вообще есть за период
sudo journalctl -u snap.microk8s.daemon-kubelite --since "4 days ago" | wc -l

# Ищем любые упоминания удалений
sudo journalctl -u snap.microk8s.daemon-kubelite --since "4 days ago" | grep -i "delete" | tail -30


# История команд пользователя user
cat ~/.bash_history | grep -iE "helm|delete|dev-devops" | tail -30

# И root
sudo cat /root/.bash_history | grep -iE "helm|delete|dev-devops" | tail -30

# Смотрим кто последний раз логинился на ноду
last | head -20
lastlog | grep -v "Never"
